@using TechExchangeApp.ViewModel
@using TechExchangeApp.Entities
@model ProductDetailViewModel
@inject TechExchangeApp.Data.AppDbContext _context

@{
    var p = Model.Product;
    var supplier = (p.NCUId != null)
        ? Model.Suppliers?.FirstOrDefault(s => s.CungUngId == p.NCUId)
        : null;

    var catIds = new List<int>();
    if (!string.IsNullOrEmpty(p.CategoryId))
    {
        foreach (var s in p.CategoryId.Split(new[]{',','|',';'}, StringSplitOptions.RemoveEmptyEntries))
        {
            if (int.TryParse(s.Trim(), out int cid)) catIds.Add(cid);
        }
    }

    Func<bool, string> chk = (v) => v ? "☑" : "☐";
}



<div class="ho-so-cong-nghe">


    @* TAB NAVIGATION — Tab 1 hiện, Tab Nhà cung ứng ẩn *@
    <ul class="nav nav-tabs" id="detailTabsThietBi" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="tb-nhandienTab" data-bs-toggle="tab"
                    data-bs-target="#tb-nhandien" type="button" role="tab">
                <i class="fa fa-id-card me-1"></i>Thông tin
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="tb-thongsoTab" data-bs-toggle="tab"
                    data-bs-target="#tb-thongso" type="button" role="tab">
                <i class="fa fa-cogs me-1"></i>Thông số kỹ thuật
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="tb-uudiemgiaTab" data-bs-toggle="tab"
                    data-bs-target="#tb-uudiemgia" type="button" role="tab">
                <i class="fa fa-star me-1"></i>Ưu điểm &amp; Giá
            </button>
        </li>
        <li class="nav-item" role="presentation" style="display:none">
            <button class="nav-link" id="tb-nhacungungTab" data-bs-toggle="tab"
                    data-bs-target="#tb-nhacungung" type="button" role="tab">
                <i class="fa fa-building me-1"></i>Nhà cung ứng
            </button>
        </li>
    </ul>

    <div class="tab-content border border-top-0 rounded-bottom p-4" id="detailTabsThietBiContent">

        @* ══════════════════════════════════════
           TAB 1 – THÔNG TIN (active)
           ══════════════════════════════════════ *@
        <div class="tab-pane fade show active" id="tb-nhandien" role="tabpanel">
            <div class="hscn-section-title"><i class="fa fa-info-circle me-2"></i>Thông tin thiết bị</div>

            @* Tên thiết bị *@
            <div class="hscn-item">
                <div class="hscn-item-title">Tên thiết bị / máy móc</div>
                <div class="ps-3 fw-bold fs-6">@p.Name</div>
            </div>

            @* Ảnh đại diện — đã hiển thị bên trên trong _DetailHeader, bỏ qua *@

            @* Xuất xứ *@
            @{
                string xuatXuName = p.XuatXu;
                if (string.IsNullOrEmpty(xuatXuName) && p.XuatXuId.HasValue)
                {
                    xuatXuName = _context.XuatXus.Where(x => x.Id == p.XuatXuId).Select(x => x.Title).FirstOrDefault();
                }
            }
            @if (!string.IsNullOrEmpty(xuatXuName))
            {
                <div class="hscn-item">
                    <div class="hscn-item-title">Xuất xứ</div>
                    <div class="ps-3"><strong>@xuatXuName</strong></div>
                </div>
            }


            @* Lĩnh vực áp dụng — chỉ hiện đã check *@
            @{
                var checkedIndsN = Model.Industries?.Where(ind => catIds.Contains(ind.CatId)).ToList();
            }
            @if (checkedIndsN != null && checkedIndsN.Any())
            {
                <div class="hscn-item">
                    <div class="hscn-item-title">Lĩnh vực áp dụng</div>
                    <div class="ps-3">
                        @foreach (var ind in checkedIndsN) { <div class="hscn-check-row">☑ @ind.Title</div> }
                    </div>
                </div>
            }
            else if (!string.IsNullOrEmpty(Model.CategoryTitle))
            {
                <div class="hscn-item">
                    <div class="hscn-item-title">Lĩnh vực áp dụng</div>
                    <div class="ps-3"><div class="hscn-check-row">☑ @Model.CategoryTitle</div></div>
                </div>
            }

            @* Mức độ phát triển *@
            @if (p.Rating.HasValue && p.Rating > 0)
            {
                <div class="hscn-item">
                    <div class="hscn-item-title">Mức độ phát triển</div>
                    <div class="ps-3">
                        @if (p.Rating == 7) { <div class="hscn-check-row">☑ <i class="fa fa-flask me-1"></i> Đã ứng dụng thử nghiệm (Pilot)</div> }
                        @if (p.Rating == 8) { <div class="hscn-check-row">☑ <i class="fa fa-industry me-1"></i> Đã ứng dụng công nghiệp</div> }
                        @if (p.Rating == 9) { <div class="hscn-check-row">☑ <i class="fa fa-shopping-cart me-1"></i> Đã thương mại hóa</div> }
                        @if (p.DaBan.HasValue && p.DaBan > 0)
                        {
                            <div class="mt-1 text-muted small ms-4">Đã bán: <strong>@p.DaBan</strong> đơn vị</div>
                        }
                        @if (p.TinhTrangHang.HasValue)
                        {
                            <div class="mt-1 ms-4">
                                Tình trạng hàng:
                                @if (p.TinhTrangHang == 1) { <span class="badge bg-success">Còn hàng</span> }
                                else { <span class="badge bg-danger">Hết hàng</span> }
                            </div>
                        }
                    </div>
                </div>
            }

            @* Keywords *@
            @if (Model.Keywords != null && Model.Keywords.Any())
            {
                <div class="hscn-item">
                    <div class="hscn-item-title">Từ khoá</div>
                    <div class="ps-3">
                        @foreach (var kw in Model.Keywords) { <span class="badge bg-secondary me-1">@kw.Keyword</span> }
                    </div>
                </div>
            }
        </div>

        @* ══════════════════════════════════════
           TAB 2 – THÔNG SỐ KỸ THUẬT
           ══════════════════════════════════════ *@
        <div class="tab-pane fade" id="tb-thongso" role="tabpanel">
            <div class="hscn-section-title"><i class="fa fa-cogs me-2"></i>Thông số kỹ thuật &amp; Vận hành</div>





            @* Thông số kỹ thuật chính *@
            @if (!string.IsNullOrEmpty(p.ThongSo))
            {
                <div class="hscn-item">
                    <div class="hscn-item-title">Thông số kỹ thuật chính</div>
                    <div class="ps-3 content-body">@Html.Raw(p.ThongSo)</div>
                </div>
            }

            @* Mô tả nguyên lý hoạt động *@
            @if (!string.IsNullOrEmpty(p.MoTa))
            {
                <div class="hscn-item">
                    <div class="hscn-item-title">Mô tả nguyên lý hoạt động</div>
                    <div class="ps-3 content-body">@Html.Raw(p.MoTa)</div>
                </div>
            }

            @* Video vận hành *@
            @{
                string embedUrl = null;
                if (!string.IsNullOrEmpty(Model.YoutubeEmbedUrl))
                {
                    embedUrl = Model.YoutubeEmbedUrl;
                }
                else if (!string.IsNullOrEmpty(p.URL))
                {
                    var rawUrl = p.URL.Trim();
                    if (rawUrl.Contains("youtube.com/embed/")) { embedUrl = rawUrl; }
                    else if (rawUrl.Contains("youtube.com/watch"))
                    {
                        var vIdx = rawUrl.IndexOf("v=");
                        if (vIdx >= 0) { var vid = rawUrl.Substring(vIdx + 2); var ampIdx = vid.IndexOf('&'); if (ampIdx >= 0) vid = vid.Substring(0, ampIdx); embedUrl = $"https://www.youtube.com/embed/{vid}"; }
                    }
                    else if (rawUrl.Contains("youtu.be/"))
                    {
                        var parts = rawUrl.Split(new[] { "youtu.be/" }, StringSplitOptions.None);
                        if (parts.Length > 1) { embedUrl = $"https://www.youtube.com/embed/{parts[1].Split('?')[0]}"; }
                    }
                }
            }
            @if (!string.IsNullOrEmpty(embedUrl))
            {
                <div class="hscn-item">
                    <div class="hscn-item-title">Video vận hành</div>
                    <div class="ps-3">
                        <div class="ratio ratio-16x9" style="max-width:640px;">
                            <iframe src="@embedUrl" title="@p.Name" allowfullscreen
                                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture">
                            </iframe>
                        </div>
                    </div>
                </div>
            }
            else if (!string.IsNullOrEmpty(Model.VideoFileUrl))
            {
                <div class="hscn-item">
                    <div class="hscn-item-title">Video vận hành</div>
                    <div class="ps-3">
                        <a href="@Model.VideoFileUrl" target="_blank" class="btn btn-sm btn-outline-danger">
                            <i class="fa fa-play me-1"></i> Xem video
                        </a>
                    </div>
                </div>
            }

            @* Keywords *@
            @if (Model.Keywords != null && Model.Keywords.Any())
            {
                <div class="hscn-item">
                    <div class="hscn-item-title">Từ khoá</div>
                    <div class="ps-3">
                        @foreach (var kw in Model.Keywords)
                        {
                            <span class="badge bg-secondary me-1">@kw.Keyword</span>
                        }
                    </div>
                </div>
            }
        </div>

        @* ══════════════════════════════════════
           TAB 3 – ƯU ĐIỂM & GIÁ
           ══════════════════════════════════════ *@
        <div class="tab-pane fade" id="tb-uudiemgia" role="tabpanel">
            <div class="hscn-section-title"><i class="fa fa-star me-2"></i>Ưu điểm &amp; Giá bán</div>

            @if (!string.IsNullOrEmpty(p.UuDiem))
            {
                <div class="hscn-item">
                    <div class="hscn-item-title">Ưu điểm nổi bật</div>
                    <div class="ps-3 content-body">@Html.Raw(p.UuDiem)</div>
                </div>
            }

            @if (!string.IsNullOrEmpty(p.GiaBanDuKien) || p.SellPrice.HasValue)
            {
                <div class="hscn-item">
                    <div class="hscn-item-title">Giá tham khảo (VNĐ)</div>
                    <div class="ps-3 content-body">
                        @if (!string.IsNullOrEmpty(p.GiaBanDuKien)) { @Html.Raw(p.GiaBanDuKien) }
                        else if (p.SellPrice.HasValue)
                        {
                            <span class="fw-bold text-danger fs-5">@string.Format("{0:N0}", p.SellPrice) @p.Currency</span>
                            @if (p.OriginalPrice.HasValue)
                            {
                                <span class="text-muted text-decoration-line-through ms-2">@string.Format("{0:N0}", p.OriginalPrice) @p.Currency</span>
                            }
                        }
                    </div>
                </div>
            }

            @if (!string.IsNullOrEmpty(p.BaoHanhHoTro))
            {
                <div class="hscn-item">
                    <div class="hscn-item-title">Chế độ bảo hành &amp; Hỗ trợ kỹ thuật</div>
                    <div class="ps-3 content-body">@Html.Raw(p.BaoHanhHoTro)</div>
                </div>
            }

            @if (!string.IsNullOrEmpty(p.GiaiThuong))
            {
                <div class="hscn-item">
                    <div class="hscn-item-title">Giải thưởng / Chứng nhận</div>
                    <div class="ps-3 content-body">@Html.Raw(p.GiaiThuong)</div>
                </div>
            }
        </div>

        @* ══════════════════════════════════════
           TAB 4 – NHÀ CUNG ỨNG
           ══════════════════════════════════════ *@
        <div class="tab-pane fade" id="tb-nhacungung" role="tabpanel">
            <div class="hscn-section-title"><i class="fa fa-building me-2"></i>Thông tin nhà cung ứng</div>

            <div class="hscn-item">
                <div class="hscn-item-title">Tên đơn vị sở hữu / cung ứng</div>
                <div class="ps-3">
                    @if (supplier != null)
                    {
                        <strong>
                            @if (!string.IsNullOrEmpty(Model.SupplierUrl))
                            { <a href="@Model.SupplierUrl" class="text-decoration-none">@supplier.FullName</a> }
                            else { @supplier.FullName }
                        </strong>
                    }
                    else if (!string.IsNullOrEmpty(Model.SupplierName))
                    {
                        <strong>
                            @if (!string.IsNullOrEmpty(Model.SupplierUrl))
                            { <a href="@Model.SupplierUrl" class="text-decoration-none">@Model.SupplierName</a> }
                            else { @Model.SupplierName }
                        </strong>
                    }
                    else { <span class="text-muted">—</span> }
                </div>
            </div>

            <div class="hscn-item">
                <div class="hscn-item-title">Thông tin liên hệ</div>
                <table class="hscn-table-info ps-3 ms-3" style="font-size:13.5px;">
                    <tbody>
                        @if (supplier != null)
                        {
                            @if (!string.IsNullOrEmpty(supplier.DiaChi)) { <tr><td>Địa chỉ:</td><td>@supplier.DiaChi</td></tr> }
                            @if (!string.IsNullOrEmpty(supplier.NguoiDaiDien)) { <tr><td>Người đại diện:</td><td>@supplier.NguoiDaiDien @(!string.IsNullOrEmpty(supplier.ChucVu) ? $"– {supplier.ChucVu}" : "")</td></tr> }
                            @if (!string.IsNullOrEmpty(supplier.Phone)) { <tr><td>Điện thoại:</td><td>@supplier.Phone</td></tr> }
                            @if (!string.IsNullOrEmpty(supplier.Email)) { <tr><td>Email:</td><td><a href="mailto:@supplier.Email">@supplier.Email</a></td></tr> }
                            @if (!string.IsNullOrEmpty(supplier.Website)) { <tr><td>Website:</td><td><a href="@supplier.Website" target="_blank">@supplier.Website</a></td></tr> }
                        }
                        else
                        {
                            @if (!string.IsNullOrEmpty(p.DiaChi)) { <tr><td>Địa chỉ:</td><td>@p.DiaChi</td></tr> }
                            @if (!string.IsNullOrEmpty(p.Phone)) { <tr><td>Điện thoại:</td><td>@p.Phone</td></tr> }
                            @if (!string.IsNullOrEmpty(p.OwnerEmail)) { <tr><td>Email:</td><td><a href="mailto:@p.OwnerEmail">@p.OwnerEmail</a></td></tr> }
                            @if (!string.IsNullOrEmpty(p.WebUrl)) { <tr><td>Website:</td><td><a href="@p.WebUrl" target="_blank">@p.WebUrl</a></td></tr> }
                        }
                    </tbody>
                </table>
            </div>

            @if (!string.IsNullOrEmpty(Model.SupplierUrl))
            {
                <div class="ps-3 mt-2">
                    <a href="@Model.SupplierUrl" class="btn btn-outline-primary btn-sm">
                        <i class="fa fa-external-link me-1"></i> Xem hồ sơ nhà cung ứng
                    </a>
                </div>
            }
        </div>

    </div>
</div>
