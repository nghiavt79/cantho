@model TechExchangeApp.ViewModel.ProductByCateViewModel

@section Scripts {
    <script>
        $(function () {
            $(".current").parent().addClass("active");

            $(".etheme_add_to_cart_button").click(function (e) {
                e.preventDefault();
                var url = $(this).closest(".product-container").find(".product-image").attr("href");
                window.location.href = url;
            });
        });
    </script>
}

<div class="container" id="columns">
    <div class="row">

        <!-- ================= CENTER COLUMN ================= -->
        <div class="center_column col-xs-12 col-sm-9" id="center_column">

            <div id="view-product-list" class="view-product-list">

                <h2 class="brand-showcase-title">
                    <a>@Model.PageTitle</a>
                </h2>

                <ul class="display-product-option">
                    <li class="view-as-grid selected"><span>grid</span></li>
                    <li class="view-as-list"><span>list</span></li>
                </ul>

                <!-- ================= PRODUCT LIST ================= -->
                <ul class="row product-list grid">

                    @foreach (var p in Model.Products)
                    {
                        <li class="col-sx-12 col-sm-3 ListProductMobile">
                            <div class="product-container">

                                <div class="left-block">
                                    <a class="product-image" href="@p.Url">
                                        <img src="@p.ImageUrl"
                                             class="img-responsive ProductListImage"
                                             alt="@p.Title" />
                                    </a>

                                    @if (p.IsSC)
                                    {
                                        <span class="label_sc"></span>
                                    }
                                    @if (p.IsNC)
                                    {
                                        <span class="label_nc"></span>
                                    }

                                    <div class="quick-view"></div>

                                </div>

                                <div class="right-block">
                                    <h5 class="product-name">
                                        <a href="@p.Url">@p.Title</a>
                                    </h5>

                                    <div class="content_price">
                                        <span class="price product-price">
                                            Giá tham khảo : @p.PriceText
                                        </span>
                                    </div>

                                    <div id="stars-sp">
                                        @{
                                            var star = p.Star;

                                            if (star < 0) star = 0;
                                            if (star > 5) star = 5;

                                            var stars = new string('★', star) + new string('☆', 5 - star);
                                        }
                                        <span style="color: gold; font-size: medium">@stars</span>
                                    </div>

                                    <div class="info-orther">
                                        <p>Mã sản phẩm: @p.Code</p>
                                    </div>
                                </div>

                            </div>
                        </li>
                    }

                </ul>
                <!-- ================= END PRODUCT LIST ================= -->

            </div>

            @{
                int totalPages = Model.PageSize > 0 ? (int)Math.Ceiling((double)Model.Total / Model.PageSize) : 1;
                int curPage   = Model.CurPage;
            }

            @if (totalPages > 1)
            {
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-3">
                    <div class="small text-muted">
                        Hiển thị <strong>@((curPage - 1) * Model.PageSize + 1)</strong>–<strong>@Math.Min(curPage * Model.PageSize, Model.Total)</strong>
                        / <strong>@Model.Total</strong> sản phẩm &nbsp;|&nbsp;
                        Sản phẩm/trang:
                        <select class="form-select form-select-sm d-inline-block w-auto" onchange="location.href='?page=1&pageSize=' + this.value">
                            @foreach (var size in new[] { 12, 24, 36, 48, 60 })
                            {
                                if (size == Model.PageSize)
                                {
                                    <option value="@size" selected>@size</option>
                                }
                                else
                                {
                                    <option value="@size">@size</option>
                                }
                            }
                        </select>
                    </div>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(curPage == 1 ? "disabled" : "")">
                            <a class="page-link" href="?page=1&pageSize=@Model.PageSize"><i class="fas fa-angles-left"></i></a>
                        </li>
                        <li class="page-item @(curPage == 1 ? "disabled" : "")">
                            <a class="page-link" href="?page=@(curPage - 1)&pageSize=@Model.PageSize"><i class="fas fa-angle-left"></i></a>
                        </li>
                        @foreach (var pg in Model.Pages)
                        {
                            <li class="page-item @(pg.IsActive ? "active" : "")">
                                <a class="page-link" href="?page=@pg.Page&pageSize=@Model.PageSize">@pg.Page</a>
                            </li>
                        }
                        <li class="page-item @(curPage == totalPages ? "disabled" : "")">
                            <a class="page-link" href="?page=@(curPage + 1)&pageSize=@Model.PageSize"><i class="fas fa-angle-right"></i></a>
                        </li>
                        <li class="page-item @(curPage == totalPages ? "disabled" : "")">
                            <a class="page-link" href="?page=@totalPages&pageSize=@Model.PageSize"><i class="fas fa-angles-right"></i></a>
                        </li>
                    </ul>
                </div>
            }
            else if (Model.Total > 0)
            {
                <div class="small text-muted mt-2">Tổng cộng <strong>@Model.Total</strong> sản phẩm</div>
            }

            <!-- hidden -->
            <input type="hidden" value="@Model.CurPage" />
            <input type="hidden" value="@Model.StoreId" />
            <input type="hidden" value="@Model.CateId" />

            <!-- PORTLET -->
            @* PortletIONhaTuVan *@

        </div>

        <!-- ================= LEFT COLUMN ================= -->
        <div class="column col-xs-12 col-sm-3" id="left_column">

            <div class="block left-module">
                <p class="title_block">@Model.CateTitle</p>

                <div class="block_content">
                    <div class="layered layered-category">
                        <div class="layered-content">
                            <ul class="tree-menu">
                                @foreach (var cate in Model.Categories)
                                {
                                    <li>
                                        <span></span>
                                        <a href="@cate.Url">@cate.Title</a>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

        </div>

    </div>
</div>
