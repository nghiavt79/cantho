@model TechExchangeApp.ViewModel.ProductByCateViewModel
@{
    ViewData["Title"] = Model.PageTitle;
    var mainDomain = Model.MainDomain;
    int totalPages = Model.PageSize > 0 ? (int)Math.Ceiling((double)Model.Total / Model.PageSize) : 1;
    int curPage = Model.CurPage;
    int startItem = Model.Total > 0 ? (curPage - 1) * Model.PageSize + 1 : 0;
    int endItem = Math.Min(curPage * Model.PageSize, Model.Total);

    string categoryDesc = !string.IsNullOrWhiteSpace(Model.Description)
        ? Model.Description
        : $"Tổng hợp các thiết bị, phần mềm, giải pháp và công nghệ thuộc lĩnh vực {Model.CateTitle}, phục vụ kết nối, giới thiệu và chuyển giao công nghệ.";
}

<div class="columns-container tech-page">
    <div class="container" id="columns">

        <!-- ===== BREADCRUMB ===== -->
        <nav class="catalog-breadcrumb" aria-label="breadcrumb">
            <a href="@mainDomain">Trang chủ</a>
            <span>/</span>
            <a href="@($"{mainDomain}san-pham")">Sản phẩm</a>
            <span>/</span>
            <strong>@Model.CateTitle</strong>
        </nav>

        <!-- ===== COMPACT HEADER ===== -->
        <div class="category-compact-header">
            <div class="category-header-top">
                <h1 class="category-title">@Model.CateTitle</h1>
                <div class="category-meta">
                    <span class="category-meta-chip"><i class="bi bi-box-seam"></i> @Model.Total sản phẩm</span>
                    @if (Model.Total > 0)
                    {
                        <span class="category-meta-chip"><i class="bi bi-eye"></i> Hiển thị @startItem–@endItem</span>
                    }
                </div>
            </div>
            <div class="category-header-bottom">
                <p class="category-desc">@categoryDesc</p>
                <div class="category-actions">
                    <div class="category-search input-group input-group-sm">
                        <input type="search" class="form-control" name="keyword" placeholder="Tìm theo tên sản phẩm, thiết bị, giải pháp..." aria-label="Tìm kiếm" />
                        <button class="btn btn-primary" type="button"><i class="bi bi-search"></i></button>
                    </div>
                    <select class="form-select form-select-sm category-sort" onchange="location.href='?sort=' + this.value + '&pageSize=@Model.PageSize'" aria-label="Sắp xếp">
                        <option value="newest" selected>Mới cập nhật</option>
                        <option value="name-asc">Tên A–Z</option>
                        <option value="name-desc">Tên Z–A</option>
                        <option value="price-asc">Giá tăng dần</option>
                        <option value="price-desc">Giá giảm dần</option>
                    </select>
                    <select class="form-select form-select-sm category-page-size" onchange="location.href='?page=1&pageSize=' + this.value" aria-label="Số sản phẩm/trang">
                        @foreach (var size in new[] { 12, 24, 36 })
                        {
                            if (size == Model.PageSize)
                            {
                                <option value="@size" selected>@size / trang</option>
                            }
                            else
                            {
                                <option value="@size">@size / trang</option>
                            }
                        }
                    </select>
                </div>
            </div>
        </div>

        <!-- ===== MAIN LAYOUT: content LEFT, sidebar RIGHT ===== -->
        <div class="row g-3">

            <!-- ===== PRODUCT GRID (col-9, LEFT) ===== -->
            <div class="col-lg-9 col-12 order-1 order-lg-1" id="center_column">

                @if (Model.Total > 0)
                {
                    <div class="catalog-info">
                        Hiển thị <strong>@startItem–@endItem</strong> trong tổng số <strong>@Model.Total</strong> sản phẩm
                    </div>
                }

                @if (!Model.Products.Any())
                {
                    <div class="catalog-empty">
                        <i class="bi bi-inbox"></i>
                        <p>Chưa có sản phẩm nào trong lĩnh vực này.</p>
                        <a href="@($"{mainDomain}cong-nghe")" class="btn-back-catalog">← Quay lại danh sách công nghệ</a>
                    </div>
                }
                else
                {
                    <div class="catalog-grid">
                        @foreach (var p in Model.Products)
                        {
                            var hasPriceText = !string.IsNullOrWhiteSpace(p.PriceText) && p.PriceText != "0 " && p.PriceText != "0";

                            <article class="tech-card">
                                <a class="tech-card__image" href="@p.Url">
                                    <img src="@p.ImageUrl" alt="@p.Title" loading="lazy" />
                                </a>
                                <div class="tech-card__body">
                                    @if (!string.IsNullOrWhiteSpace(p.CategoryName))
                                    {
                                        <span class="tech-card__badge">@p.CategoryName</span>
                                    }
                                    <h3 class="tech-card__title">
                                        <a href="@p.Url" title="@p.Title">@p.Title</a>
                                    </h3>
                                    @if (!string.IsNullOrWhiteSpace(p.Description))
                                    {
                                        <p class="tech-card__desc">@p.Description</p>
                                    }
                                    <div class="tech-card__source">
                                        <i class="bi bi-building"></i> Nhà cung ứng: @p.SupplierName
                                    </div>
                                    <div class="tech-card__price">
                                        Giá tham khảo: <strong>@(hasPriceText ? p.PriceText : "Liên hệ")</strong>
                                    </div>
                                    <a href="@p.Url" class="tech-card__btn">Chi tiết <i class="bi bi-arrow-right"></i></a>
                                </div>
                            </article>
                        }
                    </div>
                }

                <!-- ===== PAGINATION ===== -->
                @if (totalPages > 1)
                {
                    <nav class="catalog-pagination" aria-label="Phân trang">
                        <ul>
                            <li class="@(curPage == 1 ? "disabled" : "")">
                                <a href="?page=@(curPage - 1)&pageSize=@Model.PageSize" aria-label="Trang trước"><i class="bi bi-chevron-left"></i></a>
                            </li>
                            @foreach (var pg in Model.Pages)
                            {
                                <li class="@(pg.IsActive ? "active" : "")">
                                    <a href="?page=@pg.Page&pageSize=@Model.PageSize">@pg.Page</a>
                                </li>
                            }
                            <li class="@(curPage == totalPages ? "disabled" : "")">
                                <a href="?page=@(curPage + 1)&pageSize=@Model.PageSize" aria-label="Trang sau"><i class="bi bi-chevron-right"></i></a>
                            </li>
                        </ul>
                    </nav>
                }

                <!-- ===== CTA ===== -->
                <section class="catalog-cta">
                    <div>
                        <h2>Bạn cần tìm sản phẩm công nghệ phù hợp?</h2>
                        <p>Trung tâm hỗ trợ kết nối, tư vấn và chuyển giao công nghệ theo nhu cầu thực tế của doanh nghiệp, hợp tác xã và tổ chức.</p>
                    </div>
                    <div class="catalog-cta__actions">
                        <a class="catalog-cta__primary" href="@($"{mainDomain}dang-ky-tu-van")">Gửi yêu cầu tư vấn</a>
                        <a class="catalog-cta__secondary" href="@($"{mainDomain}lien-he-74")">Liên hệ trung tâm</a>
                    </div>
                </section>
            </div>

            <!-- ===== SIDEBAR (col-3, RIGHT) ===== -->
            <div class="col-lg-3 d-none d-lg-block order-2 order-lg-2" id="left_column">
                <aside class="filter-sidebar">

                    <!-- Lĩnh vực -->
                    <div class="filter-sidebar__group">
                        <h4 class="filter-title">Lĩnh vực công nghệ</h4>
                        <ul class="filter-sidebar__links category-list">
                            @foreach (var cat in Model.AllCategories)
                            {
                                var isActive = cat.CatId == Model.CateId;
                                <li class="@(isActive ? "active" : "")">
                                    <a href="@($"{mainDomain}san-pham/{TechExchangeApp.Controllers.ProductController.MakeURLFriendly(cat.QueryString)}-{cat.CatId}")">
                                        @cat.Title
                                        @if (isActive) { <i class="bi bi-check2"></i> }
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>

                    @if (Model.Categories.Any())
                    {
                        <div class="filter-sidebar__group">
                            <h4 class="filter-title">Danh mục con</h4>
                            <ul class="filter-sidebar__links">
                                @foreach (var cate in Model.Categories)
                                {
                                    <li><a href="@cate.Url">@cate.Title</a></li>
                                }
                            </ul>
                        </div>
                    }

                    <!-- Khoảng giá -->
                    <div class="filter-sidebar__group filter-section">
                        <h4 class="filter-title">Khoảng giá</h4>
                        <label class="filter-check"><input type="checkbox" name="price" value="contact" /> Liên hệ báo giá</label>
                        <label class="filter-check"><input type="checkbox" name="price" value="0-5" /> Dưới 5 triệu</label>
                        <label class="filter-check"><input type="checkbox" name="price" value="5-20" /> 5 – 20 triệu</label>
                        <label class="filter-check"><input type="checkbox" name="price" value="20+" /> Trên 20 triệu</label>
                    </div>

                    <!-- Trạng thái -->
                    <div class="filter-sidebar__group filter-section">
                        <h4 class="filter-title">Trạng thái</h4>
                        <label class="filter-check"><input type="checkbox" name="status" value="ready" /> Sẵn sàng chuyển giao</label>
                        <label class="filter-check"><input type="checkbox" name="status" value="intro" /> Đang giới thiệu</label>
                        <label class="filter-check"><input type="checkbox" name="status" value="consult" /> Có tư vấn triển khai</label>
                    </div>

                    <div class="filter-sidebar__actions">
                        <button type="button" class="btn-filter-apply">Áp dụng</button>
                        <button type="button" class="btn-filter-clear" onclick="location.href=location.pathname">Xóa lọc</button>
                    </div>
                </aside>
            </div>

        </div>

    </div>
</div>
