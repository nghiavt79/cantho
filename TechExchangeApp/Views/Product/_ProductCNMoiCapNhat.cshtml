@using TechExchangeApp.Entities
@using TechExchangeApp.Controllers
@model List<SanPhamCNTB>

@{
    var pageTitle = ViewData["PageTitle"]?.ToString() ?? "Công nghệ";
    var pageLink = pageTitle switch
    {
        "Thiết bị" => "thiet-bi",
        "Tài sản trí tuệ" => "tai-san-tri-tue",
        _ => "cong-nghe"
    };

    string ImageUrl(SanPhamCNTB p)
    {
        if (!string.IsNullOrEmpty(p.QuyTrinhHinhAnh))
        {
            return ProductController.CookedImageURL("254-170", p.QuyTrinhHinhAnh, Html.MainDomain());
        }

        return p.TypeId switch
        {
            2 => $"{Html.MainDomain()}images/sangche.png",
            3 => $"{Html.MainDomain()}images/research.jpg",
            _ => $"{Html.MainDomain()}images/research.jpg"
        };
    }

    string DetailUrl(SanPhamCNTB p) => $"{Html.MainDomain()}san-pham/chi-tiet/{ProductController.MakeURLFriendly(p.Name)}-{p.ID}";

    string PlainText(string? value)
    {
        var text = System.Text.RegularExpressions.Regex.Replace(value ?? "", "<.*?>", " ");
        return System.Net.WebUtility.HtmlDecode(text).Trim();
    }

    string Description(SanPhamCNTB p)
    {
        var text = PlainText(!string.IsNullOrWhiteSpace(p.MoTaNgan) ? p.MoTaNgan : p.MoTa);
        if (string.IsNullOrWhiteSpace(text))
        {
            return "Giải pháp công nghệ phục vụ sản xuất, vận hành và ứng dụng thực tế cho doanh nghiệp.";
        }

        return text.Length > 110 ? text.Substring(0, 107).Trim() + "..." : text;
    }

    string Price(SanPhamCNTB p) => p.OriginalPrice > 0
        ? ProductController.FormatCurrencyOto((decimal?)p.OriginalPrice, p.Currency)
        : "Liên hệ";

    string Source(SanPhamCNTB p)
    {
        if (!string.IsNullOrWhiteSpace(p.CoQuanChuTri)) return p.CoQuanChuTri;
        if (!string.IsNullOrWhiteSpace(p.CoQuanChuQuan)) return p.CoQuanChuQuan;
        if (!string.IsNullOrWhiteSpace(p.HoTen)) return p.HoTen;
        return "Nguồn công nghệ đang cập nhật";
    }
}

<section class="featured-section">
    <div class="section-heading">
        <div>
            <h2>@pageTitle mới cập nhật</h2>
        </div>
        <div class="featured-section__actions">
            <button type="button" class="featured-section__nav" data-tech-carousel-prev aria-label="Công nghệ mới trước">
                <i class="bi bi-chevron-left"></i>
            </button>
            <button type="button" class="featured-section__nav" data-tech-carousel-next aria-label="Công nghệ mới tiếp theo">
                <i class="bi bi-chevron-right"></i>
            </button>
        </div>
    </div>

    <div class="tech-carousel" data-tech-carousel>
        @foreach (var p in Model.Take(16))
        {
            <article class="tech-card">
                <a class="tech-card__image" href="@DetailUrl(p)">
                    <img src="@ImageUrl(p)" alt="@p.Name" />
                </a>
                <div class="tech-card__body">
                    <span class="tech-card__badge">Mới cập nhật</span>
                    <h3 class="tech-card__title">
                        <a href="@DetailUrl(p)" title="@p.Name">@p.Name</a>
                    </h3>
                    <p class="tech-card__desc">@Description(p)</p>
                    <div class="tech-card__source">
                        <i class="bi bi-building"></i> @Source(p)
                    </div>
                    <div class="tech-card__price">
                        Giá tham khảo: <strong>@Price(p)</strong>
                    </div>
                    <a href="@DetailUrl(p)" class="tech-card__btn">Chi tiết <i class="bi bi-arrow-right"></i></a>
                </div>
            </article>
        }
    </div>
</section>

<script>
    (function () {
        function setupTechCarousel(section) {
            var carousel = section.querySelector('[data-tech-carousel]');
            var prev = section.querySelector('[data-tech-carousel-prev]');
            var next = section.querySelector('[data-tech-carousel-next]');
            if (!carousel || !prev || !next || carousel.dataset.carouselReady === 'true') return;

            carousel.dataset.carouselReady = 'true';

            function cardStep() {
                var card = carousel.querySelector('.tech-card');
                if (!card) return carousel.clientWidth;
                var styles = window.getComputedStyle(carousel);
                var gap = parseFloat(styles.columnGap || styles.gap || 0) || 0;
                return card.getBoundingClientRect().width + gap;
            }

            function updateButtons() {
                var maxScroll = carousel.scrollWidth - carousel.clientWidth - 2;
                prev.disabled = carousel.scrollLeft <= 2;
                next.disabled = carousel.scrollLeft >= maxScroll;
            }

            prev.addEventListener('click', function () {
                carousel.scrollBy({ left: -cardStep() * 4, behavior: 'smooth' });
            });

            next.addEventListener('click', function () {
                carousel.scrollBy({ left: cardStep() * 4, behavior: 'smooth' });
            });

            carousel.addEventListener('scroll', updateButtons, { passive: true });
            window.addEventListener('resize', updateButtons);
            updateButtons();
        }

        function init() {
            document.querySelectorAll('.featured-section').forEach(setupTechCarousel);
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', init);
        } else {
            init();
        }
    })();
</script>
