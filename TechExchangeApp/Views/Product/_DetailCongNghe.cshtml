@using TechExchangeApp.ViewModel
@using TechExchangeApp.Entities
@model ProductDetailViewModel

@{
    var p = Model.Product;
    var categories = Model.RelatedCategories ?? new List<Category>();
    var productImage = Html.CookedImageURL("org", p.QuyTrinhHinhAnh);
    var rating = p.Rating ?? 0;
    var ratingText = rating > 0 ? rating.ToString("0.0") : "0.0";
    var priceText = p.SellPrice.HasValue && p.SellPrice.Value > 0
        ? string.Format("{0:N0} {1}", p.SellPrice.Value, p.Currency)
        : "Liên hệ báo giá";
    var updatedText = (p.Modified ?? p.PublishedDate ?? p.Created)?.ToString("dd/MM/yyyy") ?? "Đang cập nhật";
    var categoryText = string.IsNullOrWhiteSpace(Model.CategoryTitle) ? "Đang cập nhật" : Model.CategoryTitle;
    var supplierText = string.IsNullOrWhiteSpace(Model.SupplierName) ? "Đang cập nhật" : Model.SupplierName;
    var originText = string.IsNullOrWhiteSpace(p.XuatXu) ? "Đang cập nhật" : p.XuatXu;
    var techCode = string.IsNullOrWhiteSpace(p.Code) ? p.ID.ToString("D5") : p.Code;

    var catIds = new List<int>();
    if (!string.IsNullOrEmpty(p.CategoryId))
    {
        foreach (var s in p.CategoryId.Split(new[] { ',', '|', ';' }, StringSplitOptions.RemoveEmptyEntries))
        {
            if (int.TryParse(s.Trim(), out var cid)) catIds.Add(cid);
        }
    }

    var activeIndustries = Model.Industries?.Where(ind => catIds.Contains(ind.CatId)).ToList() ?? new List<Category>();
    var hasDocuments = !string.IsNullOrWhiteSpace(Model.YoutubeEmbedUrl)
        || !string.IsNullOrWhiteSpace(Model.VideoFileUrl)
        || !string.IsNullOrWhiteSpace(p.BrochureUrl)
        || p.ChungNhanISO == true
        || p.ChungNhanQuatest == true
        || p.ChungNhanKhac == true;
}

<div class="tech-detail-page">
    <nav class="tech-breadcrumb" aria-label="breadcrumb">
        <a href="/">Trang chủ</a><span>/</span><a href="/cong-nghe">Công nghệ</a>
        @if (!string.IsNullOrWhiteSpace(Model.CategoryTitle))
        {
            <span>/</span><span>@Model.CategoryTitle</span>
        }
    </nav>

    <h1 class="tech-page-title">Chi tiết công nghệ</h1>

    <section class="tech-card tech-hero">
        <div class="row g-4">
            <div class="col-lg-5">
                <div class="tech-hero-image"><img src="@productImage" alt="@p.Name" /></div>
                @if (Model.Images != null && Model.Images.Any())
                {
                    <div class="tech-thumbs">
                        @foreach (var img in Model.Images.Take(6))
                        {
                            <img src="@Html.CookedImageURL("68-68", img.ToString())" alt="@p.Name" />
                        }
                    </div>
                }
            </div>
            <div class="col-lg-7">
                <span class="tech-badge"><i class="fa fa-microchip"></i>@categoryText</span>
                <h2 class="tech-name">@p.Name</h2>
                <div class="tech-meta" id="headerMetaLine" data-entity-type="SanPhamCNTB" data-entity-id="@p.ID">
                    <span><span class="tech-stars">★★★★★</span> <strong id="headerRatingAvg">@ratingText</strong> (<span id="headerRatingCount">@Model.RatingCount</span> đánh giá)</span>
                    <span><i class="fa fa-eye"></i> <span id="headerViewCount">@((p.Viewed ?? 0).ToString("N0"))</span> lượt xem</span>
                </div>

                <div class="tech-info-grid">
                    <div class="tech-info-row">
                        <span class="tech-info-label">Nhà cung cấp</span>
                        <span class="tech-info-value">
                            @if (!string.IsNullOrWhiteSpace(Model.SupplierUrl) && !string.IsNullOrWhiteSpace(Model.SupplierName))
                            {
                                <a href="@Model.SupplierUrl">@Model.SupplierName</a>
                            }
                            else
                            {
                                @supplierText
                            }
                        </span>
                    </div>
                    <div class="tech-info-row"><span class="tech-info-label">Danh mục</span><span class="tech-info-value">@categoryText</span></div>
                    <div class="tech-info-row"><span class="tech-info-label">Xuất xứ</span><span class="tech-info-value">@originText</span></div>
                    <div class="tech-info-row"><span class="tech-info-label">Giá tham khảo</span><span class="tech-price">@priceText</span></div>
                </div>

                <div class="tech-actions">
                    <a href="/TechTransfer/Create?fromId=@p.ID&typeData=1" class="tech-btn tech-btn-primary"><i class="fa fa-file-signature"></i>Liên hệ báo giá</a>
                </div>
            </div>
        </div>
    </section>

    <div class="tech-layout">
        <main>
            <section class="tech-tabs-card">
                <ul class="nav nav-tabs" id="detailTabsCongNghe" role="tablist">
                    <li class="nav-item" role="presentation"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#overview" type="button" role="tab">Tổng quan</button></li>
                    <li class="nav-item" role="presentation"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#spec" type="button" role="tab">Thông số kỹ thuật</button></li>
                    <li class="nav-item" role="presentation"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#application" type="button" role="tab">Ứng dụng</button></li>
                    <li class="nav-item" role="presentation"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#transfer" type="button" role="tab">Chuyển giao</button></li>
                    <li class="nav-item" role="presentation"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#docs" type="button" role="tab">Tài liệu</button></li>
                    <li class="nav-item" role="presentation"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#review" type="button" role="tab">Đánh giá</button></li>
                </ul>

                <div class="tab-content tech-tab-body">
                    <div class="tab-pane fade show active" id="overview" role="tabpanel">
                        <h3 class="tech-section-title">Thông tin công nghệ</h3>
                        <div class="tech-info-grid mb-3">
                            <div class="tech-info-row"><span class="tech-info-label">Tên công nghệ</span><span class="tech-info-value">@p.Name</span></div>
                            <div class="tech-info-row"><span class="tech-info-label">Mã công nghệ</span><span class="tech-info-value">@techCode</span></div>
                            <div class="tech-info-row"><span class="tech-info-label">Xuất xứ</span><span class="tech-info-value">@originText</span></div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(p.MoTaNgan))
                        {
                            <div class="tech-content">@Html.Raw(p.MoTaNgan)</div>
                        }
                        else if (!string.IsNullOrWhiteSpace(p.MoTa))
                        {
                            <div class="tech-content">@Html.Raw(p.MoTa)</div>
                        }
                        else
                        {
                            <div class="tech-empty">Thông tin tổng quan đang được cập nhật.</div>
                        }
                    </div>

                    <div class="tab-pane fade" id="spec" role="tabpanel">
                        <h3 class="tech-section-title">Thông số kỹ thuật</h3>
                        @if (!string.IsNullOrWhiteSpace(p.ThongSo)) { <div class="tech-content">@Html.Raw(p.ThongSo)</div> } else { <div class="tech-empty">Thông số kỹ thuật đang được cập nhật.</div> }
                        @if (!string.IsNullOrWhiteSpace(p.UuDiem)) { <h3 class="tech-section-title mt-4">Ưu điểm nổi bật</h3><div class="tech-content">@Html.Raw(p.UuDiem)</div> }
                    </div>

                    <div class="tab-pane fade" id="application" role="tabpanel">
                        <h3 class="tech-section-title">Ứng dụng thực tế</h3>
                        @if (activeIndustries.Any())
                        {
                            <ul class="tech-category-list mb-3">
                                @foreach (var ind in activeIndustries) { <li><a href="#">@ind.Title</a></li> }
                            </ul>
                        }
                        @if (!string.IsNullOrWhiteSpace(p.TargetCustomer) || !string.IsNullOrWhiteSpace(p.Khachhang) || !string.IsNullOrWhiteSpace(p.CooperationGoal))
                        {
                            <div class="tech-content">@Html.Raw(p.TargetCustomer) @Html.Raw(p.Khachhang) @Html.Raw(p.CooperationGoal)</div>
                        }
                        else if (!activeIndustries.Any())
                        {
                            <div class="tech-empty">Thông tin ứng dụng đang được cập nhật.</div>
                        }
                    </div>

                    <div class="tab-pane fade" id="transfer" role="tabpanel">
                        <h3 class="tech-section-title">Phương thức chuyển giao</h3>
                        @if (!string.IsNullOrWhiteSpace(p.TransferMethod) || !string.IsNullOrWhiteSpace(p.TransferMethodKhac) || !string.IsNullOrWhiteSpace(p.GiaBanDuKien) || !string.IsNullOrWhiteSpace(p.BaoHanhHoTro))
                        {
                            <div class="tech-content">
                                @if (!string.IsNullOrWhiteSpace(p.TransferMethod)) { <p><strong>Hình thức:</strong> @p.TransferMethod</p> }
                                @if (!string.IsNullOrWhiteSpace(p.TransferMethodKhac)) { <p><strong>Khác:</strong> @p.TransferMethodKhac</p> }
                                @if (!string.IsNullOrWhiteSpace(p.GiaBanDuKien)) { <p><strong>Giá bán dự kiến:</strong></p>@Html.Raw(p.GiaBanDuKien) }
                                @if (!string.IsNullOrWhiteSpace(p.ChiPhiPhatSinh)) { <p><strong>Chi phí phát sinh:</strong></p>@Html.Raw(p.ChiPhiPhatSinh) }
                                @if (!string.IsNullOrWhiteSpace(p.BaoHanhHoTro)) { <p><strong>Bảo hành và hỗ trợ:</strong></p>@Html.Raw(p.BaoHanhHoTro) }
                            </div>
                        }
                        else
                        {
                            <div class="tech-empty">Thông tin chuyển giao đang được cập nhật.</div>
                        }
                    </div>

                    <div class="tab-pane fade" id="docs" role="tabpanel">
                        <h3 class="tech-section-title">Tài liệu / chứng nhận</h3>
                        @if (hasDocuments)
                        {
                            <div class="tech-content">
                                @if (!string.IsNullOrWhiteSpace(Model.YoutubeEmbedUrl))
                                {
                                    <div class="ratio ratio-16x9 mb-3"><iframe src="@Model.YoutubeEmbedUrl" title="@p.Name" allowfullscreen></iframe></div>
                                }
                                else if (!string.IsNullOrWhiteSpace(Model.VideoFileUrl))
                                {
                                    <p><a class="tech-btn tech-btn-outline" href="@Model.VideoFileUrl" target="_blank"><i class="fa fa-play"></i>Xem video</a></p>
                                }
                                @if (!string.IsNullOrWhiteSpace(p.BrochureUrl)) { <p><a class="tech-btn tech-btn-outline" href="@p.BrochureUrl" target="_blank"><i class="fa fa-download"></i>Tải tài liệu</a></p> }
                                <ul>
                                    @if (p.ChungNhanISO == true) { <li>ISO / CE / HACCP</li> }
                                    @if (p.ChungNhanQuatest == true) { <li>Phiếu kiểm nghiệm Quatest</li> }
                                    @if (p.ChungNhanKhac == true) { <li>@(string.IsNullOrWhiteSpace(p.ChungNhanKhacText) ? "Chứng nhận khác" : p.ChungNhanKhacText)</li> }
                                </ul>
                            </div>
                        }
                        else
                        {
                            <div class="tech-empty">Tài liệu và chứng nhận đang được cập nhật.</div>
                        }
                    </div>

                    <div class="tab-pane fade" id="review" role="tabpanel">
                        @if (Model.RatingCount <= 0) { <div class="tech-empty mb-3">Chưa có đánh giá nào cho công nghệ này.</div> }
                        @await Html.PartialAsync("_EntityRating", null, new ViewDataDictionary(ViewData) {
                            { "EntityType", "SanPhamCNTB" },
                            { "EntityId", p.ID }
                        })
                    </div>
                </div>
            </section>

            @await Html.PartialAsync("_ContentUtilities", new TechExchangeApp.ViewModel.ContentUtilitiesVm
            {
                TargetDataType = "San pham CNTB",
                TargetSubType = "Cong nghe",
                TargetId = p.ID,
                TargetTitle = p.Name,
                ShareTitle = p.Name
            })
        </main>

        <aside class="tech-sidebar">
            <section class="tech-sidebar-card">
                <h3 class="tech-sidebar-title">Thông tin nhanh</h3>
                <dl class="tech-quick-list">
                    <div><dt>Mã công nghệ</dt><dd>@techCode</dd></div>
                    <div><dt>Danh mục</dt><dd>@categoryText</dd></div>
                    <div><dt>Lượt xem</dt><dd>@((p.Viewed ?? 0).ToString("N0"))</dd></div>
                    <div><dt>Cập nhật</dt><dd>@updatedText</dd></div>
                    <div><dt>Trạng thái</dt><dd>Đang giới thiệu</dd></div>
                </dl>
            </section>

            @if (categories.Any())
            {
                <section class="tech-sidebar-card">
                    <h3 class="tech-sidebar-title">Danh mục liên quan</h3>
                    <ul class="tech-category-list">
                        @foreach (var cat in categories.Take(6))
                        {
                            <li><a href="/2-ds-cong-nghe-thiet-bi/@cat.QueryString-@cat.CatId">@cat.Title</a></li>
                        }
                    </ul>
                </section>
            }
        </aside>
    </div>

    <div class="tech-related-wrap">
        @await Component.InvokeAsync("ProductPortletIOSanpham", new { productId = p.ID })
    </div>
</div>
