@using TechExchangeApp.Interfaces
@using Microsoft.AspNetCore.Identity
@using TechExchangeApp.Entities
@inject IAccountService AccountService
@inject UserManager<ApplicationUser> UserManager

@model List<TechExchangeApp.ViewModel.SellerInvitationVm>

@{
    ViewData["Title"] = "Lời mời tham gia";
    ViewData["AuthWorkspace"] = true;

    var userId = int.Parse(UserManager.GetUserId(User)!);
    var sidebarData = await AccountService.GetSidebarDataAsync(userId);
}

<div class="container-fluid py-4 user-portal">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3 col-lg-2">
            @await Html.PartialAsync("_AccountSidebar", sidebarData)
        </div>

        <!-- Main Content -->
        <div class="col-md-9 col-lg-10 user-portal-main">

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show">
                    <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["InfoMessage"] != null)
            {
                <div class="alert alert-info alert-dismissible fade show">
                    <i class="fas fa-info-circle"></i> @TempData["InfoMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="user-profile-header mb-3">
                <h2 class="h4 mb-1" style="color:var(--up-navy);font-weight:700;">Lời mời tham gia</h2>
                <p class="mb-0">@Model.Count lời mời báo giá từ bên mua đang chờ bạn phản hồi.</p>
            </div>

            @if (!Model.Any())
            {
                <div class="card border-0">
                    <div class="empty-state">
                        <i class="fas fa-envelope-open-text empty-state-icon"></i>
                        <p class="empty-state-title">Chưa có lời mời nào</p>
                        <p class="empty-state-text mb-0">Hiện tại bạn chưa được mời tham gia dự án nào. Vui lòng kiểm tra lại sau.</p>
                    </div>
                </div>
            }
            else
            {
                <div class="row g-3">
                    @foreach (var item in Model)
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="user-invitation-card h-100 d-flex flex-column">
                                <div class="user-invitation-card-top">
                                    <div class="user-invitation-card-title">@item.Project.ProjectName</div>
                                    <span class="badge @item.StatusBadgeClass">@item.StatusText</span>
                                </div>

                                <div class="user-invitation-card-meta">
                                    <span><i class="fas fa-file-invoice"></i>@item.RFQ.MaRFQ</span>
                                    <span><i class="fas fa-calendar"></i>Mời ngày @item.Invitation.InvitedDate.ToString("dd/MM/yyyy")</span>
                                    <span class="@(!item.DeadlinePassed && item.DaysUntilDeadline <= 3 ? "is-urgent" : "")">
                                        <i class="fas fa-clock"></i>
                                        @if (item.DeadlinePassed)
                                        {
                                            <text>Đã hết hạn nộp hồ sơ</text>
                                        }
                                        else
                                        {
                                            <text>Hạn: @item.RFQ.HanChotNopHoSo.ToString("dd/MM/yyyy") (còn @item.DaysUntilDeadline ngày)</text>
                                        }
                                    </span>
                                    <span><i class="fas @(item.NdaSigned ? "fa-file-circle-check" : "fa-file-signature")"></i>@(item.NdaSigned ? "Đã ký NDA" : "Chưa ký NDA")</span>
                                </div>

                                <div class="user-invitation-card-actions mt-auto">
                                    @if (item.Invitation.StatusId == 0 || item.Invitation.StatusId == 1)
                                    {
                                        @if (!item.NdaSigned)
                                        {
                                            <a href="/Project/SignNda?projectId=@item.Project.Id" class="btn btn-primary btn-sm">
                                                <i class="fas fa-file-signature"></i> Ký NDA
                                            </a>
                                        }
                                        else if (item.CanSubmitProposal)
                                        {
                                            <form method="post" asp-action="AcceptInvitation" asp-route-id="@item.Invitation.Id" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-primary btn-sm">
                                                    <i class="fas fa-check"></i> Chấp nhận &amp; xem chi tiết
                                                </button>
                                            </form>
                                        }
                                        else if (item.DeadlinePassed)
                                        {
                                            <button class="btn btn-outline-secondary btn-sm" disabled>
                                                <i class="fas fa-clock"></i> Đã hết hạn
                                            </button>
                                        }

                                        @if (item.Invitation.StatusId == 0)
                                        {
                                            <button type="button" class="btn btn-outline-danger btn-sm"
                                                    data-bs-toggle="modal" data-bs-target="#declineModal@(item.Invitation.Id)">
                                                <i class="fas fa-times"></i> Từ chối
                                            </button>

                                            <!-- Decline Modal -->
                                            <div class="modal fade" id="declineModal@(item.Invitation.Id)" tabindex="-1">
                                                <div class="modal-dialog">
                                                    <div class="modal-content">
                                                        <form method="post" asp-action="DeclineInvitation" asp-route-id="@item.Invitation.Id">
                                                            @Html.AntiForgeryToken()
                                                            <div class="modal-header">
                                                                <h5 class="modal-title">Từ chối lời mời</h5>
                                                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                            </div>
                                                            <div class="modal-body">
                                                                <p>Bạn có chắc chắn muốn từ chối lời mời tham gia dự án <strong>@item.Project.ProjectName</strong>?</p>
                                                                <div class="mb-3">
                                                                    <label class="form-label">Lý do (không bắt buộc):</label>
                                                                    <textarea name="reason" class="form-control" rows="3"
                                                                              placeholder="Nhập lý do từ chối..."></textarea>
                                                                </div>
                                                            </div>
                                                            <div class="modal-footer">
                                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                                                                <button type="submit" class="btn btn-danger">Xác nhận từ chối</button>
                                                            </div>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    }
                                    else if (item.Invitation.StatusId == 2)
                                    {
                                        @if (item.CanSubmitProposal)
                                        {
                                            <a href="/Seller/ProjectDetails/@item.Project.Id" class="btn btn-primary btn-sm">
                                                <i class="fas fa-paper-plane"></i> Gửi báo giá
                                            </a>
                                        }
                                        else if (item.ProposalSubmitted)
                                        {
                                            <a href="/Proposal/Index?duAnId=@item.Project.Id" class="btn btn-primary btn-sm">
                                                <i class="fas fa-file-alt"></i> Xem báo giá đã gửi
                                            </a>
                                        }
                                        <a href="/Seller/ProjectDetails/@item.Project.Id" class="btn btn-outline-secondary btn-sm">
                                            <i class="fas fa-eye"></i> Xem chi tiết dự án
                                        </a>
                                    }
                                    else if (item.Invitation.StatusId == 3) // ProposalSubmitted
                                    {
                                        <a href="/Seller/ViewMyProposal?projectId=@item.Project.Id" class="btn btn-primary btn-sm">
                                            <i class="fas fa-check-circle"></i> Đã gửi báo giá
                                        </a>
                                        <a href="/Seller/ProjectDetails/@item.Project.Id" class="btn btn-outline-secondary btn-sm">
                                            <i class="fas fa-eye"></i> Xem chi tiết dự án
                                        </a>
                                    }
                                    else if (item.Invitation.StatusId == 4) // Declined
                                    {
                                        <button class="btn btn-outline-secondary btn-sm" disabled>
                                            <i class="fas fa-ban"></i> Đã từ chối
                                        </button>
                                    }
                                    else if (item.Invitation.StatusId == 5) // Expired
                                    {
                                        <button class="btn btn-outline-secondary btn-sm" disabled>
                                            <i class="fas fa-clock"></i> Đã hết hạn
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }

        </div><!-- End Main Content -->
    </div><!-- End row -->
</div><!-- End container-fluid -->

@section Styles {
    <link rel="stylesheet" href="~/css/user-portal.css" asp-append-version="true" />
}
