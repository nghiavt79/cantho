@using TechExchangeApp.Interfaces
@using Microsoft.AspNetCore.Identity
@using TechExchangeApp.Entities
@inject IAccountService AccountService
@inject UserManager<ApplicationUser> UserManager

@model TechExchangeApp.Entities.TechTransferRequest

@{
    ViewData["Title"] = "PHIẾU YÊU CẦU CHUYỂN GIAO CÔNG NGHỆ";
    ViewData["AuthWorkspace"] = true;
    var linhVucList = ViewBag.LinhVucList as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? new();

    var userId = int.Parse(UserManager.GetUserId(User)!);
    var sidebarData = await AccountService.GetSidebarDataAsync(userId);
}

<div class="container-fluid py-4 user-portal">
  <div class="row">
    <!-- Sidebar -->
    <div class="col-md-3 col-lg-2">
      @await Html.PartialAsync("_AccountSidebar", sidebarData)
    </div>

    <!-- Main Content -->
    <div class="col-md-9 col-lg-10 user-portal-main">
<div class="container user-tech-transfer-form" style="max-width:900px;">
    <div class="card shadow">
        <div class="card-header">
            <h2 class="h4 mb-0"><i class="fas fa-file-signature me-2"></i>@ViewData["Title"]</h2>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="FromId" />
                <input type="hidden" asp-for="TypeData" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="row">
                    <!-- Thông tin liên hệ -->
                    <div class="col-md-12 mb-4">
                        <h5 class="text-primary border-bottom pb-2 mb-3">Thông tin liên hệ</h5>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="HoTen" class="form-label">Họ và tên <span class="text-danger">*</span></label>
                                <input asp-for="HoTen" class="form-control" placeholder="Nhập họ và tên" />
                                <span asp-validation-for="HoTen" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ChucVu" class="form-label">Chức vụ</label>
                                <input asp-for="ChucVu" class="form-control" />
                                <span asp-validation-for="ChucVu" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="DonVi" class="form-label">Đơn vị</label>
                                <input asp-for="DonVi" class="form-control" />
                                <span asp-validation-for="DonVi" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="DiaChi" class="form-label">Địa chỉ</label>
                                <input asp-for="DiaChi" class="form-control" />
                                <span asp-validation-for="DiaChi" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="DienThoai" class="form-label">Điện thoại <span class="text-danger">*</span></label>
                                <input asp-for="DienThoai" class="form-control" />
                                <span asp-validation-for="DienThoai" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label">Email <span class="text-danger">*</span></label>
                                <input asp-for="Email" class="form-control" type="email" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Thông tin nhu cầu -->
                    <div class="col-md-12">
                        <h5 class="text-primary border-bottom pb-2 mb-3">Thông tin nhu cầu công nghệ</h5>
                        <div class="row g-3">
                            <div class="col-12">
                                <label asp-for="TenCongNghe" class="form-label">Tên công nghệ yêu cầu <span class="text-danger">*</span></label>
                                <input asp-for="TenCongNghe" class="form-control" placeholder="Nhập tên công nghệ cần chuyển giao" />
                                <span asp-validation-for="TenCongNghe" class="text-danger"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="MoTaNhuCau" class="form-label">Mô tả chi tiết nhu cầu <span class="text-danger">*</span></label>
                                <textarea asp-for="MoTaNhuCau" class="form-control" rows="5" placeholder="Mô tả chi tiết về công nghệ, thông số kỹ thuật, yêu cầu cụ thể..."></textarea>
                                <span asp-validation-for="MoTaNhuCau" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="LinhVuc" class="form-label">Lĩnh vực</label>
                                <select asp-for="LinhVuc" asp-items="linhVucList"
                                        class="form-select" id="selectLinhVuc">
                                    <option value="">-- Chọn lĩnh vực --</option>
                                </select>
                                <span asp-validation-for="LinhVuc" class="text-danger"></span>
                            </div>
                             <div class="col-md-6">
                                <label asp-for="NganSachDuKien" class="form-label">Ngân sách dự kiến (VNĐ)</label>
                                <input type="text" class="form-control" id="txtNganSachDisplay"
                                       placeholder="0" inputmode="numeric"
                                       value="@(Model?.NganSachDuKien > 0 ? Model.NganSachDuKien?.ToString("N0", System.Globalization.CultureInfo.GetCultureInfo("vi-VN")) : "")" />
                                <input asp-for="NganSachDuKien" type="hidden" id="hdnNganSach" />
                                <span asp-validation-for="NganSachDuKien" class="text-danger"></span>
                            </div>
                             <div class="col-md-6" style="display:none;">
                                <label asp-for="ProjectId" class="form-label">Dự án liên quan (ID)</label>
                                <input asp-for="ProjectId" class="form-control" />
                                <span asp-validation-for="ProjectId" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                    <a asp-controller="Projects" asp-action="MyProjects" class="btn btn-secondary me-md-2">Quay lại</a>
                    <button type="submit" class="btn btn-primary"><i class="fas fa-paper-plane me-2"></i>Gửi yêu cầu</button>
                </div>
            </form>
        </div>
    </div>
</div>
    </div><!-- End Main Content -->
  </div><!-- End row -->
</div><!-- End container-fluid -->

@section Styles {
    <link rel="stylesheet" href="~/css/user-portal.css" asp-append-version="true" />
}

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        $(function () {
            // Select2 searchable dropdown for Lĩnh vực
            $('#selectLinhVuc').select2({
                theme: 'bootstrap-5',
                placeholder: '-- Chọn lĩnh vực --',
                allowClear: true,
                width: '100%'
            });

            // Vietnamese currency formatting for Ngân sách
            var $display = $('#txtNganSachDisplay');
            var $hidden = $('#hdnNganSach');

            function formatVND(value) {
                var num = value.replace(/\D/g, '');
                if (!num) return '';
                return num.replace(/\B(?=(\d{3})+(?!\d))/g, '.');
            }

            $display.on('input', function () {
                var raw = $(this).val().replace(/\D/g, '');
                $(this).val(formatVND($(this).val()));
                $hidden.val(raw);
            });

            // Initialize hidden field from display value on load
            var initVal = $display.val().replace(/\D/g, '');
            if (initVal) $hidden.val(initVal);

            // Ensure hidden field is synced before form submit
            $display.closest('form').on('submit', function () {
                $hidden.val($display.val().replace(/\D/g, ''));
            });
        });
    </script>
}
