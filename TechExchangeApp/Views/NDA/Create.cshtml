@model TechExchangeApp.Entities.NDAAgreement

@{
    ViewData["Title"] = "PHIẾU THỎA THUẬN BẢO MẬT";
}

<div class="container mt-5 mb-5" style="max-width: 850px;">
    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white text-center py-3">
            <h2 class="h4 mb-0"><i class="fas fa-file-contract me-2"></i>PHIẾU THỎA THUẬN BẢO MẬT</h2>
            <div class="mt-1 small opacity-75">–oOo–</div>
        </div>
        <div class="card-body px-4 py-4">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ProjectId" />
                <input type="hidden" asp-for="LoaiNDA" value="Mẫu chuẩn của Sàn" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                @* ── Bên A / Bên B ── *@
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label asp-for="BenA" class="form-label fw-semibold">
                            Bên A (Bên Mua) <span class="text-danger">*</span>
                        </label>
                        <input asp-for="BenA" class="form-control" placeholder="Nhập tên đơn vị / cá nhân" />
                        <span asp-validation-for="BenA" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="BenB" class="form-label fw-semibold">
                            Bên B (Bên Tư vấn)
                        </label>
                        <input asp-for="BenB" class="form-control bg-light"
                               value="Trung tâm Thông tin, Thống kê và Ứng dụng tiến bộ khoa học công nghệ"
                               readonly />
                        <span asp-validation-for="BenB" class="text-danger"></span>
                    </div>
                </div>

                @* ── Nội dung điều khoản ── *@
                <div class="border rounded-3 p-4 mb-4" style="background: #f8fafc;">
                    <p class="fw-semibold text-dark mb-3">
                        Bằng việc đánh dấu tick chọn, <strong>Bên Mua</strong> xác nhận và cam kết tuân thủ các điều kiện sau:
                    </p>
                    <ol class="mb-0" style="line-height: 1.9;">
                        <li>
                            <strong>Bảo mật tuyệt đối:</strong>
                            Không sao chép, phát tán hay tiết lộ Thông Tin Mật cho bất kỳ bên thứ ba nào khi chưa được phép.
                        </li>
                        <li>
                            <strong>Sử dụng đúng mục đích:</strong>
                            Chỉ sử dụng thông tin cho giao dịch chuyển giao công nghệ, nghiêm cấm sử dụng cho mục đích thương mại riêng.
                        </li>
                        <li>
                            <strong>Tôn trọng Sở hữu trí tuệ:</strong>
                            Việc tiếp nhận thông tin không làm phát sinh quyền sở hữu hay quyền sử dụng (license) đối với tài sản trí tuệ.
                        </li>
                        <li>
                            <strong>Thời hạn ràng buộc:</strong>
                            Duy trì nghĩa vụ bảo mật <strong>03 năm</strong> sau khi kết thúc thỏa thuận; giữ kín vô thời hạn đối với các "Bí mật kinh doanh".
                        </li>
                        <li>
                            <strong>Trách nhiệm vi phạm:</strong>
                            Chấp nhận chịu phạt <strong>5% giá trị hợp đồng</strong> và bồi thường toàn bộ thiệt hại thực tế (gồm án phí, phí luật sư) nếu vi phạm.
                        </li>
                        <li>
                            <strong>Giải quyết tranh chấp:</strong>
                            Tuân thủ pháp luật Việt Nam, ưu tiên thương lượng hoặc giải quyết tại Tòa án có thẩm quyền tại Thành Phố Cần Thơ.
                        </li>
                    </ol>
                </div>

                @* ── Checkbox Đồng ý ── *@
                <div class="border rounded-3 p-3 mb-4" style="background: #fffdf0; border-color: #ffc107 !important;">
                    <div class="form-check">
                        <input asp-for="DaDongY" class="form-check-input" type="checkbox" id="chkDongY" style="width:1.2em; height:1.2em;" />
                        <label asp-for="DaDongY" class="form-check-label fw-bold fs-6 ms-1" for="chkDongY">
                            <i class="fas fa-check-circle text-success me-1"></i> Đồng ý
                        </label>
                    </div>
                    <span asp-validation-for="DaDongY" class="text-danger d-block ms-4"></span>
                </div>

                @* ── Thời hạn bảo mật ── *@
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label asp-for="ThoiHanBaoMat" class="form-label fw-semibold">
                            <i class="fas fa-calendar-alt me-1 text-primary"></i>
                            Thời hạn bảo mật <span class="text-danger">*</span>
                        </label>
                        <select asp-for="ThoiHanBaoMat" class="form-select">
                            <option value="">-- Chọn thời hạn --</option>
                            <option value="1 năm">1 năm</option>
                            <option value="2 năm">2 năm</option>
                            <option value="3 năm" selected>3 năm</option>
                            <option value="5 năm">5 năm</option>
                            <option value="Vĩnh viễn">Vĩnh viễn</option>
                        </select>
                        <span asp-validation-for="ThoiHanBaoMat" class="text-danger"></span>
                    </div>

                    @* ── Xác nhận ký số ── *@
                    <div class="col-md-6">
                        <label asp-for="XacNhanKySo" class="form-label fw-semibold">
                            <i class="fas fa-signature me-1 text-primary"></i>
                            Xác nhận ký số (E-Sign)
                        </label>
                        <select asp-for="XacNhanKySo" class="form-select">
                            <option value="">-- Chọn hình thức --</option>
                            <option value="E-Sign">Chữ ký số (E-Sign)</option>
                            <option value="OTP">OTP</option>
                        </select>
                        <span asp-validation-for="XacNhanKySo" class="text-danger"></span>
                    </div>
                </div>

                @* ── Nút hành động ── *@
                <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4 pt-3 border-top">
                    <a asp-controller="Project" asp-action="Details" asp-route-id="@Model.ProjectId"
                       class="btn btn-secondary me-md-2">
                        <i class="fas fa-arrow-left me-1"></i> Quay lại
                    </a>
                    <button type="submit" class="btn btn-primary" id="btnSubmitNDA" disabled>
                        <i class="fas fa-signature me-2"></i>Ký và xác nhận NDA
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        $(function () {
            // Enable submit button only when checkbox is checked
            var $chk = $('#chkDongY');
            var $btn = $('#btnSubmitNDA');

            $chk.on('change', function () {
                $btn.prop('disabled', !this.checked);
            });

            // Init state
            $btn.prop('disabled', !$chk.is(':checked'));
        });
    </script>
}
