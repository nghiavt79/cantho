@using TechExchangeApp.Interfaces
@using Microsoft.AspNetCore.Identity
@using TechExchangeApp.Entities
@inject IAccountService AccountService
@inject UserManager<ApplicationUser> UserManager

@model TechExchangeApp.Areas.Cms.Controllers.SanPhamCNTBFormVm
@{
    bool isEdit = Model.ID > 0;
    ViewData["Title"] = ViewData["Title"] ?? (isEdit ? "Chỉnh sửa Thiết bị" : "Đăng ký Thiết bị mới");
    Layout = "~/Views/Shared/_Layout.cshtml";
    var userId = int.Parse(UserManager.GetUserId(User)!);
    var sidebarData = await AccountService.GetSidebarDataAsync(userId);
    var linhVucItems = (List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)ViewBag.LinhVucList;
}

@section Styles {
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />
<style>.ck-editor__editable { min-height: 250px !important; }</style>
}

<div class="container-fluid py-4">
  <div class="row">
    <div class="col-md-3 col-lg-2">
      @await Html.PartialAsync("_AccountSidebar", sidebarData)
    </div>
    <div class="col-md-9 col-lg-10">

      <div class="d-flex align-items-center justify-content-between mb-3">
        <h4 class="fw-bold mb-0">
          <i class="fas fa-tools text-info me-2"></i>@ViewData["Title"]
        </h4>
        <a href="/quan-ly-san-pham.html" class="btn btn-outline-secondary btn-sm">
          <i class="fas fa-arrow-left me-1"></i>Quay lại
        </a>
      </div>

      @if (!ViewData.ModelState.IsValid)
      {
        <div class="alert alert-danger alert-dismissible fade show">
          <i class="fas fa-exclamation-triangle me-1"></i> Vui lòng kiểm tra lại thông tin bên dưới.
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      }

      @{
        var formAction = isEdit
            ? Url.Action("ChinhSua", "QuanLySanPham", new { id = Model.ID })
            : Url.Action("TaoMoi", "QuanLySanPham");
      }
      <form method="post" action="@formAction" id="frmCNTB">
        @Html.AntiForgeryToken()
        @if (isEdit) { <input type="hidden" asp-for="ID" /> }
        <input type="hidden" asp-for="ProductType" id="hdnProductType" />
        <input type="hidden" asp-for="Code" />
        <input type="hidden" asp-for="StatusId" />
        <input type="hidden" asp-for="SiteId" />

        <div class="card shadow-sm">
          <div class="card-body p-0">
            <!-- NAV TABS -->
            <ul class="nav nav-tabs px-3 pt-2 mb-0" id="cntbTabs" role="tablist">
              <li class="nav-item" role="presentation">
                <button class="nav-link active" id="tab1-tab" data-bs-toggle="tab" data-bs-target="#tab1" type="button">
                  <i class="fas fa-id-card me-1"></i> I. Nhận diện thiết bị
                </button>
              </li>
              <li class="nav-item" role="presentation">
                <button class="nav-link" id="tab2-tab" data-bs-toggle="tab" data-bs-target="#tab2" type="button">
                  <i class="fas fa-cogs me-1"></i> II. Thông số kỹ thuật
                </button>
              </li>
              <li class="nav-item" role="presentation">
                <button class="nav-link" id="tab3-tab" data-bs-toggle="tab" data-bs-target="#tab3" type="button">
                  <i class="fas fa-star me-1"></i> III. Ưu điểm &amp; Giá
                </button>
              </li>
              <li class="nav-item" role="presentation">
                <button class="nav-link" id="tab4-tab" data-bs-toggle="tab" data-bs-target="#tab4" type="button">
                  <i class="fas fa-building me-1"></i> IV. Nhà cung ứng
                </button>
              </li>
            </ul>

            <!-- TAB CONTENT -->
            <div class="tab-content border-top p-4" id="cntbTabContent">

              <!-- TAB 1 -->
              <div class="tab-pane fade show active" id="tab1" role="tabpanel">
                <h6 class="fw-bold text-primary mb-3"><i class="fas fa-id-card me-1"></i> I. Thông tin nhận diện thiết bị</h6>

                <div class="mb-3">
                  <label class="form-label fw-semibold">1. Tên thiết bị / máy móc <span class="text-danger">*</span></label>
                  <input asp-for="Name" class="form-control" placeholder="Nhập tên thiết bị..." />
                  <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                  <label class="form-label fw-semibold">2. Ảnh đại diện thiết bị <span class="text-danger">*</span></label>
                  <small class="text-muted d-block mb-2">(Đính kèm 01 ảnh chụp thực tế chất lượng cao)</small>
                  <div class="row g-3 align-items-end">
                    <div class="col-md-9">
                      <input asp-for="QuyTrinhHinhAnh" class="form-control" id="txtImageUrl" placeholder="URL ảnh đại diện..." />
                    </div>
                    <div class="col-md-3">
                      <label class="btn btn-outline-primary w-100" id="btnUploadImage">
                        <i class="fas fa-upload me-1"></i> Upload
                        <input type="file" accept="image/*" id="fileUploadImage" class="d-none" />
                      </label>
                    </div>
                  </div>
                  <div id="imgPreview" class="mt-2">
                    @if (!string.IsNullOrEmpty(Model.QuyTrinhHinhAnh))
                    {
                      <img src="@Model.QuyTrinhHinhAnh" class="img-fluid rounded" style="max-height:100px;" />
                    }
                  </div>
                </div>

                <div class="mb-3">
                  <label class="form-label fw-semibold">3. Xuất xứ <span class="text-danger">*</span></label>
                  <span asp-validation-for="XuatXuId" class="text-danger small d-block mb-1"></span>
                  <select asp-for="XuatXuId" class="form-select" id="selXuatXu" asp-items="@((List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)ViewBag.XuatXuList)">
                    <option value="">-- Chọn --</option>
                  </select>
                </div>

                <div class="mb-3">
                  <label class="form-label fw-semibold">4. Lĩnh vực áp dụng <span class="text-danger">*</span></label>
                  <span asp-validation-for="CategoryId" class="text-danger small d-block mb-1"></span>
                  <input type="hidden" asp-for="CategoryId" id="hdnCategoryId" />
                  <div class="row g-2">
                    @foreach (var item in linhVucItems.Where(x => !string.IsNullOrEmpty(x.Value)))
                    {
                      var cats = Model.CategoryId?.Split(new[]{',',';'}, StringSplitOptions.RemoveEmptyEntries) ?? Array.Empty<string>();
                      var chk = cats.Contains(item.Value) ? "checked" : "";
                      <div class="col-md-4 col-lg-3">
                        <div class="form-check">
                          <input class="form-check-input chk-linhvuc" type="checkbox"
                                 value="@item.Value" id="cat_@item.Value" @chk />
                          <label class="form-check-label" for="cat_@item.Value">@item.Text</label>
                        </div>
                      </div>
                    }
                  </div>
                </div>

                <div class="mb-3">
                  <label class="form-label fw-semibold">5. Mức độ phát triển <span class="text-danger">*</span></label>
                  <span asp-validation-for="Rating" class="text-danger small d-block mb-1"></span>
                  <div class="d-flex flex-wrap gap-2">
                    <div><input type="radio" class="btn-check" name="Rating" id="dev1" value="7" @(Model.Rating == 7 ? "checked" : "") />
                    <label class="btn btn-outline-warning btn-sm" for="dev1"><i class="fas fa-flask me-1"></i>Pilot</label></div>
                    <div><input type="radio" class="btn-check" name="Rating" id="dev2" value="8" @(Model.Rating == 8 ? "checked" : "") />
                    <label class="btn btn-outline-info btn-sm" for="dev2"><i class="fas fa-industry me-1"></i>Công nghiệp</label></div>
                    <div><input type="radio" class="btn-check" name="Rating" id="dev3" value="9" @(Model.Rating == 9 ? "checked" : "") />
                    <label class="btn btn-outline-success btn-sm" for="dev3"><i class="fas fa-shopping-cart me-1"></i>Thương mại hóa</label></div>
                  </div>
                </div>

                <div class="d-flex justify-content-end mt-4">
                  <button type="button" class="btn btn-primary btn-next-tab">Tiếp theo <i class="fas fa-arrow-right ms-1"></i></button>
                </div>
              </div>

              <!-- TAB 2 -->
              <div class="tab-pane fade" id="tab2" role="tabpanel">
                <h6 class="fw-bold text-primary mb-3"><i class="fas fa-cogs me-1"></i> II. Thông số kỹ thuật &amp; Vận hành</h6>
                <div class="mb-3">
                  <label class="form-label fw-semibold">6. Thông số kỹ thuật chính <span class="text-danger">*</span></label>
                  <span asp-validation-for="ThongSo" class="text-danger small d-block mb-1"></span>
                  <textarea asp-for="ThongSo" id="editorThongSo" class="form-control ck-editor-field-tab2" rows="10"></textarea>
                </div>
                <div class="mb-3">
                  <label class="form-label fw-semibold">7. Mô tả nguyên lý hoạt động <span class="text-danger">*</span></label>
                  <span asp-validation-for="MoTa" class="text-danger small d-block mb-1"></span>
                  <textarea asp-for="MoTa" id="editorNguyenLy" class="form-control ck-editor-field-tab2" rows="10"></textarea>
                </div>
                <div class="border rounded p-3 bg-light mb-3">
                  <h6 class="fw-semibold mb-2"><i class="fas fa-video me-1 text-primary"></i> 8. Video vận hành (nếu có)</h6>
                  <div class="mb-2">
                    <div class="form-check form-check-inline">
                      <input class="form-check-input media-toggle" type="radio" name="videoSource" id="videoYoutube" value="youtube" checked />
                      <label class="form-check-label" for="videoYoutube">YouTube URL</label>
                    </div>
                    <div class="form-check form-check-inline">
                      <input class="form-check-input media-toggle" type="radio" name="videoSource" id="videoUpload" value="upload" />
                      <label class="form-check-label" for="videoUpload">Upload file</label>
                    </div>
                  </div>
                  <div id="videoUrlBox"><input asp-for="URL" class="form-control" placeholder="https://www.youtube.com/watch?v=..." /></div>
                  <div id="videoUploadBox" style="display:none">
                    <input type="file" class="form-control" id="fileVideo" accept="video/*" />
                  </div>
                  <input type="hidden" asp-for="IsYoutube" />
                </div>
                <div class="d-flex justify-content-between mt-4">
                  <button type="button" class="btn btn-outline-secondary btn-prev-tab"><i class="fas fa-arrow-left me-1"></i> Quay lại</button>
                  <button type="button" class="btn btn-primary btn-next-tab">Tiếp theo <i class="fas fa-arrow-right ms-1"></i></button>
                </div>
              </div>

              <!-- TAB 3 -->
              <div class="tab-pane fade" id="tab3" role="tabpanel">
                <h6 class="fw-bold text-primary mb-3"><i class="fas fa-star me-1"></i> III. Ưu điểm và Giá bán</h6>
                <div class="mb-3">
                  <label class="form-label fw-semibold">9. Ưu điểm nổi bật</label>
                  <textarea asp-for="UuDiem" id="editorUuDiem" class="form-control ck-editor-field-tab3" rows="8"></textarea>
                </div>
                <div class="mb-3">
                  <label class="form-label fw-semibold">10. Giá tham khảo <span class="text-danger">*</span></label>
                  <span asp-validation-for="GiaBanDuKien" class="text-danger small d-block mb-1"></span>
                  <textarea asp-for="GiaBanDuKien" id="editorGiaBan" class="form-control ck-editor-field-tab3" rows="8" placeholder="Loại/Quy mô/Hình thức sở hữu&#10;Mô tả chi tiết&#10;Giá bán dự kiến"></textarea>
                </div>
                <div class="mb-3">
                  <label class="form-label fw-semibold">11. Chế độ bảo hành &amp; Hỗ trợ kỹ thuật</label>
                  <textarea asp-for="BaoHanhHoTro" id="editorBaoHanh" class="form-control ck-editor-field-tab3" rows="8"></textarea>
                </div>
                <div class="d-flex justify-content-between mt-4">
                  <button type="button" class="btn btn-outline-secondary btn-prev-tab"><i class="fas fa-arrow-left me-1"></i> Quay lại</button>
                  <button type="button" class="btn btn-primary btn-next-tab">Tiếp theo <i class="fas fa-arrow-right ms-1"></i></button>
                </div>
              </div>

              <!-- TAB 4 -->
              <div class="tab-pane fade" id="tab4" role="tabpanel">
                <h6 class="fw-bold text-primary mb-3"><i class="fas fa-building me-1"></i> IV. Thông tin nhà cung ứng</h6>
                <div class="mb-3">
                  <label class="form-label fw-semibold">12. Tên đơn vị sở hữu / cung ứng <span class="text-danger">*</span></label>
                  <span asp-validation-for="NCUId" class="text-danger small d-block mb-1"></span>
                  <select asp-for="NCUId" class="form-select" asp-items="@((List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)ViewBag.NhaCungUngList)">
                    <option value="">-- Chọn nhà cung ứng --</option>
                  </select>
                </div>
                <div class="mb-3">
                  <label class="form-label fw-semibold">13. Thông tin liên hệ <span class="badge bg-info text-dark ms-1">Tự động điền từ NCC</span></label>
                </div>
                <div class="row g-3 mb-3">
                  <div class="col-12"><label class="form-label">Địa chỉ</label><input id="ncuDiaChi" class="form-control bg-light" readonly /></div>
                </div>
                <div class="row g-3 mb-3">
                  <div class="col-md-4"><label class="form-label">Người đại diện</label><input id="ncuNguoiDaiDien" class="form-control bg-light" readonly /></div>
                  <div class="col-md-4"><label class="form-label">Chức vụ</label><input id="ncuChucVu" class="form-control bg-light" readonly /></div>
                  <div class="col-md-4"><label class="form-label">Điện thoại</label><input id="ncuPhone" class="form-control bg-light" readonly /></div>
                </div>
                <div class="row g-3 mb-3">
                  <div class="col-md-6"><label class="form-label">Email</label><input id="ncuEmail" class="form-control bg-light" readonly /></div>
                  <div class="col-md-6"><label class="form-label">Website</label><input id="ncuWebsite" class="form-control bg-light" readonly /></div>
                </div>
                <div class="d-flex justify-content-start mt-4">
                  <button type="button" class="btn btn-outline-secondary btn-prev-tab"><i class="fas fa-arrow-left me-1"></i> Quay lại</button>
                </div>
              </div>

            </div><!-- /tab-content -->
          </div><!-- /card-body -->

          <div class="card-footer d-flex justify-content-between align-items-center">
            <small class="text-muted"><span class="text-danger">*</span> Bắt buộc. Sau khi gửi, hồ sơ chờ xét duyệt.</small>
            <button type="submit" class="btn btn-primary px-4">
              <i class="fas fa-@(isEdit ? "save" : "paper-plane") me-1"></i>@(isEdit ? "Lưu thay đổi" : "Gửi đăng ký")
            </button>
          </div>
        </div>
      </form>

    </div>
  </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script src="https://cdn.ckeditor.com/ckeditor5/41.4.2/super-build/ckeditor.js"></script>
<script>
$(function(){
    // Select2
    $('#NCUId').select2({ theme:'bootstrap-5', placeholder:'-- Tìm nhà cung ứng --', allowClear:true, width:'100%' })
        .on('change', function(){ loadNhaCungUng($(this).val()); });
    $('#selXuatXu').select2({ theme:'bootstrap-5', placeholder:'-- Tìm xuất xứ --', allowClear:true, width:'100%' });

    // Upload ảnh
    $('#fileUploadImage').on('change', function(){
        var fd = new FormData(); fd.append('upload', this.files[0]);
        $.ajax({ url:'/cms/Upload/Upload', type:'POST', data:fd, processData:false, contentType:false,
            success:function(r){ if(r.url){ $('#txtImageUrl').val(r.url); $('#imgPreview').html('<img src="'+r.url+'" class="img-fluid rounded" style="max-height:100px">'); } }
        });
    });

    // Tab nav
    var $tabs = $('#cntbTabs button');
    function getIdx(){ return $tabs.index($tabs.filter('.active')); }
    $(document).on('click','.btn-next-tab',function(){ var i=getIdx(); if(i<$tabs.length-1) new bootstrap.Tab($tabs[i+1]).show(); });
    $(document).on('click','.btn-prev-tab',function(){ var i=getIdx(); if(i>0) new bootstrap.Tab($tabs[i-1]).show(); });

    // CKEditor 5 — lazy init per tab (dùng super-build 41.4.2 giống CMS)
    var ckRemovePlugins = [
        'ExportPdf','ExportWord','AIAssistant','CKBox','CKFinder','EasyImage',
        'MultiLevelList','RealTimeCollaborativeComments','RealTimeCollaborativeTrackChanges',
        'RealTimeCollaborativeRevisionHistory','PresenceList','Comments','TrackChanges',
        'TrackChangesData','RevisionHistory','Pagination','WProofreader','MathType',
        'SlashCommand','Template','DocumentOutline','FormatPainter','TableOfContents',
        'PasteFromOfficeEnhanced','CaseChange'
    ];
    var ckConfig = {
        simpleUpload: { uploadUrl: '/cms/Upload/Upload', withCredentials: true },
        toolbar: ['heading','|','bold','italic','fontColor','fontBackgroundColor','|',
                  'link','bulletedList','numberedList','|',
                  'imageUpload','blockQuote','insertTable','undo','redo'],
        removePlugins: ckRemovePlugins
    };
    var ckInstances = {};
    function initCkForTab(selector){
        document.querySelectorAll(selector).forEach(function(el){
            if(ckInstances[el.id]) return;
            var conf = Object.assign({}, ckConfig);
            if(el.getAttribute('placeholder')) conf.placeholder = el.getAttribute('placeholder');
            CKEDITOR.ClassicEditor.create(el, conf)
                .then(function(e){ ckInstances[el.id] = e; })
                .catch(function(err){ console.error(err); });
        });
    }
    $('button[data-bs-target="#tab2"]').on('shown.bs.tab', function(){ initCkForTab('.ck-editor-field-tab2'); });
    $('button[data-bs-target="#tab3"]').on('shown.bs.tab', function(){ initCkForTab('.ck-editor-field-tab3'); });

    $('#frmCNTB').on('submit', function(){
        Object.keys(ckInstances).forEach(function(id){
            document.getElementById(id).value = ckInstances[id].getData();
        });
    });

    // Category checkboxes
    function syncCats(){ var v=[]; $('.chk-linhvuc:checked').each(function(){ v.push($(this).val()); }); $('#hdnCategoryId').val(v.join(';')); }
    $(document).on('change','.chk-linhvuc',syncCats); syncCats();

    // Video toggle
    $('input[name="videoSource"]').on('change',function(){
        var isUpload=$(this).val()==='upload';
        $('#videoUploadBox').toggle(isUpload); $('#videoUrlBox').toggle(!isUpload);
        $('#IsYoutube').val(!isUpload);
    });
    $('#fileVideo').on('change',function(){
        var fd=new FormData(); fd.append('upload',this.files[0]);
        $.ajax({ url:'/cms/Upload/Upload', type:'POST', data:fd, processData:false, contentType:false,
            success:function(r){ if(r.url) $('[name="URL"]').val(r.url); }
        });
    });

    // Auto-fill NCC
    function loadNhaCungUng(id){
        if(!id){ $('#ncuDiaChi,#ncuNguoiDaiDien,#ncuChucVu,#ncuPhone,#ncuEmail,#ncuWebsite').val(''); return; }
        $.getJSON('/cms/SanPhamCNTB/GetNhaCungUng/'+id, function(d){
            $('#ncuDiaChi').val(d.diaChi||''); $('#ncuNguoiDaiDien').val(d.nguoiDaiDien||'');
            $('#ncuChucVu').val(d.chucVu||''); $('#ncuPhone').val(d.phone||'');
            $('#ncuEmail').val(d.email||''); $('#ncuWebsite').val(d.website||'');
        });
    }
    var initNcu=$('#NCUId').val(); if(initNcu) loadNhaCungUng(initNcu);
});
</script>
}
