@using TechExchangeApp.Interfaces
@using Microsoft.AspNetCore.Identity
@using TechExchangeApp.Entities
@inject IAccountService AccountService
@inject UserManager<ApplicationUser> UserManager

@model List<TechExchangeApp.Interfaces.ChatConversationVm>
@{
    ViewData["Title"] = "Tin nhắn";
    var userId = int.Parse(UserManager.GetUserId(User)!);
    var sidebarData = await AccountService.GetSidebarDataAsync(userId);
}

<div class="container-fluid py-4">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3 col-lg-2">
            @await Html.PartialAsync("_AccountSidebar", sidebarData)
        </div>

        <!-- Main Content -->
        <div class="col-md-9 col-lg-10">
            <div class="container-fluid py-2">

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h4 class="mb-1"><i class="fas fa-comments text-primary me-2"></i>Tin nhắn</h4>
                        <p class="text-muted mb-0">
                            @{
                                var totalUnread = Model.Sum(c => c.UnreadCount);
                            }
                            @if (totalUnread > 0)
                            {
                                <span class="badge bg-danger me-1">@totalUnread</span>
                            }
                            Tổng @Model.Count cuộc trò chuyện
                        </p>
                    </div>
                </div>

                <div class="card border-0 shadow-sm">
                    <div class="card-body p-0">
                        @if (Model.Any())
                        {
                            <ul class="list-group list-group-flush">
                                @foreach (var c in Model)
                                {
                                    <li class="list-group-item px-4 py-3 @(c.UnreadCount > 0 ? "notif-unread" : "")">
                                        <a href="/chat/@c.Id" class="text-decoration-none">
                                            <div class="d-flex align-items-start gap-3">
                                                <div class="notif-icon @(c.UnreadCount > 0 ? "notif-icon-unread" : "notif-icon-read")">
                                                    <i class="fas fa-comments"></i>
                                                </div>
                                                <div class="flex-grow-1">
                                                    <div class="d-flex justify-content-between align-items-start">
                                                        <div>
                                                            <p class="mb-1 @(c.UnreadCount > 0 ? "fw-semibold" : "") text-dark">
                                                                <i class="fas fa-user me-1 text-secondary"></i>@c.OtherUserName
                                                            </p>
                                                            @if (!string.IsNullOrEmpty(c.ProductName))
                                                            {
                                                                <p class="text-muted mb-1 small">
                                                                    <i class="fas fa-cube me-1"></i>@c.ProductName
                                                                </p>
                                                            }
                                                            @if (!string.IsNullOrEmpty(c.LastMessage))
                                                            {
                                                                <small class="text-secondary">
                                                                    @(c.LastMessage.Length > 80 ? c.LastMessage[..80] + "..." : c.LastMessage)
                                                                </small>
                                                            }
                                                        </div>
                                                        <div class="text-end ms-3 flex-shrink-0">
                                                            @if (c.LastMessageAt.HasValue)
                                                            {
                                                                <small class="text-muted d-block">
                                                                    <i class="fas fa-clock me-1"></i>@c.LastMessageAt.Value.ToString("dd/MM HH:mm")
                                                                </small>
                                                            }
                                                            @if (c.UnreadCount > 0)
                                                            {
                                                                <span class="badge bg-danger rounded-pill mt-1">@c.UnreadCount</span>
                                                            }
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </a>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <div class="text-center py-5">
                                <i class="fas fa-comments fs-1 text-muted"></i>
                                <p class="text-muted mt-3">Bạn chưa có cuộc trò chuyện nào.</p>
                            </div>
                        }
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<style>
    .notif-unread {
        background-color: #f0f7ff;
        border-left: 3px solid #0d6efd;
    }
    .notif-icon {
        width: 42px; height: 42px;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.1rem; flex-shrink: 0;
    }
    .notif-icon-unread { background-color: #dbeafe; color: #0d6efd; }
    .notif-icon-read { background-color: #f3f4f6; color: #9ca3af; }
</style>
