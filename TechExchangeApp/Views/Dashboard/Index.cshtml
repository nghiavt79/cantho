@using TechExchangeApp.Interfaces
@using Microsoft.AspNetCore.Identity
@using TechExchangeApp.Entities
@inject IAccountService AccountService
@inject UserManager<ApplicationUser> UserManager

@model TechExchangeApp.ViewModel.UserDashboardVm
@{
    ViewData["Title"] = "Dashboard";
    ViewData["AuthWorkspace"] = true;
    var currentTime = DateTime.Now.ToString("dd/MM/yyyy HH:mm");
    
    var userId = int.Parse(UserManager.GetUserId(User)!);
    var sidebarData = await AccountService.GetSidebarDataAsync(userId);
}

<div class="container-fluid py-4 user-portal">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3 col-lg-2">
            @await Html.PartialAsync("_AccountSidebar", sidebarData)
        </div>

        <!-- Main Content -->
        <div class="col-md-9 col-lg-10 user-portal-main">
<div class="user-dashboard">
    <!-- Header Section -->
    <div class="row mb-4 user-dashboard-header">
        <div class="col-md-12">
            <h2 class="mb-1">Xin chào, <strong>@Model.FullName</strong></h2>
            <p class="text-muted mb-0">
                <i class="fas fa-clock"></i> @currentTime
            </p>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="row g-3 mb-4 user-dashboard-stats">
        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm h-100 user-dashboard-stat">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-2">Tổng dự án</h6>
                            <h2 class="mb-0 text-primary">@Model.TotalProjects</h2>
                        </div>
                        <div class="user-dashboard-stat-icon bg-primary bg-opacity-10 text-primary">
                            <i class="fas fa-folder fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm h-100 user-dashboard-stat">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-2">Đang xử lý</h6>
                            <h2 class="mb-0 text-warning">@Model.InProgressProjects</h2>
                        </div>
                        <div class="user-dashboard-stat-icon bg-warning bg-opacity-10 text-warning">
                            <i class="fas fa-hourglass-half fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm h-100 user-dashboard-stat">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-2">Chờ tôi xử lý</h6>
                            <h2 class="mb-0 text-info">@Model.WaitingForMe</h2>
                        </div>
                        <div class="user-dashboard-stat-icon bg-info bg-opacity-10 text-info">
                            <i class="fas fa-bell fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3 col-sm-6">
            <div class="card border-0 shadow-sm h-100 user-dashboard-stat">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-2">Đã hoàn thành</h6>
                            <h2 class="mb-0 text-success">@Model.CompletedProjects</h2>
                        </div>
                        <div class="user-dashboard-stat-icon bg-success bg-opacity-10 text-success">
                            <i class="fas fa-check-circle fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Projects Table -->
    <div class="card border-0 shadow-sm user-dashboard-table-card">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0">Dự án của tôi</h5>
        </div>
        <div class="card-body p-0">
            @if (Model.Projects.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Mã dự án</th>
                                <th>Tên dự án</th>
                                <th>Vai trò</th>
                                <th>Bước hiện tại</th>
                                <th>Trạng thái</th>
                                <th>Tiến độ</th>
                                <th>Workflow</th>
                                <th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var project in Model.Projects)
                            {
                                <tr>
                                    <td data-label="Mã dự án">
                                        <strong class="text-primary">@project.Code</strong>
                                    </td>
                                    <td data-label="Tên dự án">@project.Name</td>
                                    <td data-label="Vai trò">
                                        <span class="badge bg-secondary">@project.RoleName</span>
                                    </td>
                                    <td data-label="Bước hiện tại">
                                        <small class="text-muted">Bước @project.CurrentStepNumber:</small><br />
                                        <strong>@project.CurrentStepName</strong>
                                    </td>
                                    <td data-label="Trạng thái">
                                        @{
                                            var statusBadge = project.CurrentStepStatus switch
                                            {
                                                "Completed" => "bg-success",
                                                "InProgress" => "bg-primary",
                                                _ => "bg-secondary"
                                            };
                                            var statusText = project.CurrentStepStatus switch
                                            {
                                                "Completed" => "Hoàn thành",
                                                "InProgress" => "Đang xử lý",
                                                _ => "Chưa bắt đầu"
                                            };
                                        }
                                        <span class="badge @statusBadge">@statusText</span>
                                    </td>
                                    <td data-label="Tiến độ">
                                        <div class="d-flex align-items-center">
                                            <div class="progress flex-grow-1 me-2" style="height: 8px;">
                                                <div class="progress-bar bg-success"
                                                     role="progressbar"
                                                     style="width: @project.ProgressPercent%"
                                                     aria-valuenow="@project.ProgressPercent"
                                                     aria-valuemin="0"
                                                     aria-valuemax="100">
                                                </div>
                                            </div>
                                            <small class="text-muted">@project.ProgressPercent%</small>
                                        </div>
                                        <small class="text-muted">@project.CompletedSteps/14 bước</small>
                                    </td>
                                    <td data-label="Workflow">
                                        <div class="workflow-steps d-flex gap-1">
                                            @foreach (var step in project.StepsSummary)
                                            {
                                                var stepClass = step.StatusId switch
                                                {
                                                    2 => "step-completed",
                                                    1 => "step-inprogress",
                                                    _ => "step-notstarted"
                                                };
                                                <div class="user-dashboard-workflow-step @stepClass"
                                                     title="Bước @step.StepNumber"
                                                     data-bs-toggle="tooltip">
                                                </div>
                                            }
                                        </div>
                                    </td>
                                    <td data-label="Thao tác">
                                        <a href="/Project/Details/@project.ProjectId"
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-eye"></i> Xem chi tiết
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="fas fa-inbox empty-state-icon"></i>
                    <p class="empty-state-title">Chưa có dự án nào</p>
                    <p class="empty-state-text">Bạn chưa tham gia dự án nào. Bắt đầu bằng cách đăng yêu cầu chuyển giao công nghệ đầu tiên.</p>
                    <a href="@Url.Action("Create", "TechTransfer")" class="btn btn-primary btn-sm">
                        <i class="fas fa-plus-circle"></i> Đăng yêu cầu chuyển giao công nghệ
                    </a>
                </div>
            }
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/user-portal.css" asp-append-version="true" />
}

@section Scripts {
    <script>
        // Initialize Bootstrap tooltips
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl);
        });
    </script>
}
        </div><!-- End Main Content col-md-9 -->
    </div><!-- End row -->
</div><!-- End container-fluid -->
