@using TechExchangeApp.Interfaces
@using Microsoft.AspNetCore.Identity
@using TechExchangeApp.Entities
@inject IAccountService AccountService
@inject UserManager<ApplicationUser> UserManager

@model List<TechExchangeApp.ViewModel.MyProjectVm>

@{
    ViewData["Title"] = "Dự án của tôi";
    ViewData["AuthWorkspace"] = true;

    var userId = int.Parse(UserManager.GetUserId(User)!);
    var sidebarData = await AccountService.GetSidebarDataAsync(userId);
}

<div class="container-fluid py-4 user-portal">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3 col-lg-2">
            @await Html.PartialAsync("_AccountSidebar", sidebarData)
        </div>

        <!-- Main Content -->
        <div class="col-md-9 col-lg-10 user-portal-main user-projects">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="mb-0"><i class="fas fa-folder"></i> Danh sách dự án</h5>
                            <span class="badge bg-primary">Tổng: @Model.Count dự án</span>
                        </div>
                        <a href="@Url.Action("Create", "TechTransfer")" class="btn btn-success">
                            <i class="fas fa-plus-circle"></i> Đăng yêu cầu chuyển giao công nghệ
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    @if (Model.Count == 0)
                    {
                        <div class="empty-state">
                            <i class="fas fa-folder-open empty-state-icon"></i>
                            <p class="empty-state-title">Chưa có dự án nào</p>
                            <p class="empty-state-text">Bạn chưa tham gia dự án nào. Bắt đầu bằng cách đăng yêu cầu chuyển giao công nghệ đầu tiên.</p>
                            <a href="@Url.Action("Create", "TechTransfer")" class="btn btn-primary btn-sm">
                                <i class="fas fa-plus-circle"></i> Đăng yêu cầu chuyển giao công nghệ
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>Mã dự án</th>
                                        <th>Tên dự án</th>
                                        <th>Vai trò</th>
                                        <th>Bước hiện tại</th>
                                        <th>Trạng thái</th>
                                        <th>Tiến độ</th>
                                        <th>Ngày tạo</th>
                                        <th>Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var project in Model)
                                    {
                                        <tr>
                                            <td data-label="Mã dự án"><strong>@project.Code</strong></td>
                                            <td data-label="Tên dự án">@project.Name</td>
                                            <td data-label="Vai trò">
                                                @switch (project.RoleId)
                                                {
                                                    case 1:
                                                        <span class="badge bg-primary">@project.Role</span>
                                                        break;
                                                    case 2:
                                                        <span class="badge bg-success">@project.Role</span>
                                                        break;
                                                    case 3:
                                                        <span class="badge bg-info">@project.Role</span>
                                                        break;
                                                    default:
                                                        <span class="badge bg-secondary">@project.Role</span>
                                                        break;
                                                }
                                            </td>
                                            <td data-label="Bước hiện tại">
                                                <span class="badge bg-warning text-dark">Bước @project.CurrentStep/14</span>
                                            </td>
                                            <td data-label="Trạng thái">
                                                @switch (project.StatusId)
                                                {
                                                    case 1:
                                                        <span class="badge bg-secondary">@project.Status</span>
                                                        break;
                                                    case 2:
                                                        <span class="badge bg-success">@project.Status</span>
                                                        break;
                                                    case 3:
                                                        <span class="badge bg-primary">@project.Status</span>
                                                        break;
                                                    case 4:
                                                        <span class="badge bg-danger">@project.Status</span>
                                                        break;
                                                    default:
                                                        <span class="badge bg-secondary">@project.Status</span>
                                                        break;
                                                }
                                            </td>
                                            <td data-label="Tiến độ">
                                                <div class="progress" style="height: 20px;">
                                                    <div class="progress-bar @(project.ProgressPercent >= 100 ? "bg-success" : project.ProgressPercent >= 50 ? "bg-info" : "bg-warning")"
                                                         role="progressbar"
                                                         style="width: @project.ProgressPercent%"
                                                         aria-valuenow="@project.ProgressPercent"
                                                         aria-valuemin="0"
                                                         aria-valuemax="100">
                                                        @project.ProgressPercent%
                                                    </div>
                                                </div>
                                            </td>
                                            <td data-label="Ngày tạo">@project.CreatedDate.ToString("dd/MM/yyyy")</td>
                                            <td data-label="Thao tác">
                                                <a href="@Url.Action("Details", "Project", new { id = project.Id })" class="btn btn-sm btn-primary">
                                                    <i class="fas fa-eye"></i> Xem
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            @if (Model.Count > 0)
            {
                <div class="row mt-4 g-3">
                    <div class="col-md-4">
                        <div class="card user-projects-summary-card" data-accent="info">
                            <div class="card-body">
                                <h3>@Model.Count</h3>
                                <p class="mb-0">Tổng dự án</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card user-projects-summary-card" data-accent="success">
                            <div class="card-body">
                                <h3>@Model.Count(p => p.StatusId == 2)</h3>
                                <p class="mb-0">Dự án đang hoạt động</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card user-projects-summary-card" data-accent="warning">
                            <div class="card-body">
                                <h3>@Model.Count(p => p.ProgressPercent < 100)</h3>
                                <p class="mb-0">Dự án chưa hoàn thành</p>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div><!-- End Main Content -->
    </div><!-- End row -->
</div><!-- End container-fluid -->

@section Styles {
    <link rel="stylesheet" href="~/css/user-portal.css" asp-append-version="true" />
}
