@model TechExchangeApp.ViewModel.DichVuTuVanVm

@{
    int startIdx = (Model.CurrentPage - 1) * Model.PageSize + 1;
    int endIdx = Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalCount);
}

@if (Model.TotalCount == 0)
{
    <div class="dvtv-empty">
        <i class="fa fa-user-tie fa-2x mb-3 text-muted"></i>
        <p>Không tìm thấy nhà tư vấn nào phù hợp.</p>
    </div>
}
else
{
    <div class="dvtv-result-info">
        Hiển thị <strong>@startIdx–@endIdx</strong> trong tổng số <strong>@Model.TotalCount</strong> nhà tư vấn
    </div>

    <div class="dvtv-card-list">
        @foreach (var row in Model.Items)
        {
            var detailUrl = $"{Model.MainDomain}chuyen-gia/{row.QueryString}-{row.TuVanId}";
            var rating = row.Rating ?? 0;
            var star = Math.Clamp(rating, 0, 5);
            var stars = new string('★', star) + new string('☆', 5 - star);
            var avatarUrl = !string.IsNullOrEmpty(row.HinhDaiDien)
                ? $"{Model.MainDomain}{row.HinhDaiDien}"
                : "/image/NoAvarta.jpg";

            <article class="dvtv-card dvtv-card--expert">
                <div class="dvtv-card__header">
                    <div class="dvtv-card__avatar">
                        <img src="@avatarUrl" alt="@row.FullName" />
                    </div>
                    <div class="dvtv-card__header-info">
                        <h3 class="dvtv-card__name">
                            <a href="@detailUrl">
                                @if (!string.IsNullOrEmpty(row.HocHam))
                                {
                                    <span class="dvtv-card__title-prefix">@row.HocHam</span>
                                }
                                @row.FullName
                            </a>
                        </h3>
                        @if (!string.IsNullOrEmpty(row.ChucVu))
                        {
                            <span class="dvtv-card__role">@row.ChucVu</span>
                        }
                        <span class="dvtv-card__stars" title="Đánh giá: @star/5">@stars</span>
                    </div>
                </div>
                <div class="dvtv-card__body">
                    @if (!string.IsNullOrEmpty(row.CoQuan))
                    {
                        <div class="dvtv-card__meta"><i class="fa fa-building"></i><span>@row.CoQuan</span></div>
                    }
                    @if (!string.IsNullOrEmpty(row.Phone))
                    {
                        <div class="dvtv-card__meta"><i class="fa fa-phone"></i><a href="tel:@row.Phone">@row.Phone</a></div>
                    }
                    @if (!string.IsNullOrEmpty(row.Email))
                    {
                        <div class="dvtv-card__meta"><i class="fa fa-envelope"></i><a href="mailto:@row.Email">@row.Email</a></div>
                    }
                </div>
                <div class="dvtv-card__footer">
                    <a href="@detailUrl" class="dvtv-btn dvtv-btn--sm dvtv-btn--accent">Xem hồ sơ</a>
                </div>
            </article>
        }
    </div>

    <!-- PAGINATION -->
    @if (Model.Pages.Count > 1)
    {
        <nav class="dvtv-pagination">
            @if (Model.CurrentPage > 1)
            {
                <a href="javascript:void(0)" class="dvtv-page-link" data-page="@(Model.CurrentPage - 1)"><i class="fa fa-chevron-left"></i> Trước</a>
            }
            @foreach (var pg in Model.Pages)
            {
                <a href="javascript:void(0)" class="dvtv-page-link @(pg == Model.CurrentPage ? "active" : "")" data-page="@pg">@pg</a>
            }
            @if (Model.CurrentPage < Model.TotalPage)
            {
                <a href="javascript:void(0)" class="dvtv-page-link" data-page="@(Model.CurrentPage + 1)">Sau <i class="fa fa-chevron-right"></i></a>
            }
        </nav>
    }
}
