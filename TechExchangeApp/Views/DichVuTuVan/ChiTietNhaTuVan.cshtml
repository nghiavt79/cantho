@model TechExchangeApp.ViewModel.ChiTietNhaTuVanVm
@{
    Layout = "_Layout";
    ViewData["Title"] = Model.FullName;
}

<div class="columns-container">
    <div class="container" id="columns">
        <div class="row">

            <!-- LEFT: SIDEBAR -->
            <div class="column col-xs-12 col-sm-3" id="left_column">
                <div class="block left-module">
                    <p class="title_block">DANH MỤC</p>
                    <div class="block_content">
                        <ul class="tree-menu">
                            @foreach (var c in Model.Categories)
                            {
                                <li><a href="@c.Url">@c.Name</a></li>
                            }
                        </ul>
                    </div>
                </div>

                @if (Model.NhaTuVanKhac.Any())
                {
                    <div class="block left-module">
                        <p class="title_block">NHÀ TƯ VẤN KHÁC</p>
                        <div class="block_content">
                            @foreach (var other in Model.NhaTuVanKhac)
                            {
                                <div class="d-flex align-items-center mb-2">
                                    <img src="@other.ImageUrl" alt="@other.FullName"
                                         style="width:48px;height:48px;object-fit:cover;border-radius:50%;margin-right:8px;" />
                                    <div>
                                        <a href="@other.DetailUrl" class="d-block" style="font-size:13px;font-weight:600;">@other.FullName</a>
                                        <span class="small text-muted">@other.CoQuan</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- CENTER -->
            <div class="center_column col-xs-12 col-sm-9" id="center_column">

                <!-- Breadcrumb -->
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
                        <li class="breadcrumb-item"><a href="/dich-vu-tu-van">Dịch vụ tư vấn</a></li>
                        <li class="breadcrumb-item active">@Model.FullName</li>
                    </ol>
                </nav>

                <!-- ══════ HEADER CARD ══════ -->
                <div class="card shadow-sm mb-4">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-xs-12 col-sm-3 text-center mb-3">
                                <img src="@Model.ImageUrl" alt="@Model.FullName"
                                     class="rounded-circle shadow-sm"
                                     style="width:140px;height:140px;object-fit:cover;" />
                            </div>
                            <div class="col-xs-12 col-sm-9">
                                <h1 style="font-size:20px;font-weight:700;margin-bottom:4px;">
                                    @(!string.IsNullOrEmpty(Model.HocHam) ? Model.HocHam + " " : "")@Model.FullName
                                </h1>
                                @if (!string.IsNullOrEmpty(Model.ChucVu))
                                {
                                    <p class="text-primary mb-1" style="font-size:14px;"><i class="fas fa-user-tag me-1"></i>@Model.ChucVu</p>
                                }
                                @if (!string.IsNullOrEmpty(Model.CoQuan))
                                {
                                    <p class="text-muted mb-2" style="font-size:14px;"><i class="fas fa-building me-1"></i>@Model.CoQuan</p>
                                }

                                <!-- Meta line -->
                                <div class="tp-meta-line mb-3" id="headerMetaLine"
                                     data-entity-type="NhaTuVan" data-entity-id="@Model.Id">
                                    <span class="tp-rating">
                                        <i class="fa fa-star"></i>
                                        <strong id="headerRatingAvg">@(Model.Rating > 0 ? Model.Rating.ToString("0.0") : "—")</strong>
                                        <span class="tp-muted">(<span id="headerRatingCount">@Model.LuotDanhGia</span> đánh giá)</span>
                                    </span>
                                    <span class="tp-dot">·</span>
                                    <span class="tp-view">
                                        <i class="fa fa-eye"></i>
                                        <span id="headerViewCount">@Model.LuotXem.ToString("N0")</span> lượt xem
                                    </span>
                                    @if (Model.TongTrichDan.HasValue)
                                    {
                                        <span class="tp-dot">·</span>
                                        <span><i class="fas fa-quote-right me-1"></i>@Model.TongTrichDan trích dẫn</span>
                                    }
                                    @if (Model.HIndex.HasValue)
                                    {
                                        <span class="tp-dot">·</span>
                                        <span><strong>h-index:</strong> @Model.HIndex</span>
                                    }
                                </div>

                                <table class="table table-sm table-borderless mb-0" style="font-size:14px;">
                                    <tbody>
                                        @if (!string.IsNullOrEmpty(Model.Phone))
                                        {
                                            <tr><td class="fw-bold" style="width:110px;"><i class="fas fa-phone me-1 text-secondary"></i>ĐT</td><td><a href="tel:@Model.Phone">@Model.Phone</a></td></tr>
                                        }
                                        @if (!string.IsNullOrEmpty(Model.Email))
                                        {
                                            <tr><td class="fw-bold"><i class="fas fa-envelope me-1 text-secondary"></i>Email</td><td><a href="mailto:@Model.Email">@Model.Email</a></td></tr>
                                        }
                                        @if (!string.IsNullOrEmpty(Model.DiaChi))
                                        {
                                            <tr><td class="fw-bold"><i class="fas fa-map-marker-alt me-1 text-secondary"></i>Địa chỉ</td><td>@Model.DiaChi</td></tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ══════ 6 TABS ══════ -->
                <ul class="nav nav-tabs mb-0" role="tablist">
                    <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#tab1"><i class="fas fa-id-card me-1"></i>Thông tin</a></li>
                    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab2"><i class="fas fa-chart-line me-1"></i>Chỉ số KH</a></li>
                    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab3"><i class="fas fa-graduation-cap me-1"></i>Đào tạo & CT</a></li>
                    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab4"><i class="fas fa-book me-1"></i>Công bố & SHTT</a></li>
                    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab5"><i class="fas fa-briefcase me-1"></i>Tư vấn & DA</a></li>
                    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab6"><i class="fas fa-certificate me-1"></i>Minh chứng</a></li>
                </ul>

                <div class="tab-content border border-top-0 rounded-bottom p-3 mb-4">

                    <!-- TAB 1: THÔNG TIN ĐỊNH DANH -->
                    <div class="tab-pane fade show active" id="tab1">
                        <table class="table table-sm table-bordered mb-0" style="font-size:14px;">
                            <tbody>
                                <tr><td class="fw-bold bg-light" style="width:200px;">Họ và tên</td><td>@Model.FullName</td></tr>
                                @if (!string.IsNullOrEmpty(Model.HocHam))
                                {
                                    <tr><td class="fw-bold bg-light">Học hàm / Học vị</td><td>@Model.HocHam</td></tr>
                                }
                                @if (!string.IsNullOrEmpty(Model.CoQuan))
                                {
                                    <tr><td class="fw-bold bg-light">Cơ quan công tác</td><td>@Model.CoQuan</td></tr>
                                }
                                @if (!string.IsNullOrEmpty(Model.ChucVu))
                                {
                                    <tr><td class="fw-bold bg-light">Chức vụ</td><td>@Model.ChucVu</td></tr>
                                }
                                @if (!string.IsNullOrEmpty(Model.Phone))
                                {
                                    <tr><td class="fw-bold bg-light">Điện thoại</td><td><a href="tel:@Model.Phone">@Model.Phone</a></td></tr>
                                }
                                @if (!string.IsNullOrEmpty(Model.Email))
                                {
                                    <tr><td class="fw-bold bg-light">Email</td><td><a href="mailto:@Model.Email">@Model.Email</a></td></tr>
                                }
                                @if (!string.IsNullOrEmpty(Model.DiaChi))
                                {
                                    <tr><td class="fw-bold bg-light">Địa chỉ</td><td>@Model.DiaChi</td></tr>
                                }
                                @if (!string.IsNullOrEmpty(Model.NgaySinh))
                                {
                                    <tr><td class="fw-bold bg-light">Ngày sinh</td><td>@Model.NgaySinh</td></tr>
                                }
                                @if (!string.IsNullOrEmpty(Model.MaDinhDanh))
                                {
                                    <tr>
                                        <td class="fw-bold bg-light">Mã định danh quốc tế</td>
                                        <td>
                                            @foreach (var line in Model.MaDinhDanh.Split('\n', StringSplitOptions.RemoveEmptyEntries))
                                            {
                                                var trimmed = line.Trim();
                                                if (trimmed.StartsWith("http"))
                                                {
                                                    <div><a href="@trimmed" target="_blank" rel="noopener"><i class="fas fa-external-link-alt me-1"></i>@trimmed</a></div>
                                                }
                                                else
                                                {
                                                    <div>@trimmed</div>
                                                }
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- TAB 2: CHỈ SỐ ẢNH HƯỞNG KHOA HỌC -->
                    <div class="tab-pane fade" id="tab2">
                        @if (Model.TongTrichDan.HasValue || Model.HIndex.HasValue)
                        {
                            <div class="row g-3 mb-3">
                                @if (Model.TongTrichDan.HasValue)
                                {
                                    <div class="col-md-4">
                                        <div class="card text-center border-primary">
                                            <div class="card-body py-3">
                                                <h3 class="text-primary mb-1">@Model.TongTrichDan</h3>
                                                <small class="text-muted">Tổng số trích dẫn</small>
                                            </div>
                                        </div>
                                    </div>
                                }
                                @if (Model.HIndex.HasValue)
                                {
                                    <div class="col-md-4">
                                        <div class="card text-center border-success">
                                            <div class="card-body py-3">
                                                <h3 class="text-success mb-1">@Model.HIndex</h3>
                                                <small class="text-muted">h-index</small>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.LinhVucText))
                        {
                            <h6 class="fw-semibold mb-2"><i class="fas fa-layer-group me-1 text-primary"></i>Lĩnh vực nghiên cứu trọng tâm</h6>
                            <div class="ps-3 mb-3">@Html.Raw(Model.LinhVucText)</div>
                        }
                        @if (string.IsNullOrEmpty(Model.LinhVucText) && !Model.TongTrichDan.HasValue && !Model.HIndex.HasValue)
                        {
                            <p class="text-muted">Chưa có thông tin.</p>
                        }
                    </div>

                    <!-- TAB 3: ĐÀO TẠO & CÔNG TÁC -->
                    <div class="tab-pane fade" id="tab3">
                        @if (!string.IsNullOrEmpty(Model.QuaTrinhDaoTao))
                        {
                            <h6 class="fw-semibold mb-2"><i class="fas fa-graduation-cap me-1 text-primary"></i>Quá trình đào tạo</h6>
                            <div class="mb-3">@Html.Raw(Model.QuaTrinhDaoTao)</div>
                        }
                        @if (!string.IsNullOrEmpty(Model.QuaTrinhCongTac))
                        {
                            <h6 class="fw-semibold mb-2"><i class="fas fa-briefcase me-1 text-primary"></i>Quá trình công tác</h6>
                            <div>@Html.Raw(Model.QuaTrinhCongTac)</div>
                        }
                        @if (string.IsNullOrEmpty(Model.QuaTrinhDaoTao) && string.IsNullOrEmpty(Model.QuaTrinhCongTac))
                        {
                            <p class="text-muted">Chưa có thông tin.</p>
                        }
                    </div>

                    <!-- TAB 4: CÔNG BỐ & SHTT -->
                    <div class="tab-pane fade" id="tab4">
                        @* Mục 11: Sách & Chương sách đã xuất bản *@
                        @if (!string.IsNullOrEmpty(Model.KetQuaNghienCuu))
                        {
                            <h6 class="fw-semibold mb-2"><i class="fas fa-book-open me-1 text-primary"></i>Sách &amp; Chương sách đã xuất bản</h6>
                            <div class="mb-3">@Html.Raw(Model.KetQuaNghienCuu)</div>
                        }
                        @* Mục 12: Bài báo khoa học / Báo cáo Hội nghị *@
                        @if (!string.IsNullOrEmpty(Model.CongBoKhoaHoc))
                        {
                            <h6 class="fw-semibold mb-2"><i class="fas fa-book me-1 text-primary"></i>Bài báo khoa học / Báo cáo Hội nghị</h6>
                            <div class="mb-3">@Html.Raw(Model.CongBoKhoaHoc)</div>
                        }
                        @* Mục 13: Bằng độc quyền Sáng chế / Tác quyền *@
                        @if (!string.IsNullOrEmpty(Model.SangChe))
                        {
                            <h6 class="fw-semibold mb-2"><i class="fas fa-lightbulb me-1 text-warning"></i>Bằng độc quyền Sáng chế / Tác quyền</h6>
                            <div class="mb-3">@Html.Raw(Model.SangChe)</div>
                        }
                        @if (string.IsNullOrEmpty(Model.KetQuaNghienCuu) && string.IsNullOrEmpty(Model.CongBoKhoaHoc) && string.IsNullOrEmpty(Model.SangChe))
                        {
                            <p class="text-muted">Chưa có thông tin.</p>
                        }
                    </div>

                    <!-- TAB 5: TƯ VẤN & DỰ ÁN -->
                    <div class="tab-pane fade" id="tab5">
                        @if (!string.IsNullOrEmpty(Model.DuAnNghienCuu))
                        {
                            <h6 class="fw-semibold mb-2"><i class="fas fa-project-diagram me-1 text-primary"></i>Dự án nghiên cứu đã chủ trì</h6>
                            <div class="mb-3">@Html.Raw(Model.DuAnNghienCuu)</div>
                        }
                        @if (!string.IsNullOrEmpty(Model.DichVuText))
                        {
                            <h6 class="fw-semibold mb-2"><i class="fas fa-concierge-bell me-1 text-primary"></i>Dịch vụ tư vấn chuyên sâu</h6>
                            <div class="mb-3 ps-3">@Html.Raw(Model.DichVuText)</div>
                        }
                        @if (!string.IsNullOrEmpty(Model.KinhNghiem))
                        {
                            <h6 class="fw-semibold mb-2"><i class="fas fa-handshake me-1 text-primary"></i>Kinh nghiệm thực chiến tại Doanh nghiệp</h6>
                            <div>@Html.Raw(Model.KinhNghiem)</div>
                        }
                        @if (string.IsNullOrEmpty(Model.DuAnNghienCuu) && string.IsNullOrEmpty(Model.DichVuText) && string.IsNullOrEmpty(Model.KinhNghiem))
                        {
                            <p class="text-muted">Chưa có thông tin.</p>
                        }
                    </div>

                    <!-- TAB 6: MINH CHỨNG -->
                    <div class="tab-pane fade" id="tab6">
                        @if (!string.IsNullOrEmpty(Model.HoSoDinhKem))
                        {
                            var files = Model.HoSoDinhKem
                                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
                            if (files.Length > 0)
                            {
                            <h6 class="fw-semibold mb-2"><i class="fas fa-paperclip me-1 text-primary"></i>Hồ sơ đính kèm</h6>
                            <div class="list-group mb-3">
                                @foreach (var f in files)
                                {
                                    var fname = System.IO.Path.GetFileName(f);
                                    var isPdf = fname.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase);
                                    <a href="@f" target="_blank" rel="noopener"
                                       class="list-group-item list-group-item-action d-flex align-items-center gap-2 py-2">
                                        <i class="fas @(isPdf ? "fa-file-pdf text-danger" : "fa-file-image text-primary") fa-fw"></i>
                                        <span class="flex-grow-1 small">@fname</span>
                                        <i class="fas fa-download text-muted small"></i>
                                    </a>
                                }
                            </div>
                            }
                        }
                        @if (!string.IsNullOrEmpty(Model.HiepHoiKhoaHoc))
                        {
                            <h6 class="fw-semibold mb-2"><i class="fas fa-users me-1 text-primary"></i>Thành viên hiệp hội khoa học</h6>
                            <p>@Model.HiepHoiKhoaHoc</p>
                        }
                        @if (Model.TuKhoa.Any())
                        {
                            <h6 class="fw-semibold mb-2"><i class="fas fa-tags me-1 text-secondary"></i>Từ khóa</h6>
                            <div>
                                @foreach (var kw in Model.TuKhoa)
                                {
                                    <span class="badge bg-secondary me-1">@kw</span>
                                }
                            </div>
                        }
                        @if (string.IsNullOrEmpty(Model.HoSoDinhKem) && string.IsNullOrEmpty(Model.HiepHoiKhoaHoc) && !Model.TuKhoa.Any())
                        {
                            <p class="text-muted">Chưa có thông tin.</p>
                        }
                    </div>

                </div>

                <!-- RATING + VIEW WIDGET -->
                <div class="mt-3">
                    @await Html.PartialAsync("_EntityRating", null, new ViewDataDictionary(ViewData) {
                        { "EntityType", "NhaTuVan" },
                        { "EntityId", Model.Id }
                    })
                </div>

            </div>
        </div>
    </div>
</div>
