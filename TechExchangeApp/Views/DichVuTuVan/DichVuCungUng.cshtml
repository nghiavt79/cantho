@model TechExchangeApp.ViewModel.DichVuTuVanVm

@{
    int startIdx = (Model.CurrentPage - 1) * Model.PageSize + 1;
    int endIdx = Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalCount);
}

@if (Model.TotalCount == 0)
{
    <div class="dvtv-empty">
        <i class="fa fa-building fa-2x mb-3 text-muted"></i>
        <p>Không tìm thấy đơn vị tư vấn nào phù hợp.</p>
    </div>
}
else
{
    <div class="dvtv-result-info">
        Hiển thị <strong>@startIdx–@endIdx</strong> trong tổng số <strong>@Model.TotalCount</strong> đơn vị tư vấn
    </div>

    <div class="dvtv-card-list">
        @foreach (var p in Model.ItemsCungUng)
        {
            var detailUrl = $"{Model.MainDomain}nha-cung-ung/{p.QueryString}-{p.CungUngId}";
            var star = Math.Clamp(p.Rating ?? 0, 0, 5);
            var stars = new string('★', star) + new string('☆', 5 - star);

            <article class="dvtv-card dvtv-card--org">
                <div class="dvtv-card__header">
                    <div class="dvtv-card__icon-wrap"><i class="fa fa-building"></i></div>
                    <div class="dvtv-card__header-info">
                        <h3 class="dvtv-card__name"><a href="@detailUrl">@p.FullName</a></h3>
                        <span class="dvtv-card__stars" title="Đánh giá: @star/5">@stars</span>
                    </div>
                </div>
                <div class="dvtv-card__body">
                    @if (!string.IsNullOrEmpty(p.DiaChi))
                    {
                        <div class="dvtv-card__meta"><i class="fa fa-map-marker-alt"></i><span>@p.DiaChi</span></div>
                    }
                    @if (!string.IsNullOrEmpty(p.Phone))
                    {
                        <div class="dvtv-card__meta"><i class="fa fa-phone"></i><a href="tel:@p.Phone">@p.Phone</a></div>
                    }
                    @if (!string.IsNullOrEmpty(p.Email))
                    {
                        <div class="dvtv-card__meta"><i class="fa fa-envelope"></i><a href="mailto:@p.Email">@p.Email</a></div>
                    }
                    @if (!string.IsNullOrEmpty(p.Website))
                    {
                        <div class="dvtv-card__meta"><i class="fa fa-globe"></i><a href="@p.Website" target="_blank" rel="nofollow">@p.Website</a></div>
                    }
                </div>
                <div class="dvtv-card__footer">
                    <a href="@detailUrl" class="dvtv-btn dvtv-btn--sm dvtv-btn--primary">Xem chi tiết</a>
                    <a href="/TechTransfer/Create" class="dvtv-btn dvtv-btn--sm dvtv-btn--outline">Gửi yêu cầu</a>
                </div>
            </article>
        }
    </div>

    <!-- PAGINATION -->
    @if (Model.Pages.Count > 1)
    {
        <nav class="dvtv-pagination">
            @if (Model.CurrentPage > 1)
            {
                <a href="javascript:void(0)" class="dvtv-page-link" data-page="@(Model.CurrentPage - 1)"><i class="fa fa-chevron-left"></i> Trước</a>
            }
            @foreach (var pg in Model.Pages)
            {
                <a href="javascript:void(0)" class="dvtv-page-link @(pg == Model.CurrentPage ? "active" : "")" data-page="@pg">@pg</a>
            }
            @if (Model.CurrentPage < Model.TotalPage)
            {
                <a href="javascript:void(0)" class="dvtv-page-link" data-page="@(Model.CurrentPage + 1)">Sau <i class="fa fa-chevron-right"></i></a>
            }
        </nav>
    }
}
