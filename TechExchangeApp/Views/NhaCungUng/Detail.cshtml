@using TechExchangeApp.ViewModel
@model NhaCungUngDetailVm

@{
    ViewData["Title"] = Model.FullName + " — Nhà cung ứng";
}

<div class="columns-container">
    <div class="container" id="columns">
        <div class="row">

            @* =============== LEFT: SIDEBAR =============== *@
            <div class="column col-xs-12 col-sm-3" id="left_column">

                @* Category filter *@
                <div class="block left-module">
                    <p class="title_block">Lĩnh vực cung ứng</p>
                    <div class="block_content">
                        <ul class="tree-menu">
                            @foreach (var c in Model.Categories)
                            {
                                <li>
                                    <span></span>
                                    <a href="/nha-cung-ung?cateId=@c.Id">@c.Title</a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>

                @* Other suppliers *@
                @if (Model.NhaCungUngKhac.Any())
                {
                    <div class="block left-module">
                        <p class="title_block">Nhà cung ứng khác</p>
                        <div class="block_content">
                            @foreach (var other in Model.NhaCungUngKhac)
                            {
                                <div class="d-flex align-items-center mb-2">
                                    <img src="@other.ImageUrl"
                                         alt="@other.FullName"
                                         style="width:48px;height:40px;object-fit:contain;background:#f8f8f8;margin-right:8px;" />
                                    <div>
                                        <a href="@other.DetailUrl" class="d-block" style="font-size:13px;font-weight:600;">@other.FullName</a>
                                        <span class="small text-muted">@other.DiaChi</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            @* =============== CENTER: COMPANY DETAIL =============== *@
            <div class="center_column col-xs-12 col-sm-9" id="center_column">

                @* Breadcrumb *@
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
                        <li class="breadcrumb-item"><a href="/nha-cung-ung">Nhà cung ứng</a></li>
                        <li class="breadcrumb-item active">@Model.FullName</li>
                    </ol>
                </nav>

                @* ── HEADER CARD ── *@
                <div class="card shadow-sm mb-4">
                    <div class="card-body">
                        <div class="row">
                            @* Logo / Image *@
                            <div class="col-xs-12 col-sm-3 text-center mb-3">
                                @if (!string.IsNullOrEmpty(Model.LogoUrl))
                                {
                                    <img src="@Model.LogoUrl"
                                         alt="@Model.FullName"
                                         class="img-thumbnail mb-2"
                                         style="max-width:160px;max-height:160px;object-fit:contain;padding:8px;"
                                         onerror="this.style.display='none';" />
                                }
                            </div>

                            @* Info *@
                            <div class="col-xs-12 col-sm-9">
                                <h1 style="font-size:20px;font-weight:700;margin-bottom:4px;">@Model.FullName</h1>

                                @if (!string.IsNullOrEmpty(Model.TenVietTat))
                                {
                                    <p class="text-muted mb-2" style="font-size:14px;">@Model.TenVietTat</p>
                                }

                                @* Meta line *@
                                <div class="tp-meta-line mb-3" id="headerMetaLine"
                                     data-entity-type="NhaCungUng" data-entity-id="@Model.Id">
                                    <span class="tp-rating">
                                        <i class="fa fa-star"></i>
                                        <strong id="headerRatingAvg">@(Model.Rating > 0 ? Model.Rating.ToString("0.0") : "—")</strong>
                                        <span class="tp-muted">(<span id="headerRatingCount">@Model.LuotDanhGia</span> đánh giá)</span>
                                    </span>
                                    <span class="tp-dot">·</span>
                                    <span class="tp-view">
                                        <i class="fa fa-eye"></i>
                                        <span id="headerViewCount">@Model.LuotXem.ToString("N0")</span> lượt xem
                                    </span>
                                </div>

                                @if (!string.IsNullOrEmpty(Model.LoaiHinhToChucText))
                                {
                                    <p class="mb-2" style="font-size:14px;">
                                        <i class="fa fa-tag me-1 text-secondary"></i>
                                        <strong>Loại hình:</strong> @Model.LoaiHinhToChucText
                                    </p>
                                }

                                <table class="table table-sm table-borderless mb-2" style="font-size:14px;">
                                    <tbody>
                                        @if (!string.IsNullOrEmpty(Model.DiaChi))
                                        {
                                            <tr><td class="fw-bold" style="width:140px;"><i class="fa fa-map-marker-alt me-1 text-secondary"></i>Địa chỉ</td><td>@Model.DiaChi</td></tr>
                                        }
                                        @if (!string.IsNullOrEmpty(Model.Phone))
                                        {
                                            <tr><td class="fw-bold"><i class="fa fa-phone me-1 text-secondary"></i>Điện thoại</td><td><a href="tel:@Model.Phone">@Model.Phone</a></td></tr>
                                        }
                                        @if (!string.IsNullOrEmpty(Model.Email))
                                        {
                                            <tr><td class="fw-bold"><i class="fa fa-envelope me-1 text-secondary"></i>Email</td><td><a href="mailto:@Model.Email">@Model.Email</a></td></tr>
                                        }
                                        @if (!string.IsNullOrEmpty(Model.Website))
                                        {
                                            <tr><td class="fw-bold"><i class="fa fa-globe me-1 text-secondary"></i>Website</td><td><a href="@Model.Website" target="_blank" rel="noopener">@Model.Website</a></td></tr>
                                        }
                                        @if (!string.IsNullOrEmpty(Model.MaSoThue))
                                        {
                                            <tr><td class="fw-bold"><i class="fa fa-file-alt me-1 text-secondary"></i>Mã số thuế</td><td>@Model.MaSoThue</td></tr>
                                        }
                                        @if (!string.IsNullOrEmpty(Model.Fax))
                                        {
                                            <tr><td class="fw-bold"><i class="fa fa-fax me-1 text-secondary"></i>Fax</td><td>@Model.Fax</td></tr>
                                        }
                                        @if (!string.IsNullOrEmpty(Model.NguoiDaiDien))
                                        {
                                            <tr>
                                                <td class="fw-bold"><i class="fa fa-user me-1 text-secondary"></i>Đại diện</td>
                                                <td>@Model.NguoiDaiDien @(!string.IsNullOrEmpty(Model.ChucVu) ? $"— {Model.ChucVu}" : "")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                @* ── 4 TABS (tương ứng CMS form) ── *@
                <ul class="nav nav-tabs mb-0" role="tablist">
                    <li class="nav-item">
                        <a class="nav-link active" data-bs-toggle="tab" href="#tab2">
                            <i class="fa fa-cogs me-1"></i>Năng lực & Lĩnh vực
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="tab" href="#tab3">
                            <i class="fa fa-box me-1"></i>Dịch vụ & Sản phẩm
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="tab" href="#tab4">
                            <i class="fa fa-images me-1"></i>Hồ sơ năng lực số
                        </a>
                    </li>
                </ul>

                <div class="tab-content border border-top-0 rounded-bottom p-3 mb-4">

                    @* ══════ TAB 2: NĂNG LỰC & LĨNH VỰC ══════ *@
                    <div class="tab-pane fade show active" id="tab2">
                        @if (!string.IsNullOrEmpty(Model.LinhVucText))
                        {
                            <h6 class="fw-semibold mb-2"><i class="fa fa-layer-group me-1 text-primary"></i>Lĩnh vực hoạt động chính</h6>
                            <div class="mb-3 ps-3">@Html.Raw(Model.LinhVucText)</div>
                        }
                        @if (!string.IsNullOrEmpty(Model.ChucNang))
                        {
                            <h6 class="fw-semibold mb-2"><i class="fa fa-bullseye me-1 text-primary"></i>Chức năng nhiệm vụ / Giá trị cốt lõi</h6>
                            <div class="ps-3">@Html.Raw(Model.ChucNang)</div>
                        }
                        @if (string.IsNullOrEmpty(Model.LinhVucText) && string.IsNullOrEmpty(Model.ChucNang))
                        {
                            <p class="text-muted">Chưa có thông tin.</p>
                        }
                    </div>

                    @* ══════ TAB 3: DỊCH VỤ & SẢN PHẨM ══════ *@
                    <div class="tab-pane fade" id="tab3">
                        @if (!string.IsNullOrEmpty(Model.DichVuText))
                        {
                            <h6 class="fw-semibold mb-2"><i class="fa fa-concierge-bell me-1 text-primary"></i>Dịch vụ khoa học và công nghệ</h6>
                            <div class="mb-3 ps-3">@Html.Raw(Model.DichVuText)</div>
                        }

                        @if (!string.IsNullOrEmpty(Model.SanPham) || Model.Products.Any())
                        {
                            <h6 class="fw-semibold mb-2 mt-3"><i class="fa fa-flask me-1 text-primary"></i>Sản phẩm công nghệ / Kết quả nghiên cứu</h6>
                            
                            @if (!string.IsNullOrEmpty(Model.SanPham))
                            {
                                <div class="mb-3 ps-3">@Html.Raw(Model.SanPham)</div>
                            }

                            @if (Model.Products.Any())
                            {
                                <div class="row g-3">
                                    @foreach (var p in Model.Products)
                                    {
                                        <div class="col-6 col-md-4 col-lg-3">
                                            <div class="card h-100 border product-card">
                                                <a href="@p.Url">
                                                    <img src="@p.ImageUrl"
                                                         alt="@p.Title"
                                                         class="card-img-top"
                                                         style="height:140px;object-fit:contain;padding:8px;background:#f8f8f8;"
                                                         onerror="this.src='/images/254-170_noImage.jpg';" />
                                                </a>
                                                <div class="card-body p-2">
                                                    <a href="@p.Url" class="text-decoration-none text-dark">
                                                        <h6 class="card-title mb-1" style="font-size:13px;line-height:1.3;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                                                            @p.Title
                                                        </h6>
                                                    </a>
                                                    @if (!string.IsNullOrEmpty(p.PriceText))
                                                    {
                                                        <div class="text-danger fw-bold" style="font-size:13px;">@p.PriceText</div>
                                                    }
                                                    <div style="color:gold;font-size:12px;">
                                                        @for (int i = 1; i <= 5; i++)
                                                        {
                                                            @(i <= p.Rating ? "★" : "☆")
                                                        }
                                                    </div>
                                                    @if (!string.IsNullOrEmpty(p.Code))
                                                    {
                                                        <small class="text-muted">Mã: @p.Code</small>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        }

                        @if (string.IsNullOrEmpty(Model.DichVuText) && !Model.Products.Any() && string.IsNullOrEmpty(Model.SanPham))
                        {
                            <p class="text-muted">Chưa có thông tin.</p>
                        }
                    </div>

                    @* ══════ TAB 4: HỒ SƠ NĂNG LỰC SỐ ══════ *@
                    <div class="tab-pane fade" id="tab4">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <h6 class="fw-semibold mb-2"><i class="fa fa-building text-success me-1"></i>Hình ảnh trụ sở / Hoạt động tiêu biểu</h6>
                            <div class="ps-3 mb-4">
                                <a href="@Model.ImageUrl" target="_blank">
                                    <img src="@Model.ImageUrl" alt="Hình ảnh trụ sở" class="img-fluid rounded border shadow-sm" style="max-height: 400px; object-fit: contain;" onerror="this.style.display='none';" title="Nhấn để xem ảnh lớn" />
                                </a>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(Model.VideoUrl))
                        {
                            var videoId = "";
                            if (Model.VideoUrl.Contains("watch?v="))
                            {
                                videoId = Model.VideoUrl.Split("watch?v=").Last().Split('&').First();
                            }
                            else if (Model.VideoUrl.Contains("youtu.be/"))
                            {
                                videoId = Model.VideoUrl.Split("youtu.be/").Last().Split('?').First();
                            }

                            <h6 class="fw-semibold mb-2"><i class="fab fa-youtube text-danger me-1"></i>Video giới thiệu đơn vị</h6>
                            if (!string.IsNullOrEmpty(videoId))
                            {
                                <div class="ratio ratio-16x9 mb-3" style="max-width:560px;">
                                    <iframe src="https://www.youtube.com/embed/@videoId" allowfullscreen></iframe>
                                </div>
                            }
                            else if (Model.VideoUrl.EndsWith(".mp4", StringComparison.OrdinalIgnoreCase))
                            {
                                <div class="ps-3 mb-3" style="max-width:560px;">
                                    <video controls style="width:100%; border-radius:8px;" class="shadow-sm">
                                        <source src="@Model.VideoUrl" type="video/mp4">
                                        Trình duyệt của bạn không hỗ trợ hiển thị video.
                                    </video>
                                    <div class="mt-2">
                                        <a href="@Model.VideoUrl" download target="_blank" class="btn btn-sm btn-outline-primary"><i class="fa fa-download me-1"></i>Tải video về máy</a>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <p class="ps-3">
                                    <a href="@Model.VideoUrl" target="_blank" rel="noopener" class="btn btn-sm btn-outline-primary"><i class="fa fa-external-link-alt me-1"></i>Xem video / Tải video</a>
                                </p>
                            }
                        }
                        @if (!string.IsNullOrEmpty(Model.ChungNhan))
                        {
                            <h6 class="fw-semibold mb-2 mt-4"><i class="fa fa-certificate text-warning me-1"></i>Chứng nhận năng lực / Giấy phép</h6>
                            <div class="ps-3 mb-4">
                                @{
                                    var ext = string.Empty;
                                    try { ext = System.IO.Path.GetExtension(Model.ChungNhan)?.ToLower() ?? ""; } catch { }

                                    if (ext == ".jpg" || ext == ".jpeg" || ext == ".png" || ext == ".gif" || ext == ".webp")
                                    {
                                        <div class="mb-2">
                                            <a href="@Model.ChungNhan" target="_blank">
                                                <img src="@Model.ChungNhan" alt="Chứng nhận năng lực" class="img-fluid rounded border shadow-sm" style="max-height: 500px;" title="Nhấn để xem ảnh lớn" />
                                            </a>
                                        </div>
                                    }
                                    else if (ext == ".pdf")
                                    {
                                        <div class="mb-2">
                                            <iframe src="@Model.ChungNhan" style="width: 100%; height: 700px; border: none;" class="rounded border shadow-sm"></iframe>
                                        </div>
                                    }
                                }
                                <div class="mt-2">
                                    <a href="@Model.ChungNhan" target="_blank" download class="btn btn-sm btn-outline-primary">
                                        <i class="fa fa-download me-1"></i>Tải file chứng nhận
                                    </a>
                                </div>
                            </div>
                        }
                        @if (string.IsNullOrEmpty(Model.VideoUrl) && string.IsNullOrEmpty(Model.ChungNhan))
                        {
                            <p class="text-muted">Chưa có thông tin.</p>
                        }
                    </div>

                </div>

                @* ── RATING + VIEW WIDGET ── *@
                <div class="mt-3">
                    @await Html.PartialAsync("_EntityRating", null, new ViewDataDictionary(ViewData) {
                    { "EntityType", "NhaCungUng" },
                                        { "EntityId", Model.Id }
                                        })
                </div>
                <div class="text-end mt-3">
                    <button type="button" class="btn btn-outline-danger btn-sm btn-report-violation"
                            data-target-datatype="Nha cung ung"
                            data-target-id="@Model.Id"
                            data-target-title="@Model.FullName"
                            data-target-url="@Context.Request.Path">
                        <i class="fa fa-flag me-1"></i>Bao cao vi pham
                    </button>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ReportViolationModal")
}
