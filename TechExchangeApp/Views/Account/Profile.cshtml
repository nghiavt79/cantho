@using TechExchangeApp.Interfaces
@using Microsoft.AspNetCore.Identity
@using TechExchangeApp.Entities
@using TechExchangeApp.ViewModel
@inject IAccountService AccountService
@inject UserManager<ApplicationUser> UserManager

@model TechExchangeApp.ViewModel.ProfileVm

@{
    ViewData["Title"] = "Hồ sơ tài khoản";
    ViewData["AuthWorkspace"] = true;
    var userId = int.Parse(UserManager.GetUserId(User)!);
    var sidebarData = await AccountService.GetSidebarDataAsync(userId);

    // Trust score
    int trustScore = 0;
    if (Model.FullName != null) trustScore += 20;
    if (Model.EmailVerified)   trustScore += 25;
    if (Model.PhoneVerified)   trustScore += 25;
    bool hasDoc = Model.AccountTypeId == 1
        ? Model.Docs.Any(d => d.DocType == 1) && Model.Docs.Any(d => d.DocType == 2)
        : Model.Docs.Any(d => d.DocType == 3);
    if (hasDoc) trustScore += 30;

    string trustColor = trustScore >= 80 ? "success" : trustScore >= 50 ? "warning" : "danger";
}

<div class="container-fluid py-4 user-portal">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3 col-lg-2">
            @await Html.PartialAsync("_AccountSidebar", sidebarData)
        </div>

        <!-- Main Content -->
        <div class="col-md-9 col-lg-10 user-portal-main user-profile">

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show">
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <!-- Page header -->
            <div class="user-profile-header mb-3">
                <h2 class="h4 mb-1" style="color:var(--up-navy);font-weight:700;">Hồ sơ tài khoản</h2>
                <p class="mb-0">Quản lý thông tin cá nhân, doanh nghiệp và mức độ xác thực tài khoản.</p>
            </div>

            <!-- Profile completion card -->
            <div class="card mb-4 border-0 user-profile-trust">
                <div class="card-body">
                    <div class="user-profile-trust-top">
                        <img src="@Model.AvatarUrl" alt="Avatar" class="user-profile-trust-avatar">
                        <div class="user-profile-trust-info">
                            <div class="name">@Model.FullName</div>
                            <div class="type">@(Model.AccountTypeId == 2 ? "Tài khoản doanh nghiệp" : "Tài khoản cá nhân")</div>
                            <div class="email">@Model.Email</div>
                        </div>
                        <div class="user-profile-trust-score">
                            <div class="label">Hồ sơ hoàn thiện · @trustScore%</div>
                            <div class="progress">
                                <div class="progress-bar bg-@trustColor" style="width:@trustScore%"></div>
                            </div>
                        </div>
                    </div>
                    <div class="user-profile-trust-checklist">
                        <span class="user-profile-trust-chip @(Model.EmailVerified ? "is-done" : "")">
                            <i class="fas fa-@(Model.EmailVerified ? "check-circle" : "circle")"></i> Email
                        </span>
                        <span class="user-profile-trust-chip @(Model.PhoneVerified ? "is-done" : "")">
                            <i class="fas fa-@(Model.PhoneVerified ? "check-circle" : "circle")"></i> Điện thoại
                        </span>
                        <span class="user-profile-trust-chip @(hasDoc ? "is-done" : "is-pending")">
                            <i class="fas fa-@(hasDoc ? "check-circle" : "clock")"></i> Hồ sơ pháp lý
                        </span>
                    </div>
                </div>
            </div>

            <div class="user-profile-grid">
                <!-- Left: Basic Info -->
                <div>
                    <div class="card shadow-sm h-100">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0"><i class="fas fa-user me-2"></i>Thông tin cơ bản</h5>
                        </div>
                        <form asp-action="Profile" method="post" enctype="multipart/form-data">
                            @Html.AntiForgeryToken()
                            <div class="card-body">
                                <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>

                                <!-- Avatar -->
                                <div class="text-center mb-4">
                                    <div class="user-profile-avatar-wrap">
                                        <img src="@Model.AvatarUrl" alt="Avatar" class="rounded-circle user-profile-avatar"
                                             id="avatarPreview">
                                        <label class="user-profile-avatar-edit" for="avatarInput" title="Đổi ảnh đại diện" aria-label="Đổi ảnh đại diện">
                                            <i class="fas fa-camera"></i>
                                        </label>
                                        <input type="file" name="avatar" id="avatarInput" class="d-none" accept="image/*">
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Tên đăng nhập</label>
                                    <input asp-for="UserName" class="form-control" readonly>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="FullName" class="form-label">Họ và tên <span class="text-danger">*</span></label>
                                    <input asp-for="FullName" class="form-control" placeholder="Nhập họ và tên">
                                    <span asp-validation-for="FullName" class="text-danger small"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="Email" class="form-label">Email <span class="text-danger">*</span></label>
                                    <input asp-for="Email" class="form-control" type="email" placeholder="Nhập email">
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>

                                <!-- Account Type -->
                                <div class="mb-3">
                                    <label class="form-label">Loại tài khoản</label>
                                    <div class="user-profile-type-select">
                                        <div class="form-check user-profile-type-option">
                                            <input class="form-check-input" type="radio" asp-for="AccountTypeId" value="1" id="typePersonal">
                                            <label class="form-check-label" for="typePersonal"><i class="fas fa-user"></i> Cá nhân</label>
                                        </div>
                                        <div class="form-check user-profile-type-option">
                                            <input class="form-check-input" type="radio" asp-for="AccountTypeId" value="2" id="typeBusiness">
                                            <label class="form-check-label" for="typeBusiness"><i class="fas fa-building"></i> Doanh nghiệp</label>
                                        </div>
                                    </div>
                                </div>

                                <div class="row text-muted small">
                                    <div class="col-6">Đăng nhập cuối: @(Model.LastLogin?.ToString("dd/MM/yyyy HH:mm") ?? "Chưa có")</div>
                                    <div class="col-6">Ngày tạo: @(Model.Created?.ToString("dd/MM/yyyy") ?? "N/A")</div>
                                </div>
                            </div>
                            <div class="card-footer">
                                <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i>Lưu thay đổi</button>
                                <a href="@Url.Action("ChangePassword","Account")" class="btn btn-outline-secondary ms-2"><i class="fas fa-shield-halved me-1"></i>Bảo mật &amp; mật khẩu</a>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Right: Verification -->
                <div>

                    <div class="card shadow-sm h-100">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0"><i class="fas fa-shield-alt me-2"></i>Xác thực tài khoản</h5>
                        </div>
                        <div class="card-body p-0">

                            <!-- Phone Verification -->
                            <div class="user-profile-verify-section">
                                <div class="user-profile-verify-section-header">
                                    <i class="fas fa-mobile-alt"></i>
                                    <span>Số điện thoại</span>
                                    @if (Model.PhoneVerified)
                                    {
                                        <span class="badge bg-success ms-auto"><i class="fas fa-check-circle"></i> Đã xác thực</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary ms-auto">Chưa xác thực</span>
                                    }
                                </div>
                                @if (Model.PhoneVerified)
                                {
                                    <p class="text-muted small mb-0">@Model.PhoneNumber</p>
                                }
                                else
                                {
                                    <p class="text-muted small mb-2">Bảo vệ tài khoản và nhận mã OTP khi cần xác nhận giao dịch.</p>
                                    <button type="button" class="btn btn-sm btn-outline-primary" data-target="phoneVerifyForm" onclick="pv_toggleVerifyForm(this)">
                                        <i class="fas fa-shield-halved"></i> Xác thực số điện thoại
                                    </button>
                                    <div id="phoneVerifyForm" class="mt-2 d-none">
                                        <div class="input-group mb-2">
                                            <input type="tel" id="phoneInput" class="form-control"
                                                   placeholder="Nhập số điện thoại" value="@Model.PhoneNumber">
                                            <button class="btn btn-outline-primary" onclick="pv_savePhone()">Lưu SĐT</button>
                                        </div>
                                        <button class="btn btn-sm btn-primary mt-1" id="btnSendPhoneOtp"
                                                onclick="pv_sendPhoneOtp()" @(!string.IsNullOrEmpty(Model.PhoneNumber) ? "" : "disabled")>
                                            <i class="fas fa-paper-plane"></i> Gửi mã OTP qua SMS
                                        </button>
                                        <div id="phoneOtpBox" class="mt-2 d-none">
                                            <div class="input-group">
                                                <input type="text" id="phoneOtpInput" class="form-control" placeholder="Nhập mã 6 số" maxlength="6">
                                                <button class="btn btn-success" onclick="pv_verifyPhoneOtp()">Xác nhận</button>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>

                            <!-- Email Verification -->
                            <div class="user-profile-verify-section">
                                <div class="user-profile-verify-section-header">
                                    <i class="fas fa-envelope"></i>
                                    <span>Email</span>
                                    @if (Model.EmailVerified)
                                    {
                                        <span class="badge bg-success ms-auto"><i class="fas fa-check-circle"></i> Đã xác thực</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary ms-auto">Chưa xác thực</span>
                                    }
                                </div>
                                <p class="text-muted small mb-2">@Model.Email</p>
                                @if (!Model.EmailVerified)
                                {
                                    <button type="button" class="btn btn-sm btn-outline-primary" data-target="emailVerifyForm" onclick="pv_toggleVerifyForm(this)">
                                        <i class="fas fa-shield-halved"></i> Xác thực email
                                    </button>
                                    <div id="emailVerifyForm" class="mt-2 d-none">
                                        <button class="btn btn-sm btn-primary" id="btnSendEmailOtp"
                                                onclick="pv_sendEmailOtp()">
                                            <i class="fas fa-paper-plane"></i> Gửi mã OTP xác thực Email
                                        </button>
                                        <div id="emailOtpBox" class="mt-2 d-none">
                                            <div class="input-group">
                                                <input type="text" id="emailOtpInput" class="form-control" placeholder="Nhập mã 6 số" maxlength="6">
                                                <button class="btn btn-success" onclick="pv_verifyEmailOtp()">Xác nhận</button>
                                            </div>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="text-success small"><i class="fas fa-check-circle"></i> Email đã được xác thực</div>
                                }
                            </div>

                            <!-- Document Upload -->
                            <div class="user-profile-verify-section">
                                <div class="user-profile-verify-section-header">
                                    <i class="fas fa-id-card"></i>
                                    <span>Tài liệu xác minh</span>
                                </div>
                                @{
                                    // Personal: CCCD front + back
                                    // Business: Business license
                                    bool isBusiness = Model.AccountTypeId == 2;
                                }

                                @if (!isBusiness)
                                {
                                    <!-- CCCD Front -->
                                    @await Html.PartialAsync("_DocUpload", new ViewDataDictionary(ViewData) {
                                        { "DocType", 1 }, { "Label", "CCCD / CMND Mặt trước" },
                                        { "Doc", Model.Docs.FirstOrDefault(d => d.DocType == 1) },
                                        { "Icon", "fas fa-id-card" }
                                    })
                                    <!-- CCCD Back -->
                                    @await Html.PartialAsync("_DocUpload", new ViewDataDictionary(ViewData) {
                                        { "DocType", 2 }, { "Label", "CCCD / CMND Mặt sau" },
                                        { "Doc", Model.Docs.FirstOrDefault(d => d.DocType == 2) },
                                        { "Icon", "fas fa-id-card-alt" }
                                    })
                                }
                                else
                                {
                                    <!-- Business License -->
                                    @await Html.PartialAsync("_DocUpload", new ViewDataDictionary(ViewData) {
                                        { "DocType", 3 }, { "Label", "Giấy phép kinh doanh" },
                                        { "Doc", Model.Docs.FirstOrDefault(d => d.DocType == 3) },
                                        { "Icon", "fas fa-file-contract" }
                                    })
                                }
                            </div>

                        </div>
                    </div>

                </div><!-- /Right column -->
            </div><!-- /user-profile-grid -->

        </div><!-- /Main Content -->
    </div>
</div>

<script>
    // Avatar preview
    document.getElementById('avatarInput').addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = e => document.getElementById('avatarPreview').src = e.target.result;
            reader.readAsDataURL(file);
        }
    });

    function pv_toggleVerifyForm(btn) {
        const target = document.getElementById(btn.dataset.target);
        if (target) {
            target.classList.remove('d-none');
            btn.classList.add('d-none');
        }
    }

    function pv_toast(msg, type = 'success') {
        const t = document.createElement('div');
        t.className = `toast align-items-center text-bg-${type} border-0 show position-fixed bottom-0 end-0 m-3`;
        t.style = 'z-index:9999;min-width:280px';
        t.innerHTML = `<div class="d-flex"><div class="toast-body">${msg}</div>
            <button class="btn-close btn-close-white me-2 m-auto" onclick="this.closest('.toast').remove()"></button></div>`;
        document.body.appendChild(t);
        setTimeout(() => t.remove(), 4500);
    }

    async function pv_savePhone() {
        const phone = document.getElementById('phoneInput').value.trim();
        if (!phone) { pv_toast('Nhập SĐT trước.', 'warning'); return; }
        const r = await fetch('/Account/UpdatePhone', {
            method:'POST', headers:{'Content-Type':'application/json'},
            body: JSON.stringify({ phone })
        });
        const d = await r.json();
        pv_toast(d.message, d.success ? 'success' : 'danger');
        if (d.success) document.getElementById('btnSendPhoneOtp')?.removeAttribute('disabled');
    }

    async function pv_sendPhoneOtp() {
        const btn = document.getElementById('btnSendPhoneOtp');
        btn.disabled = true; btn.textContent = 'Đang gửi...';
        const r = await fetch('/Account/SendPhoneOtp', { method:'POST' });
        const d = await r.json();
        pv_toast(d.message, d.success ? 'info' : 'danger');
        if (d.success) {
            document.getElementById('phoneOtpBox').classList.remove('d-none');
            pv_startCountdown(btn, 'Gửi lại OTP', 60);
        } else btn.disabled = false;
    }

    async function pv_verifyPhoneOtp() {
        const otp = document.getElementById('phoneOtpInput').value.trim();
        const r = await fetch('/Account/VerifyPhoneOtp', {
            method:'POST', headers:{'Content-Type':'application/json'},
            body: JSON.stringify({ otp })
        });
        const d = await r.json();
        pv_toast(d.message, d.success ? 'success' : 'danger');
        if (d.success) setTimeout(() => location.reload(), 1500);
    }

    async function pv_sendEmailOtp() {
        const btn = document.getElementById('btnSendEmailOtp');
        btn.disabled = true; btn.textContent = 'Đang gửi...';
        const r = await fetch('/Account/SendEmailOtp', { method:'POST' });
        const d = await r.json();
        pv_toast(d.message, d.success ? 'info' : 'danger');
        if (d.success) {
            document.getElementById('emailOtpBox').classList.remove('d-none');
            pv_startCountdown(btn, 'Gửi lại OTP', 60);
        } else btn.disabled = false;
    }

    async function pv_verifyEmailOtp() {
        const otp = document.getElementById('emailOtpInput').value.trim();
        const r = await fetch('/Account/VerifyEmailOtp', {
            method:'POST', headers:{'Content-Type':'application/json'},
            body: JSON.stringify({ otp })
        });
        const d = await r.json();
        pv_toast(d.message, d.success ? 'success' : 'danger');
        if (d.success) setTimeout(() => location.reload(), 1500);
    }

    function pv_startCountdown(btn, label, seconds) {
        let s = seconds;
        const iv = setInterval(() => {
            btn.textContent = `Gửi lại sau ${s--}s`;
            if (s < 0) {
                clearInterval(iv);
                btn.disabled = false;
                btn.innerHTML = `<i class='fas fa-paper-plane'></i> ${label}`;
            }
        }, 1000);
    }
</script>
@section Styles {
    <link rel="stylesheet" href="~/css/user-portal.css" asp-append-version="true" />
}

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
