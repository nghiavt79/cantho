@using TechExchangeApp.Interfaces
@using Microsoft.AspNetCore.Identity
@using TechExchangeApp.Entities
@inject IAccountService AccountService
@inject UserManager<ApplicationUser> UserManager

@model TechExchangeApp.ViewModel.ChangePasswordVm

@{
    ViewData["Title"] = "Bảo mật & mật khẩu";
    ViewData["AuthWorkspace"] = true;

    var userId = int.Parse(UserManager.GetUserId(User)!);
    var sidebarData = await AccountService.GetSidebarDataAsync(userId);
}

<div class="container-fluid py-4 user-portal">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3 col-lg-2">
            @await Html.PartialAsync("_AccountSidebar", sidebarData)
        </div>

        <!-- Main Content -->
        <div class="col-md-9 col-lg-10 user-portal-main user-password">

            <div class="user-profile-header mb-3">
                <h2 class="h4 mb-1" style="color:var(--up-navy);font-weight:700;">Bảo mật &amp; mật khẩu</h2>
                <p class="mb-0">Cập nhật mật khẩu đăng nhập để bảo vệ tài khoản của bạn.</p>
            </div>

            <div class="row justify-content-center">
                <div class="col-lg-6">
                    <div class="card shadow-sm">
                        <div class="card-header">
                            <h5 class="mb-0"><i class="fas fa-key me-2"></i> Đổi mật khẩu</h5>
                        </div>

                        <form asp-action="ChangePassword" method="post">
                            @Html.AntiForgeryToken()
                            <div class="card-body">
                                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                                <div class="mb-3">
                                    <label asp-for="CurrentPassword" class="form-label">Mật khẩu hiện tại</label>
                                    <div class="input-group">
                                        <input asp-for="CurrentPassword" class="form-control" placeholder="Nhập mật khẩu hiện tại" />
                                        <button class="btn btn-outline-secondary" type="button" tabindex="-1" aria-label="Hiện/ẩn mật khẩu" onclick="pv_togglePwd(this)"><i class="fas fa-eye"></i></button>
                                    </div>
                                    <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="NewPassword" class="form-label">Mật khẩu mới</label>
                                    <div class="input-group">
                                        <input asp-for="NewPassword" class="form-control" placeholder="Nhập mật khẩu mới (tối thiểu 6 ký tự)" />
                                        <button class="btn btn-outline-secondary" type="button" tabindex="-1" aria-label="Hiện/ẩn mật khẩu" onclick="pv_togglePwd(this)"><i class="fas fa-eye"></i></button>
                                    </div>
                                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="ConfirmPassword" class="form-label">Xác nhận mật khẩu</label>
                                    <div class="input-group">
                                        <input asp-for="ConfirmPassword" class="form-control" placeholder="Nhập lại mật khẩu mới" />
                                        <button class="btn btn-outline-secondary" type="button" tabindex="-1" aria-label="Hiện/ẩn mật khẩu" onclick="pv_togglePwd(this)"><i class="fas fa-eye"></i></button>
                                    </div>
                                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                                </div>

                                <div class="user-password-note">
                                    <i class="fas fa-info-circle"></i> <strong>Lưu ý:</strong>
                                    <ul class="mb-0 mt-2">
                                        <li>Mật khẩu mới phải có ít nhất 6 ký tự</li>
                                        <li>Bạn sẽ không bị đăng xuất sau khi đổi mật khẩu</li>
                                        <li>Hãy nhớ mật khẩu mới của bạn</li>
                                    </ul>
                                </div>
                            </div>

                            <div class="card-footer">
                                <button type="submit" class="btn btn-warning">
                                    <i class="fas fa-save"></i> Cập nhật mật khẩu
                                </button>
                                <a href="@Url.Action("Profile", "Account")" class="btn btn-secondary">
                                    <i class="fas fa-times"></i> Hủy
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div><!-- End Main Content -->
    </div><!-- End row -->
</div><!-- End container-fluid -->

<script>
    function pv_togglePwd(btn) {
        const input = btn.closest('.input-group').querySelector('input');
        const icon = btn.querySelector('i');
        if (input.type === 'password') {
            input.type = 'text';
            icon.classList.replace('fa-eye', 'fa-eye-slash');
        } else {
            input.type = 'password';
            icon.classList.replace('fa-eye-slash', 'fa-eye');
        }
    }
</script>

@section Styles {
    <link rel="stylesheet" href="~/css/user-portal.css" asp-append-version="true" />
}

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
