@model List<TechExchangeApp.ViewModel.ProjectStepNavVm>

@{
    var visibleSteps = Model.Where(s => s.IsVisible).ToList();
    var totalVisible = visibleSteps.Count;
    var completedCount = visibleSteps.Count(s => s.StatusId > 0);
    var progressPercent = totalVisible > 0 ? (int)Math.Round((completedCount / (double)totalVisible) * 100) : 0;
    var isComplete = totalVisible > 0 && completedCount == totalVisible;
}

<div class="project-steps-nav tx-workflow-card mb-4">
    <div class="card">
        <div class="card-body">

            <!-- Header summary -->
            <div class="tx-workflow-header">
                <div class="tx-workflow-heading">
                    <h3 class="tx-workflow-title">Tiến trình giao dịch</h3>
                    <p class="tx-workflow-subtitle">Theo dõi toàn bộ quy trình chuyển giao công nghệ</p>
                </div>
                <div class="tx-workflow-summary">
                    <span class="tx-workflow-chip">
                        <i class="fas fa-list-check" aria-hidden="true"></i>@completedCount/@totalVisible bước
                    </span>
                    <span class="tx-workflow-chip tx-workflow-chip-percent">@progressPercent%</span>
                </div>
            </div>

            <!-- Connected stepper -->
            <ul class="nav tx-workflow-stepper">
                @for (var i = 0; i < visibleSteps.Count; i++)
                {
                    var step = visibleSteps[i];
                    var stepClass = step.StatusId > 0 ? "completed" : (step.IsCurrent ? "current" : "pending");
                    var badgeClass = step.StatusId > 0 ? "bg-success" : (step.IsCurrent ? "bg-primary" : "bg-light text-muted");
                    var connectorFilled = i > 0 && visibleSteps[i - 1].StatusId > 0;

                    <li class="nav-item step-item tx-workflow-step @stepClass @(connectorFilled ? "tx-connector-filled" : "")">
                        @if (step.IsAccessible)
                        {
                            <a class="nav-link step-link tx-workflow-node-link @stepClass" href="#" data-step="@step.StepNumber"
                               aria-current="@(step.IsCurrent ? "step" : null)">
                                <span class="step-circle tx-workflow-node @badgeClass">
                                    @if (step.StatusId > 0)
                                    {
                                        <i class="fas fa-check" aria-hidden="true"></i>
                                    }
                                    else
                                    {
                                        <span>@step.StepNumber.ToString("D2")</span>
                                    }
                                </span>
                                <span class="step-name tx-workflow-label">@step.StepName</span>
                            </a>
                        }
                        else
                        {
                            <span class="nav-link disabled tx-workflow-node-link @stepClass" aria-disabled="true">
                                <span class="step-circle tx-workflow-node @badgeClass">@step.StepNumber.ToString("D2")</span>
                                <span class="step-name tx-workflow-label">@step.StepName</span>
                            </span>
                        }
                    </li>
                }
            </ul>

            <!-- Overall progress -->
            <div class="tx-workflow-progress-wrap">
                <div class="tx-workflow-progress-label">
                    <span>Tiến độ tổng thể</span>
                    <span class="tx-workflow-progress-value">@progressPercent%</span>
                </div>
                <div class="progress tx-workflow-progress" role="progressbar"
                     aria-label="Tiến độ tổng thể dự án" aria-valuenow="@progressPercent" aria-valuemin="0" aria-valuemax="100">
                    <div class="progress-bar @(isComplete ? "bg-success" : "bg-primary")" style="width: @progressPercent%"></div>
                </div>
            </div>

            @if (isComplete)
            {
                <div class="tx-workflow-complete">
                    <i class="fas fa-circle-check" aria-hidden="true"></i>
                    <div>
                        <div class="tx-workflow-complete-title">Quy trình giao dịch đã hoàn tất</div>
                        <div class="tx-workflow-complete-text">Toàn bộ @totalVisible bước đã được xử lý thành công.</div>
                    </div>
                </div>
            }

        </div>
    </div>
</div>
