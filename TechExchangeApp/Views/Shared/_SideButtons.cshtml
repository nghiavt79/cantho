@{
    var isEn = Context.Request.Cookies["site_lang"] == "en";
    string T(string vi, string en) => isEn ? en : vi;
    var vrTourUrl = "https://smarttravel-vr.mobifone.vn/vr-tour/san-giao-dich-cong-nghe";
}

<div class="action-dock">
    <div class="action-dock__card">
        <div class="action-dock__group">
            <button type="button" class="action-dock__btn" data-ai-chat-toggle data-tooltip="@T("Chat hỗ trợ", "Support chat")">
                <i class="bi bi-chat-dots-fill"></i>
            </button>
            <button type="button" class="action-dock__btn" data-bs-toggle="modal" data-bs-target="#vrTourModal" data-tooltip="@T("Trải nghiệm VR360°", "VR360° experience")">
                <i class="bi bi-badge-vr"></i>
            </button>
        </div>

        <div class="action-dock__divider" aria-hidden="true"></div>

        <div class="action-dock__group">
            <a class="action-dock__btn action-dock__btn--fb" href="https://www.facebook.com/profile.php?id=100069991094645" target="_blank" rel="noopener" data-tooltip="Facebook">
                <i class="bi bi-facebook"></i>
            </a>
            <a class="action-dock__btn action-dock__btn--zalo" href="https://id.zalo.me/account/login?continue=http%3A%2F%2Fzalo.me%2F02923907037" target="_blank" rel="noopener" data-tooltip="Zalo">
                <img src="/image/zalo-icon.webp" alt="Zalo">
            </a>
        </div>
    </div>

    <button type="button" id="btnBackToTop" class="action-dock__top" data-tooltip="@T("Về đầu trang", "Back to top")" aria-label="@T("Về đầu trang", "Back to top")">
        <i class="bi bi-chevron-up"></i>
    </button>
</div>

<button type="button" class="action-dock-vr-shortcut" data-bs-toggle="modal" data-bs-target="#vrTourModal" data-tooltip="@T("Trải nghiệm VR360°", "VR360° experience")" aria-label="@T("Trải nghiệm VR360°", "VR360° experience")">
    <i class="bi bi-badge-vr"></i>
</button>

<div class="modal fade" id="vrTourModal" tabindex="-1" aria-labelledby="vrTourModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="vrTourModalLabel">@T("Trải nghiệm VR360° - Sàn Giao Dịch Công Nghệ", "VR360° Experience - Technology Exchange Floor")</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="@T("Đóng", "Close")"></button>
            </div>
            <div class="modal-body p-0">
                <div id="vrTourFrameWrap" class="vr-tour-frame-wrap"></div>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        var backToTop = document.getElementById('btnBackToTop');
        if (backToTop) {
            backToTop.addEventListener('click', function () {
                window.scrollTo({ top: 0, behavior: 'smooth' });
            });

            var toggleVisibility = function () {
                backToTop.classList.toggle('is-visible', window.scrollY > 320);
            };
            toggleVisibility();
            window.addEventListener('scroll', toggleVisibility, { passive: true });
        }

        var modal = document.getElementById('vrTourModal');
        if (!modal) return;
        var wrap = document.getElementById('vrTourFrameWrap');
        var vrUrl = '@vrTourUrl';

        modal.addEventListener('shown.bs.modal', function () {
            if (!wrap.querySelector('iframe')) {
                var iframe = document.createElement('iframe');
                iframe.title = 'Sàn Giao Dịch Công Nghệ';
                iframe.src = vrUrl;
                iframe.width = '100%';
                iframe.height = '400';
                iframe.frameBorder = '0';
                iframe.scrolling = 'no';
                iframe.allow = 'vr; gyroscope; accelerometer';
                iframe.loading = 'eager';
                wrap.appendChild(iframe);
            }
        });

        modal.addEventListener('hidden.bs.modal', function () {
            wrap.innerHTML = '';
        });
    })();
</script>
