@{
    var isEn = Context.Request.Cookies["site_lang"] == "en";
    string T(string vi, string en) => isEn ? en : vi;
    var vrTourUrl = "https://smarttravel-vr.mobifone.vn/vr-tour/san-giao-dich-cong-nghe";
}

<div class="action-dock">
    <div class="action-dock__card">
        <div class="action-dock__group">
            <button type="button" class="action-dock__btn" data-ai-chat-toggle data-tooltip="@T("Chat hỗ trợ", "Support chat")">
                <i class="bi bi-chat-dots-fill"></i>
            </button>
            <a class="action-dock__btn" href="@vrTourUrl" target="_blank" rel="noopener" data-tooltip="@T("Trải nghiệm VR360°", "VR360° experience")">
                <i class="bi bi-badge-vr"></i>
            </a>
        </div>

        <div class="action-dock__divider" aria-hidden="true"></div>

        <div class="action-dock__group">
            <a class="action-dock__btn action-dock__btn--fb" href="https://www.facebook.com/profile.php?id=100069991094645" target="_blank" rel="noopener" data-tooltip="Facebook">
                <i class="bi bi-facebook"></i>
            </a>
            <a class="action-dock__btn action-dock__btn--zalo" href="https://id.zalo.me/account/login?continue=http%3A%2F%2Fzalo.me%2F02923907037" target="_blank" rel="noopener" data-tooltip="Zalo">
                <img src="/image/zalo-icon.webp" alt="Zalo">
            </a>
        </div>
    </div>

    <button type="button" id="btnBackToTop" class="action-dock__top" data-tooltip="@T("Về đầu trang", "Back to top")" aria-label="@T("Về đầu trang", "Back to top")">
        <i class="bi bi-chevron-up"></i>
    </button>
</div>

<a class="action-dock-vr-shortcut" href="@vrTourUrl" target="_blank" rel="noopener" data-tooltip="@T("Trải nghiệm VR360°", "VR360° experience")" aria-label="@T("Trải nghiệm VR360°", "VR360° experience")">
    <i class="bi bi-badge-vr"></i>
</a>

<script>
    (function () {
        var backToTop = document.getElementById('btnBackToTop');
        if (backToTop) {
            backToTop.addEventListener('click', function () {
                window.scrollTo({ top: 0, behavior: 'smooth' });
            });

            var toggleVisibility = function () {
                backToTop.classList.toggle('is-visible', window.scrollY > 320);
            };
            toggleVisibility();
            window.addEventListener('scroll', toggleVisibility, { passive: true });
        }
    })();
</script>
