@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@inject TechExchangeApp.Interfaces.ICmsAccessService CmsAccessService
@{
    var mainDomain = Configuration["AppSettings:MainDomain"] ?? "/";
    var shortName = Configuration["SiteBranding:ShortName"] ?? "TechExchange";
    var organizationName = Configuration["SiteBranding:OrganizationName"] ?? "TechExchange";
    var tagline = Configuration["SiteBranding:Tagline"] ?? "";
    var phone = Configuration["SiteBranding:Phone"] ?? "";
    var email = Configuration["SiteBranding:Email"] ?? "";
    var address = Configuration["SiteBranding:Address"] ?? "";
    var canAccessCms = await CmsAccessService.CanAccessCmsAsync(ViewContext.HttpContext.User);
}

<header class="site-header-v2">
    <div class="site-header-v2__top">
        <div class="container">
            <div class="site-header-v2__contact">
                <span><i class="bi bi-telephone"></i> @phone</span>
                <span><i class="bi bi-envelope"></i> @email</span>
                <span><i class="bi bi-geo-alt"></i> @address</span>
            </div>
            <div class="site-header-v2__social">
                <span>@DateTime.Now.ToString("dddd, dd/MM/yyyy", new System.Globalization.CultureInfo("vi-VN"))</span>
                <a href="#" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                <a href="#" aria-label="YouTube"><i class="bi bi-youtube"></i></a>
                <a href="#" aria-label="Zalo"><i class="bi bi-chat-dots"></i></a>
                <a href="#" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
            </div>
        </div>
    </div>

    <nav class="site-header-v2__nav">
        <div class="container site-header-v2__nav-inner">
            <a class="site-header-v2__brand" href="@mainDomain">
                <img src="/image/logo-casta.webp" alt="@shortName" onerror="this.src='/image/logo.png'">
                <span>
                    <strong>@organizationName</strong>
                    <small>@tagline</small>
                </span>
            </a>

            <div class="site-header-v2__actions">
                <button class="site-header-v2__menu-toggle" type="button" data-bs-toggle="offcanvas" data-bs-target="#siteMenuOffcanvas" aria-controls="siteMenuOffcanvas" aria-label="Mở menu">
                    <i class="bi bi-list"></i>
                </button>
                <a class="site-header-v2__consult" href="/dang-ky-tu-van">
                    <i class="bi bi-people"></i> Đăng ký tư vấn
                </a>
            </div>
        </div>
    </nav>

    <div class="offcanvas offcanvas-end site-menu-offcanvas" tabindex="-1" id="siteMenuOffcanvas" aria-labelledby="siteMenuOffcanvasLabel">
        <div class="offcanvas-header">
            <h5 class="offcanvas-title" id="siteMenuOffcanvasLabel">@shortName</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Đóng"></button>
        </div>
        <div class="offcanvas-body">
            <form class="site-menu-offcanvas__search" action="/Search" method="get">
                <i class="bi bi-search"></i>
                <input type="search" name="q" placeholder="Tìm kiếm dịch vụ, công nghệ..." aria-label="Tìm kiếm">
            </form>

            <nav class="site-menu-offcanvas__nav">
                <a href="/">Trang chủ</a>
                <a href="/gioi-thieu-chung-3">Giới thiệu</a>
                <a href="/dich-vu-tu-van-8">Dịch vụ & Giải pháp</a>
                <a href="/cong-nghe">Chuyển giao công nghệ</a>
                <a href="/thiet-bi">Cơ sở & Phòng thí nghiệm</a>
                <a href="/tin-su-kien-44">Tin tức - Sự kiện</a>
                <a href="/lien-he-74">Liên hệ</a>
            </nav>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="site-menu-offcanvas__account">
                    <strong>@User.Identity.Name</strong>
                    @if (canAccessCms)
                    {
                        <a href="/cms"><i class="bi bi-gear-wide-connected"></i> CMS Admin</a>
                    }
                    <a href="/Dashboard"><i class="bi bi-speedometer2"></i> Dashboard</a>
                    <a href="/Projects/MyProjects"><i class="bi bi-folder2-open"></i> Dự án của tôi</a>
                    <a href="/Chat"><i class="bi bi-chat-dots"></i> Tin nhắn</a>
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit"><i class="bi bi-box-arrow-right"></i> Đăng xuất</button>
                    </form>
                </div>
            }
            else
            {
                <button type="button" class="site-menu-offcanvas__login" data-bs-toggle="modal" data-bs-target="#loginModal" data-bs-dismiss="offcanvas">
                    <i class="bi bi-person-circle"></i> Đăng nhập
                </button>
            }
        </div>
    </div>
</header>
