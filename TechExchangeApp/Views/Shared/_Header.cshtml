@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@inject TechExchangeApp.Interfaces.ICmsAccessService CmsAccessService
@inject TechExchangeApp.Data.AppDbContext AppDb
@{
    var mainDomain = Configuration["AppSettings:MainDomain"] ?? "/";
    var shortName = Configuration["SiteBranding:ShortName"] ?? "CASTA";
    var canAccessCms = await CmsAccessService.CanAccessCmsAsync(ViewContext.HttpContext.User);
    var isEn = Context.Request.Cookies["site_lang"] == "en";
    string T(string vi, string en) => isEn ? en : vi;
    var currentUrl = Context.Request.Path + Context.Request.QueryString;
    var accountDisplayName = User.Identity?.Name ?? "Tài khoản";
    var accountInitial = string.IsNullOrWhiteSpace(accountDisplayName)
        ? "U"
        : accountDisplayName.Trim().Substring(0, 1).ToUpperInvariant();
    var productCategories = AppDb.Categories
        .Where(x => x.ParentId == 1 && x.MainCate == true && x.StatusId == 1 && x.LanguageId == 1)
        .OrderBy(x => x.Sort ?? int.MaxValue)
        .ThenBy(x => x.Title)
        .ToList();
    var serviceCategories = AppDb.Categories
        .Where(x => x.ParentId == 2 && x.MainCate == true && x.StatusId == 1 && x.LanguageId == 1)
        .OrderBy(x => x.Sort ?? int.MaxValue)
        .ThenBy(x => x.Title)
        .ToList();

    string CategorySlug(TechExchangeApp.Entities.Category category)
    {
        return TechExchangeApp.Controllers.ProductController.MakeURLFriendly(category.QueryString ?? category.Title);
    }
}

<header class="site-header-v2">
    <nav class="site-header-v2__nav">
        <div class="container site-header-v2__nav-inner">
            <a class="site-header-v2__brand" href="@mainDomain">
                <img src="/image/logo-casta.webp" alt="@shortName" onerror="this.src='/image/logo.png'">
            </a>

            <div class="site-header-v2__actions">
                <nav class="site-header-v2__menu" aria-label="Menu chính">
                    <a class="nav-link" href="/gioi-thieu-chung-3">@T("Giới thiệu", "About")</a>
                    <div class="site-header-v2__menu-item">
                        <a class="nav-link site-header-v2__has-submenu" href="/san-pham">
                            <span>@T("Sản phẩm", "Products")</span>
                            @if (productCategories.Any())
                            {
                                <i class="bi bi-chevron-down"></i>
                            }
                        </a>
                        @if (productCategories.Any())
                        {
                            var productSubmenuRows = (int)Math.Ceiling(productCategories.Count / 2.0);
                            <div class="site-header-v2__submenu site-header-v2__submenu--cols" style="grid-template-rows: repeat(@productSubmenuRows, auto);">
                                @foreach (var category in productCategories)
                                {
                                    <a href="/san-pham/@CategorySlug(category)-@category.CatId">@category.Title</a>
                                }
                            </div>
                        }
                    </div>
                    <div class="site-header-v2__menu-item">
                        <a class="nav-link site-header-v2__has-submenu" href="/dich-vu-tu-van">
                            <span>@T("Dịch vụ", "Services")</span>
                            @if (serviceCategories.Any())
                            {
                                <i class="bi bi-chevron-down"></i>
                            }
                        </a>
                        @if (serviceCategories.Any())
                        {
                            <div class="site-header-v2__submenu">
                                @foreach (var category in serviceCategories)
                                {
                                    <a href="/8-ds-dich-vu-tu-van/@CategorySlug(category)-@category.CatId">@category.Title</a>
                                }
                            </div>
                        }
                    </div>
                    <a class="nav-link" href="/tin-su-kien-44">@T("Tin tức sự kiện", "News & Events")</a>
                    <a class="nav-link" href="/lien-he-74">@T("Liên hệ", "Contact")</a>
                    <a class="nav-link site-header-v2__ocop-link" href="/ocop"><i class="bi bi-star-fill"></i> OCOP</a>
                    <form class="site-header-v2__quick-search" action="/Search" method="get" role="search">
                        <input type="search" name="q" placeholder="@T("Tìm kiếm...", "Search...")" aria-label="@T("Tìm kiếm", "Search")" autocomplete="off">
                        <button type="submit" class="site-header-v2__quick-search-btn" aria-label="@T("Tìm kiếm", "Search")">
                            <i class="bi bi-search"></i>
                        </button>
                    </form>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="site-header-v2__account-actions">
                            <div class="dropdown site-header-v2__account">
                                <button type="button"
                                        class="nav-link site-header-v2__login-link site-header-v2__account-toggle"
                                        data-bs-toggle="dropdown"
                                        data-bs-auto-close="outside"
                                        aria-expanded="false"
                                        aria-label="Menu tài khoản">
                                    <span class="site-header-v2__account-avatar">@accountInitial</span>
                                    <i class="bi bi-chevron-down site-header-v2__account-chevron"></i>
                                </button>
                                <div class="dropdown-menu dropdown-menu-end site-header-v2__account-menu">
                                    @if (canAccessCms)
                                    {
                                        <a class="dropdown-item site-header-v2__account-admin" href="/cms"><i class="bi bi-gear-wide-connected"></i> CMS Admin</a>
                                    }
                                    <a class="dropdown-item" href="/Dashboard"><i class="bi bi-speedometer2"></i> Dashboard</a>
                                    <a class="dropdown-item" href="/Projects/MyProjects"><i class="bi bi-folder2-open"></i> Dự án của tôi</a>
                                    <a class="dropdown-item" href="/Chat"><i class="bi bi-chat-dots"></i> Tin nhắn</a>
                                    <div class="dropdown-divider"></div>
                                    <a class="dropdown-item" href="/Account/Profile"><i class="bi bi-person"></i> Thông tin cá nhân</a>
                                    <a class="dropdown-item" href="/Account/ChangePassword"><i class="bi bi-key"></i> Đổi mật khẩu</a>
                                    <div class="dropdown-divider"></div>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item site-header-v2__account-logout">
                                            <i class="bi bi-box-arrow-right"></i> Đăng xuất
                                        </button>
                                    </form>
                                </div>
                            </div>

                            <div class="dropdown site-header-v2__notify">
                                <button type="button"
                                        class="site-header-v2__notify-btn"
                                        data-bs-toggle="dropdown"
                                        data-bs-auto-close="outside"
                                        aria-expanded="false"
                                        aria-label="Thông báo">
                                    <i class="bi bi-bell"></i>
                                    <span id="tpBadge" class="badge bg-danger tp-badge d-none">0</span>
                                </button>
                                <div class="dropdown-menu dropdown-menu-end tp-dropdown">
                                    <div class="tp-header d-flex justify-content-between align-items-center px-3 py-2">
                                        <strong>Thông báo</strong>
                                        <button type="button" class="btn btn-sm btn-link text-decoration-none" onclick="tpMarkAllRead()">Đánh dấu đã đọc</button>
                                    </div>
                                    <div id="tpList" class="tp-list">
                                        <div class="tp-empty text-center text-muted py-3 small">Không có thông báo</div>
                                    </div>
                                    <a class="tp-footer d-block text-center py-2 text-decoration-none" href="/Notifications">Xem tất cả</a>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <button type="button" class="nav-link site-header-v2__login-link site-header-v2__icon-link" data-bs-toggle="modal" data-bs-target="#loginModal" aria-label="@T("Đăng nhập", "Log in")">
                            <i class="bi bi-person-circle"></i>
                        </button>
                    }
                    <div class="site-header-v2__lang">
                        <a class="@(!isEn ? "is-active" : "")" href="/Language/SetLanguage?lang=vi&returnUrl=@Uri.EscapeDataString(currentUrl)">VI</a>
                        <span>/</span>
                        <a class="@(isEn ? "is-active" : "")" href="/Language/SetLanguage?lang=en&returnUrl=@Uri.EscapeDataString(currentUrl)">EN</a>
                    </div>
                </nav>
                <button class="site-header-v2__menu-toggle" type="button" data-bs-toggle="offcanvas" data-bs-target="#siteMenuOffcanvas" aria-controls="siteMenuOffcanvas" aria-label="Mở menu">
                    <i class="bi bi-list"></i>
                </button>
            </div>
        </div>
    </nav>

    <div class="offcanvas offcanvas-end site-menu-offcanvas" tabindex="-1" id="siteMenuOffcanvas" aria-labelledby="siteMenuOffcanvasLabel">
        <div class="offcanvas-header">
            <h5 class="offcanvas-title" id="siteMenuOffcanvasLabel">@shortName</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Đóng"></button>
        </div>
        <div class="offcanvas-body">
            <div class="site-header-v2__lang site-header-v2__lang--offcanvas">
                <a class="@(!isEn ? "is-active" : "")" href="/Language/SetLanguage?lang=vi&returnUrl=@Uri.EscapeDataString(currentUrl)">VI</a>
                <span>/</span>
                <a class="@(isEn ? "is-active" : "")" href="/Language/SetLanguage?lang=en&returnUrl=@Uri.EscapeDataString(currentUrl)">EN</a>
            </div>
            <form class="site-menu-offcanvas__search" action="/Search" method="get">
                <i class="bi bi-search"></i>
                <input type="search" name="q" placeholder="@T("Tìm kiếm dịch vụ, công nghệ...", "Search services, technologies...")" aria-label="@T("Tìm kiếm", "Search")">
            </form>

            <nav class="site-menu-offcanvas__nav">
                <a href="/">@T("Trang chủ", "Home")</a>
                <a href="/gioi-thieu-chung-3">@T("Giới thiệu", "About")</a>
                <a href="/san-pham">@T("Sản phẩm", "Products")</a>
                @foreach (var category in productCategories)
                {
                    <a class="site-menu-offcanvas__child" href="/san-pham/@CategorySlug(category)-@category.CatId">@category.Title</a>
                }
                <a href="/dich-vu-tu-van">@T("Dịch vụ", "Services")</a>
                @foreach (var category in serviceCategories)
                {
                    <a class="site-menu-offcanvas__child" href="/8-ds-dich-vu-tu-van/@CategorySlug(category)-@category.CatId">@category.Title</a>
                }
                <a href="/tin-su-kien-44">@T("Tin tức sự kiện", "News & Events")</a>
                <a href="/lien-he-74">@T("Liên hệ", "Contact")</a>
                <a class="site-menu-offcanvas__ocop" href="/ocop"><i class="bi bi-star-fill"></i> OCOP &amp; Truy xuất nguồn gốc</a>
                <a href="/Search">@T("Tìm kiếm", "Search")</a>
            </nav>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="site-menu-offcanvas__account">
                    <strong>@User.Identity.Name</strong>
                    @if (canAccessCms)
                    {
                        <a href="/cms"><i class="bi bi-gear-wide-connected"></i> CMS Admin</a>
                    }
                    <a href="/Dashboard"><i class="bi bi-speedometer2"></i> Hệ thống</a>
                    <a href="/Projects/MyProjects"><i class="bi bi-folder2-open"></i> Dự án của tôi</a>
                    <a href="/Chat"><i class="bi bi-chat-dots"></i> Tin nhắn</a>
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit"><i class="bi bi-box-arrow-right"></i> Đăng xuất</button>
                    </form>
                </div>
            }
            else
            {
                <button type="button" class="site-menu-offcanvas__login" data-bs-toggle="modal" data-bs-target="#loginModal" data-bs-dismiss="offcanvas">
                    <i class="bi bi-person-circle"></i> @T("Đăng nhập", "Log in")
                </button>
                <button type="button" class="site-menu-offcanvas__login" data-bs-toggle="modal" data-bs-target="#registerModal" data-bs-dismiss="offcanvas">
                    <i class="bi bi-person-plus"></i> @T("Đăng ký", "Sign up")
                </button>
            }
        </div>
    </div>
</header>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.site-header-v2__quick-search').forEach(function (form) {
            const input = form.querySelector('input[type="search"]');
            const button = form.querySelector('button[type="submit"]');

            button.addEventListener('click', function (event) {
                if (!form.classList.contains('is-open')) {
                    event.preventDefault();
                    form.classList.add('is-open');
                    window.setTimeout(function () { input.focus(); }, 120);
                    return;
                }

                if (!input.value.trim()) {
                    event.preventDefault();
                    input.focus();
                }
            });

            document.addEventListener('click', function (event) {
                if (!form.contains(event.target) && !input.value.trim()) {
                    form.classList.remove('is-open');
                }
            });
        });
    });
</script>
