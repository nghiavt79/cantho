@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@inject TechExchangeApp.Interfaces.ICmsAccessService CmsAccessService
@{
    var mainDomain = Configuration["AppSettings:MainDomain"] ?? "/";
    var shortName = Configuration["SiteBranding:ShortName"] ?? "TechExchange";
    var organizationName = Configuration["SiteBranding:OrganizationName"] ?? "TechExchange";
    var tagline = Configuration["SiteBranding:Tagline"] ?? "";
    var phone = Configuration["SiteBranding:Phone"] ?? "";
    var email = Configuration["SiteBranding:Email"] ?? "";
    var address = Configuration["SiteBranding:Address"] ?? "";
    var canAccessCms = await CmsAccessService.CanAccessCmsAsync(ViewContext.HttpContext.User);
}

<header class="site-header-v2">
    <div class="site-header-v2__top">
        <div class="container">
            <div class="site-header-v2__contact">
                <span><i class="bi bi-telephone"></i> @phone</span>
                <span><i class="bi bi-envelope"></i> @email</span>
                <span><i class="bi bi-geo-alt"></i> @address</span>
            </div>
            <div class="site-header-v2__social">
                <span>@DateTime.Now.ToString("dddd, dd/MM/yyyy", new System.Globalization.CultureInfo("vi-VN"))</span>
                <a href="#" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                <a href="#" aria-label="YouTube"><i class="bi bi-youtube"></i></a>
                <a href="#" aria-label="Zalo"><i class="bi bi-chat-dots"></i></a>
                <a href="#" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
            </div>
        </div>
    </div>

    <nav class="navbar navbar-expand-xl site-header-v2__nav">
        <div class="container">
            <a class="site-header-v2__brand" href="@mainDomain">
                <img src="/image/logo-casta.webp" alt="@shortName" onerror="this.src='/image/logo.png'">
                <span>
                    <strong>@organizationName</strong>
                    <small>@tagline</small>
                </span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#siteHeaderNav" aria-controls="siteHeaderNav" aria-expanded="false" aria-label="Mở menu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="siteHeaderNav">
                <ul class="navbar-nav ms-auto site-header-v2__menu">
                    <li class="nav-item"><a class="nav-link active" href="/">Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link" href="/gioi-thieu-chung-3.html">Giới thiệu</a></li>
                    <li class="nav-item"><a class="nav-link" href="/dich-vu-tu-van-8.html">Dịch vụ & Giải pháp</a></li>
                    <li class="nav-item"><a class="nav-link" href="/cong-nghe.html">Chuyển giao công nghệ</a></li>
                    <li class="nav-item"><a class="nav-link" href="/thiet-bi.html">Cơ sở & Phòng thí nghiệm</a></li>
                    <li class="nav-item"><a class="nav-link" href="/tin-su-kien-44.html">Tin tức - Sự kiện</a></li>
                    <li class="nav-item"><a class="nav-link" href="/lien-he-74.html">Liên hệ</a></li>
                </ul>

                <form class="site-header-v2__search" action="/Search" method="get">
                    <i class="bi bi-search"></i>
                    <input type="search" name="q" placeholder="Tìm kiếm dịch vụ, công nghệ..." aria-label="Tìm kiếm">
                </form>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="dropdown site-header-v2__account">
                        <button class="btn dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-person-circle"></i> @User.Identity.Name
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            @if (canAccessCms)
                            {
                                <li><a class="dropdown-item" href="/cms"><i class="bi bi-gear-wide-connected me-2"></i>CMS Admin</a></li>
                            }
                            <li><a class="dropdown-item" href="/Dashboard"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a></li>
                            <li><a class="dropdown-item" href="/Projects/MyProjects"><i class="bi bi-folder2-open me-2"></i>Dự án của tôi</a></li>
                            <li><a class="dropdown-item" href="/Chat"><i class="bi bi-chat-dots me-2"></i>Tin nhắn</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="/Account/Profile"><i class="bi bi-person me-2"></i>Thông tin cá nhân</a></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item text-danger"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
                <a class="site-header-v2__consult" href="/dang-ky-tu-van.html">
                    <i class="bi bi-people"></i> Đăng ký tư vấn
                </a>
            </div>
        </div>
    </nav>
</header>
