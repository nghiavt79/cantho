@model TechExchangeApp.Configuration.AiChatOptions

@if (Model.IsEnabled)
{
    <section class="ai-chatbox" data-ai-chatbox>
        <button class="ai-chatbox__launcher" type="button" aria-label="@Model.BotName" data-ai-chat-toggle>
            <i class="bi bi-chat-dots-fill" aria-hidden="true"></i>
        </button>

        <div class="ai-chatbox__panel" role="dialog" aria-label="@Model.BotName" aria-hidden="true">
            <header class="ai-chatbox__header">
                <div class="ai-chatbox__header-info">
                    <span class="ai-chatbox__avatar"><i class="bi bi-robot" aria-hidden="true"></i></span>
                    <div>
                        <strong>@Model.BotName</strong>
                        <span><span class="ai-chatbox__status-dot" aria-hidden="true"></span>Trợ lý Công nghệ · Trực tuyến</span>
                    </div>
                </div>
                <button type="button" class="ai-chatbox__close" aria-label="Đóng" data-ai-chat-toggle>
                    <i class="bi bi-x-lg" aria-hidden="true"></i>
                </button>
            </header>

            <div class="ai-chatbox__messages" data-ai-chat-messages>
                <div class="ai-chatbox__message ai-chatbox__message--bot ai-chatbox__welcome">
                    <span class="ai-chatbox__welcome-icon"><i class="bi bi-robot" aria-hidden="true"></i></span>
                    <p class="ai-chatbox__welcome-text">@Model.WelcomeMessage</p>
                    <p class="ai-chatbox__welcome-lead">Tôi có thể hỗ trợ</p>
                    <ul class="ai-chatbox__welcome-list">
                        <li><i class="bi bi-cpu" aria-hidden="true"></i> Tìm công nghệ &amp; thiết bị</li>
                        <li><i class="bi bi-person-badge" aria-hidden="true"></i> Gợi ý chuyên gia tư vấn</li>
                        <li><i class="bi bi-box-seam" aria-hidden="true"></i> Tra cứu sản phẩm OCOP</li>
                        <li><i class="bi bi-shop" aria-hidden="true"></i> Kết nối nhà cung ứng</li>
                    </ul>
                    <p class="ai-chatbox__welcome-lead">Bạn có thể chọn nhanh</p>
                    <div class="ai-chatbox__quick-actions" data-ai-chat-suggestions></div>
                </div>
            </div>

            <form class="ai-chatbox__feedback" data-ai-chat-feedback hidden>
                <div class="ai-chatbox__feedback-grid">
                    <input type="text" name="fullName" autocomplete="name" placeholder="Họ tên" maxlength="255" />
                    <input type="tel" name="phone" autocomplete="tel" placeholder="Số điện thoại" maxlength="50" />
                    <input type="email" name="email" autocomplete="email" placeholder="Email" maxlength="100" />
                </div>
                <button type="submit">Gửi thông tin</button>
            </form>

            <form class="ai-chatbox__composer" data-ai-chat-form>
                <input type="text" name="message" autocomplete="off" maxlength="2000" placeholder="Hỏi AI về công nghệ, sản phẩm, chuyên gia..." required />
                <button type="submit" aria-label="Gửi">
                    <i class="bi bi-send-fill" aria-hidden="true"></i>
                </button>
            </form>
        </div>
    </section>
}
