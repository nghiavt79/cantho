@model int

@if (Model > 0)
{
    <a href="/Seller/InvitedProjects" class="position-relative d-flex align-items-center text-decoration-none me-3" style="color: #333;">
        <i class="fas fa-file-invoice" style="font-size: 20px;"></i>
        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 10px;">
            @Model
            <span class="visually-hidden">yêu cầu báo giá mới</span>
        </span>
    </a>
}
