@model List<TechExchangeApp.ViewModel.ProductPortletItemVm>

@if (Model != null && Model.Any())
{
    <section class="related-tech-section">
        <h2 class="related-tech-title">Sản phẩm tương tự</h2>
        <div class="related-tech-grid">
            @foreach (var p in Model.Take(4))
            {
                var price = string.IsNullOrWhiteSpace(p.PriceText) ? "Liên hệ báo giá" : p.PriceText;
                <article class="related-tech-card">
                    <a class="related-tech-image" href="@p.Url">
                        <img src="@Html.CookedImageURL("org", p.ImageUrl)" alt="@p.Name" />
                    </a>
                    <div class="related-tech-body">
                        <h3 class="related-tech-name"><a href="@p.Url">@p.Name</a></h3>
                        <div class="related-tech-price">@price</div>
                        <div class="related-tech-meta">Mã sản phẩm: @p.Code</div>
                        <a class="related-tech-link" href="@p.Url">Xem chi tiết</a>
                    </div>
                </article>
            }
        </div>
    </section>
}
