@model List<TechExchangeApp.Entities.ImageAdver>
@{
    var isEn = Context.Request.Cookies["site_lang"] == "en";
    var ctaText = isEn ? "Learn more" : "Xem thêm";
}

@if (Model.Any())
{
    <section class="home-v2-hero">
        <div id="homeHeroCarousel" class="carousel slide carousel-fade home-v2-hero__carousel" data-bs-ride="carousel" data-bs-interval="6000">
            <div class="carousel-inner">
                @for (var i = 0; i < Model.Count; i++)
                {
                    var item = Model[i];
                    var url = string.IsNullOrWhiteSpace(item.URL) ? "#" : item.URL;

                    <div class="carousel-item home-v2-hero__slide @(i == 0 ? "active" : "")" style="background-image:url('@item.SRC')">
                        <div class="container">
                            <div class="home-v2-hero__content">
                                <h1>@item.Title</h1>
                                <div class="home-v2-hero__actions">
                                    <a class="home-v2-btn home-v2-btn--primary" href="@url">
                                        @ctaText <i class="bi bi-arrow-right"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (Model.Count > 1)
            {
                <div class="home-v2-hero__dots carousel-indicators">
                    @for (var i = 0; i < Model.Count; i++)
                    {
                        <button type="button" data-bs-target="#homeHeroCarousel" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")" aria-label="Slide @(i + 1)"></button>
                    }
                </div>
            }
        </div>
    </section>
}
