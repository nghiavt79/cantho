@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    var shortName = Configuration["SiteBranding:ShortName"] ?? "TechExchange";
    var organizationName = Configuration["SiteBranding:OrganizationName"] ?? "TechExchange";
    var tagline = Configuration["SiteBranding:Tagline"] ?? "";
    var phone = Configuration["SiteBranding:Phone"] ?? "";
    var email = Configuration["SiteBranding:Email"] ?? "";
    var address = Configuration["SiteBranding:Address"] ?? "";
    var mapUrl = "https://www.google.com/maps/search/?api=1&query=" + Uri.EscapeDataString(address);
    var fullOrgTitle = "TRUNG TÂM ỨNG DỤNG TIẾN BỘ KH&CN TP. CẦN THƠ";
    var fullOrgSlogan = "Kết nối nghiên cứu · Ứng dụng thực tiễn · Đổi mới sáng tạo";
    var isEn = Context.Request.Cookies["site_lang"] == "en";
    string T(string vi, string en) => isEn ? en : vi;
}

<footer class="site-footer-v2">
    <div class="container">
        <div class="site-footer-v2__grid">
            <div>
                <div class="site-footer-v2__brand">
                    <img src="/image/logo-casta.webp" alt="@shortName" onerror="this.src='/image/logo.png'">
                    <span>
                        <strong>@fullOrgTitle</strong>
                        <small>@fullOrgSlogan</small>
                    </span>
                </div>
                <p>@organizationName @T("là đơn vị sự nghiệp khoa học và công nghệ, hỗ trợ kết nối nghiên cứu, ứng dụng và chuyển giao công nghệ.", "is a science & technology public service unit that connects research, application and technology transfer.")</p>
                <div class="site-footer-v2__social">
                    <a href="https://www.facebook.com/profile.php?id=100069991094645" target="_blank" rel="noopener" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                    <a href="https://www.youtube.com/@@TrungtamUngdungCanTho" target="_blank" rel="noopener" aria-label="YouTube"><i class="bi bi-youtube"></i></a>
                    <a href="https://id.zalo.me/account/login?continue=http%3A%2F%2Fzalo.me%2F02923907037" target="_blank" rel="noopener" aria-label="Zalo"><img class="site-footer-v2__zalo-icon" src="/image/zalo-icon.webp" alt=""></a>
                </div>
            </div>

            <div>
                <h3>@T("Liên kết nhanh", "Quick Links")</h3>
                <a href="/">@T("Trang chủ", "Home")</a>
                <a href="/gioi-thieu-chung-3">@T("Giới thiệu", "About")</a>
                <a href="/dich-vu-tu-van">@T("Dịch vụ & Giải pháp", "Services & Solutions")</a>
                <a href="/tin-su-kien-44">@T("Tin tức - Sự kiện", "News & Events")</a>
                <a href="/lien-he-74">@T("Liên hệ", "Contact")</a>
            </div>

            <div>
                <h3>@T("Dịch vụ", "Services")</h3>
                <a href="/cong-nghe">@T("Cung cấp công nghệ", "Technology supply")</a>
                <a href="/dang-ky-tu-van">@T("Tư vấn & chuyển giao công nghệ", "Consulting & tech transfer")</a>
                <a href="/8-ds-dich-vu-tu-van/truy-xuat-nguon-goc-29">@T("Truy xuất nguồn gốc", "Traceability")</a>
                <a href="/chuyen-gia">@T("Mạng lưới chuyên gia", "Expert network")</a>
            </div>

            <div>
                <h3>@T("Liên hệ", "Contact")</h3>
                <p><a href="@mapUrl" target="_blank" rel="noopener"><i class="bi bi-geo-alt"></i> @address</a></p>
                <p><i class="bi bi-telephone"></i> @phone</p>
                <p><i class="bi bi-envelope"></i> @email</p>
                <form class="site-footer-v2__newsletter">
                    <input type="email" placeholder="@T("Nhập email của bạn", "Enter your email")" aria-label="@T("Email nhận bản tin", "Newsletter email")">
                    <button type="submit" aria-label="@T("Đăng ký nhận bản tin", "Subscribe")"><i class="bi bi-send"></i></button>
                </form>
            </div>
        </div>

        <div class="site-footer-v2__bottom">
            <span>© @DateTime.Now.Year @shortName. All rights reserved.</span>
            <span>@tagline</span>
        </div>
    </div>
</footer>
