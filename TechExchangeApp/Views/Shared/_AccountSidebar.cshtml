@model TechExchangeApp.ViewModel.AccountSidebarVm

<div class="card shadow-sm mb-4 user-sidebar">
    <div class="card-body">
        <!-- User Panel -->
        <div class="text-center mb-4 user-sidebar-profile">
            <img src="@Model.AvatarUrl" class="rounded-circle mb-3 user-sidebar-avatar" alt="Avatar" style="width: 80px; height: 80px; object-fit: cover;">
            <div class="user-sidebar-meta">
                <h6 class="mb-1 user-sidebar-name">@Model.FullName</h6>
                <small class="text-muted">@Model.Email</small>
            </div>
        </div>

        <hr>

        <!-- Navigation Menu -->
        <nav class="nav flex-column">
            <div class="user-sidebar-section-label">Tổng quan</div>
            <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Dashboard") ? "active" : "")" href="@Url.Action("Index", "Dashboard")">
                <i class="fas fa-house me-2"></i> Tổng quan
            </a>

            <div class="user-sidebar-section-label">Giao dịch</div>
            <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Projects/MyProjects") ? "active" : "")" href="@Url.Action("MyProjects", "Projects")">
                <i class="fas fa-folder-open me-2"></i> Dự án của tôi
                @if (Model.ProjectCount > 0)
                {
                    <span class="badge bg-primary float-end">@Model.ProjectCount</span>
                }
            </a>
            @if (Model.IsSeller && Model.InvitationCount > 0)
            {
                <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Seller/InvitedProjects") ? "active" : "")" href="@Url.Action("InvitedProjects", "Seller")">
                    <i class="fas fa-envelope-open-text me-2"></i> Lời mời tham gia
                    <span class="badge bg-danger float-end">@Model.InvitationCount</span>
                </a>
            }
            <a class="nav-link @(Context.Request.Path.StartsWithSegments("/OcopOrder/Index") ? "active" : "")" href="@Url.Action("Index", "OcopOrder")">
                <i class="fas fa-shopping-cart me-2"></i> Đơn hàng OCOP của tôi
                @if (Model.OcopOrderCount > 0)
                {
                    <span class="badge bg-primary float-end">@Model.OcopOrderCount</span>
                }
            </a>
            <a class="nav-link @(Context.Request.Path.StartsWithSegments("/chat") ? "active" : "")" href="/chat">
                <i class="fas fa-comments me-2"></i> Tin nhắn
                <span id="chatUnreadBadge" class="badge bg-danger float-end" style="display:none;"></span>
            </a>

            <div class="user-sidebar-section-label">Tài khoản</div>
            <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Account/Profile") ? "active" : "")" href="@Url.Action("Profile", "Account")">
                <i class="fas fa-user me-2"></i> Hồ sơ tài khoản
            </a>
            <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Account/ChangePassword") ? "active" : "")" href="@Url.Action("ChangePassword", "Account")">
                <i class="fas fa-shield-halved me-2"></i> Bảo mật &amp; mật khẩu
            </a>

            <div class="user-sidebar-section-label">Dịch vụ của tôi</div>
            <a class="nav-link" href="/dang-ky-nha-cung-ung">
                <i class="fas fa-handshake me-2"></i> Hồ sơ nhà cung ứng
            </a>
            <a class="nav-link" href="/quan-ly-san-pham">
                <i class="fas fa-boxes-stacked me-2"></i> Công nghệ &amp; thiết bị
            </a>
            <a class="nav-link" href="/dang-ky-tu-van">
                <i class="fas fa-user-graduate me-2"></i> Hồ sơ chuyên gia
            </a>
            @if (Model.IsSeller)
            {
                <a class="nav-link @(Context.Request.Path.StartsWithSegments("/OcopOrder/Manage") ? "active" : "")" href="@Url.Action("Manage", "OcopOrder")">
                    <i class="fas fa-clipboard-list me-2"></i> Đơn OCOP khách đặt
                    @if (Model.PendingOcopOrderCount > 0)
                    {
                        <span class="badge bg-danger float-end">@Model.PendingOcopOrderCount</span>
                    }
                </a>
            }

            <hr>

            <a class="nav-link text-danger" href="#" onclick="event.preventDefault(); document.getElementById('logout-form').submit();">
                <i class="fas fa-arrow-right-from-bracket me-2"></i> Đăng xuất
            </a>
        </nav>
    </div>
</div>

<form id="logout-form" action="@Url.Action("Logout", "Account")" method="POST" style="display: none;">
    @Html.AntiForgeryToken()
</form>

<script>
    (function () {
        async function updateChatBadge() {
            try {
                const res = await fetch('/api/chat/unread-count');
                if (!res.ok) return;
                const data = await res.json();
                const badge = document.getElementById('chatUnreadBadge');
                if (badge) {
                    if (data.count > 0) {
                        badge.textContent = data.count;
                        badge.style.display = '';
                    } else {
                        badge.style.display = 'none';
                    }
                }
            } catch { }
        }
        updateChatBadge();
        setInterval(updateChatBadge, 15000);
    })();
</script>
