            <div class="carousel-inner">

                <div class="carousel-item active">
                    <div class="row g-4 align-items-center justify-content-center">
                        <div class="col-6 col-md-2">
                            <a href="#" class="partner-logo-link">
                                <img src="~/image/logo-don-vi-tu-van/Viettel.png" alt="Viettel" class="partner-logo">
                                <div class="partner-name-overlay">Viettel TP.HCM</div>
                            </a>
                        </div>
                        <div class="col-6 col-md-2">
                            <a href="#" class="partner-logo-link">
                                <img src="~/image/logo-don-vi-tu-van/VNPT.jpg" alt="VNPT" class="partner-logo">
                                <div class="partner-name-overlay">VNPT TP.HCM</div>
                            </a>
                        </div>
                        <div class="col-6 col-md-2">
                            <a href="#" class="partner-logo-link">
                                <img src="~/image/logo-don-vi-tu-van/vn pay.png" alt="VN PAY" class="partner-logo">
                                <div class="partner-name-overlay">VN PAY</div>
                            </a>
                        </div>
                        <div class="col-6 col-md-2">
