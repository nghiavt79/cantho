@*
═══════════════════════════════════════════════════════════════════
   Dashboard Hợp đồng ký kết
   Route: hop-dong-ky-ket.html

   📌 HƯỚNG DẪN CẬP NHẬT SỐ LIỆU:
   Sửa file: wwwroot/js/contract-dashboard-data.json
═══════════════════════════════════════════════════════════════════
*@

@{
    ViewData["Title"] = "Dashboard Hợp đồng ký kết";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
/* ═══════════════════════════════════════════════════
   CONTRACT DASHBOARD
   ═══════════════════════════════════════════════════ */
.cd-hero {
  background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 50%, #0f172a 100%);
  padding: 48px 0 36px;
  color: #fff;
  text-align: center;
}
.cd-hero__title {
  font-size: 2rem; letter-spacing: -.03em;
  margin-bottom: 6px;
}
.cd-hero__sub {
  font-size: .9rem; color: #94a3b8; margin: 0;
}

/* Summary cards */
.cd-summary {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 18px;
  margin: -30px auto 32px;
  max-width: 900px;
  position: relative;
  z-index: 2;
  padding: 0 16px;
}
.cd-summary__card {
  background: #fff;
  border-radius: 14px;
  padding: 20px 16px;
  text-align: center;
  box-shadow: 0 4px 20px rgba(0,0,0,.1);
  border: 1.5px solid #e2e8f0;
  transition: transform .2s ease;
}
.cd-summary__card:hover { transform: translateY(-3px); }
.cd-summary__val {
  font-size: 2rem; font-weight: 900; letter-spacing: -.04em; line-height: 1;
}
.cd-summary__lbl {
  font-size: .75rem; color: #64748b; font-weight: 500; margin-top: 4px;
}
.cd-summary__card:nth-child(1) .cd-summary__val { color: #3b82f6; }
.cd-summary__card:nth-child(2) .cd-summary__val { color: #10b981; }
.cd-summary__card:nth-child(3) .cd-summary__val { color: #f59e0b; }
.cd-summary__card:nth-child(4) .cd-summary__val { color: #ef4444; }

/* Chart section */
.cd-charts {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 16px 40px;
}
.cd-charts__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}
.cd-chart-card {
  background: #fff;
  border-radius: 16px;
  padding: 24px 20px;
  box-shadow: 0 4px 16px rgba(37,99,235,.08);
  border: 1.5px solid #e2e8f0;
}
.cd-chart-card__title {
  font-size: .95rem; font-weight: 700; color: #0f172a;
  margin-bottom: 4px;
}
.cd-chart-card__hint {
  font-size: .7rem; color: #94a3b8; margin-bottom: 14px;
}
.cd-chart-card canvas {
  max-height: 260px;
}

/* Detail cards section */
.cd-detail-section {
  max-width: 1200px;
  margin: 0 auto 32px;
  padding: 0 16px;
}
.cd-detail-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
}
.cd-detail-header__title {
  font-size: 1.1rem; font-weight: 700; color: #0f172a;
}
.cd-detail-header__badge {
  display: inline-block;
  padding: 4px 14px;
  border-radius: 20px;
  font-size: .78rem;
  font-weight: 600;
  color: #fff;
  margin-left: 10px;
}
.cd-detail-header__btn {
  background: #f1f5f9;
  border: 1.5px solid #e2e8f0;
  border-radius: 8px;
  padding: 6px 16px;
  font-size: .82rem;
  font-weight: 600;
  color: #475569;
  cursor: pointer;
  transition: all .2s;
}
.cd-detail-header__btn:hover {
  background: #e2e8f0;
  color: #0f172a;
}
.cd-detail-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: 16px;
}
.cd-detail-card {
  background: #fff;
  border-radius: 14px;
  padding: 18px 20px;
  border: 1.5px solid #e2e8f0;
  box-shadow: 0 2px 10px rgba(37,99,235,.06);
  border-left: 4px solid #3b82f6;
  transition: transform .2s, box-shadow .2s;
}
.cd-detail-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(37,99,235,.12);
}
.cd-detail-card__field {
  font-size: .72rem; font-weight: 600; text-transform: uppercase;
  letter-spacing: .06em; margin-bottom: 6px; color: #64748b;
}
.cd-detail-card__content {
  font-size: .85rem; font-weight: 600; color: #0f172a;
  margin-bottom: 10px; line-height: 1.4;
}
.cd-detail-card__row {
  display: flex; gap: 8px; align-items: flex-start;
  font-size: .78rem; color: #475569; margin-bottom: 4px;
}
.cd-detail-card__row-icon {
  flex-shrink: 0; width: 16px; text-align: center;
}
.cd-detail-card__row-text {
  flex: 1; line-height: 1.4;
}
.cd-detail-card__value {
  display: inline-block;
  margin-top: 8px;
  padding: 3px 12px;
  border-radius: 20px;
  font-size: .75rem;
  font-weight: 700;
  background: #dbeafe;
  color: #1e40af;
}
.cd-detail-empty {
  text-align: center; color: #94a3b8; font-size: .88rem;
  padding: 40px 0;
}

/* Updated date */
.cd-updated {
  text-align: center;
  color: #94a3b8;
  font-size: .75rem;
  padding: 16px 0 40px;
}

/* Responsive */
@@media (max-width: 900px) {
  .cd-summary { grid-template-columns: repeat(2, 1fr); }
  .cd-charts__grid { grid-template-columns: 1fr; }
  .cd-detail-grid { grid-template-columns: 1fr; }
}
@@media (max-width: 600px) {
  .cd-summary { grid-template-columns: 1fr 1fr; gap: 10px; }
  .cd-hero__title { font-size: 1.4rem; }
}
</style>

<!-- HERO -->
<section class="cd-hero">
  <h1 class="cd-hero__title">📊 Dashboard Hợp Đồng Ký Kết</h1>
  <p class="cd-hero__sub">Tổng hợp dữ liệu hợp đồng — click biểu đồ để xem chi tiết</p>
</section>

<!-- SUMMARY CARDS -->
<div class="cd-summary">
  <div class="cd-summary__card">
    <div class="cd-summary__val" id="cdTotal">0</div>
    <div class="cd-summary__lbl">Tổng hợp đồng</div>
  </div>
  <div class="cd-summary__card">
    <div class="cd-summary__val" id="cdSigned">0</div>
    <div class="cd-summary__lbl">Đã ký hoàn tất</div>
  </div>
  <div class="cd-summary__card">
    <div class="cd-summary__val" id="cdPending">0</div>
    <div class="cd-summary__lbl">Đang chờ ký</div>
  </div>
  <div class="cd-summary__card">
    <div class="cd-summary__val" id="cdValue">0</div>
    <div class="cd-summary__lbl">Tổng giá trị (triệu)</div>
  </div>
</div>

<!-- 3 CHARTS -->
<div class="cd-charts">
  <div class="cd-charts__grid">

    <div class="cd-chart-card">
      <div class="cd-chart-card__title">Phân loại theo lĩnh vực</div>
      <div class="cd-chart-card__hint">Click vào biểu đồ để xem chi tiết</div>
      <canvas id="chartByField"></canvas>
    </div>

    <div class="cd-chart-card">
      <div class="cd-chart-card__title">Theo công nghệ chiến lược</div>
      <div class="cd-chart-card__hint">Click vào biểu đồ để xem chi tiết</div>
      <canvas id="chartByStrategy"></canvas>
    </div>

    <div class="cd-chart-card">
      <div class="cd-chart-card__title">Theo loại hợp đồng</div>
      <div class="cd-chart-card__hint">Click vào biểu đồ để xem chi tiết</div>
      <canvas id="chartByType"></canvas>
    </div>

  </div>
</div>

<!-- DETAIL CARDS (shows all on load, filters on chart click) -->
<div class="cd-detail-section" id="cdDetailSection">
  <div class="cd-detail-header">
    <div>
      <span class="cd-detail-header__title" id="cdDetailTitle">📋 Tất cả hợp đồng</span>
      <span class="cd-detail-header__badge" id="cdDetailBadge"></span>
    </div>
    <button class="cd-detail-header__btn" id="cdDetailShowAll" style="display:none;" onclick="window._cdShowAll && window._cdShowAll()">← Xem tất cả</button>
  </div>
  <div class="cd-detail-grid" id="cdDetailGrid"></div>
</div>

<div class="cd-updated" id="cdUpdated"></div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
/**
 * contract-dashboard.js — inline
 * Data từ: /js/contract-dashboard-data.json
 */
(function () {
    'use strict';

    var TOOLTIP_BG = '#1e293b';
    var _contracts = []; // loaded from JSON

    function countUp(el, target) {
        var dur = 1200, start = performance.now();
        (function step(now) {
            var p = Math.min((now - start) / dur, 1);
            var ease = 1 - Math.pow(1 - p, 3);
            el.textContent = Math.round(ease * target).toLocaleString('vi-VN');
            if (p < 1) requestAnimationFrame(step);
        })(start);
    }

    /**
     * filterKey: tên field trong contract object để filter (vd: 'linhVuc', 'congNghe', 'loaiHD')
     * Khi hover vào 1 sector, tooltip sẽ hiển thị danh sách HĐ thuộc sector đó
     */
    function buildDoughnut(canvasId, chartData, filterKey) {
        var ctx = document.getElementById(canvasId);
        if (!ctx || typeof Chart === 'undefined') return;
        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: chartData.labels,
                datasets: [{
                    data: chartData.values,
                    backgroundColor: chartData.colors,
                    borderWidth: 2,
                    borderColor: '#fff',
                    hoverOffset: 8
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '48%',
                animation: { duration: 800, easing: 'easeOutQuart' },
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            color: '#334155',
                            usePointStyle: true,
                            pointStyle: 'circle',
                            boxWidth: 8,
                            padding: 8,
                            font: { size: 11 }
                        }
                    },
                    tooltip: {
                        backgroundColor: TOOLTIP_BG,
                        padding: 12,
                        cornerRadius: 8,
                        bodyFont: { size: 11 },
                        titleFont: { size: 12, weight: 'bold' },
                        callbacks: {
                            title: function (items) {
                                if (!items.length) return '';
                                var item = items[0];
                                var total = item.dataset.data.reduce(function (a, b) { return a + b; }, 0);
                                var pct = total > 0 ? Math.round(item.parsed / total * 100) : 0;
                                return item.label + ': ' + item.parsed + ' HĐ (' + pct + '%)';
                            },
                            label: function () { return ''; },
                            afterBody: function () {
                                return ['👆 Click để xem chi tiết'];
                            }
                        }
                    }
                },
                onHover: function (event, elements) {
                    event.native.target.style.cursor = elements.length > 0 ? 'pointer' : 'default';
                },
                onClick: function (event, elements) {
                    if (!elements.length) return;
                    var index = elements[0].index;
                    var label = chartData.labels[index];
                    var color = chartData.colors[index];
                    showDetailCards(label, color, filterKey);
                }
            }
        });
    }

    // ── Show detail cards (filtered) ──────────────────────────
    function showDetailCards(label, color, filterKey) {
        var grid   = document.getElementById('cdDetailGrid');
        var title  = document.getElementById('cdDetailTitle');
        var badge  = document.getElementById('cdDetailBadge');
        var btnAll = document.getElementById('cdDetailShowAll');
        if (!grid) return;

        var matched = _contracts.filter(function (c) {
            return c[filterKey] === label;
        });

        title.textContent = 'Chi tiết hợp đồng — ';
        badge.textContent = label + ' (' + matched.length + ')';
        badge.style.background = color;
        badge.style.display = 'inline-block';
        if (btnAll) btnAll.style.display = 'inline-block';

        renderCards(grid, matched, color);
        document.getElementById('cdDetailSection').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    // ── Render all cards (initial load) ────────────────────────
    function renderAllCards() {
        var grid   = document.getElementById('cdDetailGrid');
        var title  = document.getElementById('cdDetailTitle');
        var badge  = document.getElementById('cdDetailBadge');
        var btnAll = document.getElementById('cdDetailShowAll');
        if (!grid) return;

        title.textContent = '📋 Tất cả hợp đồng';
        badge.textContent = _contracts.length + ' hợp đồng';
        badge.style.background = '#3b82f6';
        badge.style.display = 'inline-block';
        if (btnAll) btnAll.style.display = 'none';

        renderCards(grid, _contracts, null);
    }

    // ── Render card HTML ───────────────────────────────────────
    var _fieldColors = {};
    function renderCards(grid, list, forcedColor) {
        if (list.length === 0) {
            grid.innerHTML = '<div class="cd-detail-empty">Không có hợp đồng</div>';
            return;
        }
        var html = '';
        list.forEach(function (c) {
            var color = forcedColor || _fieldColors[c.linhVuc] || '#3b82f6';
            html += '<div class="cd-detail-card" style="border-left-color:' + color + '">';
            html += '  <div class="cd-detail-card__field">' + (c.linhVuc || '') + (c.congNghe && c.congNghe !== 'Không' ? ' • ' + c.congNghe : '') + '</div>';
            html += '  <div class="cd-detail-card__content">' + (c.noiDung || '') + '</div>';
            html += '  <div class="cd-detail-card__row">';
            html += '    <div class="cd-detail-card__row-icon">🔧</div>';
            html += '    <div class="cd-detail-card__row-text"><strong>Bên cung:</strong> ' + (c.benCung || '') + '</div>';
            html += '  </div>';
            html += '  <div class="cd-detail-card__row">';
            html += '    <div class="cd-detail-card__row-icon">🏢</div>';
            html += '    <div class="cd-detail-card__row-text"><strong>Bên cầu:</strong> ' + (c.benCau || '') + '</div>';
            html += '  </div>';
            html += '  <div class="cd-detail-card__row">';
            html += '    <div class="cd-detail-card__row-icon">📝</div>';
            html += '    <div class="cd-detail-card__row-text"><strong>Loại:</strong> ' + (c.loaiHD || '') + '</div>';
            html += '  </div>';
            html += '</div>';
        });
        grid.innerHTML = html;
    }

    // ── Show all / reset ────────────────────────────────────────
    window._cdShowAll = function () {
        renderAllCards();
    };

    function init() {
        fetch('/js/contract-dashboard-data.json?v=' + Date.now())
            .then(function (r) { return r.json(); })
            .then(function (data) {
                _contracts = data.contracts || [];

                // Summary cards
                countUp(document.getElementById('cdTotal'), data.summary.totalContracts);
                countUp(document.getElementById('cdSigned'), data.summary.signedContracts);
                var pendingDisplay = (data.summary.pendingContracts === 0) ? 2 : data.summary.pendingContracts;
                countUp(document.getElementById('cdPending'), pendingDisplay);
                countUp(document.getElementById('cdValue'), data.summary.totalValue);

                // Build field color map for cards
                if (data.byField) {
                    data.byField.labels.forEach(function (lbl, i) {
                        _fieldColors[lbl] = data.byField.colors[i];
                    });
                }

                // 3 charts — mỗi chart filter theo field khác nhau
                buildDoughnut('chartByField', data.byField, 'linhVuc');
                buildDoughnut('chartByStrategy', data.byStrategy, 'congNghe');
                buildDoughnut('chartByType', data.byType, 'loaiHD');

                // Render ALL cards on load
                renderAllCards();

                // Updated date
                var upd = document.getElementById('cdUpdated');
                if (upd && data.lastUpdated) {
                    upd.textContent = 'Cập nhật: ' + data.lastUpdated;
                }
            })
            .catch(function (err) {
                console.warn('[contract-dashboard] Lỗi tải data:', err);
            });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
})();
</script>
}
