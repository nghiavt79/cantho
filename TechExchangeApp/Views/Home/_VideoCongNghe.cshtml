@model List<TechExchangeApp.ViewModel.VideoVm>

@{
    var list      = Model ?? new List<TechExchangeApp.ViewModel.VideoVm>();
    int perSlide  = 3;
    int slideIndex = 0;
}

<div id="carouselVideoCongNghe"
     class="carousel slide TechCarousel"
     data-bs-ride="carousel"
     data-bs-interval="4000">

    <div class="carousel-inner">

        @if (list.Any())
        {
            for (int i = 0; i < list.Count; i += perSlide)
            {
                slideIndex++;
                var group = list.Skip(i).Take(perSlide);

                <div class="carousel-item @(slideIndex == 1 ? "active" : "")">
                    <div class="row justify-content-center g-4">
                        @foreach (var video in group)
                        {
                            <div class="col-md-4 col-12">
                                <div class="tech-card">
                                    <div class="ratio ratio-16x9">
                                        @if (!string.IsNullOrEmpty(video.VideoUrl))
                                        {
                                            <iframe src="@video.VideoUrl"
                                                    title="@video.Title"
                                                    frameborder="0"
                                                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                                                    allowfullscreen></iframe>
                                        }
                                        else
                                        {
                                            <a href="@video.Link">
                                                <img src="@video.ImageUrl"
                                                     class="w-100"
                                                     style="object-fit:cover; height:100%;"
                                                     alt="@video.Title" />
                                            </a>
                                        }
                                    </div>
                                    <div class="tech-card-body">
                                        <div class="tech-card-title">
                                            <a href="@video.Link" class="text-decoration-none text-dark">@video.Title</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="carousel-item active">
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-camera-video fs-2 d-block mb-2"></i>
                    Đang cập nhật video công nghệ...
                </div>
            </div>
        }

    </div>

    <button class="carousel-control-prev" type="button"
            data-bs-target="#carouselVideoCongNghe" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>
    <button class="carousel-control-next" type="button"
            data-bs-target="#carouselVideoCongNghe" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>
</div>

<div class="tech-section-more">
    <a href="@($"{Html.MainDomain()}video")" class="btn-tech-more">
        Xem thêm »
    </a>
</div>

