@model TechExchangeApp.ViewModel.YeuCauCongNgheVm

<section class="yc-section">
    <div class="container">

        <!-- TITLE -->
        <h2 class="hp-section-title">
            <a href="yeu-cau-cong-nghe-67.html" class="text-decoration-none text-dark">
                @Model.Title
            </a>
        </h2>

        <div class="row g-4">

            <!-- COL 1 -->
            @foreach (var item in Model.Col1)
            {
                <div class="col-lg-4 col-md-6">
                    <a href="@item.Link" class="text-decoration-none d-block">
                        <div class="yc-card">
                            <!-- IMAGE -->
                            <img src="@item.ImageUrl"
                                 alt="@item.Title"
                                 onerror="this.src='/image/yeucaucongnghe.jpg'">

                            <!-- INFO -->
                            <div class="yc-content">
                                @*<div class="yc-meta">
                                    <span><i class="bi bi-eye"></i> @item.Viewed</span>
                                    <span><i class="bi bi-star"></i> 4.9/5</span>
                                </div>*@

                                <div class="yc-name">@item.Title</div>
                            </div>
                        </div>
                    </a>
                </div>
            }

            <!-- COL 2 -->
            @foreach (var item in Model.Col2)
            {
                <div class="col-lg-4 col-md-6">
                    <a href="@item.Link" class="text-decoration-none d-block">
                        <div class="yc-card">
                            <img src="@item.ImageUrl"
                                 alt="@item.Title"
                                 onerror="this.src='/image/yeucaucongnghe.jpg'">

                            <div class="yc-content">
                                @*<div class="yc-meta">
                                    <span><i class="bi bi-eye"></i> @item.Viewed</span>
                                    <span><i class="bi bi-star"></i> 4.9/5</span>
                                </div>*@

                                <div class="yc-name">@item.Title</div>
                            </div>
                        </div>
                    </a>
                </div>
            }

        </div><!-- /row g-4 -->

        <div class="tech-section-more">
            <a href="yeu-cau-cong-nghe-67.html" class="btn-tech-more">Xem thêm »</a>
        </div>

    </div><!-- /container -->
</section><!-- /yc-section -->

