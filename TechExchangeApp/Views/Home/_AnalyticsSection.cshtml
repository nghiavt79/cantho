<style>
/* ═══════════════════════════════════════════════════════════════
   HOME ENTERPRISE ANALYTICS — with Tabs + 5 Stat Boxes
   ═══════════════════════════════════════════════════════════════ */
.tp-metrics { padding: 0 !important; }

.tp-metrics__grid {
  display: grid;
  gap: 28px;
  grid-template-columns: 1fr 1fr;    /* 2 cột bằng nhau */
  align-items: stretch;              /* Cả 2 cột cùng cao */
}
/* Cả 2 panel đều co giãn đều */
.tp-kpi, .tp-analytics {
  display: flex;
  flex-direction: column;
}

/* ─── Shared typography ──────────────────────────────────── */
.tp-overline {
  font-size: .68rem; letter-spacing: .14em; text-transform: uppercase;
  color: #3b82f6; font-weight: 700; display: block; margin-bottom: 6px;
}
.tp-title { margin: 0 0 6px; font-size: 1.65rem; font-weight: 800; color: #0f172a; letter-spacing: -.03em; }
.tp-sub   { margin: 0 0 22px; color: #64748b; font-size: .88rem; line-height: 1.6; }

/* ─── KPI Tab Buttons ────────────────────────────────────── */
.tp-kpi-tabs {
  display: flex;
  gap: 6px;
  border-bottom: 2px solid #e5e7eb;
  padding: 0;
  list-style: none;
}
.tp-kpi-tabs .nav-link {
  font-size: .82rem;
  font-weight: 700;
  color: #64748b;
  padding: 8px 18px;
  border: none;
  border-bottom: 3px solid transparent;
  border-radius: 0;
  background: transparent;
  transition: color .2s, border-color .2s;
  position: relative;
  bottom: -2px;
  cursor: pointer;
}
.tp-kpi-tabs .nav-link:hover {
  color: #2563eb;
  border-bottom-color: #93c5fd;
}
.tp-kpi-tabs .nav-link.active {
  color: #2563eb;
  border-bottom: 3px solid #2563eb;
  background: transparent;
}

/* ─── KPI cards 4×2 ──────────────────────────────────────── */
.tp-kpi__cards {
  display: grid; gap: 12px;
  grid-template-columns: 1fr 1fr;
  margin-bottom: 16px;
}
.tp-card {
  position: relative;
  border: 1px solid #e5e7eb;
  border-radius: 16px;
  padding: 14px;
  background: #fff;
  box-shadow: 0 8px 22px rgba(15,23,42,.05);
  transition: transform .2s ease, box-shadow .2s ease;
  min-height: 100px;
  overflow: hidden;
}
.tp-card a { text-decoration: none; color: inherit; display: block; }
.tp-card:hover { transform: translateY(-3px); box-shadow: 0 14px 32px rgba(15,23,42,.09); }
.tp-card__icon {
  width: 36px; height: 36px; border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
}
.tp-card__icon svg { width: 17px; height: 17px; }

.i-blue   { background: rgba(59,130,246,.12);  color: #2563eb; }
.i-cyan   { background: rgba(6,182,212,.12);   color: #0891b2; }
.i-green  { background: rgba(16,185,129,.12);  color: #059669; }
.i-amber  { background: rgba(245,158,11,.12);  color: #d97706; }
.i-purple { background: rgba(139,92,246,.12);  color: #7c3aed; }
.i-rose   { background: rgba(244,63,94,.12);   color: #e11d48; }
.i-indigo { background: rgba(99,102,241,.12);  color: #4f46e5; }
.i-teal   { background: rgba(20,184,166,.12);  color: #0d9488; }

.tp-card__meta  { margin-top: 9px; }
.tp-card__value { font-size: 1.75rem; font-weight: 900; color: #0f172a; letter-spacing: -.04em; font-variant-numeric: tabular-nums; line-height: 1; }
.tp-card__label { color: #475569; font-size: .71rem; margin-top: 3px; font-weight: 500; }

.tp-updated {
  display: inline-flex; align-items: center; gap: 4px;
  font-size: .68rem; color: #94a3b8;
}

