@model TechExchangeApp.ViewModel.HomeViewModel

@{
    ViewData["Title"] = "Trang chủ";
    var branding = Model.Branding;
    var isEn = Model.IsEnglish;
    string T(string vi, string en) => isEn ? en : vi;

    string StatTarget(string value) => new string((value ?? "").Where(char.IsDigit).ToArray());
    string StatSuffix(string value) => (value ?? "").Contains('+') ? "+" : "";
}

<div class="home-v2">
    @await Component.InvokeAsync("HeroBanner")

    <section class="home-v2-search-wrap home-v2-search-wrap--overlap">
        <div class="container">
            <div class="home-v2-search-panel">
                <div class="home-v2-search-tabs" role="tablist" aria-label="@T("Nhóm tìm kiếm", "Search groups")">
                    <button class="active" type="button" data-search-type="Technology">@T("Công nghệ", "Technology")</button>
                    <button type="button" data-search-type="Equipment">@T("Thiết bị", "Equipment")</button>
                    <button type="button" data-search-type="Expert">@T("Chuyên gia", "Experts")</button>
                    <button type="button" data-search-type="Service">@T("Dịch vụ", "Services")</button>
                    <button type="button" data-search-type="Demand">@T("Nhu cầu công nghệ", "Technology needs")</button>
                </div>
                <form class="home-v2-search-form" action="/Search" method="get">
                    <input type="hidden" name="type" value="Technology" id="homeSearchType">
                    <input type="text" name="q" placeholder="@T("Nhập từ khóa: công nghệ, thiết bị, chuyên gia, dịch vụ...", "Enter a keyword: technology, equipment, expert, service...")" aria-label="@T("Từ khóa tìm kiếm", "Search keyword")">
                    <select name="field" aria-label="@T("Lĩnh vực", "Field")">
                        <option value="">@T("Tất cả lĩnh vực", "All fields")</option>
                        @foreach (var fieldOption in Model.SearchFields)
                        {
                            <option value="@fieldOption.Value">@fieldOption.Label</option>
                        }
                    </select>
                    <button type="submit">
                        <i class="bi bi-search"></i> @T("Tìm kiếm", "Search")
                    </button>
                </form>
                <div class="home-v2-tags">
                    <span>@T("Tìm kiếm phổ biến:", "Popular searches:")</span>
                    @foreach (var tag in Model.PopularTags)
                    {
                        <a href="/Search?q=@Uri.EscapeDataString(tag)&type=Technology">@tag</a>
                    }
                </div>
            </div>
        </div>
    </section>

    <section class="container home-v2-section home-v2-section--first">
        <div class="home-v2-section-head">
            <h2>@T("Sản phẩm & Công nghệ nổi bật", "Featured Products & Technologies")</h2>
            <a href="/cong-nghe">@T("Xem tất cả", "View all") <i class="bi bi-arrow-right"></i></a>
        </div>
        <div class="home-v2-carousel-wrap" data-carousel-per-page="4">
            <button type="button" class="home-v2-carousel-nav home-v2-carousel-nav--prev" data-carousel-prev aria-label="@T("Trang trước", "Previous page")">
                <i class="bi bi-chevron-left"></i>
            </button>
            <div class="home-v2-carousel" data-carousel>
                @foreach (var item in Model.FeaturedTechnologies)
                {
                    <a class="home-v2-carousel-card" href="@item.Url">
                        <div class="home-v2-carousel-card__image">
                            @if (!string.IsNullOrEmpty(item.Badge))
                            {
                                <span class="home-v2-carousel-card__badge home-v2-carousel-card__badge--@item.BadgeType">@item.Badge</span>
                            }
                            <img src="@item.ImageUrl" alt="@item.Title" onerror="this.src='/images/254-170_noImage.jpg'">
                        </div>
                        <div class="home-v2-carousel-card__body">
                            <strong>@item.Title</strong>
                            <span class="home-v2-carousel-card__meta"><i class="bi bi-tools"></i> @item.Category</span>
                            @if (!string.IsNullOrEmpty(item.Company))
                            {
                                <span class="home-v2-carousel-card__meta"><i class="bi bi-building"></i> @item.Company</span>
                            }
                            <span class="home-v2-carousel-card__btn">@T("Xem chi tiết", "View details")</span>
                        </div>
                    </a>
                }
            </div>
            <button type="button" class="home-v2-carousel-nav home-v2-carousel-nav--next" data-carousel-next aria-label="@T("Trang sau", "Next page")">
                <i class="bi bi-chevron-right"></i>
            </button>
        </div>
        <div class="home-v2-carousel-dots" data-carousel-dots></div>
    </section>

    <section class="home-v2-stats-wrap" aria-label="@T("Thống kê", "Statistics")">
        <div class="container">
            <div class="home-v2-stats">
                @foreach (var stat in Model.Stats)
                {
                    <div class="home-v2-stat">
                        <i class="bi @stat.Icon"></i>
                        <div>
                            <strong class="js-home-stat-number"
                                    data-count-target="@StatTarget(stat.Value)"
                                    data-count-suffix="@StatSuffix(stat.Value)">@stat.Value</strong>
                            <span>@stat.Label</span>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>

    <section class="container home-v2-band">
        <div class="home-v2-grid home-v2-grid--intro">
            <div class="home-v2-card home-v2-card--wide">
                <h2>@T("Chúng tôi làm gì?", "What we do")</h2>
                <div class="home-v2-feature-grid">
                    @foreach (var item in Model.WhatWeDo)
                    {
                        <a class="home-v2-feature" href="@item.Url">
                            <i class="bi @item.Icon"></i>
                            <span>@item.Title</span>
                        </a>
                    }
                </div>
            </div>

            <div class="home-v2-card">
                <h2>@T("Dịch vụ nổi bật", "Featured services")</h2>
                <div class="home-v2-service-list">
                    @foreach (var item in Model.Services)
                    {
                        <a class="home-v2-service" href="@item.Url">
                            <i class="bi @item.Icon"></i>
                            <span>
                                <strong>@item.Title</strong>
                                <small>@item.Description</small>
                            </span>
                        </a>
                    }
                </div>
            </div>

            <div class="home-v2-card">
                <h2>@T($"Vì sao chọn {branding.ShortName}?", $"Why choose {branding.ShortName}?")</h2>
                <div class="home-v2-reason-list">
                    @foreach (var item in Model.Reasons)
                    {
                        <div class="home-v2-reason">
                            <i class="bi @item.Icon"></i>
                            <span>@item.Title</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>

    <section class="container home-v2-section">
        <div class="home-v2-process">
            <h2>@T("Quy trình hỗ trợ", "Support process")</h2>
            <div class="home-v2-process__row">
                @foreach (var step in Model.ProcessSteps)
                {
                    <div class="home-v2-process-step">
                        <div class="home-v2-process-step__icon">
                            <span>@step.Number</span>
                            <i class="bi @step.Icon"></i>
                        </div>
                        <strong>@step.Title</strong>
                        <p>@step.Description</p>
                    </div>
                }
            </div>
        </div>
    </section>

    <section class="container home-v2-section">
        <div class="home-v2-grid home-v2-grid--news">
            <div class="home-v2-card">
                <div class="home-v2-section-head home-v2-section-head--compact">
                    <h2>@T("Tin tức - Sự kiện", "News & Events")</h2>
                    <a href="/tin-su-kien-44">@T("Xem tất cả", "View all") <i class="bi bi-arrow-right"></i></a>
                </div>
                <div class="home-v2-news-list">
                    @foreach (var item in Model.FeaturedNews)
                    {
                        <a class="home-v2-news-card" href="@item.Url">
                            <img src="@item.ImageUrl" alt="@item.Title" onerror="this.src='/images/254-170_noImage.jpg'">
                            <span>@(item.PublishedDate?.ToString("dd/MM/yyyy") ?? T("Đang cập nhật", "Updating"))</span>
                            <strong>@item.Title</strong>
                            <p>@item.Description</p>
                        </a>
                    }
                </div>
            </div>

            <div class="home-v2-card">
                <div class="home-v2-section-head home-v2-section-head--compact">
                    <h2>@T("Chuyên gia của chúng tôi", "Our experts")</h2>
                    <a href="/chuyen-gia">@T("Xem tất cả", "View all") <i class="bi bi-arrow-right"></i></a>
                </div>
                <div class="home-v2-expert-list">
                    @foreach (var item in Model.Experts)
                    {
                        <a class="home-v2-expert-card" href="@item.Url">
                            <img src="@item.ImageUrl" alt="@item.Name" onerror="this.src='/images/NoImages.jpg'">
                            <strong>@item.Name</strong>
                            <span>@item.Title</span>
                            <p>@item.Field</p>
                        </a>
                    }
                </div>
            </div>
        </div>
    </section>

    @if (Model.Customers.Any())
    {
        <section class="container home-v2-section">
            <div class="home-v2-partners">
                <h2>@T("Khách hàng tiêu biểu", "Featured customers")</h2>
                <div class="home-v2-partner-row">
                    @foreach (var customer in Model.Customers)
                    {
                        <div class="home-v2-partner @(!string.IsNullOrEmpty(customer.LogoUrl) ? "home-v2-partner--logo" : "")">
                            @if (!string.IsNullOrEmpty(customer.LogoUrl))
                            {
                                <img src="@customer.LogoUrl" alt="@customer.Name">
                            }
                            <span class="home-v2-partner-name">@customer.Name</span>
                        </div>
                    }
                </div>
            </div>
        </section>
    }

    <section class="container home-v2-section">
        <div class="home-v2-partners">
            <h2>@T("Đối tác đồng hành", "Partners")</h2>
            <div class="home-v2-partner-row">
                @foreach (var partner in Model.Partners)
                {
                    <div class="home-v2-partner @(!string.IsNullOrEmpty(partner.LogoUrl) ? "home-v2-partner--logo" : "")">
                        @if (!string.IsNullOrEmpty(partner.LogoUrl))
                        {
                            <img src="@partner.LogoUrl" alt="@partner.Name">
                        }
                        <span class="home-v2-partner-name">@partner.Name</span>
                    </div>
                }
            </div>
        </div>
    </section>

    <section class="home-v2-cta-wrap">
        <div class="container">
            <div class="home-v2-cta">
                <div>
                    <h2>@T("Bạn cần tư vấn giải pháp công nghệ phù hợp?", "Need advice on the right technology solution?")</h2>
                    <p>@T($"Đội ngũ chuyên gia của {branding.ShortName} luôn sẵn sàng đồng hành cùng bạn.", $"The {branding.ShortName} expert team is always ready to accompany you.")</p>
                </div>
                <a class="home-v2-btn home-v2-btn--light" href="/dang-ky-tu-van">
                    @T("Đăng ký tư vấn ngay", "Request consulting now") <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script>
        (function () {
            document.querySelectorAll('.home-v2-carousel-wrap').forEach(function (wrap) {
                var track = wrap.querySelector('[data-carousel]');
                var prev = wrap.querySelector('[data-carousel-prev]');
                var next = wrap.querySelector('[data-carousel-next]');
                var dotsWrap = wrap.parentElement.querySelector('[data-carousel-dots]');
                var cards = track ? Array.from(track.children) : [];
                if (!track || !cards.length) return;

                var perPage = parseInt(wrap.dataset.carouselPerPage, 10) || 4;

                function cardStep() {
                    var styles = window.getComputedStyle(track);
                    var gap = parseFloat(styles.columnGap || styles.gap || 0) || 0;
                    return cards[0].getBoundingClientRect().width + gap;
                }

                function pageCount() {
                    return Math.max(1, Math.ceil(cards.length / perPage));
                }

                function currentPage() {
                    var step = cardStep() * perPage;
                    return step ? Math.round(track.scrollLeft / step) : 0;
                }

                function buildDots() {
                    if (!dotsWrap) return;
                    dotsWrap.innerHTML = '';
                    var total = pageCount();
                    if (total <= 1) return;
                    for (var i = 0; i < total; i++) {
                        var dot = document.createElement('button');
                        dot.type = 'button';
                        dot.className = 'home-v2-carousel-dot';
                        dot.setAttribute('aria-label', 'Trang ' + (i + 1));
                        (function (page) {
                            dot.addEventListener('click', function () {
                                track.scrollTo({ left: cardStep() * perPage * page, behavior: 'smooth' });
                            });
                        })(i);
                        dotsWrap.appendChild(dot);
                    }
                    updateState();
                }

                function updateState() {
                    var maxScroll = track.scrollWidth - track.clientWidth - 2;
                    if (prev) prev.disabled = track.scrollLeft <= 2;
                    if (next) next.disabled = track.scrollLeft >= maxScroll;
                    if (dotsWrap) {
                        var page = currentPage();
                        Array.from(dotsWrap.children).forEach(function (dot, i) {
                            dot.classList.toggle('is-active', i === page);
                        });
                    }
                }

                prev?.addEventListener('click', function () {
                    track.scrollBy({ left: -cardStep() * perPage, behavior: 'smooth' });
                });

                next?.addEventListener('click', function () {
                    track.scrollBy({ left: cardStep() * perPage, behavior: 'smooth' });
                });

                track.addEventListener('scroll', function () {
                    window.requestAnimationFrame(updateState);
                }, { passive: true });
                window.addEventListener('resize', function () {
                    buildDots();
                });

                buildDots();
            });
        })();

        document.querySelectorAll('.home-v2-search-tabs button').forEach(function (button) {
            button.addEventListener('click', function () {
                document.querySelectorAll('.home-v2-search-tabs button').forEach(function (item) {
                    item.classList.remove('active');
                });
                button.classList.add('active');
                document.getElementById('homeSearchType').value = button.dataset.searchType || 'Technology';
            });
        });

        (function () {
            var statWrap = document.querySelector('.home-v2-stats-wrap');
            var statNumbers = document.querySelectorAll('.js-home-stat-number[data-count-target]');
            if (!statWrap || !statNumbers.length) return;

            function easeOutCubic(t) {
                return 1 - Math.pow(1 - t, 3);
            }

            function formatNumber(value) {
                return Math.round(value).toLocaleString('vi-VN');
            }

            function animateNumber(el) {
                var target = parseInt(el.dataset.countTarget, 10);
                if (Number.isNaN(target)) return;

                var suffix = el.dataset.countSuffix || '';
                var duration = 1400;
                var start = performance.now();

                function step(now) {
                    var progress = Math.min((now - start) / duration, 1);
                    el.textContent = formatNumber(easeOutCubic(progress) * target) + suffix;
                    if (progress < 1) requestAnimationFrame(step);
                }

                el.textContent = '0' + suffix;
                requestAnimationFrame(step);
            }

            function runStatsAnimation() {
                if (statWrap.dataset.animated === 'true') return;
                statWrap.dataset.animated = 'true';
                statNumbers.forEach(animateNumber);
            }

            if (!('IntersectionObserver' in window)) {
                runStatsAnimation();
                return;
            }

            var observer = new IntersectionObserver(function (entries) {
                entries.forEach(function (entry) {
                    if (entry.isIntersecting) {
                        runStatsAnimation();
                        observer.disconnect();
                    }
                });
            }, { threshold: 0.35 });

            observer.observe(statWrap);
        })();
    </script>
}
