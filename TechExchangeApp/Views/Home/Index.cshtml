@{
    ViewData["Title"] = "Home Page";
}

@model TechExchangeApp.ViewModel.HomeViewModel

<div class="home-page-container">
    @await Html.PartialAsync("_TopBigBanner")
    @await Html.PartialAsync("_MainIcon")

    @* ── Enterprise Analytics Section ── *@
    @await Html.PartialAsync("_AnalyticsSection")

    <div class="container">
        <h3 class="hp-section-title">Công nghệ nổi bật</h3>
        <ul class="nav tech-tabs mb-0" role="tablist">
            <li class="nav-item">
                <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#cnmcn" type="button">
                    Công nghệ mới cập nhật
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#vdcn" type="button">
                    Video công nghệ
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#gpcn" type="button">
                    Trên tay công nghệ
                </button>
            </li>
        </ul>

        <div class="tab-content pt-4">
            <div class="tab-pane fade show active" id="cnmcn">
                @await Html.PartialAsync(
                "_CongNgheMoiCapNhat",
                            (IEnumerable<TechExchangeApp.Entities.SanPhamCNTB>)ViewBag.NewTech
                            )
            </div>

            <div class="tab-pane fade" id="vdcn">
                @await Html.PartialAsync("_VideoCongNghe", Model.VideoCongNghe)
            </div>

            <div class="tab-pane fade" id="gpcn">
                @await Html.PartialAsync("_GiaiPhapCongNghe", Model.TinSuKien)
            </div>
        </div>
    </div>



    @* YeuCauCongNghe *@
    @await Html.PartialAsync("_YeuCauCongNghe", Model.YeuCauCongNghe)

    @* TinSuKien *@
    @await Html.PartialAsync("_TinSuKien", Model.TinSuKien)

    @* Hệ thống sàn giao dịch công nghệ *@
    @* Đối tác *@
    @* Đơn vị tư vấn *@
    @* → Gộp vào _ManLuoiDoiTac *@
    @await Component.InvokeAsync("ManLuoiDoiTac")
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="~/js/home-analytics.js" asp-append-version="true"></script>
}