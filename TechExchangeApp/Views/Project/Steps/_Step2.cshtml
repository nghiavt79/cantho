@model TechExchangeApp.ViewModel.StepContentVm

@{
    var nda = Model.StepData as TechExchangeApp.Entities.NDAAgreement;
    var isCompleted = nda != null && nda.DaDongY;
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="fas fa-file-signature"></i> Bước 2: Thỏa thuận Bảo mật (NDA)
        </h5>
    </div>
    <div class="card-body">
        <i class="step-desc">
            Bên mua đồng ý các điều khoản bảo mật thông tin nhằm đảm bảo an toàn cho các thông tin sắp trao đổi với Sàn.
        </i>

        <div class="p-4 bg-light border rounded mt-3">
            <h6 class="text-center mb-1"><i class="fas fa-file-contract"></i> PHIẾU THỎA THUẬN BẢO MẬT</h6>
            <p class="text-center text-muted small mb-4">–oOo–</p>

            @* ── Bên A / Bên B ── *@
            <div class="row mb-3">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-semibold">Bên A (Bên Mua)</label>
                    @{
                        var techTransfer = ViewBag.TechTransfer as TechExchangeApp.Entities.TechTransferRequest;
                        var benA = nda?.BenA ?? techTransfer?.DonVi ?? techTransfer?.HoTen ?? "";
                    }
                    <input type="text" class="form-control @(isCompleted ? "bg-white" : "")" id="benA" value="@benA"
                           @(isCompleted ? "readonly" : "") placeholder="Nhập tên đơn vị / cá nhân" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-semibold">Bên B (Bên Tư vấn)</label>
                    <input type="text" class="form-control bg-light" id="benB"
                           value="Trung tâm Thông tin, Thống kê và Ứng dụng tiến bộ khoa học công nghệ"
                           readonly />
                </div>
            </div>

            @* ── 6 điều khoản ── *@
            <div class="border rounded-3 p-4 mb-4" style="background: #f8fafc;">
                <p class="fw-semibold text-dark mb-3">
                    Bằng việc đánh dấu tick chọn, <strong>Bên Mua</strong> đồng ý các điều kiện sau:
                </p>
                <ol class="mb-0" style="line-height: 1.9;">
                    <li>
                        <strong>Bảo mật thông tin:</strong>
                        Không sao chép, phát tán hay tiết lộ Thông Tin dự án cho bất kỳ bên thứ ba nào khi chưa được phép.
                    </li>
                    <li>
                        <strong>Sử dụng đúng mục đích:</strong>
                        Chỉ sử dụng thông tin cho giao dịch chuyển giao công nghệ, nghiêm cấm sử dụng cho mục đích thương mại riêng.
                    </li>
                    <li>
                        <strong>Tôn trọng Sở hữu trí tuệ:</strong>
                        Việc tiếp nhận thông tin không làm phát sinh quyền sở hữu hay quyền sử dụng (license) đối với tài sản trí tuệ.
                    </li>
                    <li>
                        <strong>Thời hạn ràng buộc:</strong>
                        Duy trì nghĩa vụ bảo mật <strong>12 tháng</strong> sau khi kết thúc thỏa thuận.
                    </li>
                    <li>
                        <strong>Trách nhiệm vi phạm:</strong>
                        Chịu hoàn toàn trách nhiệm và bồi thường toàn bộ thiệt hại thực tế (gồm án phí, phí luật sư) nếu vi phạm.
                    </li>
                    <li>
                        <strong>Giải quyết tranh chấp:</strong>
                        Tuân thủ pháp luật Việt Nam, ưu tiên thương lượng hoặc giải quyết tại Tòa án có thẩm quyền tại Thành Phố Cần Thơ.
                    </li>
                </ol>
            </div>

            @* ── Checkbox Đồng ý ── *@
            @if (isCompleted)
            {
                <div class="border rounded-3 p-3 mb-3" style="background: #eafaf1; border-color: #28a745 !important;">
                    <i class="fas fa-check-circle text-success fa-lg me-2"></i>
                    <strong class="text-success">Đã đồng ý các điều khoản</strong>
                    <br />
                    <small class="text-muted">
                        <i class="fas fa-clock me-1"></i>Ngày tạo: @nda.NgayTao.ToString("dd/MM/yyyy HH:mm")
                        - bởi <strong>@(!string.IsNullOrEmpty(ViewBag.NdaCreatorName) ? ViewBag.NdaCreatorName : ViewBag.NdaCreatorUserName)</strong>.
                        @if (nda.NgaySua.HasValue)
                        {
                            <span class="ms-2"><i class="fas fa-edit me-1"></i>Cập nhật: @nda.NgaySua.Value.ToString("dd/MM/yyyy HH:mm")</span>
                        }
                    </small>
                </div>
            }
            else
            {
                <div class="border rounded-3 p-3 mb-3" style="background: #fffdf0; border-color: #ffc107 !important;">
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="daDongY"
                               style="width:1.2em; height:1.2em;" />
                        <label class="form-check-label fw-bold fs-6 ms-1" for="daDongY">
                            <i class="fas fa-check-circle text-success me-1"></i> Đồng ý
                        </label>
                    </div>
                </div>

                <button type="button" class="btn btn-primary btn-lg" id="btnAgreeNda" disabled>
                    <i class="fas fa-check-double me-2"></i>Xác nhận đồng ý NDA
                </button>
            }
        </div>
    </div>
    <div class="card-footer">
        <button class="btn btn-secondary step-nav-btn" data-step="1">
            <i class="fas fa-arrow-left"></i> Quay lại bước trước
        </button>
        @if (isCompleted)
        {
            <button class="btn btn-primary step-nav-btn" data-step="3">
                Tiếp tục bước 3 <i class="fas fa-arrow-right"></i>
            </button>
        }
    </div>
</div>

@if (!isCompleted)
{
<script>
var projectId = @Model.ProjectId;

// Local showToast: delegates to parent page's showToast if available, else self-creates
function showToast(type, message) {
    if (typeof window.showToast === 'function' && window.showToast !== showToast) {
        window.showToast(type, message);
    } else {
        var container = document.getElementById('toast-container');
        if (!container) {
            container = document.createElement('div');
            container.id = 'toast-container';
            container.className = 'position-fixed top-0 end-0 p-3';
            container.style.zIndex = '9999';
            document.body.appendChild(container);
        }
        var bgClass = type === 'success' ? 'bg-success' : type === 'error' || type === 'danger' ? 'bg-danger' : 'bg-warning';
        var html = '<div class="toast align-items-center text-white ' + bgClass + ' border-0 show" role="alert">' +
            '<div class="d-flex"><div class="toast-body">' + message + '</div>' +
            '<button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div></div>';
        container.insertAdjacentHTML('beforeend', html);
        var toast = container.lastElementChild;
        setTimeout(function() { toast.remove(); }, 5000);
    }
}

// Checkbox toggle
(function() {
    var chk = document.getElementById('daDongY');
    var btn = document.getElementById('btnAgreeNda');
    if (chk && btn) {
        chk.addEventListener('change', function() {
            btn.disabled = !this.checked;
        });
    }
})();

// Submit NDA agreement (simple - just agree, no OTP)
document.getElementById('btnAgreeNda')?.addEventListener('click', async function() {
    var btn = this;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang xử lý...';

    try {
        var res = await fetch('/NDA/AgreeNda', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                projectId: projectId,
                benA: document.getElementById('benA')?.value || '',
                benB: document.getElementById('benB')?.value || ''
            })
        });
        var data = await res.json();

        if (data.success) {
            showToast('success', '✅ ' + data.message);
            // Reload step 2 content after short delay
            setTimeout(function() {
                if (typeof loadStep === 'function') {
                    loadStep(2);
                } else {
                    location.reload();
                }
            }, 1000);
        } else {
            showToast('danger', '❌ ' + data.message);
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-check-double me-2"></i>Xác nhận đồng ý NDA';
        }
    } catch(ex) {
        showToast('danger', 'Lỗi kết nối: ' + ex.message);
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-check-double me-2"></i>Xác nhận đồng ý NDA';
    }
});
</script>
}
