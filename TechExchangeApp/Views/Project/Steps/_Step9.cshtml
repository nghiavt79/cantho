@model TechExchangeApp.ViewModel.StepContentVm
@using System.IO
@using Microsoft.EntityFrameworkCore
@inject TechExchangeApp.Data.AppDbContext DbCtx

@{
    var pilot = Model.StepData as TechExchangeApp.Entities.PilotTestReport;
    if (pilot == null)
    {
        pilot = await DbCtx.PilotTestReports
            .FirstOrDefaultAsync(x => x.ProjectId == Model.ProjectId);
    }
    bool hasData = pilot != null;
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="fas fa-flask"></i> Bước 9: Thử nghiệm Pilot
        </h5>
        @if (hasData)
        {
            <button class="btn btn-light btn-sm" id="s9EditToggle" onclick="s9_toggleEdit()">
                <i class="fas fa-edit"></i> Chỉnh sửa
            </button>
        }
    </div>
    <div class="card-body">
        <i class="step-desc">
            Bên bán sẽ tiến hành sản xuất mẫu hoặc chạy thử nghiệm dự án (Pilot) để bên mua đánh giá, tinh chỉnh và đối chiếu chất lượng thực tế với các cam kết ban đầu.
        </i>
        <!-- ═══ Display Mode ═══ -->
        <div id="s9Display" class="@(!hasData ? "d-none" : "")">
            @if (hasData)
            {
                <dl class="row mb-0">
                    <dt class="col-sm-4">Mô tả thử nghiệm:</dt>
                    <dd class="col-sm-8">
                        <div class="border rounded p-2 bg-light">
                            @Html.Raw(pilot!.MoTaThuNghiem?.Replace("\n", "<br />") ?? "")
                        </div>
                    </dd>

                    <dt class="col-sm-4">Kết quả thử nghiệm:</dt>
                    <dd class="col-sm-8">
                        <div class="border rounded p-2 bg-light">
                            @Html.Raw(pilot.KetQuaThuNghiem?.Replace("\n", "<br />") ?? "")
                        </div>
                    </dd>

                    @if (!string.IsNullOrEmpty(pilot.VanDePhatSinh))
                    {
                        <dt class="col-sm-4">Vấn đề phát sinh:</dt>
                        <dd class="col-sm-8">
                            <div class="alert alert-warning mb-0">
                                @Html.Raw(pilot.VanDePhatSinh.Replace("\n", "<br />"))
                            </div>
                        </dd>
                    }

                    @if (!string.IsNullOrEmpty(pilot.GiaiPhap))
                    {
                        <dt class="col-sm-4">Giải pháp:</dt>
                        <dd class="col-sm-8">@Html.Raw(pilot.GiaiPhap.Replace("\n", "<br />"))</dd>
                    }

                    <dt class="col-sm-4">Đạt yêu cầu:</dt>
                    <dd class="col-sm-8">
                        @if (pilot.DatYeuCau)
                        {
                            <span class="badge bg-success"><i class="fas fa-check"></i> Đạt yêu cầu</span>
                        }
                        else
                        {
                            <span class="badge bg-danger"><i class="fas fa-times"></i> Chưa đạt</span>
                        }
                    </dd>

                    @if (pilot.NgayBatDau.HasValue)
                    {
                        <dt class="col-sm-4">Ngày bắt đầu:</dt>
                        <dd class="col-sm-8">@pilot.NgayBatDau.Value.ToString("dd/MM/yyyy")</dd>
                    }

                    @if (pilot.NgayKetThuc.HasValue)
                    {
                        <dt class="col-sm-4">Ngày kết thúc:</dt>
                        <dd class="col-sm-8">@pilot.NgayKetThuc.Value.ToString("dd/MM/yyyy")</dd>
                    }

                    <dt class="col-sm-4">File kết quả:</dt>
                    <dd class="col-sm-8">
                        @if (!string.IsNullOrEmpty(pilot.FileKetQua))
                        {
                            <a href="/uploads/@pilot.FileKetQua" target="_blank" class="text-decoration-none">
                                <i class="fas fa-file text-primary"></i>
                                <strong>@System.IO.Path.GetFileName(pilot.FileKetQua)</strong>
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">Chưa có file</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Ngày tạo:</dt>
                    <dd class="col-sm-8">@pilot.NgayTao.ToString("dd/MM/yyyy HH:mm")</dd>

                    @if (pilot.NgaySua.HasValue)
                    {
                        <dt class="col-sm-4">Cập nhật lần cuối:</dt>
                        <dd class="col-sm-8">@pilot.NgaySua.Value.ToString("dd/MM/yyyy HH:mm")</dd>
                    }
                </dl>
            }
        </div>

        <!-- ═══ Form Mode ═══ -->
        <div id="s9Form" class="@(hasData ? "d-none" : "")">
            <form id="s9PilotForm" enctype="multipart/form-data">
                <input type="hidden" name="projectId" value="@Model.ProjectId" />

                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-clipboard me-1 text-primary"></i>Mô tả thử nghiệm <span class="text-danger">*</span>
                        </label>
                        <textarea class="form-control" name="MoTaThuNghiem" id="s9MoTa" rows="3"
                                  placeholder="Mô tả chi tiết quá trình thử nghiệm..." required>@(pilot?.MoTaThuNghiem ?? "")</textarea>
                    </div>

                    <div class="col-12">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-chart-line me-1 text-success"></i>Kết quả thử nghiệm <span class="text-danger">*</span>
                        </label>
                        <textarea class="form-control" name="KetQuaThuNghiem" id="s9KetQua" rows="3"
                                  placeholder="Kết quả đạt được sau thử nghiệm..." required>@(pilot?.KetQuaThuNghiem ?? "")</textarea>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-exclamation-triangle me-1 text-warning"></i>Vấn đề phát sinh
                        </label>
                        <textarea class="form-control" name="VanDePhatSinh" rows="2"
                                  placeholder="Các vấn đề phát sinh (nếu có)...">@(pilot?.VanDePhatSinh ?? "")</textarea>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-lightbulb me-1 text-info"></i>Giải pháp
                        </label>
                        <textarea class="form-control" name="GiaiPhap" rows="2"
                                  placeholder="Giải pháp khắc phục (nếu có)...">@(pilot?.GiaiPhap ?? "")</textarea>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-calendar-alt me-1 text-primary"></i>Ngày bắt đầu
                        </label>
                        <input type="date" class="form-control" name="NgayBatDau"
                               value="@(pilot?.NgayBatDau?.ToString("yyyy-MM-dd") ?? "")" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-calendar-check me-1 text-success"></i>Ngày kết thúc
                        </label>
                        <input type="date" class="form-control" name="NgayKetThuc"
                               value="@(pilot?.NgayKetThuc?.ToString("yyyy-MM-dd") ?? "")" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-check-double me-1 text-info"></i>Đạt yêu cầu
                        </label>
                        <div class="form-check form-switch mt-2">
                            <input class="form-check-input" type="checkbox" name="DatYeuCau" id="s9DatYeuCau"
                                   @(pilot?.DatYeuCau == true ? "checked" : "") />
                            <label class="form-check-label" for="s9DatYeuCau">Thử nghiệm đạt yêu cầu</label>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-file-upload me-1 text-warning"></i>File kết quả
                        </label>
                        <input type="file" class="form-control" name="FileKetQua"
                               accept=".pdf,.jpg,.jpeg,.png,.doc,.docx,.xls,.xlsx" />
                        <small class="text-muted">PDF, Word, Excel, ảnh — tối đa 10MB</small>
                        @if (hasData && !string.IsNullOrEmpty(pilot!.FileKetQua))
                        {
                            <div class="mt-1 small text-success">
                                <i class="fas fa-check-circle me-1"></i>File hiện tại: @System.IO.Path.GetFileName(pilot.FileKetQua)
                            </div>
                        }
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="button" class="btn btn-primary px-4" onclick="s9_save()">
                        <i class="fas fa-save me-1"></i>@(hasData ? "Cập nhật" : "Lưu")
                    </button>
                    @if (hasData)
                    {
                        <button type="button" class="btn btn-outline-secondary" onclick="s9_cancelEdit()">
                            <i class="fas fa-times me-1"></i>Hủy
                        </button>
                    }
                </div>
            </form>
        </div>

    </div>
    <div class="card-footer bg-white d-flex justify-content-between">
        <button class="btn btn-outline-secondary step-nav-btn" data-step="@(Model.StepNumber - 1)">
            <i class="fas fa-arrow-left"></i> Quay lại bước trước
        </button>
        @if (Model.StepNumber < 14 && Model.Steps.Count > Model.StepNumber && Model.Steps[Model.StepNumber].IsAccessible)
        {
            <button class="btn btn-primary step-nav-btn" data-step="@(Model.StepNumber + 1)">
                Tiếp tục bước @(Model.StepNumber + 1) <i class="fas fa-arrow-right"></i>
            </button>
        }
    </div>
</div>

<script>
    function s9_toggleEdit() {
        document.getElementById('s9Display').classList.add('d-none');
        document.getElementById('s9Form').classList.remove('d-none');
        document.getElementById('s9EditToggle').classList.add('d-none');
    }

    function s9_cancelEdit() {
        document.getElementById('s9Display').classList.remove('d-none');
        document.getElementById('s9Form').classList.add('d-none');
        document.getElementById('s9EditToggle').classList.remove('d-none');
    }

    async function s9_save() {
        const form = document.getElementById('s9PilotForm');
        const moTa = document.getElementById('s9MoTa').value.trim();
        const ketQua = document.getElementById('s9KetQua').value.trim();

        if (!moTa) { s9_toast('Vui lòng nhập mô tả thử nghiệm.', 'warning'); return; }
        if (!ketQua) { s9_toast('Vui lòng nhập kết quả thử nghiệm.', 'warning'); return; }

        const fd = new FormData(form);
        fd.set('DatYeuCau', document.getElementById('s9DatYeuCau').checked ? 'true' : 'false');

        const btn = event.target.closest('button');
        const origHtml = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang lưu...';

        try {
            const r = await fetch('/PilotTest/SaveInline', { method: 'POST', body: fd });
            const d = await r.json();

            if (d.success) {
                s9_toast(d.message || '✅ Đã lưu thành công!', 'success');
                setTimeout(() => {
                    const stepBtn = document.querySelector('.step-nav-btn[data-step="9"], [data-step-number="9"]');
                    if (stepBtn) stepBtn.click();
                    else location.reload();
                }, 1000);
            } else {
                s9_toast(d.message || 'Lỗi khi lưu.', 'danger');
            }
        } catch (e) {
            s9_toast('Lỗi kết nối: ' + e.message, 'danger');
        } finally {
            btn.disabled = false;
            btn.innerHTML = origHtml;
        }
    }

    function s9_toast(msg, type = 'success') {
        const t = document.createElement('div');
        t.className = `toast align-items-center text-bg-${type} border-0 show position-fixed bottom-0 end-0 m-3`;
        t.style = 'z-index:9999;min-width:280px';
        t.innerHTML = `<div class="d-flex"><div class="toast-body">${msg}</div>
            <button class="btn-close btn-close-white me-2 m-auto" onclick="this.closest('.toast').remove()"></button></div>`;
        document.body.appendChild(t);
        setTimeout(() => t.remove(), 5000);
    }
</script>
