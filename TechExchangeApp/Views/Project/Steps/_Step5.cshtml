@model TechExchangeApp.ViewModel.StepContentVm
@using System.IO
@using TechExchangeApp.Enums

@{
    var negotiation = Model.StepData as TechExchangeApp.Entities.NegotiationForm;
    bool isBuyer  = Model.UserRole == 1;
    bool isSeller = Model.UserRole == 2;
    bool isConsultant = Model.UserRole == 3;
    bool isCompleted = negotiation?.StatusId == (int)NegotiationStatus.Completed;

    bool alreadySigned = (isSeller && (negotiation?.SellerSigned ?? false))
                      || (isBuyer  && (negotiation?.BuyerSigned  ?? false));

    bool canSign = negotiation != null
        && negotiation.StatusId >= (int)NegotiationStatus.WaitingSignature
        && !isCompleted
        && !alreadySigned
        && (isBuyer || isSeller);

    var hinhThucKy = negotiation?.HinhThucKy ?? "OTP";

    // Inline form chỉ hiện ở Draft (chưa có giá); modal cho phép edit mọi trạng thái chưa Completed
    bool canEditInline = isBuyer && negotiation != null && !isCompleted
        && negotiation.StatusId < (int)NegotiationStatus.WaitingSignature;
    bool canEdit = canEditInline; // alias để không vỡ logic cũ bên dưới

    var sellerName = (string?)ViewBag.SellerName ?? "Seller";
    var buyerName = (string?)ViewBag.BuyerName ?? "Buyer";
}

@* OTP Modal *@
<div class="modal fade" id="otpModal" tabindex="-1" aria-labelledby="otpModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="otpModalLabel"><i class="fas fa-shield-alt me-2"></i>Nhập mã OTP</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center">
                <p class="text-muted small mb-3" id="otpSentMessage">Mã OTP đã được gửi.<br/>Có hiệu lực trong <strong id="otpCountdown" class="text-danger">5:00</strong></p>
                <input type="text" id="otpInput" class="form-control form-control-lg text-center fw-bold"
                       maxlength="6" placeholder="_ _ _ _ _ _" style="letter-spacing:6px;font-size:1.5rem"/>
                <div id="otpError" class="text-danger small mt-2 d-none"></div>
            </div>
            <div class="modal-footer justify-content-center">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary" id="btnVerifyOtp" onclick="verifyOtp()">
                    <i class="fas fa-check-circle me-1"></i> Xác nhận OTP
                </button>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="fas fa-handshake"></i> Bước 5: Đàm phán Thương mại</h5>
        @if (isBuyer && negotiation != null && !isCompleted)
        {
            <button class="btn btn-sm btn-light" type="button"
                    data-bs-toggle="modal" data-bs-target="#editNegotiationModal">
                <i class="fas fa-pen me-1"></i> Chỉnh sửa
            </button>
        }
    </div>
    <div class="card-body">
        <i class="step-desc">
            Hai bên đối tác sẽ trực tiếp đàm phán, phản hồi và đi đến thống nhất các điều khoản thương mại cũng như tiêu chuẩn kỹ thuật thông qua công cụ tương tác trực tuyến của Sàn.
        </i>
        @if (negotiation != null)
        {
            @* Status badge *@
            <div class="mb-3">
                @{
                    var (badgeClass, badgeIcon, badgeText) = negotiation.StatusId switch
                    {
                        (int)NegotiationStatus.Draft            => ("bg-secondary",          "fa-clock",       "Đang soạn thảo"),
                        (int)NegotiationStatus.PriceAgreed      => ("bg-info",               "fa-check-circle","Đã thống nhất giá"),
                        (int)NegotiationStatus.WaitingSignature => ("bg-warning text-dark",  "fa-pen",         "Chờ ký xác nhận"),
                        (int)NegotiationStatus.PartiallySigned  => ("bg-warning text-dark",  "fa-pen-alt",     "Đã ký một phần"),
                        (int)NegotiationStatus.Completed        => ("bg-success",            "fa-check-double","Hoàn tất thương lượng"),
                        _                                       => ("bg-secondary",          "fa-question",    "Không xác định")
                    };
                }
                <span class="badge @badgeClass fs-6"><i class="fas @badgeIcon me-1"></i>@badgeText</span>
            </div>

            @if (canEdit)
            {
                @* ── Inline form for editing negotiation ── *@
                <div class="alert alert-info mb-3">
                    <i class="fas fa-info-circle"></i>
                    <strong>Đang chờ thương lượng.</strong> Vui lòng điền thông tin giá và điều khoản bên dưới.
                </div>

                <form id="negotiationInlineForm" enctype="multipart/form-data">
                    <input type="hidden" name="projectId" value="@Model.ProjectId" />
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">Giá chốt cuối cùng (VNĐ)</label>
                            <input type="text" name="giaChotCuoiCung" class="form-control currency-input" placeholder="0"
                                   value="@AppHtmlHelper.FormatVndNumber(negotiation.GiaChotCuoiCung)" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Điều khoản thanh toán</label>
                            <textarea name="dieuKhoanThanhToan" class="form-control" rows="3" placeholder="Ví dụ: Thanh toán 30% khi ký hợp đồng, 70% khi nghiệm thu...">@(negotiation.DieuKhoanThanhToan ?? "")</textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Hình thức ký <span class="text-danger">*</span></label>
                            <select name="hinhThucKy" class="form-select" id="inlineHinhThucKySelect">
                                <option value="">-- Chọn hình thức --</option>
                                @{
                                    var htk = negotiation.HinhThucKy ?? "";
                                }
                                <option value="Upload file" selected="@(htk == "Upload file")">Upload file</option>
                                <option value="E-Sign" selected="@(htk == "E-Sign")">E-Sign</option>
                                <option value="OTP" selected="@(htk == "OTP")">OTP</option>
                            </select>
                        </div>
                        <div class="col-md-6" id="inlineUploadArea">
                            <label class="form-label">Biên bản thương lượng (File đính kèm)</label>
                            @if (!string.IsNullOrEmpty(negotiation.BienBanThuongLuongFile))
                            {
                                <div class="mb-2">
                                    <i class="fas fa-file-pdf text-danger"></i>
                                    <a href="@negotiation.BienBanThuongLuongFile" target="_blank">
                                        @System.IO.Path.GetFileName(negotiation.BienBanThuongLuongFile)
                                    </a>
                                    <small class="text-muted">(Upload mới để thay thế)</small>
                                </div>
                            }
                            <input type="file" name="bienBanFile" class="form-control" accept=".pdf,.doc,.docx" />
                            <small class="text-muted">Chấp nhận: .pdf, .doc, .docx (Tối đa 20MB)</small>
                        </div>
                    </div>
                    <div class="mt-3">
                        <button type="button" class="btn btn-primary" id="btnSaveNegotiation" onclick="saveNegotiationInline()">
                            <i class="fas fa-save me-1"></i> Lưu kết quả thương thảo
                        </button>
                    </div>
                </form>
            }
            else
            {
                <dl class="row">
                    <dt class="col-sm-3">Giá chốt cuối cùng:</dt>
                    <dd class="col-sm-9">
                        @Html.Raw(AppHtmlHelper.FormatVndBadge(negotiation.GiaChotCuoiCung))
                    </dd>

                    <dt class="col-sm-3">Điều khoản thanh toán:</dt>
                    <dd class="col-sm-9">
                        <div class="border rounded p-2 bg-light">
                            @Html.Raw((negotiation.DieuKhoanThanhToan ?? "").Replace("\n", "<br />"))
                        </div>
                    </dd>

                    <dt class="col-sm-3">Biên bản thương lượng:</dt>
                    <dd class="col-sm-9">
                        @if (!string.IsNullOrEmpty(negotiation.BienBanThuongLuongFile))
                        {
                            <i class="fas fa-file-pdf text-danger"></i>
                            <a href="@negotiation.BienBanThuongLuongFile" target="_blank">
                                <strong>@System.IO.Path.GetFileName(negotiation.BienBanThuongLuongFile)</strong>
                            </a>
                        }
                        else { <span class="text-muted">Chưa có file</span> }
                    </dd>

                    <dt class="col-sm-3">Hình thức ký:</dt>
                    <dd class="col-sm-9"><strong>@negotiation.HinhThucKy</strong></dd>

                    <dt class="col-sm-3">Ngày tạo:</dt>
                    <dd class="col-sm-9">@negotiation.NgayTao.ToString("dd/MM/yyyy HH:mm")</dd>
                </dl>

                <hr />
                <h6 class="mb-3"><i class="fas fa-signature me-1"></i> Trạng thái chữ ký</h6>
                <div class="row g-3 mb-3">
                    @* Seller *@
                    <div class="col-md-6">
                        <div class="card h-100 @(negotiation.SellerSigned ? "border-success" : "border-secondary")">
                            <div class="card-body py-3">
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    @if (negotiation.SellerSigned)
                                    {
                                        <i class="fas fa-check-circle text-success fa-lg"></i>
                                        <span class="fw-bold text-success">@sellerName đã ký</span>
                                    }
                                    else
                                    {
                                        <i class="far fa-circle text-muted fa-lg"></i>
                                        <span class="text-muted">@sellerName chưa ký</span>
                                    }
                                </div>
                                @if (negotiation.SellerSignedAt.HasValue)
                                {
                                    <small class="text-muted">
                                        <i class="fas fa-clock me-1"></i>@negotiation.SellerSignedAt.Value.ToString("HH:mm dd/MM/yyyy")
                                    </small>
                                }
                            </div>
                        </div>
                    </div>
                    @* Buyer *@
                    <div class="col-md-6">
                        <div class="card h-100 @(negotiation.BuyerSigned ? "border-success" : "border-secondary")">
                            <div class="card-body py-3">
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    @if (negotiation.BuyerSigned)
                                    {
                                        <i class="fas fa-check-circle text-success fa-lg"></i>
                                        <span class="fw-bold text-success">@buyerName đã ký</span>
                                    }
                                    else
                                    {
                                        <i class="far fa-circle text-muted fa-lg"></i>
                                        <span class="text-muted">@buyerName chưa ký</span>
                                    }
                                </div>
                                @if (negotiation.BuyerSignedAt.HasValue)
                                {
                                    <small class="text-muted">
                                        <i class="fas fa-clock me-1"></i>@negotiation.BuyerSignedAt.Value.ToString("HH:mm dd/MM/yyyy")
                                    </small>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                @* Sign section — depends on HinhThucKy *@
                @if (canSign)
                {
                    @if (hinhThucKy == "OTP")
                    {
                        @* ── OTP signing ── *@
                        <div class="card border-primary mb-3">
                            <div class="card-body">
                                <h6 class="card-title mb-3"><i class="fas fa-shield-alt me-1"></i> Ký xác nhận bằng OTP</h6>
                                <div class="d-flex gap-3 mb-3">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="otpChannel" id="channelEmail" value="email" checked />
                                        <label class="form-check-label" for="channelEmail">
                                            <i class="fas fa-envelope me-1"></i> Email
                                        </label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="otpChannel" id="channelSms" value="sms" />
                                        <label class="form-check-label" for="channelSms">
                                            <i class="fas fa-sms me-1"></i> SMS
                                        </label>
                                    </div>
                                </div>
                                <div id="smsPhoneSection" class="mb-3" style="display:none;">
                                    <label class="form-label small">Số điện thoại nhận OTP:</label>
                                    <input type="tel" class="form-control" id="otpPhoneNumber" placeholder="0912345678" />
                                </div>
                                <button type="button" class="btn btn-primary" onclick="requestOtp(this)">
                                    <i class="fas fa-pen-nib me-1"></i> Gửi OTP & Ký xác nhận
                                </button>
                            </div>
                        </div>
                    }
                    else if (hinhThucKy == "E-Sign")
                    {
                        @* ── E-Sign (digital signature) ── *@
                        <div class="card border-info mb-3">
                            <div class="card-body">
                                <h6 class="card-title mb-3"><i class="fas fa-file-signature me-1"></i> Ký xác nhận bằng Chữ ký số (E-Sign)</h6>
                                <p class="text-muted small">Sử dụng chữ ký số để xác nhận biên bản thương lượng. Hệ thống sẽ tạo tài liệu E-Sign và gửi đến bạn.</p>
                                <button type="button" class="btn btn-info text-white" onclick="requestESign(this)">
                                    <i class="fas fa-file-signature me-1"></i> Tạo & Ký chữ ký số
                                </button>
                            </div>
                        </div>
                    }
                    else if (hinhThucKy == "Upload file")
                    {
                        @* ── Confirm uploaded file ── *@
                        <div class="card border-warning mb-3">
                            <div class="card-body">
                                <h6 class="card-title mb-3"><i class="fas fa-file-check me-1"></i> Xác nhận biên bản thương lượng</h6>
                                @if (!string.IsNullOrEmpty(negotiation.BienBanThuongLuongFile))
                                {
                                    <div class="alert alert-light border mb-3">
                                        <i class="fas fa-file-pdf text-danger me-2"></i>
                                        <a href="@negotiation.BienBanThuongLuongFile" target="_blank" class="fw-bold">
                                            @System.IO.Path.GetFileName(negotiation.BienBanThuongLuongFile)
                                        </a>
                                        <small class="text-muted d-block mt-1">Xem lại file biên bản trước khi xác nhận</small>
                                    </div>
                                }
                                else
                                {
                                    <div class="alert alert-warning mb-3">
                                        <i class="fas fa-exclamation-triangle me-1"></i> Chưa có file biên bản được tải lên.
                                    </div>
                                }
                                <button type="button" class="btn btn-success" onclick="confirmUploadFile(this)" @(string.IsNullOrEmpty(negotiation.BienBanThuongLuongFile) ? "disabled" : "")>
                                    <i class="fas fa-check-circle me-1"></i> Xác nhận
                                </button>
                            </div>
                        </div>
                    }
                }
                else if (!isCompleted && alreadySigned)
                {
                    <button class="btn btn-success" disabled>
                        <i class="fas fa-check me-1"></i> Bạn đã ký
                    </button>
                }
            }
        }
        else
        {
            <div class="alert alert-info d-flex align-items-center gap-3">
                <i class="fas fa-info-circle fa-lg"></i>
                <div>
                    <strong>Chưa có biên bản đàm phán.</strong><br/>
                    @if (isBuyer)
                    {
                        <span class="text-muted small">Nhấn nút bên dưới để bắt đầu quá trình đàm phán thương mại.</span>
                    }
                    else
                    {
                        <span class="text-muted small">Đang chờ Buyer khởi tạo biên bản đàm phán.</span>
                    }
                </div>
            </div>
            @if (isBuyer)
            {
                <button class="btn btn-primary" onclick="initNegotiation(this)">
                    <i class="fas fa-plus me-1"></i> Khởi tạo biên bản đàm phán
                </button>
            }
        }
    </div>
    <div class="card-footer">
        <button class="btn btn-secondary step-nav-btn" data-step="@(Model.StepNumber - 1)">
            <i class="fas fa-arrow-left"></i> Quay lại bước trước
        </button>
        @if (Model.StepNumber < 11 && Model.Steps[Model.StepNumber].IsAccessible)
        {
            <button class="btn btn-primary step-nav-btn" data-step="@(Model.StepNumber + 1)">
                Tiếp tục bước @(Model.StepNumber + 1) <i class="fas fa-arrow-right"></i>
            </button>
        }
    </div>
</div>

@section Scripts {
<script>
    // Placeholder to avoid Razor section errors if rendered in full page context
</script>
}

<script>
    const projectId = @Model.ProjectId;
    let otpCountdownTimer = null;

    // Local showToast: delegates to parent page's showToast if available, else self-creates
    function showToast(type, message) {
        if (typeof window.showToast === 'function' && window.showToast !== showToast) {
            window.showToast(type, message);
            return;
        }
        var bgMap = { success: 'bg-success', danger: 'bg-danger', error: 'bg-danger', warning: 'bg-warning', info: 'bg-info' };
        var bg = bgMap[type] || 'bg-secondary';
        var textClass = (type === 'warning') ? 'text-dark' : 'text-white';
        var toast = document.createElement('div');
        toast.style.cssText = 'position:fixed;top:16px;right:16px;z-index:9999;min-width:260px';
        toast.innerHTML = '<div class="toast show ' + bg + ' ' + textClass + '" role="alert"><div class="toast-body"><i class="fas fa-info-circle me-1"></i>' + message + '</div></div>';
        document.body.appendChild(toast);
        setTimeout(function() { toast.style.opacity='0'; toast.style.transition='opacity .4s'; setTimeout(function(){toast.remove();},400); }, 3000);
    }

    function getAntiForgeryToken() {
        return document.querySelector('meta[name="__RequestVerificationToken"]')?.content ?? '';
    }

    // ── Save inline negotiation form ─────────────────────────────────────────
    async function saveNegotiationInline() {
        const form = document.getElementById('negotiationInlineForm');
        if (!form) return;

        const hinhThucKy = form.querySelector('[name="hinhThucKy"]')?.value;
        if (!hinhThucKy) {
            showToast('warning', 'Vui lòng chọn hình thức ký');
            return;
        }

        const giaChotRaw = form.querySelector('[name="giaChotCuoiCung"]')?.value.replace(/\./g, '') || '';
        if (!giaChotRaw || isNaN(giaChotRaw)) {
            showToast('warning', 'Vui lòng nhập giá chốt cuối cùng');
            return;
        }

        const btn = document.getElementById('btnSaveNegotiation');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang lưu...';

        const formData = new FormData(form);
        // Replace formatted currency with raw number
        formData.set('giaChotCuoiCung', giaChotRaw);

        try {
            const res = await fetch('/Negotiation/SaveInline', {
                method: 'POST',
                body: formData
            });
            const data = await res.json();

            if (data.success) {
                showToast('success', data.message);
                // Close the modal if open
                const modalEl = document.getElementById('editNegotiationModal');
                if (modalEl) {
                    const modal = bootstrap.Modal.getInstance(modalEl);
                    if (modal) modal.hide();
                }
                setTimeout(function() { window.location.href = '/Project/Details/' + projectId + '?step=5'; }, 1500);
            } else {
                showToast('danger', data.message);
            }
        } catch (e) {
            showToast('danger', 'Lỗi kết nối: ' + e.message);
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-save me-1"></i> Lưu thay đổi';
        }
    }

    // Upload area always visible

    // ── Currency formatting (VNĐ: dots as thousand separators) ────────────────
    document.querySelectorAll('.currency-input').forEach(function(input) {
        input.addEventListener('input', function() {
            var raw = this.value.replace(/\D/g, '');
            if (raw) {
                this.value = parseInt(raw, 10).toLocaleString('vi-VN');
            } else {
                this.value = '';
            }
        });
    });

    // ── Request OTP ──────────────────────────────────────────────────────────
    async function requestOtp(btnEl) {
        const btn = btnEl;
        const channel = document.querySelector('input[name="otpChannel"]:checked')?.value || 'email';
        const phoneNumber = document.getElementById('otpPhoneNumber')?.value || '';

        if (channel === 'sms' && !phoneNumber) {
            showToast('warning', 'Vui lòng nhập số điện thoại nhận OTP');
            return;
        }

        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang gửi...';

        try {
            const res = await fetch('/Negotiation/RequestOtp', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ projectId, channel, phoneNumber })
            });
            const data = await res.json();

            if (data.success) {
                document.getElementById('otpInput').value = '';
                document.getElementById('otpError').classList.add('d-none');
                document.getElementById('btnVerifyOtp').disabled = false;
                document.getElementById('otpSentMessage').innerHTML = 
                    data.message + '<br/>Có hiệu lực trong <strong id="otpCountdown" class="text-danger">5:00</strong>';
                startCountdown(300);
                new bootstrap.Modal(document.getElementById('otpModal')).show();
            } else {
                showToast('danger', data.message);
            }
        } catch (e) {
            showToast('danger', 'Lỗi kết nối: ' + e.message);
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-pen-nib me-1"></i> Gửi OTP & Ký xác nhận';
        }
    }

    // ── Toggle SMS phone input ──────────────────────────────────────────────
    document.querySelectorAll('input[name="otpChannel"]').forEach(radio => {
        radio.addEventListener('change', function() {
            const smsSection = document.getElementById('smsPhoneSection');
            if (smsSection) smsSection.style.display = this.value === 'sms' ? 'block' : 'none';
        });
    });

    // ── Countdown timer ───────────────────────────────────────────────────────
    function startCountdown(seconds) {
        clearInterval(otpCountdownTimer);
        const el = document.getElementById('otpCountdown');
        let remaining = seconds;

        otpCountdownTimer = setInterval(() => {
            remaining--;
            const m = Math.floor(remaining / 60);
            const s = remaining % 60;
            el.textContent = `${m}:${s.toString().padStart(2, '0')}`;

            if (remaining <= 0) {
                clearInterval(otpCountdownTimer);
                el.textContent = 'Hết hạn';
                document.getElementById('btnVerifyOtp').disabled = true;
                document.getElementById('otpError').textContent = 'OTP đã hết hạn. Vui lòng yêu cầu lại.';
                document.getElementById('otpError').classList.remove('d-none');
            }
        }, 1000);
    }

    // ── Verify OTP ────────────────────────────────────────────────────────────
    async function verifyOtp() {
        const otp = document.getElementById('otpInput').value.trim();
        const errEl = document.getElementById('otpError');
        errEl.classList.add('d-none');

        if (otp.length !== 6) {
            errEl.textContent = 'Vui lòng nhập đủ 6 chữ số.';
            errEl.classList.remove('d-none');
            return;
        }

        const btn = document.getElementById('btnVerifyOtp');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang xác nhận...';

        try {
            const res = await fetch('/Negotiation/VerifyOtp', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ projectId, otp })
            });
            const data = await res.json();

            if (data.success) {
                clearInterval(otpCountdownTimer);
                bootstrap.Modal.getInstance(document.getElementById('otpModal'))?.hide();
                showToast('success', data.message);
                setTimeout(function() { location.reload(); }, 1500);
            } else {
                errEl.textContent = data.message;
                errEl.classList.remove('d-none');
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-check-circle me-1"></i> Xác nhận OTP';
            }
        } catch (e) {
            errEl.textContent = 'Lỗi kết nối: ' + e.message;
            errEl.classList.remove('d-none');
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-check-circle me-1"></i> Xác nhận OTP';
        }
    }

    // Allow Enter key in OTP input
    document.getElementById('otpInput')?.addEventListener('keypress', function(e) {
        if (e.key === 'Enter') verifyOtp();
    });

    // ── E-Sign flow ──────────────────────────────────────────────────────────
    async function requestESign(btnEl) {
        const btn = btnEl;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang tạo tài liệu E-Sign...';

        try {
            const res = await fetch('/Negotiation/RequestESign', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ projectId })
            });
            const data = await res.json();

            if (data.success) {
                showToast('success', data.message);
                setTimeout(function() { location.reload(); }, 1500);
            } else {
                showToast('danger', data.message);
            }
        } catch (e) {
            showToast('danger', 'Lỗi kết nối: ' + e.message);
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-file-signature me-1"></i> Tạo & Ký chữ ký số';
        }
    }

    // ── Confirm uploaded file flow ────────────────────────────────────────────
    async function confirmUploadFile(btnEl) {
        const btn = btnEl;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang xác nhận...';

        try {
            const res = await fetch('/Negotiation/ConfirmUploadFile', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ projectId })
            });
            const data = await res.json();

            if (data.success) {
                showToast('success', data.message);
                setTimeout(function() { location.reload(); }, 1500);
            } else {
                showToast('danger', data.message);
            }
        } catch (e) {
            showToast('danger', 'Lỗi kết nối: ' + e.message);
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-check-circle me-1"></i> Xác nhận';
        }
    }

    // ── Khởi tạo biên bản đàm phán (khi chưa có) ──────────────────────────
    async function initNegotiation(btnEl) {
        btnEl.disabled = true;
        btnEl.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang khởi tạo...';
        try {
            const res = await fetch('/Negotiation/Init', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ projectId })
            });
            const d = await res.json();
            showToast(d.success ? 'success' : 'danger', d.message);
            if (d.success) setTimeout(() => location.reload(), 1200);
        } catch (e) {
            showToast('danger', 'Lỗi: ' + e.message);
        } finally {
            btnEl.disabled = false;
            btnEl.innerHTML = '<i class="fas fa-plus me-1"></i> Khởi tạo biên bản đàm phán';
        }
    }

    // ── Lưu từ modal edit (dùng negotiationModalForm) ─────────────────────
    async function saveNegotiationModal() {
        const form = document.getElementById('negotiationModalForm');
        if (!form) return;

        const hinhThucKy = form.querySelector('[name="hinhThucKy"]')?.value;
        if (!hinhThucKy) { showToast('warning', 'Vui lòng chọn hình thức ký'); return; }

        const giaChotRaw = form.querySelector('[name="giaChotCuoiCung"]')?.value.replace(/\./g, '') || '';
        if (!giaChotRaw || isNaN(giaChotRaw)) {
            showToast('warning', 'Vui lòng nhập giá chốt cuối cùng');
            return;
        }

        const btn = document.getElementById('btnSaveNegotiationModal');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang lưu...';

        const formData = new FormData(form);
        formData.set('giaChotCuoiCung', giaChotRaw);

        try {
            const res = await fetch('/Negotiation/SaveInline', { method: 'POST', body: formData });
            const data = await res.json();
            showToast(data.success ? 'success' : 'danger', data.message);
            if (data.success) {
                bootstrap.Modal.getInstance(document.getElementById('editNegotiationModal'))?.hide();
                setTimeout(() => location.reload(), 1200);
            }
        } catch (e) {
            showToast('danger', 'Lỗi kết nối: ' + e.message);
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-save me-1"></i> Lưu thay đổi';
        }
    }
</script>

@* ── Edit Negotiation Modal (Buyer only) ─────────────────────────────── *@
@if (isBuyer && !isCompleted && negotiation != null)
{
    <div class="modal fade" id="editNegotiationModal" tabindex="-1" aria-labelledby="editNegotiationModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title" id="editNegotiationModalLabel">
                        <i class="fas fa-pen me-2"></i> Chỉnh sửa thông tin thương lượng
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    @if (negotiation.SellerSigned || negotiation.BuyerSigned)
                    {
                        <div class="alert alert-warning">
                            <i class="fas fa-exclamation-triangle me-1"></i>
                            <strong>Lưu ý:</strong> Đã có bên ký xác nhận. Nếu lưu thay đổi, chữ ký sẽ bị reset và cả hai bên phải ký lại.
                        </div>
                    }
                    <form id="negotiationModalForm" enctype="multipart/form-data">
                        <input type="hidden" name="projectId" value="@Model.ProjectId" />
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label fw-semibold">Giá chốt cuối cùng (VNĐ)</label>
                                <input type="text" name="giaChotCuoiCung" class="form-control currency-input"
                                       placeholder="0"
                                       value="@AppHtmlHelper.FormatVndNumber(negotiation.GiaChotCuoiCung)" />
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold">Điều khoản thanh toán</label>
                                <textarea name="dieuKhoanThanhToan" class="form-control" rows="4"
                                          placeholder="VD: Thanh toán 30% khi ký hợp đồng, 70% khi nghiệm thu...">@(negotiation.DieuKhoanThanhToan ?? "")</textarea>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Hình thức ký <span class="text-danger">*</span></label>
                                <select name="hinhThucKy" class="form-select" id="inlineHinhThucKySelect">
                                    <option value="">-- Chọn hình thức --</option>
                                    @{ var htk2 = negotiation.HinhThucKy ?? ""; }
                                    <option value="Upload file" selected="@(htk2 == "Upload file")">Upload file</option>
                                    <option value="E-Sign" selected="@(htk2 == "E-Sign")">E-Sign</option>
                                    <option value="OTP" selected="@(htk2 == "OTP")">OTP</option>
                                </select>
                            </div>
                            <div class="col-md-6" id="inlineUploadArea">
                                <label class="form-label fw-semibold">Biên bản thương lượng (File)</label>
                                @if (!string.IsNullOrEmpty(negotiation.BienBanThuongLuongFile))
                                {
                                    <div class="mb-2">
                                        <i class="fas fa-file-pdf text-danger"></i>
                                        <a href="@negotiation.BienBanThuongLuongFile" target="_blank">
                                            @System.IO.Path.GetFileName(negotiation.BienBanThuongLuongFile)
                                        </a>
                                        <small class="text-muted">(Upload mới để thay thế)</small>
                                    </div>
                                }
                                <input type="file" name="bienBanFile" class="form-control" accept=".pdf,.doc,.docx" />
                                <small class="text-muted">Chấp nhận: .pdf, .doc, .docx (Tối đa 20MB)</small>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times me-1"></i> Huỷ
                    </button>
                    <button type="button" class="btn btn-primary" id="btnSaveNegotiationModal" onclick="saveNegotiationModal()">
                        <i class="fas fa-save me-1"></i> Lưu thay đổi
                    </button>
                </div>
            </div>
        </div>
    </div>
}

