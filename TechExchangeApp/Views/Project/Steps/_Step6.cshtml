<!-- CCCD Upload Modal (front + back) -->
<div class="modal fade" id="cmCccdUploadModal" tabindex="-1">
    <div class="modal-dialog"><div class="modal-content">
        <div class="modal-header">
            <h5 class="modal-title"><i class="fas fa-id-card me-1"></i>Upload CCCD / CMND</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
            <div class="mb-3">
                <label class="form-label fw-semibold"><i class="fas fa-id-card me-1"></i>Mặt trước <span class="text-danger">*</span></label>
                <input type="file" class="form-control" id="cmCccdFront" accept="image/*,.pdf" required />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold"><i class="fas fa-id-card-alt me-1"></i>Mặt sau <span class="text-danger">*</span></label>
                <input type="file" class="form-control" id="cmCccdBack" accept="image/*,.pdf" required />
            </div>
            <small class="text-muted">Hình ảnh hoặc PDF, tối đa 5MB mỗi file</small>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Hủy</button>
            <button type="button" class="btn btn-primary" id="cmCccdSubmitBtn" onclick="cm_submitCccdUpload()">
                <i class="fas fa-upload me-1"></i>Upload cả 2 mặt
            </button>
        </div>
    </div></div>
</div>

<script>
    function cm_openDocUpload(docType, label) {
        document.getElementById('cmDocType').value = docType;
        document.getElementById('cmDocUploadLabel').textContent = 'Upload ' + label;
        document.getElementById('cmDocFile').value = '';
        new bootstrap.Modal(document.getElementById('cmDocUploadModal')).show();
    }

    function cm_openCccdUpload() {
        document.getElementById('cmCccdFront').value = '';
        document.getElementById('cmCccdBack').value = '';
        new bootstrap.Modal(document.getElementById('cmCccdUploadModal')).show();
    }

    async function cm_submitDocUpload() {
        const docType = document.getElementById('cmDocType').value;
        const fileInput = document.getElementById('cmDocFile');
        if (!fileInput.files.length) { cm_toast('Vui lòng chọn file.', 'warning'); return; }

        const formData = new FormData();
        formData.append('docType', docType);
        formData.append('docFile', fileInput.files[0]);

        try {
            const res = await fetch('/Account/UploadDocAjax', { method: 'POST', body: formData });
            const d = await res.json();
            cm_toast(d.message, d.success ? 'success' : 'danger');
            if (d.success) {
                bootstrap.Modal.getInstance(document.getElementById('cmDocUploadModal')).hide();
                setTimeout(() => location.reload(), 1500);
            }
        } catch (e) {
            cm_toast('Lỗi: ' + e.message, 'danger');
        }
    }

    async function cm_submitCccdUpload() {
        const frontFile = document.getElementById('cmCccdFront');
        const backFile = document.getElementById('cmCccdBack');
        if (!frontFile.files.length || !backFile.files.length) {
            cm_toast('Vui lòng chọn cả 2 file: mặt trước và mặt sau.', 'warning');
            return;
        }

        const btn = document.getElementById('cmCccdSubmitBtn');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Đang upload...';

        try {
            // Upload front
            const fd1 = new FormData();
            fd1.append('docType', 1);
            fd1.append('docFile', frontFile.files[0]);
            const r1 = await fetch('/Account/UploadDocAjax', { method: 'POST', body: fd1 });
            const d1 = await r1.json();
            if (!d1.success) { cm_toast('Mặt trước: ' + d1.message, 'danger'); return; }

            // Upload back
            const fd2 = new FormData();
            fd2.append('docType', 2);
            fd2.append('docFile', backFile.files[0]);
            const r2 = await fetch('/Account/UploadDocAjax', { method: 'POST', body: fd2 });
            const d2 = await r2.json();
            if (!d2.success) { cm_toast('Mặt sau: ' + d2.message, 'danger'); return; }

            cm_toast('✅ Upload CCCD thành công!', 'success');
            bootstrap.Modal.getInstance(document.getElementById('cmCccdUploadModal')).hide();
            setTimeout(() => location.reload(), 1500);
        } catch (e) {
            cm_toast('Lỗi: ' + e.message, 'danger');
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-upload me-1"></i>Upload cả 2 mặt';
        }
    }
</script>
