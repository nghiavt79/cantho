@model TechExchangeApp.ViewModel.StepContentVm
@using TechExchangeApp.Entities
@using TechExchangeApp.Enums
@using Microsoft.EntityFrameworkCore
@inject TechExchangeApp.Interfaces.IContractService     ContractSvc
@inject TechExchangeApp.Interfaces.IContractApprovalService ApprovalSvc
@inject TechExchangeApp.Data.AppDbContext               DbCtx

@{
    int projectId = Model.ProjectId;
    bool stepLocked = Model.Steps.Count >= 6 && !Model.Steps[5].IsAccessible;

    // ── Load data ──────────────────────────────────────────────────────────────
    var userIdStr = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0";
    int userId    = int.TryParse(userIdStr, out int uid) ? uid : 0;

    var proj = await DbCtx.Projects.FindAsync(projectId);
    int userRole = 0;
    if (proj != null)
    {
        if (proj.CreatedBy == userId)            userRole = 1; // Buyer
        else if (proj.SelectedSellerId == userId) userRole = 2; // Seller
        else
        {
            // Use ProjectMembers (same as controller) to detect consultant
            var member = await DbCtx.ProjectMembers
                .FirstOrDefaultAsync(m => m.ProjectId == projectId && m.UserId == userId && m.Role == 3);
            if (member != null) userRole = 3;
        }
    }

    var activeContract = await ContractSvc.GetActiveContractAsync(projectId);
    var versions       = await ContractSvc.GetAllVersionsAsync(projectId);
    var approvals      = activeContract != null
        ? await ApprovalSvc.GetApprovalSummaryAsync(activeContract.Id)
        : new List<ContractApproval>();
    bool allApproved   = activeContract != null && await ApprovalSvc.AllPartiesApprovedAsync(activeContract.Id);
    var auditLogs      = await DbCtx.ContractAuditLogs
        .Where(l => l.EntityName == "ProjectContract" || l.EntityName == "ContractApproval")
        .OrderByDescending(l => l.CreatedDate).Take(20).ToListAsync();

    // Aliases
    var ct       = activeContract;
    bool isBuyer = userRole == 1;
    bool canEdit = userRole == 1 || userRole == 2 || userRole == 3;
    bool ctLocked = ct?.StatusId >= (int)ContractStatus.ReadyToSign;

    string StatusLabel(int s) => s switch {
        0 => "Bản nháp", 1 => "Đang review", 2 => "Đã sửa",
        3 => "ReadyToSign", 4 => "Đang ký", 5 => "Đã ký đầy đủ", _ => "Lưu trữ"
    };
    string StatusClass(int s) => s switch {
        0 => "bg-secondary", 1 => "bg-info", 2 => "bg-warning text-dark",
        3 => "bg-primary",   4 => "bg-warning text-dark", 5 => "bg-success", _ => "bg-dark"
    };
    string ApprovalLabel(int s) => s switch { 1 => "✅ Đã duyệt", 2 => "❌ Từ chối", _ => "⏳ Chờ" };
    string RoleName(int r)      => r switch { 1 => "Buyer", 2 => "Seller", 3 => "Tư vấn", _ => "?" };

    // Lookup actual user names
    var buyerName6 = proj?.CreatedBy.HasValue == true
        ? (await DbCtx.Users.AsNoTracking().Where(u => u.Id == proj.CreatedBy.Value).Select(u => u.FullName ?? u.UserName).FirstOrDefaultAsync()) ?? "Buyer"
        : "Buyer";
    var sellerName6 = proj?.SelectedSellerId.HasValue == true
        ? (await DbCtx.Users.AsNoTracking().Where(u => u.Id == proj.SelectedSellerId.Value).Select(u => u.FullName ?? u.UserName).FirstOrDefaultAsync()) ?? "Seller"
        : "Seller";
    var consultantName6 = "Tư vấn";
    if (proj != null)
    {
        var consultantMember = await DbCtx.ProjectMembers
            .Where(m => m.ProjectId == projectId && m.Role == 3)
            .Select(m => m.UserId)
            .FirstOrDefaultAsync();
        if (consultantMember > 0)
        {
            consultantName6 = (await DbCtx.Users.AsNoTracking().Where(u => u.Id == consultantMember).Select(u => u.FullName ?? u.UserName).FirstOrDefaultAsync()) ?? "Tư vấn";
        }
    }
    string DisplayName(int r) => r switch { 1 => $"{buyerName6} (Buyer)", 2 => $"{sellerName6} (Seller)", 3 => $"{consultantName6} (Tư vấn)", _ => "?" };

    // Load buyer/seller account type + verification docs
    var partyUserIds = new List<int>();
    if (proj?.CreatedBy.HasValue == true) partyUserIds.Add(proj.CreatedBy.Value);
    if (proj?.SelectedSellerId.HasValue == true) partyUserIds.Add(proj.SelectedSellerId.Value);

    var partyAccountTypes = new Dictionary<int, int>();
    if (partyUserIds.Any())
    {
        partyAccountTypes = await DbCtx.Users.AsNoTracking()
            .Where(u => partyUserIds.Contains(u.Id))
            .ToDictionaryAsync(u => u.Id, u => u.AccountTypeId);
    }

    var partyDocs = new List<TechExchangeApp.Entities.UserVerificationDoc>();
    if (partyUserIds.Any())
    {
        partyDocs = await DbCtx.Set<TechExchangeApp.Entities.UserVerificationDoc>().AsNoTracking()
            .Where(d => partyUserIds.Contains(d.UserId))
            .ToListAsync();
    }

    int GetAccountType(int role) {
        int uid = role == 1 ? (proj?.CreatedBy ?? 0) : (proj?.SelectedSellerId ?? 0);
        return partyAccountTypes.ContainsKey(uid) ? partyAccountTypes[uid] : 1;
    }
    List<TechExchangeApp.Entities.UserVerificationDoc> GetDocs(int role) {
        int uid = role == 1 ? (proj?.CreatedBy ?? 0) : (proj?.SelectedSellerId ?? 0);
        return partyDocs.Where(d => d.UserId == uid).ToList();
    }
}

<div class="card shadow-sm border-0">
    <div class="card-header d-flex justify-content-between align-items-center"
         style="background:linear-gradient(135deg,#1565c0,#1e88e5);color:#fff">
        <h5 class="mb-0">
            <i class="fas fa-file-contract me-2"></i>Bước 6: Kiểm tra pháp lý &amp; Hợp đồng
        </h5>
        @if (ct != null)
        {
            <span class="badge @StatusClass(ct.StatusId) fs-6">@StatusLabel(ct.StatusId)</span>
        }
    </div>

    <div class="card-body p-3">
        <i class="step-desc">
            Dựa trên các nội dung đã thống nhất, hệ thống sẽ tạo lập bản dự thảo hợp đồng. (file mẫu 1)
        </i>
        @if (stepLocked)
        {
            <div class="alert alert-warning d-flex gap-2 align-items-start">
                <i class="fas fa-lock fa-2x mt-1"></i>
                <div>
                    <strong>Bước này chưa được mở khóa.</strong><br/>
                    Hoàn thành Bước 5 (Đàm phán – cả 2 bên đã ký) để kích hoạt.
                </div>
            </div>
        }
        else if (ct == null)
        {
            <div class="card border-0 shadow-sm text-center py-5">
                <div class="card-body">
                    <i class="fas fa-file-circle-plus fa-4x text-muted mb-3"></i>
                    <h5>Chưa có hợp đồng nào</h5>
                    <p class="text-muted mb-4">Tạo bản nháp tự động từ kết quả đàm phán hoặc upload file hợp đồng.</p>
                    @if (canEdit)
                    {
                        <div class="d-flex gap-2 justify-content-center flex-wrap">
                            <button class="btn btn-primary" onclick="cm_createAuto()">
                                <i class="fas fa-magic me-1"></i>Tạo tự động
                            </button>
                            <button class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#cmUploadModal">
                                <i class="fas fa-upload me-1"></i>Upload hợp đồng
                            </button>
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="row g-4">
                <!-- ── Left: Contract preview ── -->
                <div class="col-lg-7">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-header bg-white border-bottom d-flex align-items-center gap-2">
                            <i class="fas fa-file-alt text-primary"></i>
                            <strong>Phiên bản @ct.VersionNumber</strong>
                            <span class="badge @StatusClass(ct.StatusId) ms-2">@StatusLabel(ct.StatusId)</span>
                            <div class="ms-auto d-flex gap-2">
                                @if (!string.IsNullOrEmpty(ct.OriginalFilePath))
                                {
                                    <a href="/Contract/Download/@ct.Id/original" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-download me-1"></i>Tải gốc
                                    </a>
                                }
                                @if (!string.IsNullOrEmpty(ct.SignedFilePath))
                                {
                                    <a href="/Contract/Download/@ct.Id/signed" class="btn btn-sm btn-success">
                                        <i class="fas fa-file-signature me-1"></i>Tải bản ký
                                    </a>
                                }
                                @if (!ctLocked && canEdit && !string.IsNullOrEmpty(ct.HtmlContent))
                                {
                                    <button class="btn btn-sm btn-outline-warning" id="cmEditBtn" onclick="cm_openEditor()" title="Chỉnh sửa nội dung hợp đồng">
                                        <i class="fas fa-pen me-1"></i>Chỉnh sửa
                                    </button>
                                }
                            </div>
                        </div>
                        <div class="card-body p-0" style="min-height:400px;overflow:auto">
                            @if (!string.IsNullOrEmpty(ct.HtmlContent))
                            {
                                @* Toolbar chỉnh sửa nổi phía trên iframe *@
                                <div id="cmEditorToolbar"
                                     class="d-none align-items-center gap-2 flex-wrap p-2 border-bottom bg-light">
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-outline-dark" onclick="cm_execCmd('bold')"      title="Bold"><b>B</b></button>
                                        <button class="btn btn-outline-dark" onclick="cm_execCmd('italic')"    title="Italic"><i>I</i></button>
                                        <button class="btn btn-outline-dark" onclick="cm_execCmd('underline')" title="Gạch chân"><u>U</u></button>
                                    </div>
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-outline-dark" onclick="cm_execCmd('justifyLeft')"   title="Trái"><i class="fas fa-align-left"></i></button>
                                        <button class="btn btn-outline-dark" onclick="cm_execCmd('justifyCenter')" title="Giữa"><i class="fas fa-align-center"></i></button>
                                        <button class="btn btn-outline-dark" onclick="cm_execCmd('justifyRight')"  title="Phải"><i class="fas fa-align-right"></i></button>
                                    </div>
                                    <select class="form-select form-select-sm" style="width:auto"
                                            onchange="cm_execCmd('fontSize', this.value); this.value=''">
                                        <option value="">Cỡ chữ</option>
                                        <option value="1">Nhỏ</option>
                                        <option value="3">Bình thường</option>
                                        <option value="5">Lớn</option>
                                        <option value="7">Rất lớn</option>
                                    </select>
                                    <div class="ms-auto d-flex gap-2">
                                        <button class="btn btn-sm btn-outline-secondary" onclick="cm_cancelEdit()">
                                            <i class="fas fa-times me-1"></i>Hủy
                                        </button>
                                        <button class="btn btn-sm btn-success" onclick="cm_saveHtml()" id="cmEditorSaveBtn">
                                            <i class="fas fa-save me-1"></i>Lưu thay đổi
                                        </button>
                                    </div>
                                </div>
                                <iframe id="cmContractIframe"
                                        srcdoc="@ct.HtmlContent"
                                        style="width:100%;min-height:600px;border:none;"
                                        title="Xem hợp đồng"
                                        onload="cm_resizeIframe(this)">
                                </iframe>
                            }
                            else if (!string.IsNullOrEmpty(ct.OriginalFilePath))
                            {
                                var ext = System.IO.Path.GetExtension(ct.OriginalFileName ?? "").ToLowerInvariant();
                                if (ext == ".pdf")
                                {
                                    <iframe src="/Contract/Download/@ct.Id/original"
                                            style="width:100%;height:600px;border:none;"
                                            title="Xem hợp đồng PDF"></iframe>
                                }
                                else
                                {
                                    <div class="d-flex flex-column align-items-center justify-content-center h-100 py-5 text-muted">
                                        <i class="fas fa-file-word fa-4x text-primary mb-3"></i>
                                        <p>@System.IO.Path.GetFileName(ct.OriginalFilePath)</p>
                                        <a href="/Contract/Download/@ct.Id/original" class="btn btn-outline-primary">
                                            <i class="fas fa-download me-1"></i>Tải xuống để xem (.docx)
                                        </a>
                                    </div>
                                }
                            }
                        </div>
                        @if (!ctLocked && canEdit)
                        {
                            <div class="card-footer bg-light border-top d-flex gap-2 flex-wrap">
                                <button class="btn btn-outline-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#cmUploadModal">
                                    <i class="fas fa-upload me-1"></i>Upload phiên bản mới
                                </button>
                                <button class="btn btn-outline-primary btn-sm" onclick="cm_createAuto()"
                                        title="Bỏ qua file đã upload — tạo lại hợp đồng chuẩn từ template HTML của hệ thống">
                                    <i class="fas fa-magic me-1"></i>Tạo lại từ template hệ thống
                                </button>
                            </div>
                        }
                    </div>
                </div>

                <!-- ── Right: Approvals + Actions ── -->
                <div class="col-lg-5">
                    <!-- Approval Cards -->
                    <div class="card border-0 shadow-sm mb-3">
                        <div class="card-header bg-white border-bottom">
                            <strong><i class="fas fa-users-check text-success me-2"></i>Phê duyệt (3 bên)</strong>
                        </div>
                        <div class="card-body">
                            @foreach (int r in new[] { 1, 2, 3 })
                            {
                                var ap   = approvals.FirstOrDefault(a => a.Role == r);
                                var icon = ap?.StatusId == 1 ? "text-success" : ap?.StatusId == 2 ? "text-danger" : "text-muted";
                                <div class="d-flex align-items-start gap-2 mb-3 pb-2 border-bottom">
                                    <i class="fas fa-user-circle fa-2x @icon mt-1"></i>
                                    <div class="flex-grow-1">
                                        <div class="fw-bold">@DisplayName(r)</div>
                                        <div class="small text-muted">
                                            @(ap != null ? ApprovalLabel(ap.StatusId) : "⏳ Chờ phê duyệt")
                                        </div>
                                        @if (!string.IsNullOrEmpty(ap?.Comment))
                                        {<div class="small fst-italic text-secondary mt-1">💬 @ap.Comment</div>}
                                        @if (ap?.DecisionAt != null)
                                        {<div class="small text-muted">@ap.DecisionAt.Value.ToLocalTime().ToString("dd/MM HH:mm")</div>}
                                        @if (r == 1 || r == 2)
                                        {
                                            var acctType = GetAccountType(r);
                                            var docs = GetDocs(r);
                                            <div class="mt-2 p-2 bg-light rounded small">
                                                <div class="text-muted mb-1">
                                                    <i class="fas @(acctType == 2 ? "fa-building" : "fa-user") me-1"></i>
                                                    @(acctType == 2 ? "Doanh nghiệp" : "Cá nhân")
                                                </div>
                                                @if (acctType == 1)
                                                {
                                                    var cccdFront = docs.FirstOrDefault(d => d.DocType == 1);
                                                    var cccdBack = docs.FirstOrDefault(d => d.DocType == 2);
                                                    <div class="d-flex gap-2 flex-wrap">
                                                        @if (cccdFront != null)
                                                        {
                                                            <div>
                                                                <div class="text-muted" style="font-size:11px">CCCD mặt trước</div>
                                                                <a href="@cccdFront.FilePath" target="_blank">
                                                                    <img src="@cccdFront.FilePath" alt="CCCD" style="max-width:120px;max-height:80px;border-radius:4px;border:1px solid #ddd" />
                                                                </a>
                                                                @if (userRole == r)
                                                                {
                                                                    <br/><a href="#" class="text-primary" style="font-size:11px" onclick="cm_openDocUpload(1, 'CCCD mặt trước'); return false;"><i class="fas fa-redo me-1"></i>Upload lại</a>
                                                                }
                                                            </div>
                                                        }
                                                        @if (cccdBack != null)
                                                        {
                                                            <div>
                                                                <div class="text-muted" style="font-size:11px">CCCD mặt sau</div>
                                                                <a href="@cccdBack.FilePath" target="_blank">
                                                                    <img src="@cccdBack.FilePath" alt="CCCD" style="max-width:120px;max-height:80px;border-radius:4px;border:1px solid #ddd" />
                                                                </a>
                                                                @if (userRole == r)
                                                                {
                                                                    <br/><a href="#" class="text-primary" style="font-size:11px" onclick="cm_openDocUpload(2, 'CCCD mặt sau'); return false;"><i class="fas fa-redo me-1"></i>Upload lại</a>
                                                                }
                                                            </div>
                                                        }
                                                        @if (cccdFront == null && cccdBack == null)
                                                        {
                                                            <span class="text-warning"><i class="fas fa-exclamation-triangle me-1"></i>Chưa upload CCCD</span>
                                                            @if (userRole == r)
                                                            {
                                                                <br/>
                                                                <button class="btn btn-sm btn-outline-primary mt-1" onclick="cm_openCccdUpload()">
                                                                    <i class="fas fa-upload me-1"></i>Upload CCCD (mặt trước + mặt sau)
                                                                </button>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            @if (cccdFront == null && userRole == r)
                                                            {
                                                                <button class="btn btn-sm btn-outline-warning mt-1" onclick="cm_openDocUpload(1, 'CCCD mặt trước')">
                                                                    <i class="fas fa-upload me-1"></i>Thiếu CCCD mặt trước
                                                                </button>
                                                            }
                                                            @if (cccdBack == null && userRole == r)
                                                            {
                                                                <button class="btn btn-sm btn-outline-warning mt-1" onclick="cm_openDocUpload(2, 'CCCD mặt sau')">
                                                                    <i class="fas fa-upload me-1"></i>Thiếu CCCD mặt sau
                                                                </button>
                                                            }
                                                        }
                                                    </div>
                                                }
                                                else
                                                {
                                                    var bizLic = docs.FirstOrDefault(d => d.DocType == 3);
                                                    @if (bizLic != null)
                                                    {
                                                        <div>
                                                            <div class="text-muted" style="font-size:11px">Giấy chứng nhận ĐKDN</div>
                                                            <a href="@bizLic.FilePath" target="_blank" class="d-flex align-items-center gap-1">
                                                                <i class="fas fa-file-contract text-primary"></i> @bizLic.FileName
                                                            </a>
                                                            @if (userRole == r)
                                                            {
                                                                <a href="#" class="text-primary" style="font-size:11px" onclick="cm_openDocUpload(3, 'Giấy chứng nhận ĐKDN'); return false;"><i class="fas fa-redo me-1"></i>Upload lại</a>
                                                            }
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-warning"><i class="fas fa-exclamation-triangle me-1"></i>Chưa upload Giấy chứng nhận ĐKDN</span>
                                                        @if (userRole == r)
                                                        {
                                                            <br/>
                                                            <button class="btn btn-sm btn-outline-primary mt-1" onclick="cm_openDocUpload(3, 'Giấy chứng nhận ĐKDN')">
                                                                <i class="fas fa-upload me-1"></i>Upload Giấy chứng nhận ĐKDN
                                                            </button>
                                                        }
                                                    }
                                                }
                                            </div>
                                        }
                                    </div>
                                    @if (!ctLocked && userRole == r)
                                    {
                                        <div class="d-flex gap-1">
                                            <button class="btn btn-sm btn-success"
                                                    onclick="cm_submitApproval(@ct.Id, @projectId, true)">✓</button>
                                            <button class="btn btn-sm btn-outline-danger"
                                                    onclick="cm_submitApproval(@ct.Id, @projectId, false)">✗</button>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>

                    <!-- ReadyToSign CTA -->
                    @if (!ctLocked && isBuyer && allApproved)
                    {
                        <div class="card border-0 shadow-sm border-primary mb-3">
                            <div class="card-body text-center">
                                <p class="text-success fw-bold"><i class="fas fa-check-circle me-1"></i>Tất cả các bên đã duyệt!</p>
                                <button class="btn btn-primary w-100 py-2" onclick="cm_setReadyToSign(@ct.Id)">
                                    <i class="fas fa-lock me-1"></i>Chốt hợp đồng – ReadyToSign
                                </button>
                                <small class="text-muted d-block mt-2">Sau khi chốt, hợp đồng sẽ không thể chỉnh sửa</small>
                            </div>
                        </div>
                    }

                    <!-- Go to Signing -->
                    @if (ct.StatusId >= (int)ContractStatus.ReadyToSign)
                    {
                        <div class="card border-0 shadow-sm border-success">
                            <div class="card-body text-center">
                                <p class="fw-bold text-primary"><i class="fas fa-signature me-1"></i>Sẵn sàng ký số</p>
                                <button class="btn btn-success w-100 py-2 step-nav-btn" data-step="7">
                                    <i class="fas fa-arrow-right me-1"></i>Đến Bước 7 – Ký hợp đồng
                                </button>
                            </div>
                        </div>
                    }

                    <!-- Version History -->
                    @if (versions.Count > 1)
                    {
                        <div class="card border-0 shadow-sm mt-3">
                            <div class="card-header bg-white border-bottom">
                                <small class="fw-bold"><i class="fas fa-history me-1"></i>Lịch sử phiên bản</small>
                            </div>
                            <div class="list-group list-group-flush">
                                @foreach (var v in versions.Take(5))
                                {
                                    <div class="list-group-item py-2">
                                        <div class="d-flex justify-content-between">
                                            <small><strong>v@v.VersionNumber</strong> @(v.IsActive ? "✅" : "🗄️")</small>
                                            <span class="badge @StatusClass(v.StatusId)">@StatusLabel(v.StatusId)</span>
                                        </div>
                                        <small class="text-muted">@v.CreatedDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</small>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>

            @* Audit Log — hidden
            @if (auditLogs.Any())
            {
                ...
            }
            *@
        }
    </div>

    <div class="card-footer bg-white d-flex justify-content-between">
        <button class="btn btn-outline-secondary step-nav-btn" data-step="@(Model.StepNumber - 1)">
            <i class="fas fa-arrow-left"></i> Quay lại
        </button>
        @if (Model.StepNumber < 11 && Model.Steps.Count > Model.StepNumber && Model.Steps[Model.StepNumber].IsAccessible)
        {
            <button class="btn btn-primary step-nav-btn" data-step="@(Model.StepNumber + 1)">
                Bước @(Model.StepNumber + 1) <i class="fas fa-arrow-right"></i>
            </button>
        }
    </div>
</div>

<!-- Upload Modal -->
<div class="modal fade" id="cmUploadModal" tabindex="-1">
    <div class="modal-dialog"><div class="modal-content">
        <form method="post" action="/Contract/Upload" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" name="projectId" value="@projectId" />
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-upload me-1"></i>Upload hợp đồng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <label class="form-label fw-semibold">File <small class="text-muted">(.pdf / .docx, tối đa 25MB)</small></label>
                <input type="file" class="form-control" name="contractFile" accept=".pdf,.docx" required />
            </div>
            <div class="modal-footer">
