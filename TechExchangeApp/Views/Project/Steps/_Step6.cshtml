</div>

<!-- Reject Modal -->
<div class="modal fade" id="cmRejectModal" tabindex="-1">
    <div class="modal-dialog"><div class="modal-content">
        <div class="modal-header"><h5 class="modal-title">Lý do từ chối</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
            <textarea id="cmRejectComment" class="form-control" rows="3" placeholder="Nhập lý do..."></textarea>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
            <button class="btn btn-danger" id="cmConfirmRejectBtn">Xác nhận từ chối</button>
        </div>
    </div></div>
</div>

<script>
    const cm_projectId = @projectId;
    let cm_rejectContractId = 0;

    async function cm_createAuto() {
        const r = await fetch('/Contract/CreateAuto', {
            method: 'POST', headers: {'Content-Type':'application/json'},
            body: JSON.stringify({ projectId: cm_projectId })
        });
        const d = await r.json();
        cm_toast(d.message, d.success ? 'success' : 'danger');
        if (d.success) setTimeout(() => location.reload(), 1000);
    }

    function cm_submitApproval(contractId, projectId, approved) {
        if (!approved) {
            cm_rejectContractId = contractId;
            new bootstrap.Modal(document.getElementById('cmRejectModal')).show();
            return;
        }
        cm_doApproval(contractId, projectId, '', true);
    }

    document.getElementById('cmConfirmRejectBtn')?.addEventListener('click', () => {
        const comment = document.getElementById('cmRejectComment').value;
        bootstrap.Modal.getInstance(document.getElementById('cmRejectModal')).hide();
        cm_doApproval(cm_rejectContractId, cm_projectId, comment, false);
    });

    async function cm_doApproval(contractId, projectId, comment, approved) {
        const url = approved ? '/Contract/Approve' : '/Contract/Reject';
        const r = await fetch(url, {
            method: 'POST', headers: {'Content-Type':'application/json'},
            body: JSON.stringify({ contractId, projectId, comment })
        });
        const d = await r.json();
        cm_toast(d.message, d.success ? 'success' : 'danger');
        if (d.success) setTimeout(() => location.reload(), 1200);
    }

    async function cm_setReadyToSign(contractId) {
        if (!confirm('Xác nhận chốt hợp đồng? Sau đó không thể chỉnh sửa.')) return;
        const r = await fetch('/Contract/SetReadyToSign', {
            method: 'POST', headers: {'Content-Type':'application/json'},
            body: JSON.stringify({ contractId })
        });
        const d = await r.json();
        cm_toast(d.message, d.success ? 'success' : 'danger');
        if (d.success) setTimeout(() => location.reload(), 1500);
    }

    function cm_toast(msg, type = 'success') {
        const t = document.createElement('div');
        t.className = `toast align-items-center text-bg-${type} border-0 show position-fixed bottom-0 end-0 m-3`;
        t.style = 'z-index:9999;min-width:280px';
        t.innerHTML = `<div class="d-flex"><div class="toast-body">${msg}</div>
            <button class="btn-close btn-close-white me-2 m-auto" onclick="this.closest('.toast').remove()"></button></div>`;
        document.body.appendChild(t);
        setTimeout(() => t.remove(), 4000);
    }

    // Tự resize iframe theo chiều cao nội dung hợp đồng
    function cm_resizeIframe(iframe) {
        try {
            const resize = () => {
                const h = iframe.contentDocument?.body?.scrollHeight;
                if (h && h > 100) iframe.style.height = (h + 32) + 'px';
            };
            resize();
            setTimeout(resize, 400);
        } catch(e) {}
    }
</script>


<script>
    const cm_contractIdForEditor = @(ct?.Id ?? 0);
    const cm_stepNumber = @Model.StepNumber; // = 6

    // Reload trang nhưng giữ ở bước hiện tại
    function cm_reloadStep() {
        const url = new URL(window.location.href);
        url.searchParams.set('step', cm_stepNumber);
        window.location.href = url.toString();
    }

    // Chạy lệnh format BÊN TRONG iframe (không phải trang ngoài)
    function cm_execCmd(cmd, value = null) {
        const iframe = document.getElementById('cmContractIframe');
        if (!iframe) return;
        iframe.contentDocument.execCommand(cmd, false, value);
        iframe.contentWindow.focus();
    }

    function cm_openEditor() {
        const iframe = document.getElementById('cmContractIframe');
        if (!iframe) return;

        iframe.contentDocument.designMode = 'on';
        iframe.style.outline = '2px solid #1e88e5';
        iframe.style.borderRadius = '4px';

        // Hiện toolbar: bỏ d-none, thêm d-flex
        const toolbar = document.getElementById('cmEditorToolbar');
        toolbar.classList.remove('d-none');
        toolbar.classList.add('d-flex');

        // Ẩn nút "Chỉnh sửa"
        const editBtn = document.getElementById('cmEditBtn');
        if (editBtn) editBtn.classList.add('d-none');

        iframe.contentWindow.focus();
    }

    function cm_cancelEdit() {
        const iframe = document.getElementById('cmContractIframe');
        if (iframe) {
            iframe.contentDocument.designMode = 'off';
            iframe.style.outline = '';
        }
        cm_reloadStep();
    }

    async function cm_saveHtml() {
        const iframe = document.getElementById('cmContractIframe');
        if (!iframe) return;

        const btn = document.getElementById('cmEditorSaveBtn');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Đang lưu...';

        try {
            const html = iframe.contentDocument.documentElement.outerHTML;
            const res  = await fetch('/Contract/SaveHtml', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ contractId: cm_contractIdForEditor, htmlContent: html })
            });
            const d = await res.json();
            cm_toast(d.message, d.success ? 'success' : 'danger');
            if (d.success) setTimeout(() => cm_reloadStep(), 800);
        } catch (e) {
            cm_toast('Lỗi: ' + e.message, 'danger');
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-save me-1"></i>Lưu thay đổi';
        }
    }
</script>


