@model TechExchangeApp.ViewModel.StepContentVm

@{
    var rfq = Model.StepData as TechExchangeApp.Entities.RFQRequest;
    var linhVucList = ViewBag.LinhVucList as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? new();
    var defaultLinhVuc = ViewBag.DefaultLinhVuc as string ?? "";
    var autoMaRFQ = ViewBag.AutoMaRFQ as string ?? "RFQ-" + DateTime.Now.ToString("yyyyMMddHHmmss");
    var hasFromId = (bool?)ViewBag.HasFromId ?? false;
    var isConsultant = Model.UserRole == 3; // Only consultant sees search controls
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="fas fa-file-invoice"></i> Bước 3: Yêu cầu Báo giá (RFQ)
        </h5>
        @if (rfq != null)
        {
            <button class="btn btn-light btn-sm edit-step-btn" data-step="3" data-project-id="@Model.ProjectId">
                <i class="fas fa-edit"></i> Chỉnh sửa
            </button>
        }
    </div>
    <div class="card-body">
            <i class="step-desc">
                Bên mua khởi tạo và phát hành yêu cầu cung cấp báo giá chi tiết dựa trên các tiêu chuẩn kỹ thuật đã được xác định. Chuyên viên Sàn sẽ thu thập thông tin nhu cầu để gửi cho bên bán.
            </i>
        @if (rfq != null)
        {
            <h6 class="border-bottom pb-2 mb-3"><i class="fas fa-file-invoice"></i> Thông tin Yêu cầu Báo giá</h6>
            <dl class="row">
                <dt class="col-sm-3">Mã RFQ:</dt>
                <dd class="col-sm-9"><strong>@rfq.MaRFQ</strong></dd>

                <dt class="col-sm-3">Yêu cầu kỹ thuật:</dt>
                <dd class="col-sm-9">
                    <div class="border rounded p-3 bg-light">
                        @Html.Raw(rfq.YeuCauKyThuat.Replace("\n", "<br />"))
                    </div>
                </dd>

                <dt class="col-sm-3">Tiêu chuẩn nghiệm thu:</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(rfq.TieuChuanNghiemThu))
                    {
                        <div class="border rounded p-3 bg-light">
                            @Html.Raw(rfq.TieuChuanNghiemThu.Replace("\n", "<br />"))
                        </div>
                    }
                    else
                    {
                        <span class="text-muted">Chưa cập nhật</span>
                    }
                </dd>

                <dt class="col-sm-3">Hạn chót nộp hồ sơ:</dt>
                <dd class="col-sm-9">
                    <span class="badge bg-danger">
                        <i class="fas fa-calendar-alt"></i> @rfq.HanChotNopHoSo.ToString("dd/MM/yyyy")
                    </span>
                </dd>

                <dt class="col-sm-3">Trạng thái:</dt>
                <dd class="col-sm-9">
                    @if (Model.Steps[2].StatusId > 0)
                    {
                        <span class="badge bg-success"><i class="fas fa-check"></i> Đã hoàn thành</span>
                    }
                    else
                    {
                        <span class="badge bg-warning"><i class="fas fa-clock"></i> Chưa hoàn thành</span>
                    }
                </dd>

                <dt class="col-sm-3">Ngày tạo:</dt>
                <dd class="col-sm-9">@rfq.NgayTao.ToString("dd/MM/yyyy HH:mm")</dd>

                @if (rfq.NgaySua.HasValue)
                {
                    <dt class="col-sm-3">Ngày cập nhật:</dt>
                    <dd class="col-sm-9">@rfq.NgaySua.Value.ToString("dd/MM/yyyy HH:mm")</dd>
                }
            </dl>

            @* Invited Suppliers List *@
            @if (ViewBag.InvitedSuppliers != null && ((IEnumerable<dynamic>)ViewBag.InvitedSuppliers).Any())
            {
                <hr class="my-4" />
                <div class="mb-4">
                    <h6 class="mb-3"><i class="fas fa-users"></i> Nhà cung ứng đã được mời</h6>
                    <div class="table-responsive">
                        <table class="table table-sm table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>Nhà cung ứng</th>
                                    <th>Liên hệ</th>
                                    <th>Người dùng</th>
                                    <th>Lĩnh vực</th>
                                    <th>Ngày mời</th>
                                    <th>Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var invited in (IEnumerable<dynamic>)ViewBag.InvitedSuppliers)
                                {
                                    <tr>
                                        <td><strong>@invited.FullName</strong></td>
                                        <td>
                                            <small>
                                                @if (!string.IsNullOrEmpty(invited.Email))
                                                {
                                                    <div><i class="fas fa-envelope"></i> @invited.Email</div>
                                                }
                                                @if (!string.IsNullOrEmpty(invited.Phone))
                                                {
                                                    <div><i class="fas fa-phone"></i> @invited.Phone</div>
                                                }
                                            </small>
                                        </td>
                                        <td class="small text-muted">@invited.UserName</td>
                                        <td class="small">@invited.LinhVuc</td>
                                        <td><small>@invited.InvitedDate.ToString("dd/MM/yyyy HH:mm")</small></td>
                                        <td>
                                            @{
                                                var hasProposal = invited.HasProposal;

                                                string statusText;
                                                string badgeClass;

                                                if (hasProposal)
                                                {
                                                    statusText = "Đã gửi báo giá";
                                                    badgeClass = "bg-success";
                                                }
                                                else
                                                {
                                                    statusText = invited.StatusId switch
                                                    {
                                                        0 => "Chờ phản hồi",
                                                        1 => "Đã xem",
                                                        2 => "Đã chấp nhận",
                                                        3 => "Đã từ chối",
                                                        _ => "Không xác định"
                                                    };
                                                    badgeClass = invited.StatusId switch
                                                    {
                                                        0 => "bg-warning",
                                                        1 => "bg-info",
                                                        2 => "bg-success",
                                                        3 => "bg-secondary",
                                                        _ => "bg-light"
                                                    };
                                                }
                                            }
                                            <span class="badge @badgeClass">@statusText</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            @* Searchable Supplier Invitation Section *@
            <hr class="my-4" />
            <div class="p-3 bg-light border rounded">
                <h6 class="mb-3"><i class="fas fa-search"></i> Nhà cung ứng phù hợp</h6>
                <p class="text-muted small">Nhà cung ứng phù hợp, trường hợp bạn muốn tìm thêm nhà cung ứng vui lòng liên hệ với tư vấn của Sàn.</p>

                @if (isConsultant)
                {
                <div class="row g-3 mb-3">
                    <div class="col-md-5">
                        <label class="form-label fw-semibold small">Tìm theo tên / Email / SĐT</label>
                        <input type="text" class="form-control" id="txtSearchSupplier" placeholder="Nhập tên nhà cung ứng..." />
                    </div>
                    <div class="col-md-5">
                        <label class="form-label fw-semibold small">Lĩnh vực</label>
                        <select class="form-select" id="selectFilterLinhVuc">
                            <option value="">-- Tất cả lĩnh vực --</option>
                            @foreach (var item in linhVucList)
                            {
                                if (item.Value == defaultLinhVuc)
                                {
                                    <option value="@item.Value" selected>@item.Text</option>
                                }
                                else
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button type="button" class="btn btn-success w-100" id="btnSearchSupplier">
                            <i class="fas fa-search me-1"></i> Tìm
                        </button>
                    </div>
                </div>
                }

                <div id="supplierSearchResults">
                    @if (!isConsultant && hasFromId)
                    {
                        <div class="text-center text-muted py-4">
                            <i class="fas fa-spinner fa-spin fa-2x d-block mb-2"></i>
                            Đang tải nhà cung ứng phù hợp...
                        </div>
                    }
                    else if (!isConsultant && !hasFromId)
                    {
                        <div class="text-center text-muted py-3">
                            <i class="fas fa-info-circle me-1"></i>
                            Chưa có nhà cung ứng phù hợp. Vui lòng liên hệ tư vấn của Sàn.
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            <i class="fas fa-users fa-2x d-block mb-2"></i>
                            Nhấn <strong>Tìm</strong> để hiển thị nhà cung ứng
                        </div>
                    }
                </div>
            </div>

            <script>
                (function () {
                    var projectId = @Model.ProjectId;
                    var rfqId = @rfq.Id;

                    // Local showToast: delegates to parent page's showToast if available, else self-creates
                    function showToast(type, message) {
                        if (typeof window.showToast === 'function' && window.showToast !== showToast) {
                            window.showToast(type, message);
                            return;
                        }
                        var typeMap = {
                            'success': 'bg-success text-white',
                            'warning': 'bg-warning text-dark',
                            'danger': 'bg-danger text-white',
                            'error': 'bg-danger text-white',
                            'info': 'bg-info text-white'
                        };
                        var cls = typeMap[type] || typeMap['info'];
                        var $t = $('<div class="position-fixed top-0 end-0 p-3" style="z-index:9999"><div class="toast show ' + cls + '" role="alert"><div class="toast-body"><i class="fas fa-info-circle"></i> ' + message + '</div></div></div>');
                        $('body').append($t);
                        setTimeout(function () { $t.fadeOut(function () { $(this).remove(); }); }, 3000);
                    }

                    // Select2 for category filter
                    $('#selectFilterLinhVuc').select2({
                        theme: 'bootstrap-5',
                        placeholder: '-- Tất cả lĩnh vực --',
                        allowClear: true,
                        width: '100%'
                    });

                    var currentPage = 1;
                    var hasFromId = @(hasFromId ? "true" : "false");
                    var isConsultant = @(isConsultant ? "true" : "false");

                    // Auto-search: for non-consultant with FromId, or consultant with default lĩnh vực
                    var defaultLV = '@Html.Raw(defaultLinhVuc)';
                    if ((!isConsultant && hasFromId) || (isConsultant && defaultLV)) {
                        searchSuppliers(1);
                    }

                    $('#btnSearchSupplier').on('click', function () {
                        searchSuppliers(1);
                    });

                    $('#txtSearchSupplier').on('keypress', function (e) {
                        if (e.which === 13) {
                            e.preventDefault();
                            searchSuppliers(1);
                        }
                    });

                    function searchSuppliers(page) {
                        currentPage = page || 1;
                        var search = $('#txtSearchSupplier').val();
                        var linhVuc = $('#selectFilterLinhVuc').val();

                        $('#supplierSearchResults').html('<div class="text-center py-4"><i class="fas fa-spinner fa-spin fa-2x text-muted"></i></div>');

                        $.getJSON('/RFQ/SearchSuppliers', {
                            projectId: projectId,
                            search: search,
                            linhVuc: linhVuc,
                            page: currentPage
                        }, function (resp) {
                            var data = resp.data;
                            var totalCount = resp.totalCount;
                            var totalPages = resp.totalPages;
                            currentPage = resp.currentPage;

                            if (!data || data.length === 0) {
                                $('#supplierSearchResults').html(
                                    '<div class="text-center text-muted py-4"><i class="fas fa-inbox fa-2x d-block mb-2"></i>Không tìm thấy nhà cung ứng phù hợp.</div>'
                                );
                                return;
                            }

                            var html = '<form method="post" action="/RFQ/SendToSuppliers/' + rfqId + '" id="sendRfqForm">';
                            html += '<input type="hidden" name="__RequestVerificationToken" value="' + $('input[name=__RequestVerificationToken]').first().val() + '" />';
                            html += '<div class="table-responsive"><table class="table table-hover table-striped table-bordered align-middle mb-0">';
                            html += '<thead class="table-light"><tr>';
                            html += '<th class="text-center" style="width:50px"><input type="checkbox" id="checkAllSuppliers" title="Chọn tất cả" /></th>';
                            html += '<th>Tên nhà cung ứng</th>';
                            html += '<th>Địa chỉ</th>';
                            html += '<th>Email</th>';
                            html += '<th>Điện thoại</th>';
                            html += '<th>Username</th>';
                            html += '<th>Lĩnh vực</th>';
                            html += '</tr></thead><tbody>';

                            $.each(data, function (i, s) {
                                html += '<tr>';
                                html += '<td class="text-center"><input type="checkbox" name="selectedSellerIds" class="chk-supplier" value="' + s.userId + '" /></td>';
                                html += '<td class="fw-semibold">' + escapeHtml(s.fullName) + '</td>';
                                html += '<td class="small">' + escapeHtml(s.diaChi) + '</td>';
                                html += '<td class="small"><a href="mailto:' + escapeHtml(s.email) + '">' + escapeHtml(s.email) + '</a></td>';
                                html += '<td class="small">' + escapeHtml(s.phone) + '</td>';
                                html += '<td class="small text-muted">' + escapeHtml(s.userName) + '</td>';
                                html += '<td class="small">' + escapeHtml(s.linhVuc) + '</td>';
                                html += '</tr>';
                            });

                            html += '</tbody></table></div>';

                            // Pagination + info bar
                            html += '<div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-2">';
                            html += '<span class="text-muted small">Tìm thấy <strong>' + totalCount + '</strong> nhà cung ứng (Trang ' + currentPage + '/' + totalPages + ')</span>';

                            // Pagination buttons
                            if (totalPages > 1) {
                                html += '<nav><ul class="pagination pagination-sm mb-0">';
                                // First page
                                html += '<li class="page-item ' + (currentPage <= 1 ? 'disabled' : '') + '"><a class="page-link page-nav" href="#" data-page="1" title="Trang đầu">&laquo;&laquo;</a></li>';
                                // Previous page
                                html += '<li class="page-item ' + (currentPage <= 1 ? 'disabled' : '') + '"><a class="page-link page-nav" href="#" data-page="' + (currentPage - 1) + '" title="Trang trước">&laquo;</a></li>';
                                // Page window: 5 before + current + 5 after
                                var startPage = Math.max(1, currentPage - 5);
                                var endPage = Math.min(totalPages, currentPage + 5);
                                for (var p = startPage; p <= endPage; p++) {
                                    html += '<li class="page-item ' + (p === currentPage ? 'active' : '') + '"><a class="page-link page-nav" href="#" data-page="' + p + '">' + p + '</a></li>';
                                }
                                // Next page
                                html += '<li class="page-item ' + (currentPage >= totalPages ? 'disabled' : '') + '"><a class="page-link page-nav" href="#" data-page="' + (currentPage + 1) + '" title="Trang sau">&raquo;</a></li>';
                                // Last page
                                html += '<li class="page-item ' + (currentPage >= totalPages ? 'disabled' : '') + '"><a class="page-link page-nav" href="#" data-page="' + totalPages + '" title="Trang cuối">&raquo;&raquo;</a></li>';
                                html += '</ul></nav>';
                            }

                            html += '<button type="submit" class="btn btn-warning" id="btnInviteSelected" disabled>';
                            html += '<i class="fas fa-paper-plane me-1"></i> Mời nhà cung ứng đã chọn</button>';
                            html += '</div></form>';

                            $('#supplierSearchResults').html(html);

                            // Pagination click
                            $(document).off('click', '.page-nav').on('click', '.page-nav', function (e) {
                                e.preventDefault();
                                var p = parseInt($(this).data('page'));
                                if (p >= 1 && p <= totalPages) searchSuppliers(p);
                            });

                            // Check all
                            $('#checkAllSuppliers').on('change', function () {
                                $('.chk-supplier').prop('checked', $(this).prop('checked'));
                                updateInviteBtn();
                            });

                            $('.chk-supplier').on('change', function () {
                                updateInviteBtn();
                            });

                            // Submit via AJAX to stay on Step 3
                            $('#sendRfqForm').on('submit', function (e) {
                                e.preventDefault();
                                var count = $('.chk-supplier:checked').length;
                                if (count === 0) {
                                    showToast('warning', 'Vui lòng chọn ít nhất một nhà cung ứng!');
                                    return;
                                }

                                var form = $(this);
                                var btn = $('#btnInviteSelected');
                                btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-1"></i> Đang gửi...');

                                $.ajax({
                                    url: form.attr('action'),
                                    type: 'POST',
                                    data: form.serialize(),
                                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                                    success: function (resp) {
                                        if (resp.success) {
                                            showToast('success', resp.message);
                                            // Reload step 3 content to refresh invited list
                                            $.get('/Project/Step', { projectId: projectId, stepNumber: 3 }, function (data) {
                                                $('#step-content').html(data);
                                            });
                                        } else {
                                            showToast('error', resp.message || 'Có lỗi xảy ra.');
                                            btn.prop('disabled', false).html('<i class="fas fa-paper-plane me-1"></i> Mời nhà cung ứng đã chọn');
                                        }
                                    },
                                    error: function () {
                                        showToast('error', 'Lỗi kết nối. Vui lòng thử lại.');
                                        btn.prop('disabled', false).html('<i class="fas fa-paper-plane me-1"></i> Mời nhà cung ứng đã chọn');
                                    }
                                });
                            });
                        });
                    }

                    function updateInviteBtn() {
                        var count = $('.chk-supplier:checked').length;
                        $('#btnInviteSelected').prop('disabled', count === 0);
                        if (count > 0) {
                            $('#btnInviteSelected').html('<i class="fas fa-paper-plane me-1"></i> Mời ' + count + ' nhà cung ứng đã chọn');
                        } else {
                            $('#btnInviteSelected').html('<i class="fas fa-paper-plane me-1"></i> Mời nhà cung ứng đã chọn');
                        }
                    }

                    function escapeHtml(str) {
                        if (!str) return '';
                        return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
                    }
                })();
            </script>
        }
        else
        {
            @* No RFQ yet - Show creation form *@
            <div class="alert alert-info">
                <i class="fas fa-info-circle"></i>
                <strong>Tạo Yêu cầu Báo giá (RFQ)</strong>
            </div>

            <div class="p-4 bg-light border rounded">
                <h6 class="mb-3"><i class="fas fa-file-invoice"></i> Thông tin Yêu cầu Báo giá</h6>
                <form id="createRfqForm" method="post" action="/RFQ/Create">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ProjectId" value="@Model.ProjectId" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Mã RFQ</label>
                            <input type="text" class="form-control bg-light" name="MaRFQ" id="maRFQ"
                                   value="@autoMaRFQ" readonly />
                            <small class="text-muted">Mã RFQ được tự động sinh</small>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Hạn chót nộp hồ sơ <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" name="HanChotNopHoSo" id="hanChotNopHoSo" required />
                            <small class="text-muted">Ngày cuối cùng nhà cung ứng có thể nộp báo giá</small>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Yêu cầu kỹ thuật <span class="text-danger">*</span></label>
                        <textarea class="form-control" name="YeuCauKyThuat" id="yeuCauKyThuat" rows="6" required
                                  placeholder="Mô tả chi tiết các yêu cầu kỹ thuật cho sản phẩm/dịch vụ..."></textarea>
                        <small class="text-muted">Mô tả chi tiết các yêu cầu kỹ thuật, thông số kỹ thuật, tiêu chuẩn cần đáp ứng</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Tiêu chuẩn nghiệm thu</label>
                        <textarea class="form-control" name="TieuChuanNghiemThu" id="tieuChuanNghiemThu" rows="4"
                                  placeholder="Mô tả các tiêu chuẩn nghiệm thu sản phẩm/dịch vụ..."></textarea>
                        <small class="text-muted">Các tiêu chí đánh giá và nghiệm thu sản phẩm/dịch vụ (không bắt buộc)</small>
                    </div>

                    <hr class="my-3" />

                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input" id="xacNhanThongTin" required />
                        <label class="form-check-label" for="xacNhanThongTin">
                            Tôi xác nhận các thông tin trên là chính xác và đầy đủ <span class="text-danger">*</span>
                        </label>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="fas fa-save"></i> Tạo Yêu cầu Báo giá
                    </button>
                </form>
            </div>
        }
    </div>
    <div class="card-footer">
        <button class="btn btn-secondary step-nav-btn" data-step="@(Model.StepNumber - 1)">
            <i class="fas fa-arrow-left"></i> Quay lại bước trước
        </button>
        @if (rfq != null && Model.StepNumber < 11 && Model.Steps[Model.StepNumber].IsAccessible)
        {
            <button class="btn btn-primary step-nav-btn" data-step="@(Model.StepNumber + 1)">
                Tiếp tục bước @(Model.StepNumber + 1) <i class="fas fa-arrow-right"></i>
            </button>
        }
    </div>
</div>

<script>
    // Set minimum date to today for deadline picker
    (function setMinDate() {
        var dateInput = document.getElementById('hanChotNopHoSo');
        if (dateInput) {
            dateInput.setAttribute('min', new Date().toISOString().split('T')[0]);
        }
    })();

    // Wait for jQuery then bind AJAX submit
    (function waitForJQuery() {
        if (typeof $ === 'undefined' || typeof jQuery === 'undefined') {
            setTimeout(waitForJQuery, 50);
            return;
        }

        // Ensure showToast is available
        if (typeof showToast !== 'function') {
            window.showToast = function(type, message) {
                var container = document.getElementById('toast-container');
                if (!container) {
                    container = document.createElement('div');
                    container.id = 'toast-container';
                    container.className = 'position-fixed top-0 end-0 p-3';
                    container.style.zIndex = '9999';
                    document.body.appendChild(container);
                }
                var bgClass = type === 'success' ? 'bg-success' : (type === 'error' || type === 'danger') ? 'bg-danger' : 'bg-warning';
                var html = '<div class="toast align-items-center text-white ' + bgClass + ' border-0 show" role="alert">' +
                    '<div class="d-flex"><div class="toast-body">' + message + '</div>' +
                    '<button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div></div>';
                container.insertAdjacentHTML('beforeend', html);
                var toast = container.lastElementChild;
                setTimeout(function() { toast.remove(); }, 5000);
            };
        }

        // AJAX submit for RFQ creation form
        $(document).on('submit', '#createRfqForm', function(e) {
            e.preventDefault();
            var form = $(this);
            var btn = form.find('button[type="submit"]');
            btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-1"></i> Đang tạo...');

            $.ajax({
                url: form.attr('action'),
                type: 'POST',
                data: form.serialize(),
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                success: function(resp) {
                    if (resp.success) {
                        showToast('success', '✅ ' + resp.message);
                        // Reload step 3 content
                        $.get('/Project/Step', { projectId: @Model.ProjectId, stepNumber: 3 }, function(data) {
                            $('#step-content').html(data);
                        });
                    } else {
                        showToast('danger', '❌ ' + (resp.message || 'Có lỗi xảy ra.'));
                        btn.prop('disabled', false).html('<i class="fas fa-save"></i> Tạo Yêu cầu Báo giá');
                    }
                },
                error: function() {
                    showToast('danger', 'Lỗi kết nối. Vui lòng thử lại.');
                    btn.prop('disabled', false).html('<i class="fas fa-save"></i> Tạo Yêu cầu Báo giá');
                }
            });
        });
    })();
</script>
