@model TechExchangeApp.ViewModel.StepContentVm
@using Microsoft.EntityFrameworkCore
@inject TechExchangeApp.Data.AppDbContext DbCtx

@{
    var techDoc = Model.StepData as TechExchangeApp.Entities.TechnicalDocHandover;
    if (techDoc == null)
    {
        techDoc = await DbCtx.TechnicalDocHandovers
            .FirstOrDefaultAsync(x => x.ProjectId == Model.ProjectId);
    }
    bool hasData = techDoc != null;
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="fas fa-file-code"></i> Bước 12: Bàn giao Hồ sơ Kỹ thuật
        </h5>
        @if (hasData)
        {
            <button class="btn btn-light btn-sm" id="s12EditToggle" onclick="s12_toggleEdit()">
                <i class="fas fa-edit"></i> Chỉnh sửa
            </button>
        }
    </div>
    <div class="card-body">
        <i class="step-desc">
            Toàn bộ bản vẽ thiết kế, thông số kỹ thuật và sổ tay hướng dẫn sử dụng sẽ được bàn giao đầy đủ làm cơ sở pháp lý và kỹ thuật cho công tác bảo trì sau này.
        </i>
        <!-- ═══ Display Mode ═══ -->
        <div id="s12Display" class="@(!hasData ? "d-none" : "")">
            @if (hasData)
            {
                <dl class="row mb-0">
                    <dt class="col-sm-4">Source Code:</dt>
                    <dd class="col-sm-8">
                        @if (!string.IsNullOrEmpty(techDoc!.SourceCode))
                        {
                            <span><i class="fas fa-code text-success me-1"></i><strong>@techDoc.SourceCode</strong></span>
                        }
                        else { <span class="text-muted">Chưa có</span> }
                    </dd>

                    <dt class="col-sm-4">Tài liệu kỹ thuật:</dt>
                    <dd class="col-sm-8">
                        @if (!string.IsNullOrEmpty(techDoc.TaiLieuKyThuat))
                        {
                            <a href="@techDoc.TaiLieuKyThuat" target="_blank" class="text-decoration-none">
                                <i class="fas fa-file-pdf text-danger me-1"></i><strong>@System.IO.Path.GetFileName(techDoc.TaiLieuKyThuat)</strong>
                            </a>
                        }
                        else { <span class="text-muted">Chưa có file</span> }
                    </dd>

                    <dt class="col-sm-4">Tài liệu hướng dẫn sử dụng:</dt>
                    <dd class="col-sm-8">
                        @if (!string.IsNullOrEmpty(techDoc.TaiLieuHuongDanSuDung))
                        {
                            <a href="@techDoc.TaiLieuHuongDanSuDung" target="_blank" class="text-decoration-none">
                                <i class="fas fa-book text-primary me-1"></i><strong>@System.IO.Path.GetFileName(techDoc.TaiLieuHuongDanSuDung)</strong>
                            </a>
                        }
                        else { <span class="text-muted">Chưa có file</span> }
                    </dd>

                    <dt class="col-sm-4">Tài liệu bảo trì:</dt>
                    <dd class="col-sm-8">
                        @if (!string.IsNullOrEmpty(techDoc.TaiLieuBaoTri))
                        {
                            <a href="@techDoc.TaiLieuBaoTri" target="_blank" class="text-decoration-none">
                                <i class="fas fa-tools text-warning me-1"></i><strong>@System.IO.Path.GetFileName(techDoc.TaiLieuBaoTri)</strong>
                            </a>
                        }
                        else { <span class="text-muted">Chưa có file</span> }
                    </dd>

                    <dt class="col-sm-4">Database:</dt>
                    <dd class="col-sm-8">
                        @if (!string.IsNullOrEmpty(techDoc.Database))
                        {
                            <span><i class="fas fa-database text-info me-1"></i><strong>@techDoc.Database</strong></span>
                        }
                        else { <span class="text-muted">Chưa có</span> }
                    </dd>

                    @if (!string.IsNullOrEmpty(techDoc.GhiChu))
                    {
                        <dt class="col-sm-4">Ghi chú:</dt>
                        <dd class="col-sm-8">
                            <div class="border rounded p-2 bg-light">@Html.Raw(techDoc.GhiChu.Replace("\n", "<br />"))</div>
                        </dd>
                    }

                    <dt class="col-sm-4">Đã bàn giao đầy đủ:</dt>
                    <dd class="col-sm-8">
                        @if (techDoc.DaBanGiaoDayDu)
                        {
                            <span class="badge bg-success"><i class="fas fa-check"></i> Đã bàn giao đầy đủ</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark"><i class="fas fa-clock"></i> Chưa đầy đủ</span>
                        }
                    </dd>

                    @if (techDoc.NgayBanGiao.HasValue)
                    {
                        <dt class="col-sm-4">Ngày bàn giao:</dt>
                        <dd class="col-sm-8">@techDoc.NgayBanGiao.Value.ToString("dd/MM/yyyy")</dd>
                    }

                    <dt class="col-sm-4">Ngày tạo:</dt>
                    <dd class="col-sm-8">@techDoc.NgayTao.ToString("dd/MM/yyyy HH:mm")</dd>

                    @if (techDoc.NgaySua.HasValue)
                    {
                        <dt class="col-sm-4">Cập nhật lần cuối:</dt>
                        <dd class="col-sm-8">@techDoc.NgaySua.Value.ToString("dd/MM/yyyy HH:mm")</dd>
                    }
                </dl>
            }
        </div>

        <!-- ═══ Form Mode ═══ -->
        <div id="s12Form" class="@(hasData ? "d-none" : "")">
            <form id="s12TechDocForm" enctype="multipart/form-data">
                <input type="hidden" name="projectId" value="@Model.ProjectId" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-code me-1 text-success"></i>Source Code (URL hoặc mô tả)
                        </label>
                        <input type="text" class="form-control" name="SourceCode"
                               value="@(techDoc?.SourceCode ?? "")"
                               placeholder="VD: https://github.com/... hoặc đường dẫn" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-database me-1 text-info"></i>Database (URL hoặc mô tả)
                        </label>
                        <input type="text" class="form-control" name="Database"
                               value="@(techDoc?.Database ?? "")"
                               placeholder="VD: SQL Server, connection string..." />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-file-pdf me-1 text-danger"></i>Tài liệu kỹ thuật
                        </label>
                        <input type="file" class="form-control" name="TaiLieuKyThuatFile"
                               accept=".pdf,.doc,.docx" />
                        <small class="text-muted">PDF, Word — tối đa 10MB</small>
                        @if (hasData && !string.IsNullOrEmpty(techDoc!.TaiLieuKyThuat))
                        {
                            <div class="mt-1 small text-success">
                                <span><i class="fas fa-check-circle me-1"></i>File hiện tại: @System.IO.Path.GetFileName(techDoc.TaiLieuKyThuat)</span>
                            </div>
                        }
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-book me-1 text-primary"></i>Tài liệu hướng dẫn SD
                        </label>
                        <input type="file" class="form-control" name="TaiLieuHuongDanFile"
                               accept=".pdf,.doc,.docx" />
                        <small class="text-muted">PDF, Word — tối đa 10MB</small>
                        @if (hasData && !string.IsNullOrEmpty(techDoc!.TaiLieuHuongDanSuDung))
                        {
                            <div class="mt-1 small text-success">
                                <span><i class="fas fa-check-circle me-1"></i>File hiện tại: @System.IO.Path.GetFileName(techDoc.TaiLieuHuongDanSuDung)</span>
                            </div>
                        }
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-tools me-1 text-warning"></i>Tài liệu bảo trì
                        </label>
                        <input type="file" class="form-control" name="TaiLieuBaoTriFile"
                               accept=".pdf,.doc,.docx" />
                        <small class="text-muted">PDF, Word — tối đa 10MB</small>
                        @if (hasData && !string.IsNullOrEmpty(techDoc!.TaiLieuBaoTri))
                        {
                            <div class="mt-1 small text-success">
                                <span><i class="fas fa-check-circle me-1"></i>File hiện tại: @System.IO.Path.GetFileName(techDoc.TaiLieuBaoTri)</span>
                            </div>
                        }
                    </div>

                    <div class="col-12">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-sticky-note me-1 text-secondary"></i>Ghi chú
                        </label>
                        <textarea class="form-control" name="GhiChu" rows="2"
                                  placeholder="Ghi chú thêm (nếu có)...">@(techDoc?.GhiChu ?? "")</textarea>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-calendar-check me-1 text-success"></i>Ngày bàn giao
                        </label>
                        <input type="date" class="form-control" name="NgayBanGiao"
                               value="@(techDoc?.NgayBanGiao?.ToString("yyyy-MM-dd") ?? "")" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-check-double me-1 text-success"></i>Bàn giao đầy đủ
                        </label>
                        <div class="form-check form-switch mt-2">
                            <input class="form-check-input" type="checkbox" name="DaBanGiaoDayDu" id="s12DaBanGiao"
                                   @(techDoc?.DaBanGiaoDayDu == true ? "checked" : "") />
                            <label class="form-check-label" for="s12DaBanGiao">Đã bàn giao đầy đủ hồ sơ</label>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="button" class="btn btn-primary px-4" onclick="s12_save()">
                        <i class="fas fa-save me-1"></i>@(hasData ? "Cập nhật" : "Lưu")
                    </button>
                    @if (hasData)
                    {
                        <button type="button" class="btn btn-outline-secondary" onclick="s12_cancelEdit()">
                            <i class="fas fa-times me-1"></i>Hủy
                        </button>
                    }
                </div>
            </form>
        </div>

    </div>
    <div class="card-footer bg-white d-flex justify-content-between">
        <button class="btn btn-outline-secondary step-nav-btn" data-step="@(Model.StepNumber - 1)">
            <i class="fas fa-arrow-left"></i> Quay lại bước trước
        </button>
        @if (Model.StepNumber < 14 && Model.Steps.Count > Model.StepNumber && Model.Steps[Model.StepNumber].IsAccessible)
        {
            <button class="btn btn-primary step-nav-btn" data-step="@(Model.StepNumber + 1)">
                Tiếp tục bước @(Model.StepNumber + 1) <i class="fas fa-arrow-right"></i>
            </button>
        }
    </div>
</div>

<script>
    function s12_toggleEdit() {
        document.getElementById('s12Display').classList.add('d-none');
        document.getElementById('s12Form').classList.remove('d-none');
        document.getElementById('s12EditToggle').classList.add('d-none');
    }
    function s12_cancelEdit() {
        document.getElementById('s12Display').classList.remove('d-none');
        document.getElementById('s12Form').classList.add('d-none');
        document.getElementById('s12EditToggle').classList.remove('d-none');
    }

    async function s12_save() {
        const form = document.getElementById('s12TechDocForm');
        const fd = new FormData(form);
        fd.set('DaBanGiaoDayDu', document.getElementById('s12DaBanGiao').checked ? 'true' : 'false');

        const btn = event.target.closest('button');
        const origHtml = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang lưu...';

        try {
            const r = await fetch('/TechDoc/SaveInline', { method: 'POST', body: fd });
            const d = await r.json();
            if (d.success) {
                s12_toast(d.message || '✅ Đã lưu!', 'success');
                setTimeout(() => {
                    const stepBtn = document.querySelector('.step-nav-btn[data-step="12"], [data-step-number="12"]');
                    if (stepBtn) stepBtn.click(); else location.reload();
                }, 1000);
            } else {
                s12_toast(d.message || 'Lỗi khi lưu.', 'danger');
            }
        } catch (e) {
            s12_toast('Lỗi kết nối: ' + e.message, 'danger');
        } finally {
            btn.disabled = false;
            btn.innerHTML = origHtml;
        }
    }

    function s12_toast(msg, type = 'success') {
        const t = document.createElement('div');
        t.className = `toast align-items-center text-bg-${type} border-0 show position-fixed bottom-0 end-0 m-3`;
        t.style = 'z-index:9999;min-width:280px';
        t.innerHTML = `<div class="d-flex"><div class="toast-body">${msg}</div>
            <button class="btn-close btn-close-white me-2 m-auto" onclick="this.closest('.toast').remove()"></button></div>`;
        document.body.appendChild(t);
        setTimeout(() => t.remove(), 5000);
    }
</script>
