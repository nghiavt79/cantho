@model TechExchangeApp.ViewModel.StepContentVm
@using Microsoft.EntityFrameworkCore
@inject TechExchangeApp.Data.AppDbContext DbCtx

@{
    var acceptance = Model.StepData as TechExchangeApp.Entities.AcceptanceReport;
    if (acceptance == null)
    {
        acceptance = await DbCtx.AcceptanceReports
            .FirstOrDefaultAsync(x => x.ProjectId == Model.ProjectId);
    }
    bool hasData = acceptance != null;

    // Derive buyer/seller
    var proj13 = await DbCtx.Projects.FindAsync(Model.ProjectId);
    var userIdStr = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0";
    int currentUserId = int.TryParse(userIdStr, out int uid13) ? uid13 : 0;

    bool isBuyer  = proj13?.CreatedBy == currentUserId;
    bool isSeller = proj13?.SelectedSellerId == currentUserId;

    var buyerName = proj13?.CreatedBy.HasValue == true
        ? (await DbCtx.Users.AsNoTracking().Where(u => u.Id == proj13.CreatedBy.Value).Select(u => u.FullName ?? u.UserName).FirstOrDefaultAsync()) ?? "Bên A"
        : "Bên A";
    var sellerName = proj13?.SelectedSellerId.HasValue == true
        ? (await DbCtx.Users.AsNoTracking().Where(u => u.Id == proj13.SelectedSellerId.Value).Select(u => u.FullName ?? u.UserName).FirstOrDefaultAsync()) ?? "Bên B"
        : "Bên B";

    bool benASigned = hasData && !string.IsNullOrEmpty(acceptance!.ChuKyBenA);
    bool benBSigned = hasData && !string.IsNullOrEmpty(acceptance!.ChuKyBenB);
    bool fullySigned = benASigned && benBSigned;
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="fas fa-clipboard-check"></i> Bước 13: Nghiệm thu
        </h5>
        @if (fullySigned)
        {
            <span class="badge bg-success fs-6"><i class="fas fa-check-double me-1"></i>Đã ký đầy đủ</span>
        }
        else if (hasData)
        {
            <button class="btn btn-light btn-sm" id="s13EditToggle" onclick="s13_toggleEdit()">
                <i class="fas fa-edit"></i> Chỉnh sửa
            </button>
        }
    </div>
    <div class="card-body">
        <i class="step-desc">
            Hai bên sẽ cùng đối soát, kiểm tra toàn diện chất lượng dự án thực tế và chính thức ký kết biên bản nghiệm thu khi mọi tiêu chuẩn đã được đáp ứng.
        </i>
        <!-- ═══ Display Mode ═══ -->
        <div id="s13Display" class="@(!hasData ? "d-none" : "")">
            @if (hasData)
            {
                <dl class="row mb-3">
                    <dt class="col-sm-4">Ngày nghiệm thu:</dt>
                    <dd class="col-sm-8"><strong>@acceptance!.NgayNghiemThu.ToString("dd/MM/yyyy")</strong></dd>

                    @if (!string.IsNullOrEmpty(acceptance.ThanhPhanThamGia))
                    {
                        <dt class="col-sm-4">Thành phần tham gia:</dt>
                        <dd class="col-sm-8">
                            <div class="border rounded p-2 bg-light">@Html.Raw(acceptance.ThanhPhanThamGia.Replace("\n", "<br />"))</div>
                        </dd>
                    }

                    <dt class="col-sm-4">Kết luận nghiệm thu:</dt>
                    <dd class="col-sm-8">
                        @if (!string.IsNullOrEmpty(acceptance.KetLuanNghiemThu))
                        {
                            <div class="border rounded p-2 bg-light">@Html.Raw(acceptance.KetLuanNghiemThu.Replace("\n", "<br />"))</div>
                        }
                        else { <span class="text-muted">Chưa có kết luận</span> }
                    </dd>

                    @if (!string.IsNullOrEmpty(acceptance.VanDeTonDong))
                    {
                        <dt class="col-sm-4">Vấn đề tồn đọng:</dt>
                        <dd class="col-sm-8">
                            <div class="alert alert-warning mb-0">@Html.Raw(acceptance.VanDeTonDong.Replace("\n", "<br />"))</div>
                        </dd>
                    }

                    <dt class="col-sm-4">Ngày tạo:</dt>
                    <dd class="col-sm-8">@acceptance.NgayTao.ToString("dd/MM/yyyy HH:mm")</dd>
                </dl>

                <!-- ═══ Signing Section ═══ -->
                @if (fullySigned)
                {
                    <div class="alert alert-success d-flex align-items-center gap-3">
                        <i class="fas fa-check-circle fa-3x"></i>
                        <div>
                            <strong class="d-block fs-5">Biên bản nghiệm thu đã được ký đầy đủ!</strong>
                            <span>@buyerName (Bên A) đã ký</span> &nbsp;|&nbsp;
                            <span>@sellerName (Bên B) đã ký</span>
                        </div>
                    </div>
                }
                else
                {
                    <hr />
                    <h6 class="fw-bold mb-3"><i class="fas fa-signature me-1"></i>Ký xác nhận nghiệm thu</h6>
                    <div class="row g-4">
                        <!-- Bên A (Buyer) -->
                        <div class="col-md-6">
                            <div class="card h-100 border-0 shadow-sm @(benASigned ? "border-success" : "")">
                                <div class="card-header bg-white border-bottom d-flex align-items-center gap-2">
                                    <i class="fas fa-user text-primary"></i>
                                    <strong>@buyerName (Bên A) – Ký OTP</strong>
                                    @if (benASigned)
                                    {<span class="badge bg-success ms-auto">✓ Đã ký</span>}
                                </div>
                                <div class="card-body">
                                    @if (benASigned)
                                    {
                                        <div class="text-center py-4">
                                            <i class="fas fa-check-circle fa-3x text-success mb-2"></i>
                                            <p class="text-success fw-bold">@buyerName đã ký thành công</p>
                                        </div>
                                    }
                                    else if (isBuyer)
                                    {
                                        <h6 class="card-title mb-3"><i class="fas fa-shield-alt me-1"></i>Ký xác nhận bằng OTP</h6>
                                        <div id="s13BenAStep1">
                                            <button class="btn btn-primary w-100 py-2" onclick="s13_requestOtp('benA')">
                                                <i class="fas fa-pen-nib me-1"></i>Gửi OTP & Ký xác nhận
                                            </button>
                                        </div>
                                        <div id="s13BenAStep2" class="d-none">
                                            <label class="form-label fw-semibold">Nhập mã OTP</label>
                                            <div class="input-group mb-2">
                                                <input type="text" id="s13BenAOtp" class="form-control form-control-lg text-center fw-bold"
                                                       placeholder="_ _ _ _ _ _" maxlength="6" inputmode="numeric" style="letter-spacing:6px" />
                                                <button class="btn btn-outline-secondary" onclick="s13_requestOtp('benA')">Gửi lại</button>
                                            </div>
                                            <div id="s13BenATimer" class="text-muted small text-center mb-3"></div>
                                            <button class="btn btn-success w-100 py-2" onclick="s13_verifyOtp('benA')">
                                                <i class="fas fa-lock me-1"></i>Xác nhận & Ký
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-center py-4 text-muted">
                                            <i class="fas fa-clock fa-2x mb-2"></i>
                                            <p>Đang chờ @buyerName (Bên A) ký…</p>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Bên B (Seller) -->
                        <div class="col-md-6">
                            <div class="card h-100 border-0 shadow-sm @(benBSigned ? "border-success" : "")">
                                <div class="card-header bg-white border-bottom d-flex align-items-center gap-2">
                                    <i class="fas fa-building text-warning"></i>
                                    <strong>@sellerName (Bên B) – Ký OTP</strong>
                                    @if (benBSigned)
                                    {<span class="badge bg-success ms-auto">✓ Đã ký</span>}
                                </div>
                                <div class="card-body">
                                    @if (benBSigned)
                                    {
                                        <div class="text-center py-4">
                                            <i class="fas fa-check-circle fa-3x text-success mb-2"></i>
                                            <p class="text-success fw-bold">@sellerName đã ký thành công</p>
                                        </div>
                                    }
                                    else if (isSeller)
                                    {
                                        <h6 class="card-title mb-3"><i class="fas fa-shield-alt me-1"></i>Ký xác nhận bằng OTP</h6>
                                        <div id="s13BenBStep1">
                                            <button class="btn btn-warning w-100 py-2" onclick="s13_requestOtp('benB')">
                                                <i class="fas fa-pen-nib me-1"></i>Gửi OTP & Ký xác nhận
                                            </button>
                                        </div>
                                        <div id="s13BenBStep2" class="d-none">
                                            <label class="form-label fw-semibold">Nhập mã OTP</label>
                                            <div class="input-group mb-2">
                                                <input type="text" id="s13BenBOtp" class="form-control form-control-lg text-center fw-bold"
                                                       placeholder="_ _ _ _ _ _" maxlength="6" inputmode="numeric" style="letter-spacing:6px" />
                                                <button class="btn btn-outline-secondary" onclick="s13_requestOtp('benB')">Gửi lại</button>
                                            </div>
                                            <div id="s13BenBTimer" class="text-muted small text-center mb-3"></div>
                                            <button class="btn btn-success w-100 py-2" onclick="s13_verifyOtp('benB')">
                                                <i class="fas fa-lock me-1"></i>Xác nhận & Ký
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-center py-4 text-muted">
                                            <i class="fas fa-clock fa-2x mb-2"></i>
                                            <p>Đang chờ @sellerName (Bên B) ký…</p>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        <!-- ═══ Form Mode ═══ -->
        <div id="s13Form" class="@(hasData ? "d-none" : "")">
            <form id="s13AcceptForm">
                <input type="hidden" name="projectId" value="@Model.ProjectId" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-calendar-day me-1 text-primary"></i>Ngày nghiệm thu <span class="text-danger">*</span>
                        </label>
                        <input type="date" class="form-control" name="NgayNghiemThu" id="s13NgayNT"
                               value="@(acceptance?.NgayNghiemThu.ToString("yyyy-MM-dd") ?? DateTime.Now.ToString("yyyy-MM-dd"))" required />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-users me-1 text-info"></i>Thành phần tham gia
                        </label>
                        <textarea class="form-control" name="ThanhPhanThamGia" rows="2"
                                  placeholder="Danh sách thành viên tham gia...">@(acceptance?.ThanhPhanThamGia ?? "")</textarea>
                    </div>

                    <div class="col-12">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-gavel me-1 text-success"></i>Kết luận nghiệm thu
                        </label>
                        <textarea class="form-control" name="KetLuanNghiemThu" rows="3"
                                  placeholder="Kết luận của hội đồng nghiệm thu...">@(acceptance?.KetLuanNghiemThu ?? "")</textarea>
                    </div>

                    <div class="col-12">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-exclamation-triangle me-1 text-warning"></i>Vấn đề tồn đọng
                        </label>
                        <textarea class="form-control" name="VanDeTonDong" rows="2"
                                  placeholder="Các vấn đề cần giải quyết (nếu có)...">@(acceptance?.VanDeTonDong ?? "")</textarea>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="button" class="btn btn-primary px-4" onclick="s13_save()">
                        <i class="fas fa-save me-1"></i>@(hasData ? "Cập nhật" : "Lưu")
                    </button>
                    @if (hasData)
                    {
                        <button type="button" class="btn btn-outline-secondary" onclick="s13_cancelEdit()">
                            <i class="fas fa-times me-1"></i>Hủy
                        </button>
                    }
                </div>
            </form>
        </div>

    </div>
    <div class="card-footer bg-white d-flex justify-content-between">
        <button class="btn btn-outline-secondary step-nav-btn" data-step="@(Model.StepNumber - 1)">
            <i class="fas fa-arrow-left"></i> Quay lại bước trước
        </button>
        @if (Model.StepNumber < 14 && Model.Steps.Count > Model.StepNumber && Model.Steps[Model.StepNumber].IsAccessible)
        {
            <button class="btn btn-primary step-nav-btn" data-step="@(Model.StepNumber + 1)">
                Tiếp tục bước @(Model.StepNumber + 1) <i class="fas fa-arrow-right"></i>
            </button>
        }
    </div>
</div>

<script>
    const s13ProjectId = @Model.ProjectId;

    function s13_toggleEdit() {
        document.getElementById('s13Display').classList.add('d-none');
        document.getElementById('s13Form').classList.remove('d-none');
        document.getElementById('s13EditToggle')?.classList.add('d-none');
    }
    function s13_cancelEdit() {
        document.getElementById('s13Display').classList.remove('d-none');
        document.getElementById('s13Form').classList.add('d-none');
        document.getElementById('s13EditToggle')?.classList.remove('d-none');
    }

    async function s13_save() {
        const ngayNT = document.getElementById('s13NgayNT').value;
        if (!ngayNT) { s13_toast('Vui lòng chọn ngày nghiệm thu.', 'warning'); return; }

        const fd = new FormData(document.getElementById('s13AcceptForm'));
        const btn = event.target.closest('button');
        const origHtml = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang lưu...';

        try {
            const r = await fetch('/Acceptance/SaveInline', { method: 'POST', body: fd });
            const d = await r.json();
            if (d.success) {
                s13_toast(d.message || '✅ Đã lưu!', 'success');
                setTimeout(() => {
                    const stepBtn = document.querySelector('.step-nav-btn[data-step="13"], [data-step-number="13"]');
                    if (stepBtn) stepBtn.click(); else location.reload();
                }, 1000);
            } else {
                s13_toast(d.message || 'Lỗi khi lưu.', 'danger');
            }
        } catch (e) {
            s13_toast('Lỗi kết nối: ' + e.message, 'danger');
        } finally {
            btn.disabled = false;
            btn.innerHTML = origHtml;
        }
    }

    // OTP signing flow
    async function s13_requestOtp(side) {
        const btn = event.target.closest('button');
        const origHtml = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Đang gửi...';

        try {
            const fd = new FormData();
            fd.append('projectId', s13ProjectId);
            fd.append('side', side);

            const r = await fetch('/Acceptance/SendOtp', { method: 'POST', body: fd });
            const d = await r.json();

            if (d.success) {
                s13_toast(d.message || 'Đã gửi OTP!', 'success');
                document.getElementById(`s13${cap(side)}Step1`).classList.add('d-none');
                document.getElementById(`s13${cap(side)}Step2`).classList.remove('d-none');
                s13_startTimer(side);
            } else {
                s13_toast(d.message || 'Lỗi gửi OTP.', 'danger');
            }
        } catch (e) {
            s13_toast('Lỗi: ' + e.message, 'danger');
        } finally {
            btn.disabled = false;
            btn.innerHTML = origHtml;
        }
    }

    async function s13_verifyOtp(side) {
        const otp = document.getElementById(`s13${cap(side)}Otp`).value.trim();
        if (!otp || otp.length !== 6) { s13_toast('Vui lòng nhập đủ 6 số.', 'warning'); return; }

        const btn = event.target.closest('button');
        const origHtml = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Đang xác nhận...';

        try {
            const fd = new FormData();
            fd.append('projectId', s13ProjectId);
            fd.append('side', side);
            fd.append('otpCode', otp);

            const r = await fetch('/Acceptance/VerifyOtp', { method: 'POST', body: fd });
            const d = await r.json();

            if (d.success) {
                s13_toast(d.message || '✅ Ký thành công!', 'success');
                setTimeout(() => {
                    const stepBtn = document.querySelector('.step-nav-btn[data-step="13"], [data-step-number="13"]');
                    if (stepBtn) stepBtn.click(); else location.reload();
                }, 1200);
            } else {
                s13_toast(d.message || 'OTP không đúng.', 'danger');
            }
        } catch (e) {
            s13_toast('Lỗi: ' + e.message, 'danger');
        } finally {
            btn.disabled = false;
            btn.innerHTML = origHtml;
        }
    }

    function cap(s) { return s.charAt(0).toUpperCase() + s.slice(1); }

    function s13_startTimer(side) {
        let sec = 120;
        const el = document.getElementById(`s13${cap(side)}Timer`);
        const iv = setInterval(() => {
            sec--;
            const m = Math.floor(sec / 60), s = sec % 60;
            el.textContent = `OTP hết hạn sau ${m}:${String(s).padStart(2, '0')}`;
            if (sec <= 0) { clearInterval(iv); el.textContent = 'OTP đã hết hạn. Bấm "Gửi lại".'; }
        }, 1000);
    }

    function s13_toast(msg, type = 'success') {
        const t = document.createElement('div');
        t.className = `toast align-items-center text-bg-${type} border-0 show position-fixed bottom-0 end-0 m-3`;
        t.style = 'z-index:9999;min-width:280px';
        t.innerHTML = `<div class="d-flex"><div class="toast-body">${msg}</div>
            <button class="btn-close btn-close-white me-2 m-auto" onclick="this.closest('.toast').remove()"></button></div>`;
        document.body.appendChild(t);
        setTimeout(() => t.remove(), 5000);
    }
</script>
