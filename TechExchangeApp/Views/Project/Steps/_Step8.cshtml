@model TechExchangeApp.ViewModel.StepContentVm
@using System.IO
@using Microsoft.EntityFrameworkCore
@inject TechExchangeApp.Data.AppDbContext DbCtx

@{
    var payment = Model.StepData as TechExchangeApp.Entities.AdvancePaymentConfirmation;
    if (payment == null)
    {
        payment = await DbCtx.AdvancePaymentConfirmations
            .FirstOrDefaultAsync(x => x.ProjectId == Model.ProjectId);
    }
    bool hasData = payment != null;
    bool isEditing = !hasData; // start in edit mode if no data
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="fas fa-money-check-alt"></i> Bước 8: Xác nhận Tạm ứng
        </h5>
        @if (hasData)
        {
            <button class="btn btn-light btn-sm" id="s8EditToggle" onclick="s8_toggleEdit()">
                <i class="fas fa-edit"></i> Chỉnh sửa
            </button>
        }
    </div>
    <div class="card-body">
        <i class="step-desc">
            Khoản tiền tạm ứng sẽ được chuyển vào hệ thống tài khoản đảm bảo trung gian nhằm bảo vệ an toàn tài chính và ràng buộc trách nhiệm cho cả hai bên trước khi triển khai.
        </i>
        <!-- ═══ Display Mode ═══ -->
        <div id="s8Display" class="@(!hasData ? "d-none" : "")">
            @if (hasData)
            {
                <dl class="row mb-0">
                    <dt class="col-sm-4">Số tiền tạm ứng:</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-success fs-6">
                            <i class="fas fa-dollar-sign"></i> @payment!.SoTienTamUng.ToString("N0") VNĐ
                        </span>
                    </dd>

                    <dt class="col-sm-4">Chứng từ chuyển tiền:</dt>
                    <dd class="col-sm-8">
                        @if (!string.IsNullOrEmpty(payment.ChungTuChuyenTienFile))
                        {
                            <a href="/uploads/@payment.ChungTuChuyenTienFile" target="_blank" class="text-decoration-none">
                                <i class="fas fa-file-pdf text-danger"></i>
                                <strong>@System.IO.Path.GetFileName(payment.ChungTuChuyenTienFile)</strong>
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">Chưa có file</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Ngày chuyển:</dt>
                    <dd class="col-sm-8"><strong>@payment.NgayChuyen.ToString("dd/MM/yyyy")</strong></dd>

                    <dt class="col-sm-4">Đã xác nhận nhận tiền:</dt>
                    <dd class="col-sm-8">
                        @if (payment.DaXacNhanNhanTien)
                        {
                            <span class="badge bg-success"><i class="fas fa-check"></i> Đã xác nhận</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark"><i class="fas fa-clock"></i> Chưa xác nhận</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Ngày tạo:</dt>
                    <dd class="col-sm-8">@payment.NgayTao.ToString("dd/MM/yyyy HH:mm")</dd>

                    @if (payment.NgaySua.HasValue)
                    {
                        <dt class="col-sm-4">Cập nhật lần cuối:</dt>
                        <dd class="col-sm-8">@payment.NgaySua.Value.ToString("dd/MM/yyyy HH:mm")</dd>
                    }
                </dl>
            }
        </div>

        <!-- ═══ Form Mode ═══ -->
        <div id="s8Form" class="@(hasData ? "d-none" : "")">
            <form id="s8PaymentForm" enctype="multipart/form-data">
                <input type="hidden" name="projectId" value="@Model.ProjectId" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-money-bill-wave me-1 text-success"></i>Số tiền tạm ứng (VNĐ) <span class="text-danger">*</span>
                        </label>
                        <div class="input-group">
                            <input type="text" class="form-control" id="s8SoTienDisplay"
                                   value="@(payment != null ? payment.SoTienTamUng.ToString("N0") : "")"
                                   placeholder="Ví dụ: 50.000.000" required
                                   oninput="s8_formatMoney(this)" />
                            <span class="input-group-text">VNĐ</span>
                        </div>
                        <input type="hidden" name="SoTienTamUng" id="s8SoTien"
                               value="@(payment?.SoTienTamUng.ToString("0") ?? "")" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-calendar-alt me-1 text-primary"></i>Ngày chuyển <span class="text-danger">*</span>
                        </label>
                        <input type="date" class="form-control" name="NgayChuyen" id="s8NgayChuyen"
                               value="@(payment?.NgayChuyen.ToString("yyyy-MM-dd") ?? DateTime.Now.ToString("yyyy-MM-dd"))" required />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-file-upload me-1 text-warning"></i>Chứng từ chuyển tiền
                        </label>
                        <input type="file" class="form-control" name="ChungTuFile" id="s8ChungTu"
                               accept=".pdf,.jpg,.jpeg,.png" />
                        <small class="text-muted">PDF, JPG, PNG — tối đa 10MB</small>
                        @if (hasData && !string.IsNullOrEmpty(payment!.ChungTuChuyenTienFile))
                        {
                            <div class="mt-1 small text-success">
                                <i class="fas fa-check-circle me-1"></i>File hiện tại: @System.IO.Path.GetFileName(payment.ChungTuChuyenTienFile)
                            </div>
                        }
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-check-double me-1 text-info"></i>Xác nhận nhận tiền
                        </label>
                        <div class="form-check form-switch mt-2">
                            <input class="form-check-input" type="checkbox" name="DaXacNhanNhanTien" id="s8DaXacNhan"
                                   @(payment?.DaXacNhanNhanTien == true ? "checked" : "") />
                            <label class="form-check-label" for="s8DaXacNhan">Bên bán đã nhận tiền tạm ứng</label>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="button" class="btn btn-primary px-4" onclick="s8_save()">
                        <i class="fas fa-save me-1"></i>@(hasData ? "Cập nhật" : "Lưu")
                    </button>
                    @if (hasData)
                    {
                        <button type="button" class="btn btn-outline-secondary" onclick="s8_cancelEdit()">
                            <i class="fas fa-times me-1"></i>Hủy
                        </button>
                    }
                </div>
            </form>
        </div>

    </div>
    <div class="card-footer bg-white d-flex justify-content-between">
        <button class="btn btn-outline-secondary step-nav-btn" data-step="@(Model.StepNumber - 1)">
            <i class="fas fa-arrow-left"></i> Quay lại bước trước
        </button>
        @if (Model.StepNumber < 14 && Model.Steps.Count > Model.StepNumber && Model.Steps[Model.StepNumber].IsAccessible)
        {
            <button class="btn btn-primary step-nav-btn" data-step="@(Model.StepNumber + 1)">
                Tiếp tục bước @(Model.StepNumber + 1) <i class="fas fa-arrow-right"></i>
            </button>
        }
    </div>
</div>

<script>
    function s8_toggleEdit() {
        document.getElementById('s8Display').classList.add('d-none');
        document.getElementById('s8Form').classList.remove('d-none');
        document.getElementById('s8EditToggle').classList.add('d-none');
    }

    function s8_cancelEdit() {
        document.getElementById('s8Display').classList.remove('d-none');
        document.getElementById('s8Form').classList.add('d-none');
        document.getElementById('s8EditToggle').classList.remove('d-none');
    }

    async function s8_save() {
        const form = document.getElementById('s8PaymentForm');
        // Sync formatted display to hidden raw value
        s8_syncRawValue();
        const soTien = document.getElementById('s8SoTien').value;
        const ngayChuyen = document.getElementById('s8NgayChuyen').value;

        if (!soTien || parseFloat(soTien) <= 0) {
            s8_toast('Vui lòng nhập số tiền tạm ứng.', 'warning');
            return;
        }
        if (!ngayChuyen) {
            s8_toast('Vui lòng chọn ngày chuyển.', 'warning');
            return;
        }

        const fd = new FormData(form);
        // Convert checkbox to string
        fd.set('DaXacNhanNhanTien', document.getElementById('s8DaXacNhan').checked ? 'true' : 'false');

        const btn = event.target.closest('button');
        const origHtml = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang lưu...';

        try {
            const r = await fetch('/AdvancePayment/SaveInline', {
                method: 'POST',
                body: fd
            });
            const d = await r.json();

            if (d.success) {
                s8_toast(d.message || '✅ Đã lưu thành công!', 'success');
                // Reload step content
                setTimeout(() => {
                    const stepBtn = document.querySelector('.step-nav-btn[data-step="8"], [data-step-number="8"]');
                    if (stepBtn) stepBtn.click();
                    else location.reload();
                }, 1000);
            } else {
                s8_toast(d.message || 'Lỗi khi lưu.', 'danger');
            }
        } catch (e) {
            s8_toast('Lỗi kết nối: ' + e.message, 'danger');
        } finally {
            btn.disabled = false;
            btn.innerHTML = origHtml;
        }
    }

    function s8_toast(msg, type = 'success') {
        const t = document.createElement('div');
        t.className = `toast align-items-center text-bg-${type} border-0 show position-fixed bottom-0 end-0 m-3`;
        t.style = 'z-index:9999;min-width:280px';
        t.innerHTML = `<div class="d-flex"><div class="toast-body">${msg}</div>
            <button class="btn-close btn-close-white me-2 m-auto" onclick="this.closest('.toast').remove()"></button></div>`;
        document.body.appendChild(t);
        setTimeout(() => t.remove(), 5000);
    }

    // Format money: 50000000 → 50.000.000
    function s8_formatMoney(el) {
        let raw = el.value.replace(/\D/g, ''); // strip non-digits
        if (raw === '') { el.value = ''; document.getElementById('s8SoTien').value = ''; return; }
        let num = parseInt(raw, 10);
        el.value = num.toLocaleString('vi-VN');
        document.getElementById('s8SoTien').value = num.toString();
    }

    // Sync display → hidden before submit
    function s8_syncRawValue() {
        let display = document.getElementById('s8SoTienDisplay').value;
        let raw = display.replace(/\D/g, '');
        document.getElementById('s8SoTien').value = raw;
    }
</script>
