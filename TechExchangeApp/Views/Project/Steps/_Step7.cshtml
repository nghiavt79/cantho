@model TechExchangeApp.ViewModel.StepContentVm
@using TechExchangeApp.Entities
@using TechExchangeApp.Interfaces
@using Microsoft.EntityFrameworkCore
@inject TechExchangeApp.Data.AppDbContext DbCtx
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

@{
    int projectId = Model.ProjectId;

    // Load contract — fallback to DB if StepData is null (initial page load)
    var contract = Model.StepData as ProjectContract;
    if (contract == null)
    {
        contract = await DbCtx.ProjectContracts
            .Where(x => x.ProjectId == projectId && x.IsActive)
            .OrderByDescending(x => x.VersionNumber)
            .FirstOrDefaultAsync();
    }

    bool isLocked = Model.Steps.Count >= 7 && !Model.Steps[6].IsAccessible;

    // Derive buyer/seller from project
    var proj7 = await DbCtx.Projects.FindAsync(projectId);
    var userIdStr = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0";
    int currentUserId = int.TryParse(userIdStr, out int uid7) ? uid7 : 0;

    bool isBuyer  = proj7?.CreatedBy == currentUserId;
    bool isSeller = proj7?.SelectedSellerId == currentUserId;

    // Lookup actual user names (same pattern as Step 6)
    var buyerName = proj7?.CreatedBy.HasValue == true
        ? (await DbCtx.Users.AsNoTracking().Where(u => u.Id == proj7.CreatedBy.Value).Select(u => u.FullName ?? u.UserName).FirstOrDefaultAsync()) ?? "Buyer"
        : "Buyer";
    var sellerName = proj7?.SelectedSellerId.HasValue == true
        ? (await DbCtx.Users.AsNoTracking().Where(u => u.Id == proj7.SelectedSellerId.Value).Select(u => u.FullName ?? u.UserName).FirstOrDefaultAsync()) ?? "Seller"
        : "Seller";

    // ── Load AccountTypeId for buyer/seller: 1=Cá nhân, 2=Doanh nghiệp ──
    int buyerAccountType = 1;
    int sellerAccountType = 1;
    if (proj7?.CreatedBy.HasValue == true)
    {
        buyerAccountType = await DbCtx.Users.AsNoTracking()
            .Where(u => u.Id == proj7.CreatedBy.Value)
            .Select(u => u.AccountTypeId)
            .FirstOrDefaultAsync();
        if (buyerAccountType == 0) buyerAccountType = 1; // default cá nhân
    }
    if (proj7?.SelectedSellerId.HasValue == true)
    {
        sellerAccountType = await DbCtx.Users.AsNoTracking()
            .Where(u => u.Id == proj7.SelectedSellerId.Value)
            .Select(u => u.AccountTypeId)
            .FirstOrDefaultAsync();
        if (sellerAccountType == 0) sellerAccountType = 1;
    }

    bool buyerUsesCA  = buyerAccountType == 2;   // Doanh nghiệp → ký CA
    bool sellerUsesCA = sellerAccountType == 2;   // Doanh nghiệp → ký CA

    var status    = ViewBag.SigningStatus as ContractSigningStatusDto ?? new ContractSigningStatusDto();
    var provider  = (string)(ViewBag.Provider ?? "VNPT");
    var auditLogs = ViewBag.AuditLogs as List<ContractAuditLog> ?? new();
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="fas fa-signature me-2"></i>Bước 7: Ký số hợp đồng
            <button type="button" class="btn btn-sm btn-outline-light ms-2" data-bs-toggle="modal" data-bs-target="#signingGuideModal" title="Hướng dẫn ký số">
                <i class="fas fa-question-circle"></i>
            </button>
        </h5>
        @if (status.FullySigned)
        {
            <span class="badge bg-success fs-6"><i class="fas fa-check-double me-1"></i>Đã ký đầy đủ</span>
        }
        else if (contract != null && contract.StatusId >= 3)
        {
            <span class="badge bg-warning text-dark fs-6"><i class="fas fa-clock me-1"></i>Đang chờ ký</span>
        }
    </div>

<!-- ═══ MODAL: Hướng dẫn ký số ═══ -->
<div class="modal fade" id="signingGuideModal" tabindex="-1" aria-labelledby="signingGuideLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="signingGuideLabel">
                    <i class="fas fa-book-open me-2"></i>Hướng dẫn ký số hợp đồng
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">

                <!-- Tab nav -->
                <ul class="nav nav-pills nav-fill mb-4" role="tablist">
                    <li class="nav-item">
                        <button class="nav-link active" data-bs-toggle="pill" data-bs-target="#guideUSB" type="button">
                            <i class="fas fa-usb me-1"></i>USB Token (Doanh nghiệp)
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link" data-bs-toggle="pill" data-bs-target="#guideOTP" type="button">
                            <i class="fas fa-shield-alt me-1"></i>OTP E-Sign (Cá nhân)
                        </button>
                    </li>
                </ul>

                <div class="tab-content">

                    <!-- ═══ USB Token (Local) ═══ -->
                    <div class="tab-pane fade show active" id="guideUSB">
                        <div class="d-flex align-items-start gap-3 mb-3">
                            <i class="fas fa-usb fa-3x text-primary"></i>
                            <div>
                                <h6 class="fw-bold">Ký bằng USB Token (Chữ ký số cứng)</h6>
                                <p class="text-muted mb-0">Dành cho <strong>Doanh nghiệp</strong> — sử dụng chứng thư số lưu trên thiết bị USB Token cắm vào máy tính.</p>
                            </div>
                        </div>
                        <div class="alert alert-primary small">
                            <i class="fas fa-info-circle me-1"></i>
                            <strong>Quy trình:</strong> Cắm USB Token → Đọc chứng thư → Nhập PIN → Ký hash văn bản → Gửi về server lưu.
                        </div>
                        <h6 class="fw-semibold mt-3"><i class="fas fa-download me-1 text-primary"></i>Cài đặt TechExchange LocalSigner</h6>
                        <div class="d-flex align-items-center gap-3 p-3 border rounded bg-light mb-2">
                            <i class="fas fa-laptop-code fa-2x text-primary"></i>
                            <div class="flex-grow-1">
                                <div class="fw-semibold">TechExchange LocalSigner</div>
                                <small class="text-muted">Agent chạy trên máy tính — phát hiện USB Token và giao tiếp qua <code>localhost:15800</code></small>
                            </div>
                            <a href="/Uploads/TechExchange.LocalSigner.zip" download class="btn btn-primary btn-sm text-nowrap">
                                <i class="fas fa-download me-1"></i>Tải xuống (.zip)
                            </a>
                        </div>
                        <h6 class="fw-semibold mt-3"><i class="fas fa-list-ol me-1 text-primary"></i>Các bước thực hiện</h6>
                        <ol class="small">
                            <li>Chạy <strong>TechExchangeSigner.exe</strong> trên máy (chỉ cần lần đầu)</li>
                            <li>Cắm USB Token vào cổng USB của máy tính</li>
                            <li>Nhấn nút <strong>"Đọc USB Token &amp; Ký"</strong> trên trang web</li>
                            <li>Kiểm tra thông tin chứng thư số hiển thị</li>
                            <li>Nhập mã PIN của USB Token</li>
                            <li>Nhấn <strong>"Xác nhận &amp; Ký"</strong></li>
                            <li>Hoàn tất — chữ ký số được lưu vào hợp đồng</li>
                        </ol>
                        <div class="alert alert-info small mt-3">
                            <i class="fas fa-shield-alt me-1"></i><strong>Bảo mật:</strong>
                            Mã PIN chỉ được xử lý ngay trên máy tính của bạn qua TechExchange LocalSigner — <strong>không bao giờ</strong> gửi lên server.
                        </div>
                    </div>

                    <!-- ═══ OTP E-Sign ═══ -->
                    <div class="tab-pane fade" id="guideOTP">
                        <div class="d-flex align-items-start gap-3 mb-3">
                            <i class="fas fa-shield-alt fa-3x text-warning"></i>
                            <div>
                                <h6 class="fw-bold">Ký OTP E-Sign (Xác thực OTP)</h6>
                                <p class="text-muted mb-0">Dành cho <strong>Cá nhân</strong> — xác nhận ký bằng mã OTP gửi qua Email hoặc SMS.</p>
                            </div>
                        </div>
                        <div class="alert alert-warning small">
                            <i class="fas fa-info-circle me-1"></i>
                            <strong>Quy trình:</strong> Chọn kênh (Email/SMS) → Gửi OTP → Nhập mã 6 số → Xác nhận ký.
                        </div>
                        <h6 class="fw-semibold mt-3"><i class="fas fa-list-ol me-1 text-warning"></i>Các bước thực hiện</h6>
                        <ol class="small">
                            <li>Chọn kênh nhận OTP: <strong>Email</strong> hoặc <strong>SMS</strong></li>
                            <li>Nếu chọn SMS, nhập số điện thoại nhận mã</li>
                            <li>Bấm <strong>"Gửi OTP & Ký xác nhận"</strong></li>
                            <li>Kiểm tra Email/SMS — nhập mã OTP 6 số</li>
                            <li>Bấm <strong>"Xác nhận & Ký"</strong></li>
                            <li>Hoàn tất — chữ ký được ghi nhận vào hợp đồng</li>
                        </ol>
                        <div class="alert alert-info small mt-3">
                            <i class="fas fa-clock me-1"></i>
                            <strong>Thời hạn OTP:</strong> Mã OTP có hiệu lực trong <strong>5 phút</strong> (300 giây). Nếu hết hạn, bấm <strong>"Gửi lại"</strong> để nhận mã mới.
                        </div>
                    </div>

                </div>

                <!-- So sánh nhanh -->
                <hr class="my-4"/>
                <h6 class="fw-bold"><i class="fas fa-balance-scale me-1"></i>So sánh các phương thức ký</h6>
                <table class="table table-sm table-bordered small text-center">
                    <thead class="table-primary">
                        <tr>
                            <th></th>
                            <th><i class="fas fa-usb me-1"></i>USB Token</th>
                            <th><i class="fas fa-shield-alt me-1"></i>OTP E-Sign</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td class="text-start fw-semibold">Đối tượng</td><td>Doanh nghiệp</td><td>Cá nhân</td></tr>
                        <tr><td class="text-start fw-semibold">Thiết bị</td><td>USB Token</td><td>Không cần</td></tr>
                        <tr><td class="text-start fw-semibold">Phần mềm</td><td>TechExchange LocalSigner</td><td>Không cần</td></tr>
                        <tr><td class="text-start fw-semibold">Xác thực</td><td>PIN trên Token</td><td>OTP qua Email/SMS</td></tr>
                        <tr><td class="text-start fw-semibold">Bảo mật</td><td>⭐⭐⭐ Cao nhất</td><td>⭐ Trung bình</td></tr>
                        <tr><td class="text-start fw-semibold">Pháp lý</td><td>✅ Đầy đủ</td><td>✅ Hợp lệ</td></tr>
                    </tbody>
                </table>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-1"></i>Đóng
                </button>
            </div>
        </div>
    </div>
</div>

    <div class="card-body">
        <i class="step-desc">
            Đại diện hợp pháp của các bên sẽ sử dụng chữ ký số đã được cơ quan có thẩm quyền chứng thực để chính thức ký kết hợp đồng chuyển giao công nghệ ngay trên nền tảng trực tuyến.
        </i>
        @if (isLocked)
        {
            <div class="alert alert-warning d-flex gap-2 align-items-start">
                <i class="fas fa-lock fa-2x mt-1"></i>
                <div>
                    <strong>Bước này chưa được mở khóa.</strong><br/>
                    Vui lòng hoàn thành Bước 6 (tất cả 3 bên đã duyệt và chốt ReadyToSign).
                </div>
            </div>
        }
        else if (contract == null)
        {
            <div class="alert alert-info d-flex gap-2 align-items-center">
                <i class="fas fa-info-circle fa-2x"></i>
                <div>
                    <strong>Hợp đồng chưa được chuẩn bị.</strong><br/>
                    Quay về Bước 6, tạo / upload hợp đồng và đảm bảo tất cả các bên đã phê duyệt.
                </div>
            </div>
        }
        else if (contract.StatusId < 3 && !Configuration.GetValue<bool>("Signing:TestMode"))
        {
            <div class="alert alert-warning d-flex gap-2 align-items-center">
                <i class="fas fa-exclamation-triangle fa-2x"></i>
                <div>
                    <strong>Hợp đồng chưa ở trạng thái ReadyToSign.</strong><br/>
                    Quay về Bước 6 để hoàn tất phê duyệt 3 bên.
                </div>
            </div>
        }
        else
        {
            <!-- TechExchange LocalSigner download banner (chỉ hiện khi có user dùng CA) -->
            @if (buyerUsesCA || sellerUsesCA)
            {
                <div class="alert alert-primary d-flex align-items-center gap-3 mb-3">
                    <i class="fas fa-usb fa-2x"></i>
                    <div class="flex-grow-1">
                        <strong>Cần phần mềm TechExchange LocalSigner để ký bằng USB Token</strong>
                        <div class="small text-muted mt-1">
                            Tải và chạy agent trên máy tính trước khi nhấn "Ký USB Token".
                        </div>
                    </div>
                    <a href="/Uploads/TechExchange.LocalSigner.zip" download class="btn btn-white btn-sm text-nowrap border border-white">
                        <i class="fas fa-download me-1"></i>Tải LocalSigner (.zip)
                    </a>
                </div>
            }
            <!-- Contract summary -->
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <div class="card border-0 bg-light h-100">
                        <div class="card-body">
                            <h6 class="fw-bold text-primary mb-2"><i class="fas fa-file-contract me-1"></i>Thông tin hợp đồng</h6>
                            <dl class="row mb-0 small">
                                <dt class="col-5">Tiêu đề:</dt>
                                <dd class="col-7 fw-semibold">@contract.Title</dd>
                                <dt class="col-5">Phiên bản:</dt>
                                <dd class="col-7">@($"v{contract.VersionNumber}")</dd>
                                <dt class="col-5">Trạng thái:</dt>
                                <dd class="col-7">
                                    @{
                                        var (lbl, cls) = contract.StatusId switch {
                                            3 => ("ReadyToSign", "bg-primary"),
                                            4 => ("Đang ký", "bg-warning text-dark"),
                                            5 => ("Đã ký đầy đủ","bg-success"),
                                            _ => ("Đang xử lý","bg-secondary")
                                        };
                                    }
                                    <span class="badge @cls">@lbl</span>
                                </dd>
                            </dl>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card border-0 bg-light h-100">
                        <div class="card-body">
                            <h6 class="fw-bold text-success mb-2"><i class="fas fa-shield-alt me-1"></i>Tính toàn vẹn</h6>
                            <dl class="row mb-0 small">
                                @if (!string.IsNullOrEmpty(contract.Sha256Original))
                                {
                                    <dt class="col-5">SHA-256 gốc:</dt>
                                    <dd class="col-7 font-monospace text-truncate" title="@contract.Sha256Original">
                                        @contract.Sha256Original[..16]…
                                    </dd>
                                }
                                @if (!string.IsNullOrEmpty(contract.Sha256Signed))
                                {
                                    <dt class="col-5">SHA-256 ký:</dt>
                                    <dd class="col-7 font-monospace text-truncate" title="@contract.Sha256Signed">
                                        @contract.Sha256Signed[..16]…
                                    </dd>
                                }
                            </dl>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Contract file preview (like Step 6) -->
            @if (!string.IsNullOrEmpty(contract.HtmlContent) || !string.IsNullOrEmpty(contract.OriginalFilePath))
            {
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white border-bottom d-flex align-items-center gap-2">
                        <i class="fas fa-file-alt text-primary"></i>
                        <strong>Nội dung hợp đồng</strong>
                        <div class="ms-auto d-flex gap-2">
                            @if (!string.IsNullOrEmpty(contract.OriginalFilePath))
                            {
                                <a href="/Contract/Download/@contract.Id/original" class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-download me-1"></i>Tải gốc
                                </a>
                            }
                            @if (!string.IsNullOrEmpty(contract.SignedFilePath) && System.IO.File.Exists(contract.SignedFilePath))
                            {
                                <a href="/Signing/DownloadSignedPdf?contractId=@contract.Id&mode=view"
                                   class="btn btn-sm btn-outline-success" target="_blank"
                                   title="Mở PDF đã ký trong trình duyệt">
                                    <i class="fas fa-eye me-1"></i>Xem
                                </a>
                                <a href="/Signing/DownloadSignedPdf?contractId=@contract.Id&mode=download"
                                   class="btn btn-sm btn-success"
                                   download="HopDong_DaKy_@(contract.Id).pdf">
                                    <i class="fas fa-file-signature me-1"></i>Tải bản đã ký
                                </a>
                            }
                        </div>
                    </div>
                    <div class="card-body p-0" style="min-height:300px;overflow:auto">
                        @if (!string.IsNullOrEmpty(contract.HtmlContent))
                        {
                            @if (contract.HtmlContent.Contains("Không tìm thấy template"))
                            {
                                <div class="alert alert-warning m-3">
                                    <i class="fas fa-exclamation-triangle me-2"></i>
                                    <strong>Nội dung hợp đồng chưa được tạo.</strong><br/>
                                    Template HTML chưa được load khi tạo auto-draft. Vui lòng vào <strong>Bước 6</strong> và nhấn
                                    <strong>"Tạo lại hợp đồng"</strong> để re-generate nội dung đúng.
                                </div>
                            }
                            else
                            {
                                <iframe id="s7ContractIframe"
                                        srcdoc="@contract.HtmlContent"
                                        style="width:100%;min-height:500px;border:none;"
                                        title="Xem hợp đồng"
                                        onload="s7_resizeIframe(this)">
                                </iframe>
                            }
                        }
                        else if (!string.IsNullOrEmpty(contract.OriginalFilePath))
                        {
                            var ext7 = System.IO.Path.GetExtension(contract.OriginalFileName ?? "").ToLowerInvariant();
                            if (ext7 == ".pdf")
                            {
                                <iframe src="/Contract/Download/@contract.Id/original"
                                        style="width:100%;height:500px;border:none;"
                                        title="Xem hợp đồng PDF"></iframe>
                            }
                            else
                            {
                                <div class="d-flex flex-column align-items-center justify-content-center h-100 py-5 text-muted">
                                    <i class="fas fa-file-word fa-4x text-primary mb-3"></i>
                                    <p>@System.IO.Path.GetFileName(contract.OriginalFilePath)</p>
                                    <a href="/Contract/Download/@contract.Id/original" class="btn btn-outline-primary">
                                        <i class="fas fa-download me-1"></i>Tải xuống để xem
                                    </a>
                                </div>
                            }
                        }
                    </div>
                </div>
            }

            @if (!status.FullySigned)
            {
                <!-- Legal disclaimer — only show when not fully signed -->
                <div class="alert alert-info d-flex gap-2 mb-4">
                    <i class="fas fa-balance-scale fs-4"></i>
                    <div>
                        <strong>Thông báo pháp lý – Luật Giao dịch điện tử 2023</strong><br/>
                        Hợp đồng điện tử có giá trị pháp lý tương đương văn bản giấy sau khi cả 2 bên ký số theo quy định.
                        <div class="form-check mt-2">
                            <input class="form-check-input" type="checkbox" id="legalAck" required />
                            <label class="form-check-label fw-semibold" for="legalAck">
                                Tôi xác nhận đã đọc và đồng ý với điều khoản pháp lý trên
                            </label>
                        </div>
                    </div>
                </div>
            }

            @if (status.FullySigned)
            {
                <!-- Both signed -->
                <div class="alert alert-success d-flex align-items-center gap-3">
                    <i class="fas fa-check-circle fa-3x"></i>
                    <div>
                        <strong class="d-block fs-5">Hợp đồng đã được ký số đầy đủ!</strong>
                        @buyerName (Buyer) ký lúc: @(status.BuyerSignedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "—") &nbsp;|&nbsp;
                        @sellerName (Seller) ký lúc: @(status.SellerSignedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "—")
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(contract.SignedFilePath))
                {
                    <a href="/Contract/Download/@contract.Id/signed" class="btn btn-success btn-lg mt-2">
                        <i class="fas fa-download me-1"></i>Tải hợp đồng đã ký
                    </a>
                }
            }
            else
            {
                <div class="row g-4">
                    <!-- ══════════════════════════════════════════════════════════
                         BUYER SIGNING CARD
                         ══════════════════════════════════════════════════════════ -->
                    <div class="col-md-6">
                        <div class="card h-100 border-0 shadow-sm @(status.BuyerSigned ? "border-success" : "")">
                            <div class="card-header bg-white border-bottom d-flex align-items-center gap-2">
                                <i class="fas @(buyerUsesCA ? "fa-building" : "fa-user") text-primary"></i>
                                <strong>@buyerName (Buyer) – @(buyerUsesCA ? "Ký số CA" : "Ký OTP")</strong>
                                <span class="badge bg-light text-muted ms-auto" style="font-size:10px">
                                    @(buyerUsesCA ? "Doanh nghiệp" : "Cá nhân")
                                </span>
                                @if (status.BuyerSigned)
                                {<span class="badge bg-success ms-1">✓ Đã ký @status.BuyerSignedAt?.ToLocalTime().ToString("dd/MM HH:mm")</span>}
                            </div>
                            <div class="card-body">
                                @if (status.BuyerSigned)
                                {
                                    <div class="text-center py-4">
                                        <i class="fas fa-check-circle fa-3x text-success mb-2"></i>
                                        <p class="text-success fw-bold">@buyerName đã ký thành công</p>
                                    </div>
                                }
                                else if (isBuyer)
                                {
                                    @if (buyerUsesCA)
                                    {
                                        <!-- ── Buyer: Doanh nghiệp → Ký USB Token ── -->
                                        <div class="alert alert-light small mb-3">
                                            <i class="fas fa-usb text-primary me-1"></i>
                                            <strong>Ký bằng USB Token</strong> — Cắm USB Token vào máy tính, chạy TechExchange LocalSigner, hệ thống sẽ đọc chứng thư số và ký trực tiếp.
                                        </div>
                                        <div id="buyerUSBStep1">
                                            <button class="btn btn-primary w-100 py-2" onclick="s7_usbSign('buyer')">
                                                <i class="fas fa-key me-1"></i>Đọc USB Token & Ký
                                            </button>
                                        </div>
                                        <div id="buyerUSBStatus" class="d-none">
                                            <div class="mb-2"><small class="text-muted">Chứng thư số:</small></div>
                                            <div id="buyerUSBCertInfo" class="alert alert-secondary small mb-3 font-monospace"></div>
                                            <button class="btn btn-success w-100 py-2" onclick="s7_usbConfirm('buyer')">
                                                <i class="fas fa-check me-1"></i>Xác nhận & Ký
                                            </button>
                                        </div>
                                        <div id="buyerUSBProgress" class="d-none text-center py-3">
                                            <div class="spinner-border text-primary mb-2" role="status"></div>
                                            <p class="text-muted">Đang ký…</p>
                                        </div>
                                    }
                                    else
                                    {
                                        <!-- ── Buyer: Cá nhân → OTP ── -->
                                        <h6 class="card-title mb-3"><i class="fas fa-shield-alt me-1"></i>Ký xác nhận bằng OTP</h6>
                                        <div class="d-flex gap-3 mb-3">
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="buyerOtpChannel" id="buyerChannelEmail" value="email" checked />
                                                <label class="form-check-label" for="buyerChannelEmail">
                                                    <i class="fas fa-envelope me-1"></i>Email
                                                </label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="buyerOtpChannel" id="buyerChannelSms" value="sms" />
                                                <label class="form-check-label" for="buyerChannelSms">
                                                    <i class="fas fa-sms me-1"></i>SMS
                                                </label>
                                            </div>
                                        </div>
                                        <div id="buyerSmsSection" class="mb-3" style="display:none;">
                                            <label class="form-label small">Số điện thoại nhận OTP:</label>
                                            <input type="tel" class="form-control" id="buyerPhoneNumber" placeholder="0912345678" />
                                        </div>
                                        <div id="buyerStep1">
                                            <button class="btn btn-primary w-100 py-2" onclick="s7_requestOtp('buyer')">
                                                <i class="fas fa-pen-nib me-1"></i>Gửi OTP & Ký xác nhận
                                            </button>
                                        </div>
                                        <div id="buyerStep2" class="d-none">
                                            <label class="form-label fw-semibold">Nhập mã OTP</label>
                                            <div class="input-group mb-2">
                                                <input type="text" id="buyerOtpInput" class="form-control form-control-lg text-center fw-bold"
                                                       placeholder="_ _ _ _ _ _" maxlength="6" inputmode="numeric" style="letter-spacing:6px" />
                                                <button class="btn btn-outline-secondary" onclick="s7_requestOtp('buyer')">Gửi lại</button>
                                            </div>
                                            <div id="buyerOtpTimer" class="text-muted small text-center mb-3"></div>
                                            <button class="btn btn-success w-100 py-2" onclick="s7_verifyOtp('buyer')">
                                                <i class="fas fa-lock me-1"></i>Xác nhận & Ký
                                            </button>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="text-center py-4 text-muted">
                                        <i class="fas fa-clock fa-2x mb-2"></i>
                                        <p>Đang chờ @buyerName (Buyer) ký…</p>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- ══════════════════════════════════════════════════════════
                         SELLER SIGNING CARD
                         ══════════════════════════════════════════════════════════ -->
                    <div class="col-md-6">
                        <div class="card h-100 border-0 shadow-sm @(status.SellerSigned ? "border-success" : "")">
                            <div class="card-header bg-white border-bottom d-flex align-items-center gap-2">
                                <i class="fas @(sellerUsesCA ? "fa-building" : "fa-user") text-warning"></i>
                                <strong>@sellerName (Seller) – @(sellerUsesCA ? "Ký số CA" : "Ký OTP")</strong>
                                <span class="badge bg-light text-muted ms-auto" style="font-size:10px">
                                    @(sellerUsesCA ? "Doanh nghiệp" : "Cá nhân")
                                </span>
                                @if (status.SellerSigned)
                                {<span class="badge bg-success ms-1">✓ Đã ký @status.SellerSignedAt?.ToLocalTime().ToString("dd/MM HH:mm")</span>}
                            </div>
                            <div class="card-body">
                                @if (status.SellerSigned)
                                {
                                    <div class="text-center py-4">
                                        <i class="fas fa-check-circle fa-3x text-success mb-2"></i>
                                        <p class="text-success fw-bold">@sellerName đã ký thành công</p>
                                    </div>
                                }
                                else if (isSeller)
                                {
                                    @if (sellerUsesCA)
                                    {
                                        <!-- ── Seller: Doanh nghiệp → Ký USB Token ── -->
                                        <div class="alert alert-light small mb-3">
                                            <i class="fas fa-usb text-warning me-1"></i>
                                            <strong>Ký bằng USB Token</strong> — Cắm USB Token vào máy tính, chạy TechExchange LocalSigner, hệ thống sẽ đọc chứng thư số và ký trực tiếp.
                                        </div>
                                        <div id="sellerUSBStep1">
                                            <button class="btn btn-warning w-100 py-2" onclick="s7_usbSign('seller')">
                                                <i class="fas fa-key me-1"></i>Đọc USB Token & Ký
                                            </button>
                                        </div>
                                        <div id="sellerUSBStatus" class="d-none">
                                            <div class="mb-2"><small class="text-muted">Chứng thư số:</small></div>
                                            <div id="sellerUSBCertInfo" class="alert alert-secondary small mb-3 font-monospace"></div>
                                            <button class="btn btn-success w-100 py-2" onclick="s7_usbConfirm('seller')">
                                                <i class="fas fa-check me-1"></i>Xác nhận & Ký
                                            </button>
                                        </div>
                                        <div id="sellerUSBProgress" class="d-none text-center py-3">
                                            <div class="spinner-border text-warning mb-2" role="status"></div>
                                            <p class="text-muted">Đang ký…</p>
                                        </div>
                                    }
                                    else
                                    {
                                        <!-- ── Seller: Cá nhân → OTP ── -->
                                        <h6 class="card-title mb-3"><i class="fas fa-shield-alt me-1"></i>Ký xác nhận bằng OTP</h6>
                                        <div class="d-flex gap-3 mb-3">
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="sellerOtpChannel" id="sellerChannelEmail" value="email" checked />
                                                <label class="form-check-label" for="sellerChannelEmail">
                                                    <i class="fas fa-envelope me-1"></i>Email
                                                </label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="sellerOtpChannel" id="sellerChannelSms" value="sms" />
                                                <label class="form-check-label" for="sellerChannelSms">
                                                    <i class="fas fa-sms me-1"></i>SMS
                                                </label>
                                            </div>
                                        </div>
                                        <div id="sellerSmsSection" class="mb-3" style="display:none;">
                                            <label class="form-label small">Số điện thoại nhận OTP:</label>
                                            <input type="tel" class="form-control" id="sellerPhoneNumber" placeholder="0912345678" />
                                        </div>
                                        <div id="sellerStep1">
                                            <button class="btn btn-warning w-100 py-2" onclick="s7_requestOtp('seller')">
                                                <i class="fas fa-pen-nib me-1"></i>Gửi OTP & Ký xác nhận
                                            </button>
                                        </div>
                                        <div id="sellerStep2" class="d-none">
                                            <label class="form-label fw-semibold">Nhập mã OTP</label>
                                            <div class="input-group mb-2">
                                                <input type="text" id="sellerOtpInput" class="form-control form-control-lg text-center fw-bold"
                                                       placeholder="_ _ _ _ _ _" maxlength="6" inputmode="numeric" style="letter-spacing:6px" />
                                                <button class="btn btn-outline-secondary" onclick="s7_requestOtp('seller')">Gửi lại</button>
                                            </div>
                                            <div id="sellerOtpTimer" class="text-muted small text-center mb-3"></div>
                                            <button class="btn btn-success w-100 py-2" onclick="s7_verifyOtp('seller')">
                                                <i class="fas fa-lock me-1"></i>Xác nhận & Ký
                                            </button>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="text-center py-4 text-muted">
                                        <i class="fas fa-clock fa-2x mb-2"></i>
                                        <p>Đang chờ @sellerName (Seller) ký…</p>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <div class="card-footer bg-white d-flex justify-content-between">
        <button class="btn btn-outline-secondary step-nav-btn" data-step="@(Model.StepNumber - 1)">
            <i class="fas fa-arrow-left"></i> Quay lại bước trước
        </button>
        @if (Model.StepNumber < 14 && Model.Steps.Count > Model.StepNumber && Model.Steps[Model.StepNumber].IsAccessible)
        {
            <button class="btn btn-primary step-nav-btn" data-step="@(Model.StepNumber + 1)">
                Tiếp tục bước @(Model.StepNumber + 1) <i class="fas fa-arrow-right"></i>
            </button>
        }
    </div>
</div>

<script>
    const s7_contractId = @(contract?.Id ?? 0);
    const s7_projectId = @Model.ProjectId;
    const s7_buyerUsesCA = @(buyerUsesCA ? "true" : "false");
    const s7_sellerUsesCA = @(sellerUsesCA ? "true" : "false");

    // Tự resize iframe hợp đồng theo chiều cao nội dung (giống Step 6)
    function s7_resizeIframe(iframe) {
        try {
            const resize = () => {
                const h = iframe.contentDocument?.body?.scrollHeight;
                if (h && h > 100) iframe.style.height = (h + 32) + 'px';
            };
            resize();
            setTimeout(resize, 400);
        } catch(e) {}
    }

    let s7_timers = {};
    let s7_requestIds = {};

    function checkLegalAck() {
        const el = document.getElementById('legalAck');
        if (!el || !el.checked) {
            s7_toast('Vui lòng xác nhận điều khoản pháp lý trước.', 'warning');
            return false;
        }
        return true;
    }

    // Toggle SMS phone input (only for OTP roles)
    ['buyer', 'seller'].forEach(role => {
        document.querySelectorAll(`input[name="${role}OtpChannel"]`).forEach(radio => {
            radio.addEventListener('change', function() {
                const section = document.getElementById(`${role}SmsSection`);
                if (section) section.style.display = this.value === 'sms' ? 'block' : 'none';
            });
        });
    });

    // ═══════════════════════════════════════════════════════════════════════
    // OTP FLOW (Cá nhân)
    // ═══════════════════════════════════════════════════════════════════════
    async function s7_requestOtp(role) {
        if (!checkLegalAck()) return;

        const channel = document.querySelector(`input[name="${role}OtpChannel"]:checked`)?.value || 'email';
        const phoneNumber = document.getElementById(`${role}PhoneNumber`)?.value || '';

        if (channel === 'sms' && !phoneNumber) {
            s7_toast('Vui lòng nhập số điện thoại nhận OTP.', 'warning');
            return;
        }

        const endpoint = role === 'buyer' ? '/Signing/BuyerStart' : '/Signing/SellerStart';
        const btn = event.target.closest('button');
        const origHtml = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang gửi...';

        try {
            const r = await fetch(endpoint, {
                method: 'POST',
                headers: {'Content-Type':'application/json'},
                body: JSON.stringify({ contractId: s7_contractId, channel, phoneNumber })
            });
            const d = await r.json();

            if (d.success) {
                s7_requestIds[role] = d.requestId;
                const sentMsg = channel === 'email'
                    ? 'Mã OTP đã được gửi đến email của bạn.'
                    : `Mã OTP đã được gửi đến số ${phoneNumber}.`;
                s7_toast(sentMsg, 'info');

                document.getElementById(`${role}Step1`).classList.add('d-none');
                document.getElementById(`${role}Step2`).classList.remove('d-none');
                document.getElementById(`${role}OtpInput`).value = '';
                s7_startCountdown(role, 300);
            } else {
                s7_toast(d.message || 'Lỗi gửi OTP.', 'danger');
            }
        } catch (e) {
            s7_toast('Lỗi kết nối: ' + e.message, 'danger');
        } finally {
            btn.disabled = false;
            btn.innerHTML = origHtml;
        }
    }

    function s7_startCountdown(role, seconds) {
        if (s7_timers[role]) clearInterval(s7_timers[role]);
        const el = document.getElementById(`${role}OtpTimer`);
        let remaining = seconds;

        s7_timers[role] = setInterval(() => {
            remaining--;
            const m = Math.floor(remaining / 60);
            const s = remaining % 60;
            el.innerHTML = `OTP hết hạn sau: <strong class="text-danger">${m}:${s.toString().padStart(2,'0')}</strong>`;
            if (remaining <= 0) {
                clearInterval(s7_timers[role]);
                el.innerHTML = '<span class="text-danger">OTP đã hết hạn. Vui lòng gửi lại.</span>';
            }
        }, 1000);
    }

    async function s7_verifyOtp(role) {
        const otp = document.getElementById(`${role}OtpInput`).value.trim();
        if (!otp || otp.length !== 6) {
            s7_toast('Vui lòng nhập đủ 6 chữ số OTP.', 'warning');
            return;
        }

        const endpoint = role === 'buyer' ? '/Signing/BuyerConfirm' : '/Signing/SellerConfirm';
        const btn = event.target.closest('button');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang xác nhận...';

        try {
            const r = await fetch(endpoint, {
                method: 'POST',
                headers: {'Content-Type':'application/json'},
                body: JSON.stringify({ contractId: s7_contractId, requestId: s7_requestIds[role] || 0, otpCode: otp })
            });
            const d = await r.json();

            if (d.success) {
                clearInterval(s7_timers[role]);
                s7_toast(d.message || '✅ Ký thành công!', 'success');
                setTimeout(() => location.reload(), 1500);
            } else {
                s7_toast(d.message || 'OTP không hợp lệ.', 'danger');
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-lock me-1"></i>Xác nhận & Ký';
            }
        } catch (e) {
            s7_toast('Lỗi kết nối: ' + e.message, 'danger');
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-lock me-1"></i>Xác nhận & Ký';
        }
    }

    // ═══════════════════════════════════════════════════════════════════════
    // CA FLOW (Doanh nghiệp — chữ ký số)
    // ═══════════════════════════════════════════════════════════════════════
    async function s7_requestCA(role) {
        if (!checkLegalAck()) return;

        const endpoint = role === 'buyer' ? '/Signing/BuyerCAStart' : '/Signing/SellerCAStart';
        const btn = event.target.closest('button');
        const origHtml = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang gửi yêu cầu...';

        try {
            const r = await fetch(endpoint, {
                method: 'POST',
                headers: {'Content-Type':'application/json'},
                body: JSON.stringify({ contractId: s7_contractId })
            });
            const d = await r.json();

            if (d.success) {
                s7_toast(d.message || '✅ Yêu cầu ký CA đã được gửi!', 'success');
                // Hide the button, show waiting status
                document.getElementById(`${role}CAStep1`).classList.add('d-none');
                document.getElementById(`${role}CAStatus`).classList.remove('d-none');
                // Start polling for completion
                s7_pollCAStatus();
            } else {
                s7_toast(d.message || 'Lỗi gửi yêu cầu CA.', 'danger');
                btn.disabled = false;
                btn.innerHTML = origHtml;
            }
        } catch (e) {
            s7_toast('Lỗi kết nối: ' + e.message, 'danger');
            btn.disabled = false;
            btn.innerHTML = origHtml;
        }
    }

    // Poll for CA signing completion (every 5s, max 60 attempts = 5 min)
    let s7_pollCount = 0;
    function s7_pollCAStatus() {
        const interval = setInterval(async () => {
            s7_pollCount++;
            if (s7_pollCount > 60) {
                clearInterval(interval);
                return;
            }
            try {
                const r = await fetch(`/Signing/Status?contractId=${s7_contractId}`);
                const d = await r.json();
                if (d.buyerSigned || d.sellerSigned) {
                    clearInterval(interval);
                    s7_toast('🎉 Ký số CA thành công!', 'success');
                    setTimeout(() => location.reload(), 1500);
                }
            } catch (e) { /* ignore polling errors */ }
        }, 5000);
    }

    // Allow Enter key in OTP inputs
    ['buyerOtpInput', 'sellerOtpInput'].forEach(id => {
        document.getElementById(id)?.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                const role = id.startsWith('buyer') ? 'buyer' : 'seller';
                s7_verifyOtp(role);
            }
        });
    });

    // ═══════════════════════════════════════════════════════════════════════
    // USB TOKEN FLOW — TechExchange LocalSigner Agent
    // ═══════════════════════════════════════════════════════════════════════
    //
    // TechExchange LocalSigner chạy trên máy user (localhost:15800 HTTP)
    // Agent đọc USB Token qua PKCS#11 (Vina-CAv5.dll / vnpt-ca_csp11.dll)
    //
    // API Endpoints:
    //   GET  /health        → trạng thái agent + token
    //   GET  /certificates  → danh sách chứng thư số trên USB Token
    //   POST /sign          → ký hash bằng private key trên Token
    //
    // PIN KHÔNG BAO GIỜ được gửi lên server — chỉ gửi tới agent trên localhost.
    //
    const LOCAL_SIGNER_BASE = 'http://localhost:15800';

    // State object to hold cert data between steps
    const _usbState = { buyer: {}, seller: {} };

    async function s7_usbSign(role) {
        if (!checkLegalAck()) return;

        const step1    = document.getElementById(`${role}USBStep1`);
        const status   = document.getElementById(`${role}USBStatus`);
        const certInfo = document.getElementById(`${role}USBCertInfo`);
        const progress = document.getElementById(`${role}USBProgress`);

        // Show progress
        step1.classList.add('d-none');
        progress.classList.remove('d-none');

        try {
            // ─── Step 1: Health check — agent đang chạy? Token cắm chưa? ───
            let healthResp;
            try {
                healthResp = await fetch(`${LOCAL_SIGNER_BASE}/health`, {
                    signal: AbortSignal.timeout(5000)
                });
            } catch (e) {
                s7_toast(
                    '⚠️ Không kết nối được <b>TechExchange LocalSigner</b> trên máy tính.<br/>' +
                    '<strong>Hướng dẫn:</strong><br/>' +
                    '1. Chạy <code>TechExchangeSigner.exe</code> trên máy (nếu chưa chạy)<br/>' +
                    '2. Cắm USB Token vào máy<br/>' +
                    '3. Đợi vài giây và thử lại',
                    'warning'
                );
                progress.classList.add('d-none');
                step1.classList.remove('d-none');
                return;
            }

            const healthData = await healthResp.json();
            if (!healthData.tokenDetected) {
                s7_toast(
                    '⚠️ USB Token chưa được phát hiện.<br/>' +
                    'Hãy kiểm tra:<br/>' +
                    '• USB Token đã cắm vào máy chưa?<br/>' +
                    '• Driver đã cài đặt chưa?',
                    'warning'
                );
                progress.classList.add('d-none');
                step1.classList.remove('d-none');
                return;
            }

            // ─── Step 2: Đọc danh sách chứng thư số ───
            const certResp = await fetch(`${LOCAL_SIGNER_BASE}/certificates`, {
                signal: AbortSignal.timeout(10000)
            });
            const certList = await certResp.json();

            if (!Array.isArray(certList) || certList.length === 0) {
                s7_toast('⚠️ Không tìm thấy chứng thư số trên USB Token.', 'warning');
                progress.classList.add('d-none');
                step1.classList.remove('d-none');
                return;
            }

            // Lọc chỉ cert còn hiệu lực
            const validCerts = certList.filter(c => c.isValid !== false);
            const displayCerts = validCerts.length > 0 ? validCerts : certList;

            // Chọn cert hiệu lực đầu tiên (hoặc hiển thị picker nếu có nhiều)
            const cert = displayCerts[0];
            _usbState[role] = {
                certSerial:  cert.serialNumber || '',
                certSubject: cert.subject || '',
                certIssuer:  cert.issuer || '',
                thumbprint:  cert.thumbprint || '',
                validFrom:   cert.notBefore || '',
                validTo:     cert.notAfter || ''
            };

            // Parse CN từ Subject: "CN=Nguyễn Văn A, O=Công ty ABC"
            const cnMatch = _usbState[role].certSubject.match(/CN=([^,]+)/);
            const ownerName = cnMatch ? cnMatch[1] : _usbState[role].certSubject;

            const issuerMatch = _usbState[role].certIssuer.match(/CN=([^,]+)/);
            const issuerName = issuerMatch ? issuerMatch[1] : _usbState[role].certIssuer;

            const validTo = new Date(_usbState[role].validTo);
            const validToStr = validTo.toLocaleDateString('vi-VN');

            // Hiển thị thông tin chứng thư + ô nhập PIN
            certInfo.innerHTML = `
                <div class="alert alert-success py-2 mb-2">
                    <i class="fas fa-certificate me-1"></i> <strong>Chứng thư số đã tìm thấy</strong>
                </div>
                <div class="mb-1"><i class="fas fa-user-tie me-1 text-primary"></i><strong>Chủ sở hữu:</strong> ${ownerName}</div>
                <div class="mb-1"><i class="fas fa-building me-1 text-secondary"></i><strong>Cấp bởi:</strong> ${issuerName}</div>
                <div class="mb-1"><i class="fas fa-barcode me-1 text-secondary"></i><strong>Serial:</strong> <code>${_usbState[role].certSerial}</code></div>
                <div class="mb-2"><i class="fas fa-calendar-alt me-1 text-secondary"></i><strong>Hiệu lực đến:</strong> ${validToStr}</div>
                ${displayCerts.length > 1 ? `
                <div class="mb-2">
                    <label class="form-label small fw-bold">Chọn chứng thư:</label>
                    <select class="form-select form-select-sm" onchange="s7_selectCert('${role}', this.value, ${JSON.stringify(displayCerts).replace(/"/g,'&quot;')})">
                        ${displayCerts.map((c, i) => {
                            const cn = (c.subject || '').match(/CN=([^,]+)/);
                            return `<option value="${i}" ${i===0?'selected':''}>${cn?cn[1]:c.subject} (${c.serialNumber})</option>`;
                        }).join('')}
                    </select>
                </div>` : ''}
                <div class="mt-3">
                    <label class="form-label fw-bold"><i class="fas fa-key me-1"></i>Mã PIN USB Token:</label>
                    <input type="password" class="form-control" id="${role}TokenPIN" placeholder="Nhập mã PIN..." maxlength="20" autocomplete="off" />
                    <div class="form-text text-muted"><small>PIN chỉ xử lý ngay trên máy bạn, KHÔNG gửi lên server.</small></div>
                </div>
            `;

            progress.classList.add('d-none');
            status.classList.remove('d-none');

        } catch (e) {
            s7_toast('Lỗi đọc USB Token: ' + e.message, 'danger');
            progress.classList.add('d-none');
            step1.classList.remove('d-none');
        }
    }

    function s7_selectCert(role, idx, certs) {
        const cert = certs[parseInt(idx)];
        if (!cert) return;
        _usbState[role].certSerial  = cert.serialNumber || '';
        _usbState[role].certSubject = cert.subject || '';
        _usbState[role].certIssuer  = cert.issuer || '';
        _usbState[role].thumbprint  = cert.thumbprint || '';
        _usbState[role].validFrom   = cert.notBefore || '';
        _usbState[role].validTo     = cert.notAfter || '';
    }

    async function s7_usbConfirm(role) {
        const status   = document.getElementById(`${role}USBStatus`);
        const progress = document.getElementById(`${role}USBProgress`);
        const pinInput = document.getElementById(`${role}TokenPIN`);
        const btn      = event.target.closest('button');
        const origHtml = btn.innerHTML;

        // Validate PIN
        const pin = pinInput?.value?.trim();
        if (!pin) {
            s7_toast('⚠️ Vui lòng nhập mã PIN của USB Token.', 'warning');
            pinInput?.focus();
            return;
        }

        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Đang ký số...';

        try {
            // ─── Step 3: Lấy PDF hash từ server ───
            const hashResp = await fetch(`/Signing/ContractHash?contractId=${s7_contractId}`, {
                credentials: 'same-origin'   // đảm bảo cookie auth được gửi kèm
            });

            if (hashResp.status === 401) {
                s7_toast('⚠️ Phiên đăng nhập đã hết hạn. Vui lòng tải lại trang.', 'warning');
                btn.disabled = false; btn.innerHTML = origHtml;
                return;
            }
            if (!hashResp.ok) {
                s7_toast(`Lỗi lấy hash hợp đồng (HTTP ${hashResp.status}).`, 'danger');
                btn.disabled = false; btn.innerHTML = origHtml;
                return;
            }

            const hashData = await hashResp.json();
            if (!hashData.success) {
                s7_toast(hashData.message || 'Không lấy được hash hợp đồng.', 'danger');
                btn.disabled = false;
                btn.innerHTML = origHtml;
                return;
            }

            // ─── Step 4: Gửi hash tới LocalSigner → ký bằng private key trên USB Token ───
            let signResp;
            try {
                signResp = await fetch(`${LOCAL_SIGNER_BASE}/sign`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        base64Hash:        hashData.hashBase64,
                        certificateSerial: _usbState[role].certSerial,
                        pin:               pin
                    }),
                    signal: AbortSignal.timeout(30000)
                });
            } catch (e) {
                s7_toast('⚠️ Không kết nối được LocalSigner. Kiểm tra agent đang chạy.', 'warning');
                btn.disabled = false;
                btn.innerHTML = origHtml;
                return;
            }

            if (!signResp.ok) {
                const errData = await signResp.json().catch(() => ({}));
                if (signResp.status === 401) {
                    s7_toast('❌ Mã PIN không đúng. Vui lòng nhập lại.', 'danger');
                    pinInput.value = '';
                    pinInput.focus();
                } else if (signResp.status === 403) {
                    s7_toast('🔒 USB Token đã bị khóa do nhập sai PIN quá nhiều lần!', 'danger');
                } else {
                    s7_toast('Lỗi ký số: ' + (errData.error || 'Unknown error'), 'danger');
                }
                btn.disabled = false;
                btn.innerHTML = origHtml;
                return;
            }

            const signResult = await signResp.json();
            // signResult = { signature: "base64...", certificate: "base64..." }

            // ─── Step 5: Gửi kết quả ký về server → embed vào PDF ───
            const submitResp = await fetch('/Signing/USBTokenSign', {
                method: 'POST',
                credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    contractId:        s7_contractId,
                    signatureBase64:   signResult.signature,
                    certificateBase64: signResult.certificate,
                    certSerial:        _usbState[role].certSerial,
                    certSubject:       _usbState[role].certSubject,
                    certIssuer:        _usbState[role].certIssuer
                })
            });

            if (submitResp.status === 401) {
                s7_toast('⚠️ Phiên đăng nhập hết hạn. Vui lòng tải lại trang và thử lại.', 'warning');
                btn.disabled = false; btn.innerHTML = origHtml;
                return;
            }

            const submitData = await submitResp.json().catch(() => ({ success: false, message: `HTTP ${submitResp.status}` }));


            if (submitData.success) {
                s7_toast(submitData.message || '✅ Ký USB Token thành công!', 'success');
                status.classList.add('d-none');
                progress.classList.remove('d-none');
                progress.querySelector('.spinner-border')?.remove();

                // Show success + download buttons immediately
                progress.innerHTML = `
                    <div class="text-center py-2">
                        <i class="fas fa-check-circle fa-2x text-success mb-2"></i>
                        <p class="fw-bold text-success mb-3">✅ Đã ký thành công!</p>
                        <div class="d-flex justify-content-center gap-2">
                            <a href="/Signing/DownloadSignedPdf?contractId=${s7_contractId}&mode=view"
                               target="_blank" class="btn btn-outline-primary btn-sm">
                                <i class="fas fa-eye me-1"></i>Xem PDF đã ký
                            </a>
                            <a href="/Signing/DownloadSignedPdf?contractId=${s7_contractId}&mode=download"
                               class="btn btn-success btn-sm">
                                <i class="fas fa-download me-1"></i>Tải về
                            </a>
                        </div>
                    </div>
                `;

                setTimeout(() => location.reload(), 10000);
            } else {
                s7_toast(submitData.message || 'Lỗi lưu chữ ký.', 'danger');
                btn.disabled = false;
                btn.innerHTML = origHtml;
            }

        } catch (e) {
            if (e.name === 'TimeoutError') {
                s7_toast('⚠️ Hết thời gian chờ ký số. Vui lòng thử lại.', 'warning');
            } else {
                s7_toast('Lỗi ký USB Token: ' + e.message, 'danger');
            }
            btn.disabled = false;
            btn.innerHTML = origHtml;
        }
    }

    function s7_toast(msg, type = 'success') {
        const t = document.createElement('div');
        t.className = `toast align-items-center text-bg-${type} border-0 show position-fixed bottom-0 end-0 m-3`;
        t.style = 'z-index:9999;min-width:280px';
        t.innerHTML = `<div class="d-flex"><div class="toast-body">${msg}</div>
            <button class="btn-close btn-close-white me-2 m-auto" onclick="this.closest('.toast').remove()"></button></div>`;
        document.body.appendChild(t);
        setTimeout(() => t.remove(), 5000);
    }
</script>
