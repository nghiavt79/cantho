@model TechExchangeApp.ViewModel.StepContentVm
@using System.IO
@using Microsoft.EntityFrameworkCore
@inject TechExchangeApp.Interfaces.IProposalService ProposalService
@inject TechExchangeApp.Interfaces.IScoringService ScoringService
@inject TechExchangeApp.Data.AppDbContext Context

@{
    var proposal = Model.StepData as TechExchangeApp.Entities.ProposalSubmission;
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="fas fa-folder-open"></i> Bước 4: Nộp Hồ sơ Đề xuất
        </h5>
        @if (proposal != null && Model.UserRole == 2)
        {
            <button class="btn btn-light btn-sm edit-step-btn" data-step="4" data-project-id="@Model.ProjectId">
                <i class="fas fa-edit"></i> Chỉnh sửa
            </button>
        }
    </div>
    <div class="card-body">
        <i class="step-desc">
            Bên bán tiến hành đăng tải hồ sơ năng lực pháp lý kèm theo bản đề xuất phương án kỹ thuật và báo giá tài chính tương ứng lên hệ thống Sàn.
        </i>
        @* BUYER VIEW: Show comparison table *@
        @if (Model.UserRole == 1)
        {
            var proposals = await Context.ProposalSubmissions
                .Include(p => p.Seller)
                .Where(p => p.ProjectId == Model.ProjectId && p.StatusId != 0) // Show all non-draft proposals
                .ToListAsync();


            <h6 class="mb-3"><i class="fas fa-list"></i> Bảng so sánh báo giá</h6>

            @if (!proposals.Any())
            {
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i> Chưa có báo giá nào được gửi.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover table-bordered">
                        <thead class="table-light">
                            <tr>
                                <th>Tên nhà cung ứng</th>
                                <th>Địa chỉ</th>
                                <th>Giá</th>
                                <th>Thời gian</th>
                                <th>Hồ sơ</th>
                                <th>Điểm TB</th>
                                <th>Comments của Consultants</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in proposals)
                            {
                                var scores = await ScoringService.GetProposalScoresAsync(item.Id);
                                var avgScore = await ScoringService.GetAverageScoreAsync(item.Id);
                                var isSelected = Model.Project.SelectedSellerId == item.NguoiTao;

                                <tr class="@(isSelected ? "table-success" : "")">
                                    <td>
                                        <strong>@(item.Seller?.FullName ?? "Unknown")</strong>
                                        @if (isSelected)
                                        {
                                            <span class="badge bg-success ms-2">
                                                <i class="fas fa-check"></i> Đã chọn
                                            </span>
                                        }
                                    </td>
                                    <td>@(Context.NhaCungUngs.FirstOrDefault(n => n.UserId == (item.Seller != null ? item.Seller.Id : 0))?.DiaChi ?? "N/A")</td>
                                    <td>
                                        @if (item.BaoGiaSoBo.HasValue)
                                        {
                                            <strong class="text-primary">@item.BaoGiaSoBo.Value.ToString("N0")</strong>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>@item.ThoiGianTrienKhai</td>
                                    <td>
                                        <a href="@item.GiaiPhapKyThuat" class="btn btn-sm btn-outline-primary" target="_blank">
                                            <i class="fas fa-download"></i> Giải pháp
                                        </a>
                                        <a href="@item.HoSoNangLucDinhKem" class="btn btn-sm btn-outline-primary ms-1" target="_blank">
                                            <i class="fas fa-download"></i> Hồ sơ
                                        </a>
                                    </td>
                                    <td>
                                        @if (avgScore > 0)
                                        {
                                            <span class="badge bg-info">
                                                <i class="fas fa-star"></i> @avgScore.ToString("F1")
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Chưa chấm</span>
                                        }
                                    </td>
                                    <td>
                                        @if (scores != null && scores.Any())
                                        {
                                            <div class="consultant-comments">
                                                @foreach (var score in scores)
                                                {
                                                    <div class="mb-2 p-2 border-start border-3 border-primary bg-light">
                                                        <small class="text-muted">
                                                            <i class="fas fa-user"></i> <strong>@(score.Consultant?.FullName ?? "Consultant")</strong>
                                                        </small>
                                                        <div class="mt-1">
                                                            @if (!string.IsNullOrEmpty(score.Comments))
                                                            {
                                                                <small>@score.Comments</small>
                                                            }
                                                            else
                                                            {
                                                                <small class="text-muted fst-italic">Không có comment</small>
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Chưa có đánh giá</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!isSelected && Model.Project.SelectedSellerId == null)
                                        {
                                            <button type="button" class="btn btn-sm btn-success" 
                                                    data-bs-toggle="modal" 
                                                    data-bs-target="#selectModal@(item.Id)">
                                                <i class="fas fa-check-circle"></i> Chọn
                                            </button>
                                        }
                                    </td>
                                </tr>

                                @* Select Modal *@
                                <div class="modal fade" id="selectModal@(item.Id)" tabindex="-1">
                                    <div class="modal-dialog">
                                        <div class="modal-content">
                                            <div class="modal-header bg-success text-white">
                                                <h5 class="modal-title">Xác nhận chọn nhà cung ứng</h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                            </div>
                                            <div class="modal-body">
                                                <p>Bạn có chắc chắn muốn chọn <strong>@(item.Seller?.FullName ?? "Unknown")</strong> làm nhà cung ứng?</p>
                                                <div class="alert alert-warning">
                                                    <i class="fas fa-exclamation-triangle"></i>
                                                    <strong>Lưu ý:</strong> Hành động này sẽ:
                                                    <ul class="mb-0 mt-2">
                                                        <li>Chuyển dự án sang Bước 5</li>
                                                        <li>Từ chối tất cả báo giá khác</li>
                                                        <li>Không thể hoàn tác</li>
                                                    </ul>
                                                </div>
                                                <div id="selectError@(item.Id)" class="alert alert-danger d-none"></div>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                                                <button type="button" class="btn btn-success" 
                                                        id="confirmSelectBtn@(item.Id)"
                                                        onclick="confirmSelectSeller(@Model.ProjectId, @item.Id, this)">
                                                    <i class="fas fa-check-circle"></i> Xác nhận chọn
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
        @* CONSULTANT VIEW: Show proposal cards with scoring *@
        else if (Model.UserRole == 3)
        {
            var proposals = await Context.ProposalSubmissions
                .Include(p => p.Seller)
                .Where(p => p.ProjectId == Model.ProjectId && p.StatusId == 1)
                .ToListAsync();

            <h6 class="mb-3"><i class="fas fa-star"></i> Đánh giá báo giá</h6>

            @if (!proposals.Any())
            {
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i> Chưa có báo giá nào để đánh giá.
                </div>
            }
            else
            {
                <div class="row">
                    @foreach (var item in proposals)
                    {
                        var consultantScore = await ScoringService.GetConsultantScoreAsync(item.Id, User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier) != null ? int.Parse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)!.Value) : 0);
                        var avgScore = await ScoringService.GetAverageScoreAsync(item.Id);

                        <div class="col-md-6 mb-3">
                            <div class="card">
                                <div class="card-header bg-light">
                                    <h6 class="mb-0">
                                        <i class="fas fa-building"></i> Proposal Card
                                        <button type="button" class="btn btn-sm btn-outline-secondary float-end" onclick="navigator.clipboard.writeText('pgzql')">
                                            <i class="fas fa-copy"></i> Copy code
                                        </button>
                                    </h6>
                                </div>
                                <div class="card-body">
                                    <p class="mb-2"><strong>Seller:</strong> @(item.Seller?.FullName ?? "ABC Company")</p>
                                    <p class="mb-2">
                                        <strong>Giá:</strong> 
                                        @if (item.BaoGiaSoBo.HasValue)
                                        {
                                            <span class="text-danger">@item.BaoGiaSoBo.Value.ToString("N0") VNĐ</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Chưa cung cấp</span>
                                        }
                                    </p>
                                    <p class="mb-3"><strong>Thời gian:</strong> @item.ThoiGianTrienKhai</p>

                                    <div class="mb-3">
                                        <a href="@item.GiaiPhapKyThuat" class="btn btn-sm btn-outline-primary" target="_blank">
                                            <i class="fas fa-download"></i> Download Technical
                                        </a>
                                        <a href="@item.HoSoNangLucDinhKem" class="btn btn-sm btn-outline-primary" target="_blank">
                                            <i class="fas fa-download"></i> Download Capability
                                        </a>
                                    </div>

                                    <hr />

                                    <h6 class="text-muted mb-2">ĐÁNH GIÁ CỦA BẠN (Consultant)</h6>

                                    <form class="scoringForm" method="post" asp-controller="Scoring" asp-action="ScoreProposal" data-proposal-id="@item.Id">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="ProposalId" value="@item.Id" />
                                        <input type="hidden" name="ProjectId" value="@Model.ProjectId" />

                                        <div class="mb-3">
                                            <label class="form-label small">Technical Score</label>
                                            <div class="star-rating" data-field="TechnicalScore">
                                                @for (int i = 1; i <= 10; i++)
                                                {
                                                    var isChecked = (consultantScore?.TechnicalScore ?? 0) >= i;
                                                    <i class="@(isChecked ? "fas" : "far") fa-star" data-value="@i"></i>
                                                }
                                            </div>
                                            <input type="hidden" name="TechnicalScore" value="@(consultantScore?.TechnicalScore ?? 0)" required />
                                            <small class="text-muted">Score: <span class="score-display">@(consultantScore?.TechnicalScore ?? 0)</span>/10</small>
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label small">Price Score</label>
                                            <div class="star-rating" data-field="PriceScore">
                                                @for (int i = 1; i <= 10; i++)
                                                {
                                                    var isChecked = (consultantScore?.PriceScore ?? 0) >= i;
                                                    <i class="@(isChecked ? "fas" : "far") fa-star" data-value="@i"></i>
                                                }
                                            </div>
                                            <input type="hidden" name="PriceScore" value="@(consultantScore?.PriceScore ?? 0)" required />
                                            <small class="text-muted">Score: <span class="score-display">@(consultantScore?.PriceScore ?? 0)</span>/10</small>
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label small">Timeline Score</label>
                                            <div class="star-rating" data-field="TimelineScore">
                                                @for (int i = 1; i <= 10; i++)
                                                {
                                                    var isChecked = (consultantScore?.TimelineScore ?? 0) >= i;
                                                    <i class="@(isChecked ? "fas" : "far") fa-star" data-value="@i"></i>
                                                }
                                            </div>
                                            <input type="hidden" name="TimelineScore" value="@(consultantScore?.TimelineScore ?? 0)" required />
                                            <small class="text-muted">Score: <span class="score-display">@(consultantScore?.TimelineScore ?? 0)</span>/10</small>
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label small">Overall Score</label>
                                            <div class="star-rating" data-field="OverallScore">
                                                @for (int i = 1; i <= 10; i++)
                                                {
                                                    var isChecked = (consultantScore?.OverallScore ?? 0) >= i;
                                                    <i class="@(isChecked ? "fas" : "far") fa-star" data-value="@i"></i>
                                                }
                                            </div>
                                            <input type="hidden" name="OverallScore" value="@(consultantScore?.OverallScore ?? 0)" required />
                                            <small class="text-muted">Score: <span class="score-display">@(consultantScore?.OverallScore ?? 0)</span>/10</small>
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label small text-danger">Comment</label>
                                            <textarea name="Comments" class="form-control form-control-sm" rows="2">@(consultantScore?.Comments ?? "")</textarea>
                                        </div>

                                        <button type="submit" class="btn btn-sm btn-warning w-100">
                                            <i class="fas fa-save"></i> Lưu đánh giá
                                        </button>
                                    </form>

                                    @if (consultantScore != null)
                                    {
                                        <div class="alert alert-success mt-2 mb-0 small">
                                            <i class="fas fa-check"></i> Bạn đã chấm điểm proposal này
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        }
        @* SELLER VIEW: Show their own proposal *@
        else if (proposal != null)
        {
            <dl class="row">
                <dt class="col-sm-3">Giải pháp kỹ thuật:</dt>
                <dd class="col-sm-9">
                    <i class="fas fa-file-pdf text-danger"></i> 
                    <strong>@System.IO.Path.GetFileName(proposal.GiaiPhapKyThuat)</strong>
                </dd>

                <dt class="col-sm-3">Báo giá sơ bộ:</dt>
                <dd class="col-sm-9">
                    @if (proposal.BaoGiaSoBo.HasValue)
                    {
                        <span class="badge bg-success">
                            <i class="fas fa-dollar-sign"></i> @proposal.BaoGiaSoBo.Value.ToString("N0") VNĐ
                        </span>
                    }
                    else
                    {
                        <span class="text-muted">Chưa cập nhật</span>
                    }
                </dd>

                <dt class="col-sm-3">Thời gian triển khai:</dt>
                <dd class="col-sm-9"><strong>@proposal.ThoiGianTrienKhai</strong></dd>

                <dt class="col-sm-3">Hồ sơ năng lực:</dt>
                <dd class="col-sm-9">
                    <i class="fas fa-file-archive text-primary"></i> 
                    <strong>@System.IO.Path.GetFileName(proposal.HoSoNangLucDinhKem)</strong>
                </dd>

                <dt class="col-sm-3">Trạng thái:</dt>
                <dd class="col-sm-9">
                    @if (Model.Steps[3].StatusId > 0)
                    {
                        <span class="badge bg-success"><i class="fas fa-check"></i> Đã hoàn thành</span>
                    }
                    else
                    {
                        <span class="badge bg-warning"><i class="fas fa-clock"></i> Chưa hoàn thành</span>
                    }
                </dd>

                <dt class="col-sm-3">Ngày tạo:</dt>
                <dd class="col-sm-9">@proposal.NgayTao.ToString("dd/MM/yyyy HH:mm")</dd>

                @if (proposal.NgaySua.HasValue)
                {
                    <dt class="col-sm-3">Ngày cập nhật:</dt>
                    <dd class="col-sm-9">@proposal.NgaySua.Value.ToString("dd/MM/yyyy HH:mm")</dd>
                }
            </dl>
        }
        else
        {
            <div class="alert alert-info">
                <i class="fas fa-info-circle"></i> 
                <strong>Mô tả:</strong> Nhà cung ứng nộp hồ sơ đề xuất kỹ thuật và báo giá
            </div>
            <p class="text-muted">Chưa có dữ liệu cho bước này.</p>
        }
    </div>
    <div class="card-footer">
        <button class="btn btn-secondary step-nav-btn" data-step="@(Model.StepNumber - 1)">
            <i class="fas fa-arrow-left"></i> Quay lại bước trước
        </button>
        @if (Model.StepNumber < 11 && Model.Steps[Model.StepNumber].IsAccessible)
        {
            <button class="btn btn-primary step-nav-btn" data-step="@(Model.StepNumber + 1)">
                Tiếp tục bước @(Model.StepNumber + 1) <i class="fas fa-arrow-right"></i>
            </button>
        }
    </div>
</div>

<script>
    // Handle star rating clicks
    $(document).ready(function() {
        // Star rating click handler
        $(document).on('click', '.star-rating i', function() {
            var star = $(this);
            var rating = star.data('value');
            var container = star.parent('.star-rating');
            var fieldName = container.data('field');
            var form = container.closest('form');
            
            // Update hidden input
            form.find('input[name="' + fieldName + '"]').val(rating);
            
            // Update score display
            container.next('input').next('small').find('.score-display').text(rating);
            
            // Update stars visual
            container.find('i').each(function() {
                var starValue = $(this).data('value');
                if (starValue <= rating) {
                    $(this).removeClass('far').addClass('fas');
                } else {
                    $(this).removeClass('fas').addClass('far');
                }
            });
        });
        
        // Star rating hover effect
        $(document).on('mouseenter', '.star-rating i', function() {
            var star = $(this);
            var hoverValue = star.data('value');
            var container = star.parent('.star-rating');
            
            container.find('i').each(function() {
                var starValue = $(this).data('value');
                if (starValue <= hoverValue) {
                    $(this).addClass('fas').removeClass('far');
                } else {
                    $(this).addClass('far').removeClass('fas');
                }
            });
        });
        
        // Star rating mouse leave - restore saved rating
        $(document).on('mouseleave', '.star-rating', function() {
            var container = $(this);
            var fieldName = container.data('field');
            var form = container.closest('form');
            var savedRating = parseFloat(form.find('input[name="' + fieldName + '"]').val()) || 0;
            
            container.find('i').each(function() {
                var starValue = $(this).data('value');
                if (starValue <= savedRating) {
                    $(this).addClass('fas').removeClass('far');
                } else {
                    $(this).addClass('far').removeClass('fas');
                }
            });
        });
    
        // Handle scoring form submission via AJAX
        $(document).on('submit', '.scoringForm', function(e) {
            e.preventDefault();
            
            var form = $(this);
            var submitBtn = form.find('button[type="submit"]');
            var originalBtnText = submitBtn.html();
            var proposalId = form.data('proposal-id');
            
            // Disable button and show loading
            submitBtn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Đang lưu...');
            
            $.ajax({
                url: form.attr('action'),
                type: 'POST',
                data: form.serialize(),
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                },
                success: function(response) {
                    if (response.success) {
                        // Show success message
                        var alertHtml = '<div class="alert alert-success alert-dismissible fade show mt-2" role="alert">' +
                            '<i class="fas fa-check-circle"></i> ' + response.message +
                            '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
                            '</div>';
                        
                        // Remove existing alerts
                        form.find('.alert').remove();
                        
                        // Insert alert after submit button
                        submitBtn.after(alertHtml);
                        
                        // Auto-dismiss after 3 seconds
                        setTimeout(function() {
                            form.find('.alert').fadeOut(function() {
                                $(this).remove();
                            });
                        }, 3000);
                        
                        // Re-enable button
                        submitBtn.prop('disabled', false).html(originalBtnText);
                    } else {
                        // Show error message
                        var alertHtml = '<div class="alert alert-danger alert-dismissible fade show mt-2" role="alert">' +
                            '<i class="fas fa-exclamation-circle"></i> ' + response.message +
                            '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
                            '</div>';
                        
                        // Remove existing alerts
                        form.find('.alert').remove();
                        
                        // Insert alert after submit button
                        submitBtn.after(alertHtml);
                        
                        // Re-enable button
                        submitBtn.prop('disabled', false).html(originalBtnText);
                    }
                },
                error: function() {
                    var alertHtml = '<div class="alert alert-danger alert-dismissible fade show mt-2" role="alert">' +
                        '<i class="fas fa-exclamation-circle"></i> Đã xảy ra lỗi. Vui lòng thử lại.' +
                        '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
                        '</div>';
                    
                    // Remove existing alerts
                    form.find('.alert').remove();
                    
                    // Insert alert after submit button
                    submitBtn.after(alertHtml);
                    
                    // Re-enable button
                    submitBtn.prop('disabled', false).html(originalBtnText);
                }
            });
        });
    });

    // Select seller via AJAX (bypasses antiforgery token issue in partial views)
    function confirmSelectSeller(projectId, proposalId, btn) {
        // Disable button and show loading
        btn.disabled = true;
        var originalHtml = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang xử lý...';

        // Get antiforgery token from the page
        var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value
                 || document.querySelector('meta[name="__RequestVerificationToken"]')?.getAttribute('content')
                 || '';

        // Build form data
        var formData = new FormData();
        formData.append('projectId', projectId);
        formData.append('proposalId', proposalId);
        formData.append('__RequestVerificationToken', token);

        fetch('/ProposalList/SelectSeller', {
            method: 'POST',
            body: formData
        })
        .then(function(response) {
            if (response.redirected) {
                // Follow the redirect
                window.location.href = response.url;
            } else if (response.ok) {
                window.location.reload();
            } else {
                // Show error in modal
                var errorDiv = document.getElementById('selectError' + proposalId);
                if (errorDiv) {
                    errorDiv.textContent = 'Không thể chọn nhà cung ứng. Vui lòng thử lại.';
                    errorDiv.classList.remove('d-none');
                }
                btn.disabled = false;
                btn.innerHTML = originalHtml;
            }
        })
        .catch(function(err) {
            console.error('SelectSeller error:', err);
            var errorDiv = document.getElementById('selectError' + proposalId);
            if (errorDiv) {
                errorDiv.textContent = 'Đã xảy ra lỗi kết nối. Vui lòng thử lại.';
                errorDiv.classList.remove('d-none');
            }
            btn.disabled = false;
            btn.innerHTML = originalHtml;
        });
    }
</script>
