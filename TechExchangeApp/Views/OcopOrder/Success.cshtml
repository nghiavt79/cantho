@model TechExchangeApp.Entities.OcopOrderRequest

@{
    ViewData["Title"] = "Đặt mua thành công";
    var product = ViewBag.Product as TechExchangeApp.Entities.SanPhamCNTB;
    var supplier = ViewBag.Supplier as TechExchangeApp.Entities.NhaCungUng;
    var hasBankInfo = supplier != null && !string.IsNullOrWhiteSpace(supplier.SoTaiKhoan);
}

<div class="container mt-5 text-center">
    <div class="card shadow-sm mx-auto" style="max-width: 600px;">
        <div class="card-body py-5">
            <div class="mb-4 text-success">
                <i class="fas fa-check-circle fa-5x"></i>
            </div>
            <h2 class="card-title text-success mb-3">Đặt mua thành công!</h2>
            <p class="card-text text-muted mb-1">
                Đơn đặt mua @Model.SoLuong @(product != null ? $"\"{product.Name}\"" : "sản phẩm OCOP") đã được gửi đến nhà cung ứng.
            </p>
            <p class="card-text text-muted mb-1">
                Hình thức thanh toán: <strong>@(Model.HinhThucThanhToan == 2 ? "Chuyển khoản" : "Thanh toán khi nhận hàng (COD)")</strong>
            </p>
            @if (Model.HinhThucThanhToan == 2 && hasBankInfo)
            {
                <div class="alert alert-light border text-start mb-4">
                    <div class="fw-semibold mb-2"><i class="fa fa-university me-1"></i> Thông tin chuyển khoản</div>
                    <div>Ngân hàng: <strong>@supplier!.TenNganHang</strong></div>
                    <div>Số tài khoản: <strong>@supplier.SoTaiKhoan</strong></div>
                    <div>Chủ tài khoản: <strong>@supplier.ChuTaiKhoan</strong></div>
                </div>
            }
            else if (Model.HinhThucThanhToan == 2)
            {
                <p class="card-text text-muted mb-4">
                    Nhà cung ứng chưa cập nhật thông tin tài khoản — sẽ gửi cho bạn qua số điện thoại <strong>@Model.DienThoai</strong> sau khi xác nhận đơn.
                </p>
            }
            else
            {
                <p class="card-text text-muted mb-4">
                    Nhà cung ứng sẽ liên hệ với bạn qua số điện thoại <strong>@Model.DienThoai</strong> để xác nhận và giao hàng.
                </p>
            }
            <a asp-controller="OcopOrder" asp-action="Index" class="btn btn-outline-primary me-2">
                <i class="fas fa-list me-2"></i>Xem đơn hàng của tôi
            </a>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                <i class="fas fa-home me-2"></i>Về trang chủ
            </a>
            <a asp-controller="Ocop" asp-action="Index" class="btn btn-outline-secondary ms-2">
                <i class="fas fa-store me-2"></i>Xem thêm sản phẩm OCOP
            </a>
        </div>
    </div>
</div>
