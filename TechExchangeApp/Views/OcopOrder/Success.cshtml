@model TechExchangeApp.Entities.OcopOrderRequest

@{
    ViewData["Title"] = "Đặt mua thành công";
    var product = ViewBag.Product as TechExchangeApp.Entities.SanPhamCNTB;
}

<div class="container mt-5 text-center">
    <div class="card shadow-sm mx-auto" style="max-width: 600px;">
        <div class="card-body py-5">
            <div class="mb-4 text-success">
                <i class="fas fa-check-circle fa-5x"></i>
            </div>
            <h2 class="card-title text-success mb-3">Đặt mua thành công!</h2>
            <p class="card-text text-muted mb-1">
                Đơn đặt mua @Model.SoLuong @(product != null ? $"\"{product.Name}\"" : "sản phẩm OCOP") đã được gửi đến nhà cung ứng.
            </p>
            <p class="card-text text-muted mb-4">
                Nhà cung ứng sẽ liên hệ với bạn qua số điện thoại <strong>@Model.DienThoai</strong> để xác nhận và giao hàng.
            </p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                <i class="fas fa-home me-2"></i>Về trang chủ
            </a>
            <a asp-controller="Ocop" asp-action="Index" class="btn btn-outline-secondary ms-2">
                <i class="fas fa-store me-2"></i>Xem thêm sản phẩm OCOP
            </a>
        </div>
    </div>
</div>
