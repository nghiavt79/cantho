@using TechExchangeApp.Interfaces
@using Microsoft.AspNetCore.Identity
@using TechExchangeApp.Entities
@inject IAccountService AccountService
@inject UserManager<ApplicationUser> UserManager

@model List<TechExchangeApp.ViewModel.OcopOrderVm>

@{
    ViewData["Title"] = "Đơn OCOP khách đặt";
    ViewData["AuthWorkspace"] = true;

    var userId = int.Parse(UserManager.GetUserId(User)!);
    var sidebarData = await AccountService.GetSidebarDataAsync(userId);

    string StatusBadge(int statusId) => statusId switch
    {
        1 => "bg-secondary",
        2 => "bg-info",
        3 => "bg-success",
        4 => "bg-danger",
        _ => "bg-secondary"
    };

    string StatusText(int statusId) => statusId switch
    {
        1 => "Mới đặt",
        2 => "Đã xác nhận",
        3 => "Hoàn tất",
        4 => "Đã huỷ",
        _ => "Không xác định"
    };

    string PaymentText(int hinhThuc) => hinhThuc == 2 ? "Chuyển khoản" : "COD";
}

<div class="container-fluid py-4 user-portal">
  <div class="row">
    <div class="col-md-3 col-lg-2">
      @await Html.PartialAsync("_AccountSidebar", sidebarData)
    </div>

    <div class="col-md-9 col-lg-10 user-portal-main">
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="fas fa-clipboard-list"></i> Đơn OCOP khách đặt</h5>
                <span class="badge bg-primary">Tổng: @Model.Count đơn</span>
            </div>
            <div class="card-body">
                @if (Model.Count == 0)
                {
                    <div class="empty-state">
                        <i class="fas fa-clipboard-list empty-state-icon"></i>
                        <p class="empty-state-title">Chưa có đơn đặt mua nào</p>
                        <p class="empty-state-text">Khi khách hàng đặt mua sản phẩm OCOP của bạn, đơn hàng sẽ hiện ở đây.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>Sản phẩm</th>
                                    <th>Khách hàng</th>
                                    <th>Điện thoại</th>
                                    <th>Số lượng</th>
                                    <th>Địa chỉ giao</th>
                                    <th>Thanh toán</th>
                                    <th>Trạng thái</th>
                                    <th>Ngày đặt</th>
                                    <th>Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in Model)
                                {
                                    <tr>
                                        <td data-label="Sản phẩm">@order.ProductName</td>
                                        <td data-label="Khách hàng">@order.HoTen</td>
                                        <td data-label="Điện thoại">@order.DienThoai</td>
                                        <td data-label="Số lượng">@order.SoLuong</td>
                                        <td data-label="Địa chỉ giao">@order.DiaChiGiao</td>
                                        <td data-label="Thanh toán">@PaymentText(order.HinhThucThanhToan)</td>
                                        <td data-label="Trạng thái"><span class="badge @StatusBadge(order.StatusId)">@StatusText(order.StatusId)</span></td>
                                        <td data-label="Ngày đặt">@order.NgayTao.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td data-label="Thao tác">
                                            @if (order.StatusId < 3)
                                            {
                                                <form asp-action="UpdateStatus" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@order.Id" />
                                                    <input type="hidden" name="statusId" value="@(order.StatusId == 1 ? 2 : 3)" />
                                                    <button type="submit" class="btn btn-sm btn-outline-primary">
                                                        @(order.StatusId == 1 ? "Xác nhận" : "Đánh dấu hoàn tất")
                                                    </button>
                                                </form>
                                            }
                                            @if (order.StatusId == 1)
                                            {
                                                <form asp-action="UpdateStatus" method="post" class="d-inline" onsubmit="return confirm('Huỷ đơn này?');">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@order.Id" />
                                                    <input type="hidden" name="statusId" value="4" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">Huỷ đơn</button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
  </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/user-portal.css" asp-append-version="true" />
}
