@model TechExchangeApp.ViewModel.SearchResultPageVm
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = string.IsNullOrWhiteSpace(Model.Query)
        ? "Tìm kiếm" : $"Tìm kiếm: {Model.Query}";
    var MainDomain = Configuration["AppSettings:MainDomain"] ?? "https://localhost:7232/";
    var enableAI = (int?)ViewBag.EnableAISearch ?? 0;

    // Define tab order
    var typeOrder = new[]
    {
        TechExchangeApp.ViewModel.SearchEntityType.All,
        TechExchangeApp.ViewModel.SearchEntityType.Technology,
        TechExchangeApp.ViewModel.SearchEntityType.Equipment,
        TechExchangeApp.ViewModel.SearchEntityType.IntellectualProperty,
        TechExchangeApp.ViewModel.SearchEntityType.Supplier,
        TechExchangeApp.ViewModel.SearchEntityType.Expert,
        TechExchangeApp.ViewModel.SearchEntityType.Article
    };
}

<link rel="stylesheet" href="~/css/search-enterprise.css" />

<div class="se-page">

    @* ── Header ─────────────────────────────────────── *@
    <div class="se-header">
        @if (!string.IsNullOrWhiteSpace(Model.Query))
        {
            <h1>Kết quả tìm kiếm: <span>"@Model.Query"</span></h1>
            var total = Model.CountsByType.GetValueOrDefault(TechExchangeApp.ViewModel.SearchEntityType.All, Model.Total);
            <p class="se-summary">
                Tìm thấy <strong>@total</strong> kết quả
                @if (Model.AIResultCount > 0)
                {
                    <text> và <strong>@Model.AIResultCount</strong> gợi ý AI</text>
                }
            </p>
        }
        else
        {
            <h1>Tìm kiếm</h1>
            <p class="se-summary">Nhập từ khóa để tìm công nghệ, thiết bị, nhà cung ứng…</p>
        }
    </div>

    @if (string.IsNullOrWhiteSpace(Model.Query))
    {
        <div class="se-empty">
            <i class="bi bi-search"></i>
            <h5>Vui lòng nhập từ khóa tìm kiếm</h5>
            <p>Sử dụng thanh tìm kiếm phía trên để bắt đầu.</p>
        </div>
    }
    else
    {
        @* ── Mode tabs: Normal / AI ────────────────────── *@
        @if (enableAI == 1)
        {
            <ul class="nav nav-tabs se-mode-tabs mb-3">
                <li class="nav-item">
                    <a class="nav-link @(Model.Mode != "ai" ? "active" : "")"
                       href="/Search?q=@Uri.EscapeDataString(Model.Query)">
                        <i class="bi bi-search me-1"></i>Tìm kiếm thông thường
                        @{
                            var normalCount = Model.CountsByType.GetValueOrDefault(TechExchangeApp.ViewModel.SearchEntityType.All, Model.Total);
                        }
                        @if (normalCount > 0)
                        {
                            <span class="badge bg-primary ms-1">@normalCount</span>
                        }
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(Model.Mode == "ai" ? "active" : "")"
                       href="/Search?q=@Uri.EscapeDataString(Model.Query)&mode=ai">
                        <i class="bi bi-stars me-1"></i>Gợi ý thông minh (AI)
                        @if (Model.AIResultCount > 0)
                        {
                            <span class="badge bg-success ms-1">@Model.AIResultCount</span>
                        }
                    </a>
                </li>
            </ul>
        }

        @if (Model.Mode == "ai" && enableAI == 1)
        {
            @* ── AI results (kept from original) ───────────── *@
            if (Model.AISearchResults != null && Model.AISearchResults.Any())
            {
                <div class="ai-search-results">
                    @foreach (var company in Model.AISearchResults)
                    {
                        <div class="card mb-3" style="border-left:4px solid #0d6efd;">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div>
                                        <h5 class="mb-1">
                                            <a href="@($"{MainDomain}{company.CompanyUrl}")"
                                               class="text-primary text-decoration-none">@company.CompanyName</a>
                                        </h5>
                                        <small class="text-muted">
                                            <i class="bi bi-star-fill text-warning"></i> @company.Rating.ToString("0.0")/5
                                            &nbsp;•&nbsp;
                                            <i class="bi bi-eye"></i> @company.ViewCount.ToString("N0") lượt xem
                                        </small>
                                    </div>
                                    <span class="badge bg-success fs-6 px-3 py-2">
                                        @company.MatchPercentage.ToString("0.0")% phù hợp
                                    </span>
                                </div>
                                <div class="bg-light p-3 rounded">
                                    <h6 class="text-muted mb-2"><i class="bi bi-box-seam me-1"></i>Sản phẩm phù hợp:</h6>
                                    <ul class="list-unstyled mb-0">
                                        @foreach (var prod in company.Products)
                                        {
                                            <li class="d-flex justify-content-between py-2 border-bottom">
                                                <a href="@($"{MainDomain}{prod.ProductUrl}")"
                                                   class="text-decoration-none text-dark">@prod.ProductName</a>
                                                <span class="text-muted">@prod.RelevancePercentage.ToString("0")%</span>
                                            </li>
                                        }
                                    </ul>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="se-empty">
                    <i class="bi bi-stars"></i>
                    <h5>Không có kết quả AI</h5>
                    <p>Thử mô tả chi tiết hơn hoặc sử dụng tab "Tìm kiếm thông thường".</p>
                </div>
            }
        }
        else
        {
            @* ── Type filter pills ──────────────────────────── *@
            <div class="se-filters">
                @foreach (var et in typeOrder)
                {
                    var label = TechExchangeApp.ViewModel.SearchEntityTypeHelper.ToLabel(et);
                    var icon  = TechExchangeApp.ViewModel.SearchEntityTypeHelper.ToIcon(et);
                    var count = Model.CountsByType.GetValueOrDefault(et, 0);
                    var isActive = et == Model.Type;

                    <a href="#" class="se-filter-pill @(isActive ? "active" : "")"
                       data-type="@(et == TechExchangeApp.ViewModel.SearchEntityType.All ? "all" : et.ToString())">
                        <i class="bi @icon"></i>
                        @label
                        @if (count > 0)
                        {
                            <span class="badge">@count</span>
                        }
                    </a>
                }
            </div>

            @* ── Results host (loaded inline, updated via AJAX) *@
            <div id="resultsHost">
                @await Html.PartialAsync("_SearchResults", Model)
            </div>
        }
    }
</div>

<script src="~/js/search-enterprise.js"></script>
