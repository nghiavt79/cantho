@model TechExchangeApp.ViewModel.FeedbackCreateViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Liên hệ - Trung tâm Ứng dụng Tiến bộ KH&CN Cần Thơ";

    const string centerName = "Trung tâm Ứng dụng Tiến bộ Khoa học và Công nghệ Cần Thơ";
    const string address = "166 Nguyễn Văn Cừ, P. An Bình, TP. Cần Thơ";
    const string phone = "+(84) 292 3907 037";
    const string phoneHref = "+842923907037";
    const string fax = "";
    const string email = "trungtamungdung@cantho.gov.vn";
    const string mapsUrl = "https://maps.google.com/?q=166+Nguyen+Van+Cu,+An+Binh,+Can+Tho";
}

<link rel="stylesheet" href="~/css/contact-v2.css" asp-append-version="true" />

<input type="hidden" id="hidMaXacThuc" value="Vui lòng nhập đúng mã xác thực" />
<input type="hidden" id="hidHoTen" value="Vui lòng nhập họ tên" />
<input type="hidden" id="hidDienThoai" value="Vui lòng nhập điện thoại" />
<input type="hidden" id="hidEmail" value="Vui lòng nhập đúng Email" />
<input type="hidden" id="hidTieuDe" value="Vui lòng nhập tiêu đề" />
<input type="hidden" id="hidLoiNhat" value="Vui lòng nhập lời nhắn" />

<div class="columns-container">
    <div class="contact-page">
        <section class="ct-hero">
            <div class="container">
                <div class="ct-hero__inner">
                    <div>
                        <span class="ct-eyebrow">Kết nối Trung tâm</span>
                        <h1 class="ct-hero__title">Liên hệ với chúng tôi</h1>
                        <p class="ct-hero__sub">
                            @centerName luôn sẵn sàng tiếp nhận yêu cầu tư vấn, hợp tác, chuyển giao công nghệ
                            và hỗ trợ doanh nghiệp trong quá trình đổi mới sáng tạo.
                        </p>
                        <div class="ct-hero__badges" aria-label="Dịch vụ hỗ trợ">
                            <span>Tư vấn KH&amp;CN</span>
                            <span>Chuyển giao công nghệ</span>
                            <span>Hỗ trợ doanh nghiệp</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <main class="container">
            @if (TempData["Alert"] != null)
            {
                <div class="ct-alert-success" role="alert">
                    <i class="bi bi-check-circle-fill"></i>
                    <span>@TempData["Alert"]</span>
                </div>
            }

            <section class="ct-quick-support" aria-label="Kênh hỗ trợ nhanh">
                <button type="button" data-contact-title="Yêu cầu tư vấn dịch vụ khoa học và công nghệ">
                    <i class="bi bi-lightbulb"></i>Tư vấn dịch vụ KH&amp;CN
                </button>
                <button type="button" data-contact-title="Yêu cầu hợp tác chuyển giao công nghệ">
                    <i class="bi bi-arrow-left-right"></i>Hợp tác chuyển giao
                </button>
                <button type="button" data-contact-title="Yêu cầu hỗ trợ doanh nghiệp">
                    <i class="bi bi-briefcase"></i>Hỗ trợ doanh nghiệp
                </button>
                <button type="button" data-contact-title="Góp ý / phản ánh">
                    <i class="bi bi-chat-dots"></i>Góp ý / phản ánh
                </button>
            </section>

            <section class="ct-main">
                <div class="ct-grid">
                    <aside class="ct-card ct-info-card">
                        <span class="ct-card-kicker">Thông tin liên hệ</span>
                        <h2 class="ct-info__brand">@centerName</h2>

                        <ul class="ct-info__list">
                            <li>
                                <span class="ct-icon"><i class="bi bi-geo-alt-fill"></i></span>
                                <div>
                                    <strong>Địa chỉ</strong>
                                    <span>@address</span>
                                </div>
                            </li>
                            <li>
                                <span class="ct-icon"><i class="bi bi-telephone-fill"></i></span>
                                <div>
                                    <strong>Điện thoại</strong>
                                    <a href="tel:@phoneHref">@phone</a>
                                </div>
                            </li>
                            @if (!string.IsNullOrEmpty(fax))
                            {
                            <li>
                                <span class="ct-icon"><i class="bi bi-printer-fill"></i></span>
                                <div>
                                    <strong>Fax</strong>
                                    <span>@fax</span>
                                </div>
                            </li>
                            }
                            <li>
                                <span class="ct-icon"><i class="bi bi-envelope-fill"></i></span>
                                <div>
                                    <strong>Email</strong>
                                    <a href="mailto:@email">@email</a>
                                </div>
                            </li>
                            <li>
                                <span class="ct-icon"><i class="bi bi-clock-fill"></i></span>
                                <div>
                                    <strong>Giờ làm việc</strong>
                                    <span>Thứ 2 - Thứ 6, 8:00 - 17:00</span>
                                </div>
                            </li>
                        </ul>

                        <div class="ct-help-box">
                            <h3>Bạn cần hỗ trợ nhanh?</h3>
                            <p>Gọi trực tiếp cho chúng tôi trong giờ hành chính để được hướng dẫn nhanh nhất.</p>
                        </div>

                        <div class="ct-support-stack">
                            <div class="ct-support-item">
                                <i class="bi bi-alarm"></i>
                                <div>
                                    <strong>Thời gian phản hồi</strong>
                                    <span>Thông thường trong vòng 01 ngày làm việc.</span>
                                </div>
                            </div>
                            <div class="ct-support-item">
                                <i class="bi bi-inboxes"></i>
                                <div>
                                    <strong>Kênh tiếp nhận</strong>
                                    <span>Tư vấn dịch vụ KH&amp;CN, hợp tác chuyển giao, góp ý và phản ánh.</span>
                                </div>
                            </div>
                        </div>

                        <div class="ct-info__actions">
                            <a href="tel:@phoneHref" class="ct-btn-primary">
                                <i class="bi bi-telephone"></i>Gọi ngay
                            </a>
                            <a href="@mapsUrl" target="_blank" rel="noopener" class="ct-btn-outline">
                                <i class="bi bi-map"></i>Chỉ đường
                            </a>
                        </div>
                    </aside>

                    <section class="ct-card ct-form-card">
                        <span class="ct-card-kicker">Biểu mẫu liên hệ</span>
                        <h2 class="ct-form__title">Gửi yêu cầu tư vấn</h2>
                        <p class="ct-form__sub">
                            Vui lòng để lại thông tin, chúng tôi sẽ liên hệ lại trong thời gian sớm nhất.
                        </p>

                        <ul id="lstErrorContent"
                            class="ct-validation-summary @(ViewData.ModelState.IsValid ? "d-none" : "")">
                        </ul>

                        <form asp-controller="Feedback" asp-action="Index" method="post" id="contact-form">
                            @Html.AntiForgeryToken()

                            <div class="ct-section-label">Thông tin cá nhân</div>

                            <div class="ct-row-2">
                                <div class="ct-form-group">
                                    <label class="ct-label" for="txtFullName">Họ và tên <span class="req">*</span></label>
                                    <input id="txtFullName" name="FullName" type="text" class="ct-input"
                                           placeholder="Nguyễn Văn A" value="@Model.FullName" autocomplete="name" />
                                </div>
                                <div class="ct-form-group">
                                    <label class="ct-label" for="txtPhone">Điện thoại <span class="req">*</span></label>
                                    <input id="txtPhone" name="Phone" type="tel" class="ct-input"
                                           placeholder="09xx xxx xxx" value="@Model.Phone" autocomplete="tel" />
                                </div>
                            </div>

                            <div class="ct-row-2">
                                <div class="ct-form-group">
                                    <label class="ct-label" for="txtEmail">Email <span class="req">*</span></label>
                                    <input id="txtEmail" name="Email" type="email" class="ct-input"
                                           placeholder="email@company.com" value="@Model.Email" autocomplete="email" />
                                </div>
                                <div class="ct-form-group">
                                    <label class="ct-label" for="txtAddress">Địa chỉ</label>
                                    <input id="txtAddress" name="Address" type="text" class="ct-input"
                                           placeholder="Quận/Huyện, Tỉnh/Thành phố" value="@Model.Address"
                                           autocomplete="address-level2" />
                                </div>
                            </div>

                            <div class="ct-section-label">Nội dung liên hệ</div>

                            <div class="ct-form-group">
                                <label class="ct-label" for="txtTitle">Tiêu đề <span class="req">*</span></label>
                                <input id="txtTitle" name="Title" type="text" class="ct-input"
                                       placeholder="Nhập tiêu đề yêu cầu" value="@Model.Title" />
                            </div>

                            <div class="ct-form-group">
                                <label class="ct-label" for="txtYourMessage">Nội dung <span class="req">*</span></label>
                                <textarea id="txtYourMessage" name="Content" class="ct-textarea" rows="6"
                                          placeholder="Mô tả nhu cầu tư vấn, hợp tác hoặc hỗ trợ của bạn...">@Model.Content</textarea>
                            </div>

                            <div class="ct-form-group">
                                <label class="ct-label">Xác thực <span class="req">*</span></label>
                                <div class="ct-captcha-box">
                                    <div class="ct-math-question" aria-label="Câu hỏi xác thực">
                                        <span class="ct-math-expr">@Model.CaptchaQuestion = ?</span>
                                    </div>
                                    <input id="txtCode" name="CaptchaAnswer" type="number" inputmode="numeric"
                                           class="ct-input ct-captcha-input @(ViewData.ModelState["CaptchaAnswer"]?.Errors.Count > 0 ? "is-invalid" : "")"
                                           placeholder="Kết quả" autocomplete="off" />
                                </div>
                                @if (ViewData.ModelState["CaptchaAnswer"]?.Errors.Count > 0)
                                {
                                    <span class="ct-error-msg">
                                        <i class="bi bi-exclamation-circle me-1"></i>
                                        @ViewData.ModelState["CaptchaAnswer"]!.Errors[0].ErrorMessage
                                    </span>
                                }
                            </div>

                            <button id="btnSend" type="submit" class="ct-btn-submit">
                                <span id="ctBtnText">
                                    <i class="bi bi-send me-1"></i>Gửi yêu cầu tư vấn
                                </span>
                                <span id="ctBtnSpinner" class="d-none">
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                    Đang gửi...
                                </span>
                            </button>
                        </form>
                    </section>
                </div>
            </section>

            <section class="ct-map-section">
                <div class="ct-map-heading">
                    <span class="ct-card-kicker">Bản đồ</span>
                    <h2>Vị trí của chúng tôi</h2>
                    <p>
                        Trung tâm tọa lạc tại khu vực trung tâm Thành phố Cần Thơ, thuận tiện cho việc liên hệ,
                        làm việc và hợp tác.
                    </p>
                </div>

                <div class="ct-card ct-map-card">
                    <iframe
                        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3928.8!2d105.7875!3d10.0333!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x31a0881b09c3e6a1%3A0x4d8b0e79a9e3b87e!2s166%20Nguy%E1%BB%85n%20V%C4%83n%20C%E1%BB%AB%2C%20An%20B%C3%ACnh%2C%20Ninh%20Ki%E1%BB%81u%2C%20C%E1%BA%A7n%20Th%C6%A1!5e0!3m2!1svi!2svn!4v1698760000000"
                        allowfullscreen loading="lazy"
                        referrerpolicy="no-referrer-when-downgrade"
                        title="Bản đồ @address">
                    </iframe>
                </div>

                <div class="ct-map-actions">
                    <a href="@mapsUrl" target="_blank" rel="noopener" class="ct-btn-primary">
                        <i class="bi bi-box-arrow-up-right"></i>Mở trong Google Maps
                    </a>
                    <button type="button" class="ct-btn-outline" id="copyAddressBtn" data-address="@address">
                        <i class="bi bi-copy"></i>Sao chép địa chỉ
                    </button>
                </div>
            </section>
        </main>
    </div>
</div>

@section scripts {
    <script type="text/javascript">
        $(function () {
            $("#contact-form").on("submit", function (e) {
                if (!checkValid()) {
                    e.preventDefault();
                    return false;
                }
            });

            $("[data-contact-title]").on("click", function () {
                $("#txtTitle").val($(this).data("contact-title")).trigger("focus");
                $("html, body").animate({ scrollTop: $("#txtTitle").offset().top - 140 }, 350);
            });

            $("#copyAddressBtn").on("click", function () {
                var address = $(this).data("address");
                if (navigator.clipboard) {
                    navigator.clipboard.writeText(address);
                }
                $(this).addClass("is-copied").html('<i class="bi bi-check2"></i>Đã sao chép');
                setTimeout(() => {
                    $(this).removeClass("is-copied").html('<i class="bi bi-copy"></i>Sao chép địa chỉ');
                }, 1800);
            });
        });

        function checkValid() {
            var error = "", countbug = 0;
            var _name = $("#txtFullName").val().trim();
            var _phone = $("#txtPhone").val().trim();
            var _email = $("#txtEmail").val().trim();
            var _title = $("#txtTitle").val().trim();
            var _content = $("#txtYourMessage").val().trim();
            var _captcha = $("#txtCode").val().trim();

            if (_name === "") { error += "<li>" + $("#hidHoTen").val() + "</li>"; countbug++; }
            if (!isEmail(_email)) { error += "<li>" + $("#hidEmail").val() + "</li>"; countbug++; }
            if (_phone === "") { error += "<li>" + $("#hidDienThoai").val() + "</li>"; countbug++; }
            if (_title === "") { error += "<li>" + $("#hidTieuDe").val() + "</li>"; countbug++; }
            if (_content === "") { error += "<li>" + $("#hidLoiNhat").val() + "</li>"; countbug++; }
            if (_captcha === "") { error += "<li>" + $("#hidMaXacThuc").val() + "</li>"; countbug++; }

            if (countbug >= 1) {
                $("#lstErrorContent li").remove();
                $("#lstErrorContent").append(error);
                $("#lstErrorContent").removeClass("d-none");
                $("html, body").animate({ scrollTop: $("#lstErrorContent").offset().top - 80 }, 600);
                return false;
            }

            document.getElementById("ctBtnText").classList.add("d-none");
            document.getElementById("ctBtnSpinner").classList.remove("d-none");
            document.getElementById("btnSend").disabled = true;
            return true;
        }

        function isEmail(email) {
            return /^[^\s@@]+@@[^\s@@]+\.[^\s@@]{2,}$/.test(email);
        }

        @if (TempData["Alert"] != null)
        {
            <text>
            document.querySelector(".ct-alert-success")?.scrollIntoView({ behavior: "smooth", block: "center" });
            </text>
        }

        @if (ViewData.ModelState["CaptchaAnswer"]?.Errors.Count > 0)
        {
            <text>
            document.getElementById("txtCode")?.focus();
            </text>
        }
    </script>
}
