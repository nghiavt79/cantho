@model TechExchangeApp.ViewModel.FeedbackCreateViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Liên hệ – Techport";
}

<link rel="stylesheet" href="~/css/contact-v2.css" asp-append-version="true" />

@* ── Hidden validation messages (giữ nguyên để JS dùng) ─────────────────── *@
<input type="hidden" id="hidMaXacThuc" value="Vui lòng nhập đúng mã xác thực" />
<input type="hidden" id="hidHoTen"     value="Vui lòng nhập họ tên" />
<input type="hidden" id="hidDienThoai" value="Vui lòng nhập điện thoại" />
<input type="hidden" id="hidEmail"     value="Vui lòng nhập đúng Email" />
<input type="hidden" id="hidTieuDe"    value="Vui lòng nhập tiêu đề" />
<input type="hidden" id="hidLoiNhat"   value="Vui lòng nhập lời nhắn" />

<!-- ══════════════════════════════════════════════════════════
     MAIN
     ══════════════════════════════════════════════════════════ -->
<div class="columns-container">
<div class="container" id="columns">

<h2 class="brand-showcase-title"><span>Liên hệ</span></h2>

<section class="ct-main" style="padding-top:16px;">
    <div>

        @* ── Alert từ TempData (giữ nguyên logic controller) *@
        @if (TempData["Alert"] != null)
        {
            <div class="ct-alert-success mb-4" role="alert">
                <span class="ct-alert-icon">✅</span>
                <span>@TempData["Alert"]</span>
            </div>
        }

        <div class="ct-grid">

            <!-- ── LEFT: THÔNG TIN LIÊN HỆ ──────────────── -->
            <div>
                <div class="ct-card">
                    <p class="ct-info__brand">
                        <i class="bi bi-building me-2 text-primary"></i>
                        Sàn giao dịch công nghệ thành phố Hồ Chí Minh
                    </p>

                    @* Tạm thời hiện cứng — đã comment phần load từ DB *@
                    @*
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <div class="ct-description mb-4">
                            @Html.Raw(Model.Description)
                        </div>
                    }
                    else
                    {
                    *@
                        <ul class="ct-info__list">
                            <li>
                                <span class="ct-icon"><i class="bi bi-geo-alt-fill"></i></span>
                                <span>79 Trương Định, Phường Bến Thành, TP.HCM</span>
                            </li>
                            <li>
                                <span class="ct-icon"><i class="bi bi-telephone-fill"></i></span>
                                <a href="tel:02838297040" class="text-decoration-none text-dark">
                                    (028) 3829 7040
                                </a>
                            </li>
                            <li>
                                <span class="ct-icon"><i class="bi bi-printer-fill"></i></span>
                                <span>Fax: (028) 3829 1957</span>
                            </li>
                            <li>
                                <span class="ct-icon"><i class="bi bi-envelope-fill"></i></span>
                                <a href="mailto:info@techport.vn" class="text-decoration-none text-dark">
                                    info@techport.vn
                                </a>
                            </li>
                        </ul>
                    @* } *@

                    <div class="ct-info__meta">
                        <div><strong>🕐 Giờ làm việc:</strong> Thứ 2 – Thứ 6, 8:00 – 17:00</div>
                        <div class="mt-1"><strong>⚡ Phản hồi:</strong> Trong vòng 24 giờ làm việc</div>
                    </div>

                    <div class="ct-info__actions">
                        <a href="https://maps.google.com/?q=79+Truong+Dinh,+Ben+Thanh,+Ho+Chi+Minh"
                           target="_blank" rel="noopener" class="ct-btn-outline">
                            <i class="bi bi-map"></i> Chỉ đường
                        </a>
                        <a href="tel:02838297040" class="ct-btn-outline">
                            <i class="bi bi-telephone"></i> Gọi ngay
                        </a>
                    </div>
                </div>
            </div>

            <!-- ── RIGHT: FORM GỬI YÊU CẦU ──────────────── -->
            <div>
                <div class="ct-card ct-form-card">

                    <div class="ct-form__title">Gửi yêu cầu</div>
                    <p class="ct-form__sub">Điền thông tin bên dưới, chúng tôi sẽ liên hệ sớm nhất.</p>

                    @* Error list — giữ nguyên id để JS điền vào *@
                    <ul id="lstErrorContent"
                        class="ct-validation-summary @(ViewData.ModelState.IsValid ? "d-none" : "")"
                        style="list-style:none;padding:0;margin:0 0 16px;">
                    </ul>

                    @* ── FORM (giữ nguyên action/method/id) *@
                    <form asp-controller="Feedback" asp-action="Index"
                          method="post" id="contact-form">
                        @Html.AntiForgeryToken()

                        @* ── Phần "Thông tin cá nhân" *@
                        <div class="ct-section-label">Thông tin cá nhân</div>

                        <div class="ct-row-2">
                            <div class="ct-form-group">
                                <label class="ct-label" for="txtFullName">
                                    Họ và tên <span class="req">*</span>
                                </label>
                                <input id="txtFullName" name="FullName"
                                       type="text" class="ct-input"
                                       placeholder="Nguyễn Văn A"
                                       value="@Model.FullName"
                                       autocomplete="name" />
                            </div>
                            <div class="ct-form-group">
                                <label class="ct-label" for="txtPhone">
                                    Điện thoại <span class="req">*</span>
                                </label>
                                <input id="txtPhone" name="Phone"
                                       type="tel" class="ct-input"
                                       placeholder="09x xxx xxxx"
                                       autocomplete="tel" />
                            </div>
                        </div>

                        <div class="ct-row-2">
                            <div class="ct-form-group">
                                <label class="ct-label" for="txtEmail">
                                    Email <span class="req">*</span>
                                </label>
                                <input id="txtEmail" name="Email"
                                       type="email" class="ct-input"
                                       placeholder="email@company.com"
                                       value="@Model.Email"
                                       autocomplete="email" />
                            </div>
                            <div class="ct-form-group">
                                <label class="ct-label" for="txtAddress">Địa chỉ</label>
                                <input id="txtAddress" name="Address"
                                       type="text" class="ct-input"
                                       placeholder="Tỉnh / Thành phố"
                                       autocomplete="address-level2" />
                            </div>
                        </div>

                        @* ── Phần "Nội dung liên hệ" *@
                        <div class="ct-section-label mt-2">Nội dung liên hệ</div>

                        <div class="ct-form-group">
                            <label class="ct-label" for="txtTitle">
                                Tiêu đề <span class="req">*</span>
                            </label>
                            <input id="txtTitle" name="Title"
                                   type="text" class="ct-input"
                                   placeholder="Tóm tắt yêu cầu của bạn" />
                        </div>

                        <div class="ct-form-group">
                            <label class="ct-label" for="txtYourMessage">
                                Nội dung <span class="req">*</span>
                            </label>
                            <textarea id="txtYourMessage" name="Content"
                                      class="ct-textarea"
                                      rows="6"
                                      placeholder="Mô tả chi tiết yêu cầu hoặc góp ý của bạn..."></textarea>
                        </div>

                        @* ── Math Captcha (server-side) *@
                        <div class="ct-form-group">
                            <label class="ct-label">Xác thực <span class="req">*</span></label>
                            <div class="ct-captcha-box" style="justify-content:flex-start;gap:16px;flex-wrap:wrap;">
                                <div class="ct-math-question" aria-label="Câu hỏi xác thực">
                                    <span class="ct-math-expr">@Model.CaptchaQuestion = ?</span>
                                </div>
                                <input id="txtCode" name="CaptchaAnswer"
                                       type="number" inputmode="numeric"
                                       class="ct-input @(ViewData.ModelState["CaptchaAnswer"]?.Errors.Count > 0 ? "is-invalid" : "")"
                                       placeholder="Kết quả"
                                       style="max-width:120px;height:44px;"
                                       autocomplete="off" />
                            </div>
                            @if (ViewData.ModelState["CaptchaAnswer"]?.Errors.Count > 0)
                            {
                                <span class="ct-error-msg">
                                    <i class="bi bi-exclamation-circle me-1"></i>
                                    @ViewData.ModelState["CaptchaAnswer"]!.Errors[0].ErrorMessage
                                </span>
                            }
                        </div>

                        @* ── Submit (giữ nguyên id="btnSend") *@
                        <button id="btnSend" type="submit" class="ct-btn-submit">
                            <span id="ctBtnText">
                                <i class="bi bi-send me-1"></i> Gửi yêu cầu
                            </span>
                            <span id="ctBtnSpinner" class="d-none">
                                <span class="spinner-border spinner-border-sm me-1"></span>
                                Đang gửi...
                            </span>
                        </button>

                    </form>
                </div>
            </div>

        </div><!-- /ct-grid -->
    </div>
</section>

<!-- ══════════════════════════════════════════════════════════
     MAP
     ══════════════════════════════════════════════════════════ -->
<section class="ct-map-section">
    <div class="container">
        <div class="ct-card ct-map-card p-0">
            <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3919.4848673988876!2d106.6932!3d10.7741!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x31752f5c9e2f2585%3A0x8f1cb69cd77e4d79!2s79%20Tr%C6%B0%C6%A1ng%20%C4%90%E1%BB%8Bnh%2C%20B%E1%BA%BFn%20Th%C3%A0nh%2C%20Qu%E1%BA%ADn%201%2C%20Th%C3%A0nh%20ph%E1%BB%91%20H%E1%BB%93%20Ch%C3%AD%20Minh!5e0!3m2!1svi!2svn!4v1698760000000"
                allowfullscreen loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="Bản đồ 79 Trương Định, Bến Thành, TP.HCM">
            </iframe>
        </div>
        <div class="text-center mt-3">
            <a href="https://maps.google.com/?q=79+Truong+Dinh,+Ben+Thanh,+Ho+Chi+Minh"
               target="_blank" rel="noopener" class="ct-btn-outline">
                <i class="bi bi-box-arrow-up-right"></i> Mở trong Google Maps
            </a>
        </div>
    </div>
</section>

</div><!-- /container #columns -->
</div><!-- /columns-container -->

@section scripts {
    <script type="text/javascript">
        $(function () {
            // Bắt sự kiện submit của form (bao gồm cả nhấn Enter)
            $("#contact-form").on("submit", function (e) {
                if (!checkValid()) {
                    e.preventDefault();
                    return false;
                }
            });
        });

        function checkValid() {
            var error = "", countbug = 0;
            var _name    = $("#txtFullName").val().trim();
            var _phone   = $("#txtPhone").val().trim();
            var _email   = $("#txtEmail").val().trim();
            var _title   = $("#txtTitle").val().trim();
            var _content = $("#txtYourMessage").val().trim();
            var _captcha = $("#txtCode").val().trim();

            if (_name    === "") { error += "<li>" + $("#hidHoTen").val()      + "</li>"; countbug++; }
            if (!isEmail(_email)){ error += "<li>" + $("#hidEmail").val()    + "</li>"; countbug++; }
            if (_phone   === "") { error += "<li>" + $("#hidDienThoai").val() + "</li>"; countbug++; }
            if (_title   === "") { error += "<li>" + $("#hidTieuDe").val()    + "</li>"; countbug++; }
            if (_content === "") { error += "<li>" + $("#hidLoiNhat").val()   + "</li>"; countbug++; }
            if (_captcha === "") { error += "<li>" + $("#hidMaXacThuc").val() + "</li>"; countbug++; }

            if (countbug >= 1) {
                $('#lstErrorContent li').remove();
                $("#lstErrorContent").append(error);
                $("#lstErrorContent").removeClass('d-none');
                $('html, body').animate({ scrollTop: $("#lstErrorContent").offset().top - 80 }, 600);
                return false;
            }

            // Client OK → show loading state
            document.getElementById('ctBtnText').classList.add('d-none');
            document.getElementById('ctBtnSpinner').classList.remove('d-none');
            document.getElementById('btnSend').disabled = true;
            return true;
        }

        @Html.Raw(@"
        function isEmail(email) {
            return /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(email);
        }
        ")

        // Scroll to success alert
        @if (TempData["Alert"] != null) {
            <text>
            document.querySelector('.ct-alert-success')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
            </text>
        }

        // Scroll to captcha error if invalid
        @if (ViewData.ModelState["CaptchaAnswer"]?.Errors.Count > 0) {
            <text>
            document.getElementById('txtCode')?.focus();
            </text>
        }
    </script>
}
