@using TechExchangeApp.Interfaces
@using Microsoft.AspNetCore.Identity
@using TechExchangeApp.Entities
@inject IAccountService AccountService
@inject UserManager<ApplicationUser> UserManager

@model TechExchangeApp.Areas.Cms.Controllers.NhaCungUngFormVm
@{
    ViewData["Title"] = "Đăng ký Nhà cung ứng KH&CN";
    ViewData["AuthWorkspace"] = true;
    Layout = "~/Views/Shared/_Layout.cshtml";

    var userId = int.Parse(UserManager.GetUserId(User)!);
    var sidebarData = await AccountService.GetSidebarDataAsync(userId);

    var linhVucItems = (List<SelectListItem>?)ViewBag.LinhVucList;
    var dichVuItems  = (List<SelectListItem>?)ViewBag.DichVuList;

    var loaiHinhOptions = new[] {
        ("VienNC",    "Viện/Trung tâm nghiên cứu"),
        ("TruongDH",  "Trường Đại học"),
        ("DNKHCN",    "Doanh nghiệp KH&CN"),
        ("DNSX",      "Doanh nghiệp sản xuất"),
        ("ToChucTG",  "Tổ chức trung gian/Tư vấn"),
        ("Khac",      "Khác")
    };
    var currentLHTC = Model.LoaiHinhToChuc?.Split(';', StringSplitOptions.RemoveEmptyEntries) ?? Array.Empty<string>();
}

<div class="container-fluid py-4 user-portal">
  <div class="row">
    <div class="col-md-3 col-lg-2">
      @await Html.PartialAsync("_AccountSidebar", sidebarData)
    </div>
    <div class="col-md-9 col-lg-10 user-portal-main user-registration-form">

            <div class="d-flex align-items-center justify-content-between mb-3">
                <h4 class="fw-bold mb-0" style="color:var(--up-navy);">
                    <i class="fas fa-building me-2" style="color:var(--up-primary);"></i>
                    @(ViewBag.IsUpdate == true ? "Cập nhật hồ sơ Nhà cung ứng" : "Đăng ký Nhà cung ứng KH&CN")
                </h4>
                @if (ViewBag.IsUpdate == true && ViewBag.StatusTitle != null)
                {
                    var sid = (int?)ViewBag.StatusId;
                    var badgeClass = sid switch {
                        2 => "bg-info text-dark",   // Đang duyệt
                        3 => "bg-success",           // Đã duyệt
                        4 => "bg-danger",            // Từ chối
                        _ => "bg-warning text-dark"  // 1 = Chờ duyệt
                    };
                    <span class="badge @badgeClass fs-6 px-3 py-2">
                        <i class="fas fa-circle-dot me-1"></i>@ViewBag.StatusTitle
                    </span>
                }
            </div>

                @* ── Thông báo thành công ── *@
                @if (TempData["DangKySuccess"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                        <i class="fas fa-check-circle me-2"></i>
                        <strong>@TempData["DangKySuccess"]</strong>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @* ── Lỗi validation ── *@
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        <strong>Vui lòng kiểm tra lại các trường bắt buộc:</strong>
                        <div asp-validation-summary="All" class="mt-1 small"></div>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @* ── Form ── *@
                <form asp-action="DangKy" asp-controller="DangKyNhaCungUng" method="post" id="dangKyForm">
                    @Html.AntiForgeryToken()

                    @* ─── Tab nav ─── *@
                    <ul class="nav nav-tabs mb-0" id="regTabs" role="tablist">
                        <li class="nav-item">
                            <a class="nav-link active" data-bs-toggle="tab" href="#tab1">
                                <i class="fas fa-id-card me-1"></i>I. Thông tin định danh
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="tab" href="#tab2">
                                <i class="fas fa-cogs me-1"></i>II. Năng lực &amp; Lĩnh vực
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="tab" href="#tab3">
                                <i class="fas fa-box me-1"></i>III. Dịch vụ &amp; Sản phẩm
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="tab" href="#tab4">
                                <i class="fas fa-images me-1"></i>IV. Hồ sơ &amp; Media
                            </a>
                        </li>
                    </ul>

                    <div class="card shadow-sm border-top-0 rounded-0 rounded-bottom mb-4">
                        <div class="card-body p-4">
                            <div class="tab-content">

                                @* ══ TAB 1: THÔNG TIN ĐỊNH DANH ══ *@
                                <div class="tab-pane fade show active" id="tab1">
                                    <div class="mb-3">
                                        <label asp-for="FullName" class="form-label fw-semibold">1. Tên đơn vị <span class="text-danger">*</span></label>
                                        <input asp-for="FullName" class="form-control" placeholder="Nhập tên đầy đủ của đơn vị..." />
                                        <span asp-validation-for="FullName" class="text-danger small"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="TenVietTat" class="form-label fw-semibold">2. Tên viết tắt / Tên tiếng Anh</label>
                                        <input asp-for="TenVietTat" class="form-control" placeholder="Tên viết tắt hoặc tên tiếng Anh..." />
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">3. Loại hình tổ chức <span class="text-danger">*</span></label>
                                        <span asp-validation-for="LoaiHinhToChuc" class="text-danger small d-block mb-1"></span>
                                        <input type="hidden" asp-for="LoaiHinhToChuc" id="hdnLoaiHinhToChuc" />
                                        <div class="row g-2">
                                            @foreach (var (val, text) in loaiHinhOptions)
                                            {
                                                var chk = currentLHTC.Contains(val) ? "checked" : "";
                                                <div class="col-md-4">
                                                    <div class="form-check">
                                                        <input class="form-check-input chk-loaihinh" type="checkbox"
                                                               value="@val" id="lh_@val" @chk />
                                                        <label class="form-check-label" for="lh_@val">@text</label>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>

                                    <fieldset class="border rounded p-3 mb-3">
                                        <legend class="float-none w-auto px-2 fs-6 fw-semibold">4. Thông tin liên hệ</legend>
                                        <div class="mb-3">
                                            <label asp-for="DiaChi" class="form-label fw-semibold">Địa chỉ <span class="text-danger">*</span></label>
                                            <input asp-for="DiaChi" class="form-control" placeholder="Địa chỉ trụ sở chính..." />
                                            <span asp-validation-for="DiaChi" class="text-danger small"></span>
                                        </div>
                                        <div class="row g-3 mb-3">
                                            <div class="col-md-4">
                                                <label asp-for="Phone" class="form-label fw-semibold">Điện thoại <span class="text-danger">*</span></label>
                                                <input asp-for="Phone" class="form-control" placeholder="Số điện thoại..." />
                                                <span asp-validation-for="Phone" class="text-danger small"></span>
                                            </div>
                                            <div class="col-md-4">
                                                <label asp-for="Website" class="form-label fw-semibold">Website</label>
                                                <input asp-for="Website" class="form-control" placeholder="https://..." />
                                            </div>
                                            <div class="col-md-4">
                                                <label asp-for="Fax" class="form-label fw-semibold">Fax</label>
                                                <input asp-for="Fax" class="form-control" placeholder="Fax..." />
                                            </div>
                                        </div>
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label asp-for="Email" class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
                                                <input asp-for="Email" type="email" class="form-control" placeholder="email@example.com" />
                                                <span asp-validation-for="Email" class="text-danger small"></span>
                                            </div>
                                            <div class="col-md-6">
                                                <label asp-for="MaSoThue" class="form-label fw-semibold">Mã số thuế</label>
                                                <input asp-for="MaSoThue" class="form-control" placeholder="Mã số thuế..." />
                                            </div>
                                        </div>
                                    </fieldset>

                                    <fieldset class="border rounded p-3 mb-3">
                                        <legend class="float-none w-auto px-2 fs-6 fw-semibold">Thông tin nhận chuyển khoản</legend>
                                        <p class="text-muted small mb-3">Dùng để tự động hiện cho khách khi họ chọn thanh toán "Chuyển khoản" khi đặt mua sản phẩm OCOP. Bỏ trống nếu chưa nhận chuyển khoản qua sàn.</p>
                                        <div class="row g-3">
                                            <div class="col-md-4">
                                                <label asp-for="SoTaiKhoan" class="form-label fw-semibold">Số tài khoản</label>
                                                <input asp-for="SoTaiKhoan" class="form-control" placeholder="Số tài khoản ngân hàng..." />
                                            </div>
                                            <div class="col-md-4">
                                                <label asp-for="TenNganHang" class="form-label fw-semibold">Ngân hàng</label>
                                                <input asp-for="TenNganHang" class="form-control" placeholder="Ví dụ: Vietcombank..." />
                                            </div>
                                            <div class="col-md-4">
                                                <label asp-for="ChuTaiKhoan" class="form-label fw-semibold">Chủ tài khoản</label>
                                                <input asp-for="ChuTaiKhoan" class="form-control" placeholder="Tên chủ tài khoản..." />
                                            </div>
                                        </div>
                                    </fieldset>

                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label asp-for="NguoiDaiDien" class="form-label fw-semibold">5. Người đại diện pháp luật <span class="text-danger">*</span></label>
                                            <input asp-for="NguoiDaiDien" class="form-control" placeholder="Họ tên người đại diện..." />
                                            <span asp-validation-for="NguoiDaiDien" class="text-danger small"></span>
                                        </div>
                                        <div class="col-md-6">
                                            <label asp-for="ChucVu" class="form-label fw-semibold">Chức vụ <span class="text-danger">*</span></label>
                                            <input asp-for="ChucVu" class="form-control" placeholder="Chức vụ..." />
                                            <span asp-validation-for="ChucVu" class="text-danger small"></span>
                                        </div>
                                    </div>
                                </div>

                                @* ══ TAB 2: NĂNG LỰC & LĨNH VỰC ══ *@
                                <div class="tab-pane fade" id="tab2">
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">6. Lĩnh vực hoạt động chính <span class="text-danger">*</span> <small class="text-muted">(Chọn tối đa 03 lĩnh vực)</small></label>
                                        <span asp-validation-for="LinhVucId" class="text-danger small d-block mb-1"></span>
                                        <input type="hidden" asp-for="LinhVucId" id="hdnLinhVucId" />
                                        @if (linhVucItems != null && linhVucItems.Any())
                                        {
                                            var currentLV = Model.LinhVucId?.Split(';', StringSplitOptions.RemoveEmptyEntries) ?? Array.Empty<string>();
                                            <div class="row g-2">
                                                @foreach (var item in linhVucItems.Where(x => !string.IsNullOrEmpty(x.Value)))
                                                {
                                                    var chk = currentLV.Contains(item.Value) ? "checked" : "";
                                                    <div class="col-md-4 col-lg-3">
                                                        <div class="form-check">
                                                            <input class="form-check-input chk-linhvuc" type="checkbox"
                                                                   value="@item.Value" id="lv_@item.Value" @chk />
                                                            <label class="form-check-label" for="lv_@item.Value">@item.Text</label>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                            <small id="lvWarning" class="text-danger" style="display:none;">Chỉ được chọn tối đa 3 lĩnh vực.</small>
                                        }
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="ChucNangChinh" class="form-label fw-semibold">7. Chức năng nhiệm vụ / Giá trị cốt lõi <span class="text-danger">*</span> <small class="text-muted">(Tối đa 300 chữ)</small></label>
                                        <span asp-validation-for="ChucNangChinh" class="text-danger small d-block mb-1"></span>
                                        <textarea asp-for="ChucNangChinh" id="editorChucNangChinh" class="form-control" rows="6" placeholder="Mô tả chức năng nhiệm vụ và giá trị cốt lõi của đơn vị..."></textarea>
                                    </div>
                                </div>

                                @* ══ TAB 3: DỊCH VỤ & SẢN PHẨM ══ *@
                                <div class="tab-pane fade" id="tab3">
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">8. Dịch vụ khoa học và công nghệ <span class="text-danger">*</span></label>
                                        <span asp-validation-for="DichVu" class="text-danger small d-block mb-1"></span>
                                        <input type="hidden" asp-for="DichVu" id="hdnDichVu" />
                                        @if (dichVuItems != null && dichVuItems.Any())
                                        {
                                            var currentDV = Model.DichVu?.Split(';', StringSplitOptions.RemoveEmptyEntries) ?? Array.Empty<string>();
                                            <div class="row g-2">
                                                @foreach (var item in dichVuItems.Where(x => !string.IsNullOrEmpty(x.Value)))
                                                {
                                                    var chk = currentDV.Contains(item.Value) ? "checked" : "";
                                                    <div class="col-md-6">
                                                        <div class="form-check">
                                                            <input class="form-check-input chk-dichvu" type="checkbox"
                                                                   value="@item.Value" id="dv_@item.Value" @chk />
                                                            <label class="form-check-label" for="dv_@item.Value">@item.Text</label>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="SanPham" class="form-label fw-semibold">9. Sản phẩm công nghệ / Kết quả nghiên cứu chủ lực</label>
                                        <textarea asp-for="SanPham" id="editorSanPham" class="form-control" rows="6" placeholder="Mô tả sản phẩm công nghệ hoặc kết quả nghiên cứu..."></textarea>
                                    </div>
                                </div>

                                @* ══ TAB 4: HỒ SƠ & MEDIA ══ *@
                                <div class="tab-pane fade" id="tab4">
                                    <h6 class="fw-semibold mb-3">10. Dữ liệu hình ảnh / Truyền thông</h6>

                                    <div class="row g-3 mb-3">
                                        <div class="col-md-6">
                                            <label asp-for="Logo" class="form-label fw-semibold">Logo đơn vị</label>
                                            <input type="file" class="form-control" id="fileInputLogo" accept="image/*" />
                                            <input type="hidden" asp-for="Logo" id="inputLogo" />
                                            <div id="previewLogo" class="mt-2">
                                                @if (!string.IsNullOrEmpty(Model.Logo))
                                                {
                                                    <img src="@Model.Logo" class="rounded" style="max-height:80px" />
                                                }
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <label asp-for="HinhDaiDien" class="form-label fw-semibold">Ảnh trụ sở / Hoạt động tiêu biểu</label>
                                            <input type="file" class="form-control" id="fileInputHinh" accept="image/*" />
                                            <input type="hidden" asp-for="HinhDaiDien" id="inputHinhDaiDien" />
                                            <div id="previewHinhDaiDien" class="mt-2">
                                                @if (!string.IsNullOrEmpty(Model.HinhDaiDien))
                                                {
                                                    <img src="@Model.HinhDaiDien" class="rounded" style="max-height:120px" />
                                                }
                                            </div>
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="VideoUrl" class="form-label fw-semibold">Video giới thiệu</label>
                                        <input asp-for="VideoUrl" class="form-control" placeholder="https://www.youtube.com/watch?v=..." />
                                        <small class="text-muted">Nhập link YouTube hoặc URL video.</small>
                                    </div>

                                    <hr />
                                    <h6 class="fw-semibold mb-3">11. Chứng nhận năng lực</h6>
                                    <div class="mb-3">
                                        <label asp-for="ChungNhan" class="form-label fw-semibold">Giấy phép hoạt động KH&CN / Chứng chỉ chất lượng</label>
                                        <input type="file" class="form-control" id="fileInputChungNhan" accept=".pdf,image/*" />
                                        <input type="hidden" asp-for="ChungNhan" id="inputChungNhan" />
                                        <small class="text-muted">Đính kèm file giấy phép / chứng nhận (PDF, Ảnh...)</small>
                                        <div id="previewChungNhan" class="mt-2">
                                            @if (!string.IsNullOrEmpty(Model.ChungNhan))
                                            {
                                                <a href="@Model.ChungNhan" target="_blank" class="text-primary small">
                                                    <i class="fas fa-paperclip me-1"></i>Xem file / link đính kèm hiện tại
                                                </a>
                                            }
                                        </div>
                                    </div>

                                    <hr />
                                    <div class="mb-3">
                                        <label asp-for="Keywords" class="form-label fw-semibold">Từ khóa tìm kiếm</label>
                                        <input asp-for="Keywords" class="form-control" placeholder="công nghệ sinh học, chuyển giao, ..." />
                                        <small class="text-muted">Phân cách bằng dấu phẩy.</small>
                                    </div>
                                </div>

                        </div><!-- end tab-content -->
                        </div><!-- end card-body -->

                        <div class="card-footer d-flex justify-content-between align-items-center bg-white">
                            <small class="text-muted"><span class="text-danger">*</span> Trường bắt buộc</small>
                            <button type="submit" class="btn btn-primary px-5" id="btnDangKy">
                                @if (ViewBag.IsUpdate == true)
                                {
                                    <i class="fas fa-save me-2"></i><text>Cập nhật hồ sơ</text>
                                }
                                else
                                {
                                    <i class="fas fa-paper-plane me-2"></i><text>Gửi đăng ký</text>
                                }
                            </button>
                        </div>
                    </div><!-- end card -->

                    <input type="hidden" asp-for="CungUngId" />
                    <input type="hidden" asp-for="LanguageId" />
                    <input type="hidden" asp-for="Domain" />
                    <input type="hidden" asp-for="SiteId" />
                </form>

    </div><!-- /col main -->
  </div><!-- /row -->
</div><!-- /container-fluid -->


@section Styles {
<link rel="stylesheet" href="~/css/user-portal.css" asp-append-version="true" />
<link rel="stylesheet" href="https://cdn.ckeditor.com/ckeditor5/43.0.0/ckeditor5.css" />
<style>.ck-editor__editable { min-height: 200px; }</style>
}

@section Scripts {
<script>
(function () {
    // ── Sync checkbox groups → hidden input ──
    function syncCheckboxes(cls, hiddenId) {
        document.querySelectorAll('.' + cls).forEach(c => {
            c.addEventListener('change', () => {
                const vals = [...document.querySelectorAll('.' + cls + ':checked')].map(x => x.value);
                document.getElementById(hiddenId).value = vals.join(';');
            });
        });
    }
    syncCheckboxes('chk-loaihinh', 'hdnLoaiHinhToChuc');
    syncCheckboxes('chk-dichvu',   'hdnDichVu');

    // Lĩnh vực: max 3
    document.querySelectorAll('.chk-linhvuc').forEach(c => {
        c.addEventListener('change', () => {
            const checked = document.querySelectorAll('.chk-linhvuc:checked');
            const warn = document.getElementById('lvWarning');
            if (checked.length > 3) {
                c.checked = false;
                if (warn) warn.style.display = '';
            } else {
                if (warn) warn.style.display = 'none';
            }
            const vals = [...document.querySelectorAll('.chk-linhvuc:checked')].map(x => x.value);
            document.getElementById('hdnLinhVucId').value = vals.join(';');
        });
    });

    // ── File upload helper ──
    async function uploadFile(file, hiddenId, previewId, isDoc) {
        const fd = new FormData();
        fd.append('upload', file);
        try {
            const res = await fetch('/cms/Upload/Upload', { method: 'POST', body: fd });
            const r   = await res.json();
            if (r.url) {
                document.getElementById(hiddenId).value = r.url;
                const prev = document.getElementById(previewId);
                if (prev) {
                    prev.innerHTML = isDoc
                        ? `<a href="${r.url}" target="_blank" class="text-primary small"><i class="fas fa-paperclip me-1"></i>Xem file đã upload</a>`
                        : `<img src="${r.url}" class="rounded mt-1" style="max-height:120px" />`;
                }
            } else {
                alert('Upload thất bại: ' + (r.error?.message ?? 'Unknown error'));
            }
        } catch (e) {
            alert('Upload thất bại.');
        }
    }

    document.getElementById('fileInputLogo')?.addEventListener('change',     e => uploadFile(e.target.files[0], 'inputLogo',        'previewLogo',        false));
    document.getElementById('fileInputHinh')?.addEventListener('change',     e => uploadFile(e.target.files[0], 'inputHinhDaiDien', 'previewHinhDaiDien', false));
    document.getElementById('fileInputChungNhan')?.addEventListener('change', e => uploadFile(e.target.files[0], 'inputChungNhan',   'previewChungNhan',   true));

    // ── Tab navigation: click validation hint ──
    document.querySelectorAll('#regTabs .nav-link').forEach(tab => {
        tab.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
    });
})();
</script>

<script src="https://cdn.ckeditor.com/ckeditor5/43.0.0/ckeditor5.umd.js"></script>
<script>
(function() {
    const { ClassicEditor, Essentials, Bold, Italic, Link, Paragraph,
            Heading, List, BlockQuote, Table, TableToolbar,
            SourceEditing, Alignment, Font, HtmlEmbed } = CKEDITOR;

    var editorConfig = {
        plugins: [
            Essentials, Bold, Italic, Link, Paragraph, Heading,
            List, BlockQuote, Table, TableToolbar,
            SourceEditing, Alignment, Font, HtmlEmbed
        ],
        toolbar: {
            items: [
                'heading', '|',
                'bold', 'italic', 'link', '|',
                'alignment', '|',
                'fontSize', 'fontColor', '|',
                'bulletedList', 'numberedList', '|',
                'blockQuote', 'insertTable', 'htmlEmbed', '|',
                'sourceEditing', '|',
                'undo', 'redo'
            ]
        },
        table: { contentToolbar: ['tableColumn', 'tableRow', 'mergeTableCells'] }
    };

    var editors = {};
    ['editorChucNangChinh', 'editorSanPham'].forEach(function(id) {
        var el = document.getElementById(id);
        if (el) {
            ClassicEditor.create(el, editorConfig)
                .then(function(editor) { editors[id] = editor; })
                .catch(function(err) { console.error('CKEditor init error:', err); });
        }
    });

    document.getElementById('dangKyForm').addEventListener('submit', function() {
        try {
            for (var id in editors) {
                var el = document.getElementById(id);
                if (el) el.value = editors[id].getData();
            }
        } catch(e) { console.error('CKEditor sync error:', e); }
    });
})();
</script>
}
