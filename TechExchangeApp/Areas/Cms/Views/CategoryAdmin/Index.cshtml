@model List<TechExchangeApp.Areas.Cms.Controllers.CategoryListItem>
@{
    ViewData["Title"] = "Quản lý Danh mục";
}

<!-- ─── Search Card ─── -->
<div class="card card-outline card-primary shadow-sm mb-3">
    <div class="card-header" id="searchCardHeader" style="cursor:pointer" title="Nhấn đúp để thu gọn/mở rộng">
        <h3 class="card-title"><i class="fas fa-search me-1"></i> Tìm kiếm Danh mục</h3>
        <div class="card-tools">
            <button type="button" class="btn btn-tool" data-lte-toggle="card-collapse"><i class="fas fa-minus"></i></button>
        </div>
    </div>
    <div class="card-body">
        <form id="searchForm">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="mb-2">
                        <label class="form-label fw-semibold small mb-1">Từ khóa</label>
                        <input type="text" name="keyword" value="@ViewBag.Keyword" class="form-control form-control-sm" placeholder="Tiêu đề danh mục..." />
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-2">
                        <label class="form-label fw-semibold small mb-1">Trạng thái</label>
                        <select name="statusId" class="form-select form-select-sm">
                            <option value="">-- Tất cả --</option>
                            @{
                                var sts = ViewBag.StatusId?.ToString() ?? "";
                                var statuses = (IEnumerable<dynamic>?)ViewBag.Statuses;
                            }
                            @if (statuses != null)
                            {
                                foreach (var s in statuses)
                                {
                                    <option value="@s.StatusId" selected="@(sts == s.StatusId.ToString())">@s.Title</option>
                                }
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-2">
                        <label class="form-label fw-semibold small mb-1">Danh mục cha</label>
                        <select name="parentId" id="filterParent" class="form-select form-select-sm">
                            <option value="">---Gốc---</option>
                            @{
                                var selParent = ViewBag.ParentId?.ToString() ?? "";
                                var parentCats = ViewBag.ParentCategories as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>;
                            }
                            @if (parentCats != null)
                            {
                                foreach (var m in parentCats)
                                {
                                    <option value="@m.Value" selected="@(selParent == m.Value)">@m.Text</option>
                                }
                            }
                        </select>
                    </div>
                </div>
            </div>
        </form>
    </div>
    <div class="card-footer bg-transparent">
        <button type="button" class="btn btn-primary btn-sm me-2" id="btnSearch">
            <i class="fas fa-search me-1"></i> Tìm kiếm
        </button>
        <button type="button" class="btn btn-outline-secondary btn-sm" id="btnReset">
            <i class="fas fa-undo me-1"></i> Đặt lại
        </button>
    </div>
</div>

<!-- ─── Result Card ─── -->
<div class="card card-outline card-info shadow-sm">
    <div class="card-header d-flex align-items-center flex-wrap gap-2">
        <h3 class="card-title mb-0">
            <i class="fas fa-tags me-1"></i> Danh sách Danh mục
            <span class="badge bg-info ms-1" id="badgeTotal">@ViewBag.TotalCount</span>
        </h3>
        <div class="ms-auto d-flex gap-2">
            <a asp-action="Create" class="btn btn-success btn-sm">
                <i class="fas fa-plus me-1"></i> Thêm danh mục
            </a>
            <button type="button" class="btn btn-outline-danger btn-sm" id="btnBulkDelete" disabled>
                <i class="fas fa-trash-alt me-1"></i> Xóa chọn
            </button>
        </div>
    </div>

    <div id="listContainer">
        @await Html.PartialAsync("_ListPartial", Model)
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
<script>
$(function(){

    $('#filterParent').select2({ theme: 'bootstrap-5', placeholder: '-- Tìm danh mục cha --', allowClear: true, width: '100%' });

    toastr.options = { closeButton: true, progressBar: true, positionClass: 'toast-top-right', timeOut: 3000 };

    var token = $('input[name="__RequestVerificationToken"]').val() || '';
    var baseUrl = '@Url.Action("Index", "CategoryAdmin", new { area = "Cms" })';
    var currentPage = 1, currentSortBy = '', currentSortDir = '';

    $('#searchCardHeader').on('dblclick', function() {
        $(this).find('[data-lte-toggle="card-collapse"]').trigger('click');
    });

    function loadList(page) {
        currentPage = page || 1;
        var params = $('#searchForm').serialize()
            + '&page=' + currentPage
            + '&sortBy=' + encodeURIComponent(currentSortBy)
            + '&sortDir=' + encodeURIComponent(currentSortDir);
        $('#listContainer').css('opacity', '0.5');
        $.ajax({
            url: baseUrl, data: params,
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
            success: function(html) {
                $('#listContainer').html(html).css('opacity', '1');
                $('#chkAll').prop('checked', false);
                $('#btnBulkDelete').prop('disabled', true);
                var cnt = $('#partialTotalCount').text();
                $('#badgeTotal').text(cnt);
                initSortable();
            },
            error: function() {
                toastr.error('Lỗi tải dữ liệu.');
                $('#listContainer').css('opacity', '1');
            }
        });
    }

    $(document).on('click', '.sortable', function() {
        var col = $(this).data('sort');
        if (currentSortBy === col) currentSortDir = (currentSortDir === 'asc') ? 'desc' : 'asc';
        else { currentSortBy = col; currentSortDir = 'asc'; }
        loadList(1);
    });

    $('#searchForm').on('submit', function(e) { e.preventDefault(); loadList(1); });
    $('#btnSearch').on('click', function() { loadList(1); });
    $('#btnReset').on('click', function() {
        $('#searchForm')[0].reset();
        $('#filterParent').val('').trigger('change');
        currentSortBy = ''; currentSortDir = '';
        loadList(1);
    });

    // Drill-down: click title to see children
    $(document).on('click', '.drill-down', function(e) {
        e.preventDefault();
        var catId = $(this).data('catid');
        $('#filterParent').val(catId).trigger('change');
        loadList(1);
    });

    // Drill-up: back button to parent
    $(document).on('click', '.drill-up', function(e) {
        e.preventDefault();
        var parentId = $(this).data('parentid');
        if (parentId && parentId > 0) {
            $('#filterParent').val(parentId).trigger('change');
        } else {
            $('#filterParent').val('').trigger('change');
        }
        loadList(1);
    });

    $(document).on('click', '.ajax-page', function(e) {
        e.preventDefault();
        if ($(this).closest('.page-item').hasClass('disabled') || $(this).closest('.page-item').hasClass('active')) return;
        loadList($(this).data('page'));
    });

    $(document).on('change', '#chkAll', function() { $('.chkRow:not(:disabled)').prop('checked', this.checked); toggleBulk(); });
    $(document).on('change', '.chkRow', toggleBulk);
    function toggleBulk() { $('#btnBulkDelete').prop('disabled', !$('.chkRow:checked').length); }

    $(document).on('click', '.btn-del', function(e) {
        e.preventDefault();
        var id = $(this).data('id');
        Swal.fire({
            title: 'Xác nhận xóa?', text: 'Bạn chắc chắn muốn xóa danh mục #' + id + '?',
            icon: 'warning', showCancelButton: true,
            confirmButtonColor: '#d33', cancelButtonColor: '#6c757d',
            confirmButtonText: '<i class="fas fa-trash"></i> Xóa', cancelButtonText: 'Hủy'
        }).then(function(result) {
            if (result.isConfirmed) {
                $.post('@Url.Action("Delete", "CategoryAdmin", new { area = "Cms" })',
                    { id: id, __RequestVerificationToken: token },
                    function(r) {
                        if (r.success) { toastr.success(r.message); loadList(currentPage); }
                        else { toastr.error(r.message); }
                    });
            }
        });
    });

    $('#btnBulkDelete').on('click', function() {
        var ids = $('.chkRow:checked').map(function() { return $(this).val(); }).get();
        if (!ids.length) return;
        Swal.fire({
            title: 'Xóa nhiều danh mục?', text: 'Bạn chắc chắn xóa ' + ids.length + ' danh mục đã chọn?',
            icon: 'warning', showCancelButton: true,
            confirmButtonColor: '#d33', cancelButtonColor: '#6c757d',
            confirmButtonText: '<i class="fas fa-trash"></i> Xóa tất cả', cancelButtonText: 'Hủy'
        }).then(function(result) {
            if (result.isConfirmed) {
                var promises = ids.map(function(id) {
                    return $.post('@Url.Action("Delete", "CategoryAdmin", new { area = "Cms" })',
                        { id: id, __RequestVerificationToken: token });
                });
                $.when.apply($, promises).then(function() {
                    toastr.success('Đã xóa ' + ids.length + ' danh mục.');
                    loadList(currentPage);
                });
            }
        });
    });

    // ── Drag & Drop sorting ──
    function initSortable() {
        var el = document.getElementById('sortableBody');
        if (!el) return;
        Sortable.create(el, {
            handle: '.drag-handle',
            animation: 150,
            ghostClass: 'table-info',
            onEnd: function() {
                var items = [];
                $('#sortableBody tr[data-id]').each(function(index) {
                    items.push({ Id: parseInt($(this).data('id')), Sort: index });
                });
                $.ajax({
                    url: '@Url.Action("UpdateSort", "CategoryAdmin", new { area = "Cms" })',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(items),
                    success: function(r) {
                        if (r.success) toastr.success(r.message);
                        else toastr.error(r.message);
                    },
                    error: function() { toastr.error('Lỗi cập nhật thứ tự.'); }
                });
            }
        });
    }
    initSortable();

});
</script>
}
