<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] – CMS TechPort</title>

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <!-- Bootstrap 5.3 CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />

    <!-- AdminLTE 4 CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@4.0.0-beta3/dist/css/adminlte.min.css" />

    <!-- CMS SaaS Theme -->
    <link rel="stylesheet" href="~/css/cms-theme.css" />

    <!-- Toastr CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
    <!-- Select2 CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" />

    @RenderSection("Styles", required: false)
</head>
<body class="layout-fixed sidebar-expand-lg sidebar-mini sidebar-collapse bg-body-tertiary cms-saas-theme">
<div class="app-wrapper">

    <!-- ─── Top Navbar ─── -->
    <nav class="app-header navbar navbar-expand bg-body">
        <div class="container-fluid">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-lte-toggle="sidebar" href="#" role="button"><i class="fas fa-bars"></i></a>
                </li>
                <li class="nav-item d-none d-sm-inline-block">
                    <a href="/" class="nav-link" target="_blank"><i class="fas fa-external-link-alt me-1"></i> Xem trang chủ</a>
                </li>
            </ul>
            <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    <form method="post" action="/Account/Logout" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="nav-link btn btn-link">
                            <i class="fas fa-sign-out-alt"></i> Đăng xuất
                        </button>
                    </form>
                </li>
            </ul>
        </div>
    </nav>

    <!-- ─── Sidebar ─── -->
    <aside class="app-sidebar bg-body-secondary shadow" data-bs-theme="dark">
        <div class="sidebar-brand">
            <a href="/cms" class="brand-link">
                <span class="brand-text fw-light">
                    <i class="fas fa-cogs"></i> <strong>TechPort CMS</strong>
                </span>
            </a>
        </div>

        <div class="sidebar-wrapper">
            <nav class="mt-2">
                <ul class="nav sidebar-menu flex-column" data-lte-toggle="treeview" role="menu" data-accordion="false">

                    <li class="nav-item">
                        <a asp-area="Cms" asp-controller="Dashboard" asp-action="Index"
                           class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                            <i class="nav-icon fas fa-tachometer-alt"></i>
                            <p>Dashboard</p>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a asp-area="Cms" asp-controller="Users" asp-action="Index"
                           class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active" : "")">
                            <i class="nav-icon fas fa-users-cog"></i>
                            <p>Người dùng</p>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a asp-area="Cms" asp-controller="ProjectsAdmin" asp-action="Index"
                           class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ProjectsAdmin" ? "active" : "")">
                            <i class="nav-icon fas fa-project-diagram"></i>
                            <p>Dự án</p>
                        </a>
                    </li>
                    @{
                        var postsCtrl = ViewContext.RouteData.Values["controller"]?.ToString();
                        bool isPosts = postsCtrl == "Posts";
                        bool isMenuAdmin = postsCtrl == "MenuAdmin";
                        bool isCategoryAdmin = postsCtrl == "CategoryAdmin";
                        bool isImageAdverAdmin = postsCtrl == "ImageAdverAdmin";
                        bool isContentGroup = isPosts || isMenuAdmin || isCategoryAdmin || isImageAdverAdmin;
                    }
                    <li class="nav-item @(isContentGroup ? "menu-open" : "")">
                        <a href="#" class="nav-link @(isContentGroup ? "active" : "")">
                            <i class="nav-icon fas fa-newspaper"></i>
                            <p>
                                Tin bài / Contents
                                <i class="nav-arrow fas fa-angle-right"></i>
                            </p>
                        </a>
                        <ul class="nav nav-treeview">
                            <li class="nav-item">
                                <a asp-area="Cms" asp-controller="Posts" asp-action="Index"
                                   class="nav-link @(isPosts ? "active" : "")">
                                    <i class="nav-icon fas fa-list"></i>
                                    <p>Quản lý tin bài</p>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a asp-area="Cms" asp-controller="MenuAdmin" asp-action="Index"
                                   class="nav-link @(isMenuAdmin ? "active" : "")">
                                    <i class="nav-icon fas fa-sitemap"></i>
                                    <p>Quản lý Menu</p>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a asp-area="Cms" asp-controller="CategoryAdmin" asp-action="Index"
                                   class="nav-link @(isCategoryAdmin ? "active" : "")">
                                    <i class="nav-icon fas fa-tags"></i>
                                    <p>Quản lý Danh mục</p>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a asp-area="Cms" asp-controller="ImageAdverAdmin" asp-action="Index"
                                   class="nav-link @(isImageAdverAdmin ? "active" : "")">
                                    <i class="nav-icon fas fa-ad"></i>
                                    <p>Quản lý Quảng cáo</p>
                                </a>
                            </li>
                        </ul>
                    </li>

                    @{
                        var cntbCtrl = ViewContext.RouteData.Values["controller"]?.ToString();
                        var cntbAction = ViewContext.RouteData.Values["action"]?.ToString();
                        bool isCntb = cntbCtrl == "SanPhamCNTB";
                    }
                    <li class="nav-item @(isCntb ? "menu-open" : "")">
                        <a href="#" class="nav-link @(isCntb ? "active" : "")">
                            <i class="nav-icon fas fa-boxes-stacked"></i>
                            <p>
                                Sản phẩm CNTB
                                <i class="nav-arrow fas fa-angle-right"></i>
                            </p>
                        </a>
                        <ul class="nav nav-treeview">
                            <li class="nav-item">
                                <a asp-area="Cms" asp-controller="SanPhamCNTB" asp-action="CongNghe"
                                   class="nav-link @(isCntb && cntbAction == "CongNghe" ? "active" : "")">
                                    <i class="nav-icon fas fa-microchip"></i>
                                    <p>Quản lý Công nghệ</p>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a asp-area="Cms" asp-controller="SanPhamCNTB" asp-action="ThietBi"
                                   class="nav-link @(isCntb && cntbAction == "ThietBi" ? "active" : "")">
                                    <i class="nav-icon fas fa-cogs"></i>
                                    <p>Quản lý Thiết bị</p>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a asp-area="Cms" asp-controller="SanPhamCNTB" asp-action="SanPhamTriTue"
                                   class="nav-link @(isCntb && cntbAction == "SanPhamTriTue" ? "active" : "")">
                                    <i class="nav-icon fas fa-certificate"></i>
                                    <p>Quản lý SP trí tuệ</p>
                                </a>
                            </li>
                        </ul>
                    </li>

                    <li class="nav-item">
                        <a asp-area="Cms" asp-controller="NhaCungUngAdmin" asp-action="Index"
                           class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "NhaCungUngAdmin" ? "active" : "")">
                            <i class="nav-icon fas fa-building"></i>
                            <p>Nhà cung ứng</p>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a asp-area="Cms" asp-controller="NhaTuVanAdmin" asp-action="Index"
                           class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "NhaTuVanAdmin" ? "active" : "")">
                            <i class="nav-icon fas fa-user-tie"></i>
                            <p>Nhà tư vấn</p>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a asp-area="Cms" asp-controller="PhieuYeuCauCNTBAdmin" asp-action="Index"
                           class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "PhieuYeuCauCNTBAdmin" ? "active" : "")">
                            <i class="nav-icon fas fa-file-alt"></i>
                            <p>Phiếu yêu cầu CNTB</p>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a asp-area="Cms" asp-controller="FeedbackAdmin" asp-action="Index"
                           class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "FeedbackAdmin" ? "active" : "")">
                            <i class="nav-icon fas fa-comments"></i>
                            <p>Phản hồi (Feedback)</p>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a asp-area="Cms" asp-controller="DashboardData" asp-action="Index"
                           class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "DashboardData" ? "active" : "")">
                            <i class="nav-icon fas fa-chart-bar"></i>
                            <p>Số liệu Dashboard</p>
                        </a>
                    </li>

                </ul>
            </nav>
        </div>


        <!-- Sidebar Bottom: Notification + User -->
        <div class="sidebar-bottom">
            <div class="sidebar-notify" title="Thông báo">
                <i class="bi bi-bell"></i>
                <span class="badge bg-danger">3</span>
            </div>
            <div class="sidebar-user">
                <div class="avatar">@(User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "U")</div>
                <span class="user-name">@(User.Identity?.Name ?? "User")</span>
            </div>
        </div>
    </aside>

    <!-- ─── Content Wrapper ─── -->
    <main class="app-main">
        <div class="app-content-header">
            <div class="container-fluid">
                <div class="row mb-2">
                    <div class="col-sm-6">
                        <h3 class="mb-0">@ViewData["Title"]</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="app-content">
            <div class="container-fluid">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="fas fa-check-circle"></i> @TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @RenderBody()
            </div>
        </div>
    </main>

    <!-- ─── Footer ─── -->
    <footer class="app-footer">
        <strong>&copy; @DateTime.Now.Year TechPort.</strong> CMS Admin Panel.
    </footer>
</div>

<!-- jQuery (for Select2, Toastr, AJAX) -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<!-- Bootstrap 5.3 Bundle -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<!-- AdminLTE 4 JS -->
<script src="https://cdn.jsdelivr.net/npm/admin-lte@4.0.0-beta3/dist/js/adminlte.min.js"></script>

<!-- Toastr JS -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
<!-- SweetAlert2 -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<!-- Select2 -->
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

@RenderSection("Scripts", required: false)
</body>
</html>
