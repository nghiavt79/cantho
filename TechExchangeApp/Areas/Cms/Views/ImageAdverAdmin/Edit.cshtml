@model TechExchangeApp.Areas.Cms.Controllers.ImageAdverFormVm
@{
    ViewData["Title"] = "Sửa Quảng cáo";
}

<form asp-action="Edit" method="post" id="adverForm">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="ID" />
    <div class="card card-outline card-primary shadow-sm">
        <div class="card-header d-flex align-items-center flex-wrap gap-2">
            <h3 class="card-title mb-0">
                <i class="fas fa-pen me-1"></i> Sửa Quảng cáo #@Model.ID
            </h3>
            <div class="ms-auto d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="fas fa-save me-1"></i> Cập nhật
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                    <i class="fas fa-arrow-left me-1"></i> Quay lại
                </a>
            </div>
        </div>
        <div class="card-body">
            @if (Model.Created.HasValue)
            {
                <div class="alert alert-light small mb-3">
                    <i class="fas fa-info-circle me-1"></i>
                    Tạo bởi <strong>@(Model.Creator ?? "—")</strong> lúc <strong>@Model.Created?.ToString("dd/MM/yyyy HH:mm")</strong>
                </div>
            }
            @await Html.PartialAsync("_ImageAdverForm", Model)
        </div>
    </div>
</form>

@section Styles {
<link rel="stylesheet" href="https://cdn.ckeditor.com/ckeditor5/43.0.0/ckeditor5.css" />
<style>.ck-editor__editable { min-height: 300px; }</style>
}

@section Scripts {
<script src="https://cdn.ckeditor.com/ckeditor5/43.0.0/ckeditor5.umd.js"></script>
<script>
$(function(){
    const { ClassicEditor, Essentials, Bold, Italic, Link, Paragraph,
            Heading, List, BlockQuote, Table, TableToolbar,
            SourceEditing, Alignment, Font, HtmlEmbed, GeneralHtmlSupport } = CKEDITOR;

    ClassicEditor.create(document.querySelector('#editorDescription'), {
        plugins: [
            Essentials, Bold, Italic, Link, Paragraph, Heading,
            List, BlockQuote, Table, TableToolbar,
            SourceEditing, Alignment, Font, HtmlEmbed, GeneralHtmlSupport
        ],
        toolbar: {
            items: [
                'heading', '|',
                'bold', 'italic', 'link', '|',
                'alignment', '|',
                'fontSize', 'fontColor', '|',
                'bulletedList', 'numberedList', '|',
                'blockQuote', 'insertTable', 'htmlEmbed', '|',
                'sourceEditing', '|',
                'undo', 'redo'
            ]
        },
        table: {
            contentToolbar: ['tableColumn', 'tableRow', 'mergeTableCells']
        },
        // Preserve custom classes/attributes/inline styles (e.g. hand-authored
        // CTA buttons pasted via Source Editing) instead of CKEditor stripping
        // anything outside its default schema.
        htmlSupport: {
            allow: [
                { name: /.*/, attributes: true, classes: true, styles: true }
            ]
        }
    }).then(editor => {
        window._descEditor = editor;
    }).catch(err => console.error('CKEditor init error:', err));

    // Sync CKEditor data vào textarea TRƯỚC khi form submit
    var _submitting = false;
    document.getElementById('adverForm').addEventListener('submit', function(e) {
        if (_submitting) return; // đã sync rồi, cho submit qua
        e.preventDefault();
        if (window._descEditor) {
            document.getElementById('editorDescription').value = window._descEditor.getData();
        }
        _submitting = true;
        this.submit();
    });

    // Image upload buttons
    $('.btn-upload-field').on('click', function() {
        var targetId = $(this).data('target');
        var input = $('<input type="file" accept="image/*" style="display:none">');
        input.on('change', function() {
            var file = this.files[0];
            if (!file) return;
            var formData = new FormData();
            formData.append('upload', file);
            $.ajax({
                url: '@Url.Action("Upload", "Upload", new { area = "Cms" })',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function(r) {
                    if (r.url) {
                        $('#' + targetId).val(r.url);
                        var previewId = 'preview' + targetId.replace('input', '');
                        if ($('#' + previewId).length) {
                            $('#' + previewId).html('<img src="' + r.url + '" class="rounded" style="max-height:150px" />');
                        }
                        toastr.success('Upload thành công!');
                    } else if (r.error) {
                        toastr.error(r.error.message);
                    }
                },
                error: function() { toastr.error('Upload thất bại.'); }
            });
        });
        input.trigger('click');
    });
});
</script>
}
