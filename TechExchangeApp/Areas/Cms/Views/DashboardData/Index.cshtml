@using Microsoft.AspNetCore.Identity
@using TechExchangeApp.Entities
@inject UserManager<ApplicationUser> UserManager
@{
    ViewData["Title"] = "Quản trị số liệu Dashboard";
    var currentUser = await UserManager.GetUserAsync(User);
    var isAdmin = currentUser?.IsAdmin == true;
}

<style>
.dm-status {
  margin-top: 10px; padding: 10px 14px; border-radius: 4px; font-size: .82rem; display: none;
}
.dm-status--ok  { background: #d4edda; color: #155724; display: block; }
.dm-status--err { background: #f8d7da; color: #721c24; display: block; }
</style>

<div class="content-header">
  <div class="container-fluid">
    <div class="row mb-2">
      <div class="col-sm-6"><h1 class="m-0">⚙️ Quản trị số liệu Dashboard</h1></div>
      <div class="col-sm-6">
        <ol class="breadcrumb float-sm-right">
          <li class="breadcrumb-item"><a href="/cms">CMS</a></li>
          <li class="breadcrumb-item active">Số liệu Dashboard</li>
        </ol>
      </div>
    </div>
  </div>
</div>

<section class="content">
<div class="container-fluid">
<div class="card">
  <div class="card-header">
    <h5 class="mb-0">🏆 Số liệu Hero trang chủ</h5>
  </div>

  <div class="card-body">
    <div class="d-flex justify-content-end align-items-center mb-3">
      <div>
        @if (isAdmin)
        {
        <button class="btn btn-outline-danger btn-sm" id="dmRestoreDefault"><i class="fas fa-undo"></i> Khôi phục mặc định</button>
        }
        <button class="btn btn-default btn-sm" id="dmReload"><i class="fas fa-sync-alt"></i> Tải lại</button>
        <button class="btn btn-success btn-sm" id="dmPreview"><i class="fas fa-eye"></i> Xem trang</button>
        <button class="btn btn-primary btn-sm" id="dmSave"><i class="fas fa-save"></i> Lưu thay đổi</button>
      </div>
    </div>

    <h6 class="mt-2 mb-3"><i class="fas fa-trophy text-warning"></i> Số liệu banner trang chủ (mục "Techport trong con số")</h6>
    <div class="row">
      <div class="col-md-6 mb-3">
        <label class="form-label">Nhà khoa học &amp; chuyên gia / Chuyên gia tư vấn — số tối thiểu hiển thị</label>
        <input type="number" min="0" class="form-control" id="dmHeroExpertsFloor">
        <small class="text-muted">Nếu số thật trong hệ thống thấp hơn số này, trang chủ vẫn hiển thị số này.</small>
      </div>
      <div class="col-md-6 mb-3">
        <label class="form-label">Cơ sở &amp; phòng thí nghiệm — số tối thiểu hiển thị</label>
        <input type="number" min="0" class="form-control" id="dmHeroLabsFloor">
      </div>
      <div class="col-md-6 mb-3">
        <label class="form-label">Đối tác doanh nghiệp — số tối thiểu hiển thị</label>
        <input type="number" min="0" class="form-control" id="dmHeroPartnersFloor">
      </div>
      <div class="col-md-6 mb-3">
        <label class="form-label">Năm hoạt động &amp; phát triển — nhãn hiển thị</label>
        <input type="text" class="form-control" id="dmHeroYearsLabel" placeholder="VD: 20+">
      </div>
    </div>
    <div class="callout callout-warning mt-2">
      <p class="mb-0"><i class="fas fa-info-circle"></i> "Nhà khoa học &amp; chuyên gia" và "Chuyên gia tư vấn" dùng chung một số liệu thật (số chuyên gia đã duyệt trong hệ thống), nên chỉ có một số tối thiểu chung cho cả hai.</p>
    </div>

    <div class="dm-status" id="dmStatus"></div>
  </div>
</div>
</div>
</section>

@section scripts {
<script>
(function () {
    'use strict';

    var currentKey = 'herostats';
    var previewUrl = '/';
    var status = document.getElementById('dmStatus');

    function showStatus(msg, isError) {
        status.textContent = msg;
        status.className = 'dm-status ' + (isError ? 'dm-status--err' : 'dm-status--ok');
        if (!isError) setTimeout(function () { status.style.display = 'none'; }, 4000);
    }

    function loadData() {
        status.style.display = 'none';
        fetch('/cms/DashboardData/Load?key=' + currentKey)
            .then(function (r) { return r.text(); })
            .then(function (json) {
                var obj; try { obj = JSON.parse(json); } catch (e) { obj = null; }
                if (obj) {
                    document.getElementById('dmHeroExpertsFloor').value = obj.expertsFloor != null ? obj.expertsFloor : 1000;
                    document.getElementById('dmHeroLabsFloor').value = obj.labsFloor != null ? obj.labsFloor : 70;
                    document.getElementById('dmHeroPartnersFloor').value = obj.partnersFloor != null ? obj.partnersFloor : 2400;
                    document.getElementById('dmHeroYearsLabel').value = obj.yearsLabel || '20+';
                }
            })
            .catch(function (err) { showStatus('Lỗi tải dữ liệu: ' + err.message, true); });
    }

    function saveData() {
        var body = JSON.stringify({
            lastUpdated: new Date().toLocaleDateString('vi-VN'),
            expertsFloor: parseInt(document.getElementById('dmHeroExpertsFloor').value, 10) || 0,
            labsFloor: parseInt(document.getElementById('dmHeroLabsFloor').value, 10) || 0,
            partnersFloor: parseInt(document.getElementById('dmHeroPartnersFloor').value, 10) || 0,
            yearsLabel: document.getElementById('dmHeroYearsLabel').value || '20+'
        });

        fetch('/cms/DashboardData/Save?key=' + currentKey, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: body
        })
        .then(function (r) { return r.json(); })
        .then(function (data) {
            if (data.success) showStatus('✅ ' + data.message + ' — ' + data.lastUpdated, false);
            else showStatus('❌ ' + (data.error || 'Lỗi'), true);
        })
        .catch(function (err) { showStatus('❌ Lỗi lưu: ' + err.message, true); });
    }

    document.getElementById('dmSave').addEventListener('click', saveData);
    document.getElementById('dmReload').addEventListener('click', loadData);
    document.getElementById('dmPreview').addEventListener('click', function () { window.open(previewUrl, '_blank'); });

    var restoreBtn = document.getElementById('dmRestoreDefault');
    if (restoreBtn) restoreBtn.addEventListener('click', function () {
        if (!confirm('Bạn có chắc muốn khôi phục dữ liệu mặc định cho "Số liệu Hero trang chủ"?\n\nDữ liệu hiện tại sẽ được backup trước khi khôi phục.')) return;
        restoreBtn.disabled = true;
        restoreBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang khôi phục...';
        fetch('/cms/DashboardData/RestoreDefault?key=' + currentKey, { method: 'POST' })
            .then(function (r) { return r.json(); })
            .then(function (data) {
                if (data.success) {
                    showStatus('✅ ' + data.message, false);
                    loadData();
                } else {
                    showStatus('❌ ' + (data.error || 'Lỗi'), true);
                }
            })
            .catch(function (err) { showStatus('❌ Lỗi: ' + err.message, true); })
            .finally(function () {
                restoreBtn.disabled = false;
                restoreBtn.innerHTML = '<i class="fas fa-undo"></i> Khôi phục mặc định';
            });
    });

    document.addEventListener('keydown', function (e) {
        if ((e.ctrlKey || e.metaKey) && e.key === 's') { e.preventDefault(); saveData(); }
    });

    loadData();
})();
</script>
}
