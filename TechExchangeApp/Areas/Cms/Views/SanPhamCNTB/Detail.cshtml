@model TechExchangeApp.Entities.SanPhamCNTB
@{
    var images = (dynamic)ViewBag.Images;
    string typeName = Model.ProductType switch {
        2 => "Thiết bị",
        3 => "Sản phẩm trí tuệ",
        _ => "Công nghệ"
    };
    string trlDesc(int level) => level switch {
        1 => "Nguyên lý cơ bản được quan sát và báo cáo",
        2 => "Khái niệm công nghệ / ứng dụng được hình thành",
        3 => "Chức năng phân tích và thử nghiệm quan trọng",
        4 => "Xác nhận thành phần trong môi trường phòng thí nghiệm",
        5 => "Xác nhận thành phần trong môi trường liên quan",
        6 => "Trình diễn mô hình / hệ thống nguyên mẫu trong môi trường liên quan",
        7 => "Trình diễn nguyên mẫu hệ thống trong môi trường vận hành",
        8 => "Hệ thống thực tế hoàn chỉnh và đạt chuẩn",
        9 => "Hệ thống thực tế đã được chứng minh trong môi trường vận hành",
        _ => ""
    };
}

<div class="card card-outline card-info shadow-sm">
    <div class="card-header d-flex align-items-center">
        <h3 class="card-title mb-0"><i class="fas fa-info-circle me-1"></i> @ViewData["Title"]</h3>
        <div class="ms-auto">
            <a asp-action="Edit" asp-route-id="@Model.ID" class="btn btn-sm btn-primary">
                <i class="fas fa-pen-to-square me-1"></i> Sửa
            </a>
            <a href="javascript:history.back()" class="btn btn-sm btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i> Quay lại
            </a>
        </div>
    </div>
    <div class="card-body">

        <!-- ═══════ TAB HEADERS ═══════ -->
        <ul class="nav nav-tabs mb-3" id="detailTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#dtab1" type="button">I. Chủ sở hữu</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#dtab2" type="button">II. Định danh</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#dtab3" type="button">III. Mô tả</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#dtab4" type="button">IV. TRL</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#dtab5" type="button">V. Ứng dụng</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#dtab6" type="button">VI. Chuyển giao</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#dtab7" type="button">VII. Chứng nhận</button>
            </li>
        </ul>

        <!-- ═══════ TAB CONTENT ═══════ -->
        <div class="tab-content">

            <!-- ──── TAB 1: Chủ sở hữu ──── -->
            <div class="tab-pane fade show active" id="dtab1" role="tabpanel">
                <h6 class="fw-bold text-primary mb-3"><i class="fas fa-building me-1"></i> I. Chủ sở hữu công nghệ</h6>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <span class="small text-muted d-block">Loại sản phẩm</span>
                        <span class="badge bg-primary">@typeName</span>
                    </div>
                    <div class="col-md-6">
                        <span class="small text-muted d-block">Mã sản phẩm</span>
                        <strong>@(Model.Code ?? "—")</strong>
                    </div>
                </div>
                @{
                    var ncu = ViewBag.NhaCungUng as dynamic;
                }
                @if (ncu != null)
                {
                    <div class="border rounded p-3 bg-light">
                        <div class="row g-3">
                            <div class="col-md-12">
                                <span class="small text-muted d-block">Tên đơn vị</span>
                                <strong>@ncu.FullName</strong>
                            </div>
                            <div class="col-md-12">
                                <span class="small text-muted d-block">Địa chỉ</span>
                                <span>@(ncu.DiaChi ?? "—")</span>
                            </div>
                            <div class="col-md-6">
                                <span class="small text-muted d-block">Người đại diện</span>
                                <span>@(ncu.NguoiDaiDien ?? "—")</span>
                            </div>
                            <div class="col-md-6">
                                <span class="small text-muted d-block">Chức vụ</span>
                                <span>@(ncu.ChucVu ?? "—")</span>
                            </div>
                            <div class="col-md-4">
                                <span class="small text-muted d-block">Điện thoại</span>
                                <span>@(ncu.Phone ?? "—")</span>
                            </div>
                            <div class="col-md-4">
                                <span class="small text-muted d-block">Email</span>
                                <span>@(ncu.Email ?? "—")</span>
                            </div>
                            <div class="col-md-4">
                                <span class="small text-muted d-block">Website</span>
                                <span>@(ncu.Website ?? "—")</span>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <p class="text-muted">— Chưa chọn nhà cung ứng —</p>
                }
            </div>

            <!-- ──── TAB 2: Thông tin định danh ──── -->
            <div class="tab-pane fade" id="dtab2" role="tabpanel">
                <h6 class="fw-bold text-primary mb-3"><i class="fas fa-id-card me-1"></i> II. Thông tin định danh</h6>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <span class="small text-muted d-block">4. Tên công nghệ / quy trình</span>
                        <strong>@(Model.Name ?? "—")</strong>
                    </div>
                    <div class="col-md-6">
                        <span class="small text-muted d-block">5. Ảnh đại diện</span>
                        @if (!string.IsNullOrWhiteSpace(Model.QuyTrinhHinhAnh))
                        {
                            <img src="@Model.QuyTrinhHinhAnh" class="img-fluid rounded border" style="max-height:120px;" />
                        }
                        else
                        {
                            <span class="text-muted">— Chưa có —</span>
                        }
                    </div>
                </div>
                <!-- Gallery images -->
                @if (((IEnumerable<dynamic>)images).Any())
                {
                    <div class="mb-3">
                        <span class="small text-muted d-block mb-1">Thư viện hình ảnh</span>
                        <div class="d-flex gap-2 flex-wrap">
                            @foreach (var img in (IEnumerable<dynamic>)images)
                            {
                                <img src="@img.FileURL" alt="@img.Title" class="rounded border" style="max-height:100px;" />
                            }
                        </div>
                    </div>
                }

                @if (Model.ProductType == 3)
                {
                    <div class="row g-3 mt-2">
                        <div class="col-md-4">
                            <span class="small text-muted d-block">Số bằng</span>
                            <strong>@(Model.SoBang ?? "—")</strong>
                        </div>
                        <div class="col-md-4">
                            <span class="small text-muted d-block">Ngày cấp</span>
                            <span>@(Model.NgayCapBang?.ToString("dd/MM/yyyy") ?? "—")</span>
                        </div>
                        <div class="col-md-4">
                            <span class="small text-muted d-block">Thời hạn</span>
                            <span>@(Model.ThoiHan?.ToString("dd/MM/yyyy") ?? "—")</span>
                        </div>
                        <div class="col-md-4">
                            <span class="small text-muted d-block">Số đơn</span>
                            <span>@(Model.ApplicationNumber ?? "—")</span>
                        </div>
                        <div class="col-md-4">
                            <span class="small text-muted d-block">Ngày chấp nhận</span>
                            <span>@(Model.AcceptedDate?.ToString("dd/MM/yyyy") ?? "—")</span>
                        </div>
                    </div>
                }
            </div>

            <!-- ──── TAB 3: Mô tả chi tiết ──── -->
            <div class="tab-pane fade" id="dtab3" role="tabpanel">
                <h6 class="fw-bold text-primary mb-3"><i class="fas fa-file-lines me-1"></i> III. Mô tả chi tiết</h6>

                @if (!string.IsNullOrWhiteSpace(Model.MoTaNgan))
                {
                    <div class="mb-4">
                        <label class="form-label fw-semibold">7. Bối cảnh & Vấn đề giải quyết</label>
                        <div class="border rounded p-3 bg-light">@Html.Raw(Model.MoTaNgan)</div>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.MoTa))
                {
                    <div class="mb-4">
                        <label class="form-label fw-semibold">8. Nguyên lý vận hành & Sơ đồ quy trình</label>
                        <div class="border rounded p-3 bg-light">@Html.Raw(Model.MoTa)</div>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.ThongSo))
                {
                    <div class="mb-4">
                        <label class="form-label fw-semibold">9. Thông số kỹ thuật chủ yếu</label>
                        <div class="border rounded p-3 bg-light">@Html.Raw(Model.ThongSo)</div>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.UuDiem))
                {
                    <div class="mb-4">
                        <label class="form-label fw-semibold">10. Ưu điểm nổi bật</label>
                        <div class="border rounded p-3 bg-light">@Html.Raw(Model.UuDiem)</div>
                    </div>
                }
            </div>

            <!-- ──── TAB 4: TRL ──── -->
            <div class="tab-pane fade" id="dtab4" role="tabpanel">
                <h6 class="fw-bold text-primary mb-3"><i class="fas fa-layer-group me-1"></i> IV. Mức độ sẵn sàng công nghệ (TRL)</h6>
                @if (Model.TRLLevel.HasValue && Model.TRLLevel > 0)
                {
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <span class="badge bg-primary fs-5 px-3 py-2">TRL @Model.TRLLevel</span>
                        <span class="text-muted">@trlDesc(Model.TRLLevel.Value)</span>
                    </div>
                    <!-- Progress bar -->
                    <div class="progress" style="height: 24px;">
                        <div class="progress-bar bg-primary" role="progressbar"
                             style="width: @((Model.TRLLevel.Value / 9.0 * 100).ToString("F0"))%">
                            TRL @Model.TRLLevel / 9
                        </div>
                    </div>
                }
                else
                {
                    <p class="text-muted">— Chưa xác định —</p>
                }
            </div>

            <!-- ──── TAB 5: Ứng dụng ──── -->
            <div class="tab-pane fade" id="dtab5" role="tabpanel">
                <h6 class="fw-bold text-primary mb-3"><i class="fas fa-bullseye me-1"></i> V. Ứng dụng thực tiễn</h6>

                @if (!string.IsNullOrWhiteSpace(Model.TargetCustomer))
                {
                    <div class="mb-4">
                        <label class="form-label fw-semibold">12. Đối tượng khách hàng mục tiêu</label>
                        <div class="border rounded p-3 bg-light">@Html.Raw(Model.TargetCustomer)</div>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.CooperationGoal))
                {
                    <div class="mb-4">
                        <label class="form-label fw-semibold">13. Hiệu quả kinh tế - xã hội</label>
                        <div class="border rounded p-3 bg-light">@Html.Raw(Model.CooperationGoal)</div>
                    </div>
                }
            </div>

            <!-- ──── TAB 6: Chuyển giao ──── -->
            <div class="tab-pane fade" id="dtab6" role="tabpanel">
                <h6 class="fw-bold text-primary mb-3"><i class="fas fa-handshake me-1"></i> VI. Chuyển giao công nghệ</h6>

                @if (!string.IsNullOrWhiteSpace(Model.TransferMethod))
                {
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Hình thức chuyển giao</label>
                        <div>
                            @foreach (var m in Model.TransferMethod.Split(',', StringSplitOptions.RemoveEmptyEntries))
                            {
                                <span class="badge bg-info me-1">@m.Trim()</span>
                            }
                        </div>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.GiaBanDuKien))
                {
                    <div class="mb-4">
                        <label class="form-label fw-semibold">14. Giá bán dự kiến</label>
                        <div class="border rounded p-3 bg-light">@Html.Raw(Model.GiaBanDuKien)</div>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.ChiPhiPhatSinh))
                {
                    <div class="mb-4">
                        <label class="form-label fw-semibold">15. Các chi phí phát sinh khác (Chi phí đào tạo, hướng dẫn kỹ thuật, bảo trì, bảo hành, vận chuyển, lắp đặt,…)</label>
                        <div class="border rounded p-3 bg-light">@Html.Raw(Model.ChiPhiPhatSinh)</div>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.BaoHanhHoTro))
                {
                    <div class="mb-4">
                        <label class="form-label fw-semibold">16. Chế độ bảo hành & Hỗ trợ kỹ thuật</label>
                        <div class="border rounded p-3 bg-light">@Html.Raw(Model.BaoHanhHoTro)</div>
                    </div>
                }
            </div>

            <!-- ──── TAB 7: Chứng nhận & Tài liệu số ──── -->
            <div class="tab-pane fade" id="dtab7" role="tabpanel">
                <h6 class="fw-bold text-primary mb-3"><i class="fas fa-certificate me-1"></i> VII. Chứng nhận & Tài liệu số</h6>
                <!-- 17. Chứng nhận chất lượng -->
                @if ((Model.ChungNhanISO == true) || (Model.ChungNhanQuatest == true) || (Model.ChungNhanKhac == true))
                {
                    <div class="mb-4">
                        <label class="form-label fw-semibold">17. Chứng nhận chất lượng</label>
                        <div>
                            @if (Model.ChungNhanISO == true) { <span class="badge bg-success me-1">ISO / CE / HACCP</span> }
                            @if (Model.ChungNhanQuatest == true) { <span class="badge bg-info me-1">Phiếu kết quả kiểm nghiệm (Quatest)</span> }
                            @if (Model.ChungNhanKhac == true) { <span class="badge bg-secondary me-1">Khác: @(Model.ChungNhanKhacText ?? "—")</span> }
                        </div>
                    </div>
                }

                <!-- Video clip -->
                @if (!string.IsNullOrWhiteSpace(Model.URL))
                {
                    <div class="mb-4">
                        <label class="form-label fw-semibold">18a. Video clip vận hành</label>
                        @if (Model.IsYoutube == true && Model.URL.Contains("youtube", StringComparison.OrdinalIgnoreCase))
                        {
                            var videoId = "";
                            if (Model.URL.Contains("v=")) { videoId = Model.URL.Split("v=")[1].Split('&')[0]; }
                            else if (Model.URL.Contains("youtu.be/")) { videoId = Model.URL.Split("youtu.be/")[1].Split('?')[0]; }

                            if (!string.IsNullOrEmpty(videoId))
                            {
                                <div class="ratio ratio-16x9" style="max-width:640px;">
                                    <iframe src="https://www.youtube.com/embed/@videoId" allowfullscreen></iframe>
                                </div>
                            }
                            else
                            {
                                <a href="@Model.URL" target="_blank" class="btn btn-outline-primary btn-sm">
                                    <i class="fab fa-youtube me-1"></i> Xem video
                                </a>
                            }
                        }
                        else
                        {
                            <a href="@Model.URL" target="_blank" class="btn btn-outline-primary btn-sm">
                                <i class="fas fa-video me-1"></i> Xem video
                            </a>
                        }
                    </div>
                }

                <!-- Brochure -->
                @if (!string.IsNullOrWhiteSpace(Model.BrochureUrl))
                {
                    <div class="mb-4">
                        <label class="form-label fw-semibold">18b. Brochure / Catalogue</label>
                        <div>
                            <a href="@Model.BrochureUrl" target="_blank" class="btn btn-outline-danger btn-sm">
                                <i class="fas fa-file-pdf me-1"></i> Xem Brochure
                            </a>
                        </div>
                    </div>
                }
            </div>

        </div>

        <!-- ═══════ FOOTER META ═══════ -->
        <hr />
        <div class="row g-3 small text-muted">
            <div class="col-md-4">
                <i class="fas fa-calendar-plus me-1"></i> Tạo: @(Model.Created?.ToString("dd/MM/yyyy HH:mm") ?? "—") bởi @(Model.Creator ?? "—")
            </div>
            <div class="col-md-4">
                <i class="fas fa-calendar-pen me-1"></i> Sửa: @(Model.Modified?.ToString("dd/MM/yyyy HH:mm") ?? "—") bởi @(Model.Modifier ?? "—")
            </div>
            <div class="col-md-4">
                <i class="fas fa-eye me-1"></i> Lượt xem: @(Model.Viewed ?? 0)
            </div>
        </div>

    </div>
</div>
