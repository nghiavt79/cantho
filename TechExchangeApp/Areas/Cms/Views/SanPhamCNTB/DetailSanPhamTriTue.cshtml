@model TechExchangeApp.Entities.SanPhamCNTB
@{
    ViewData["Title"] = ViewData["Title"] ?? "Chi tiết tài sản trí tuệ";
    var linhVucItems = (List<SelectListItem>)ViewBag.LinhVucList;
    var ncu = ViewBag.NhaCungUng as dynamic;

    /* helpers for LoaiDeTai labels */
    var loaiLabel = Model.LoaiDeTai switch
    {
        1 => "Sáng chế / Giải pháp hữu ích",
        2 => "Thiết kế bố trí vi mạch",
        3 => "Phần mềm (Bản quyền tác giả)",
        4 => "Khác",
        _ => "—"
    };

    /* helpers for Rating (development stage) */
    var ratingLabel = Model.DevelopmentStageValue switch
    {
        1 => "Ý tưởng / Thiết kế",
        2 => "Đã có sản phẩm mẫu (Prototype)",
        3 => "Đã thương mại hóa",
        _ => "—"
    };
    var ratingIcon = Model.DevelopmentStageValue switch
    {
        1 => "fas fa-lightbulb text-warning",
        2 => "fas fa-flask text-info",
        3 => "fas fa-shopping-cart text-success",
        _ => "fas fa-question-circle text-muted"
    };

    /* parse comma-separated values */
    var selectedCats = Model.CategoryId?.Split(new[]{',',';'}, StringSplitOptions.RemoveEmptyEntries) ?? Array.Empty<string>();
    var selectedGoals = Model.InvestmentGoal?.Split(',', StringSplitOptions.RemoveEmptyEntries) ?? Array.Empty<string>();
    var selectedTransfer = Model.TransferMethod?.Split(',', StringSplitOptions.RemoveEmptyEntries) ?? Array.Empty<string>();

    var goalOptions = new[] {
        "Tìm nhà đầu tư tài chính",
        "Tìm đối tác sản xuất",
        "Tìm đối tác phân phối/thương mại",
        "Khác"
    };

    var transferOptions = new[] {
        "Chuyển nhượng toàn bộ bản quyền",
        "Chuyển giao quyền sử dụng (Li-xăng)",
        "Góp vốn bằng tài sản trí tuệ",
        "Hợp tác nghiên cứu phát triển thêm",
        "Khác"
    };
}

<div class="card card-outline card-info shadow-sm">
    <div class="card-header">
        <h3 class="card-title"><i class="fas fa-eye me-1"></i> @ViewData["Title"]</h3>
    </div>
    <div class="card-body">

        <!-- ═══════════════════════════════════════ -->
        <!-- NAV TABS                                -->
        <!-- ═══════════════════════════════════════ -->
        <ul class="nav nav-tabs mb-0" id="cntbTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="tab1-tab" data-bs-toggle="tab"
                        data-bs-target="#tab1" type="button" role="tab">
                    <i class="fas fa-building me-1"></i> I. Chủ sở hữu
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="tab2-tab" data-bs-toggle="tab"
                        data-bs-target="#tab2" type="button" role="tab">
                    <i class="fas fa-id-card me-1"></i> II. Phân loại & Định danh
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="tab3-tab" data-bs-toggle="tab"
                        data-bs-target="#tab3" type="button" role="tab">
                    <i class="fas fa-file-lines me-1"></i> III. Mô tả
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="tab4-tab" data-bs-toggle="tab"
                        data-bs-target="#tab4" type="button" role="tab">
                    <i class="fas fa-bullseye me-1"></i> IV. Mục tiêu kêu gọi
                </button>
            </li>
        </ul>

        <!-- ═══════════════════════════════════════ -->
        <!-- TAB CONTENT                             -->
        <!-- ═══════════════════════════════════════ -->
        <div class="tab-content border border-top-0 rounded-bottom p-4" id="cntbTabContent">

            <!-- ──────────────────────────────────────── -->
            <!-- TAB 1 — I. THÔNG TIN CHỦ SỞ HỮU         -->
            <!-- ──────────────────────────────────────── -->
            <div class="tab-pane fade show active" id="tab1" role="tabpanel">
                <h6 class="fw-bold text-primary mb-3"><i class="fas fa-building me-1"></i> I. Thông tin chủ sở hữu</h6>

                @if (ncu != null)
                {
                    <table class="table table-bordered mb-0">
                        <tbody>
                            <tr>
                                <th class="bg-light" style="width:200px">1. Tên đơn vị / Cá nhân</th>
                                <td>@ncu.FullName</td>
                            </tr>
                            <tr>
                                <th class="bg-light">2. Địa chỉ</th>
                                <td>@ncu.DiaChi</td>
                            </tr>
                            <tr>
                                <th class="bg-light">Người đại diện</th>
                                <td>@ncu.NguoiDaiDien</td>
                            </tr>
                            <tr>
                                <th class="bg-light">Điện thoại</th>
                                <td>@ncu.Phone</td>
                            </tr>
                            <tr>
                                <th class="bg-light">Email</th>
                                <td>@ncu.Email</td>
                            </tr>
                            <tr>
                                <th class="bg-light">Website</th>
                                <td>
                                    @if (!string.IsNullOrEmpty((string?)ncu.Website))
                                    {
                                        <a href="@ncu.Website" target="_blank">@ncu.Website</a>
                                    }
                                </td>
                            </tr>
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted fst-italic"><i class="fas fa-info-circle me-1"></i> Chưa có thông tin chủ sở hữu.</p>
                }
            </div>

            <!-- ──────────────────────────────────────── -->
            <!-- TAB 2 — II. PHÂN LOẠI & ĐỊNH DANH        -->
            <!-- ──────────────────────────────────────── -->
            <div class="tab-pane fade" id="tab2" role="tabpanel">
                <h6 class="fw-bold text-primary mb-3"><i class="fas fa-id-card me-1"></i> II. Phân loại và Định danh tài sản trí tuệ</h6>

                <table class="table table-bordered mb-4">
                    <tbody>
                        <!-- 3. Phân loại hồ sơ -->
                        <tr>
                            <th class="bg-light" style="width:200px">3. Phân loại hồ sơ</th>
                            <td>
                                <span class="badge bg-primary fs-6">@loaiLabel</span>
                            </td>
                        </tr>

                        <!-- 4. Tên tài sản trí tuệ -->
                        <tr>
                            <th class="bg-light">4. Tên tài sản trí tuệ</th>
                            <td class="fw-semibold">@Model.Name</td>
                        </tr>
                    </tbody>
                </table>

                <!-- 5. Tình trạng pháp lý -->
                <div class="border rounded p-3 mb-4 bg-light">
                    <h6 class="fw-bold text-info mb-3"><i class="fas fa-gavel me-1"></i> 5. Tình trạng pháp lý</h6>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label text-muted small">Số đơn</label>
                            <div class="fw-semibold">@(Model.ApplicationNumber ?? "—")</div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted small">Ngày chấp nhận đơn</label>
                            <div class="fw-semibold">@(Model.NgayCapBang?.ToString("dd/MM/yyyy") ?? "—")</div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted small">Thời hạn bảo hộ đến</label>
                            <div class="fw-semibold">@(Model.ThoiHan?.ToString("dd/MM/yyyy") ?? "—")</div>
                        </div>
                    </div>
                </div>

                <!-- 6. Lĩnh vực áp dụng -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">6. Lĩnh vực áp dụng</label>
                    <div class="row g-2">
                        @foreach (var item in linhVucItems.Where(x => !string.IsNullOrEmpty(x.Value)))
                        {
                            var isSelected = selectedCats.Contains(item.Value);
                            <div class="col-md-4 col-lg-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" disabled
                                           @(isSelected ? "checked" : "") />
                                    <label class="form-check-label @(isSelected ? "fw-bold text-success" : "text-muted")">
                                        @item.Text
                                    </label>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- ──────────────────────────────────────── -->
            <!-- TAB 3 — III. NỘI DUNG MÔ TẢ              -->
            <!-- ──────────────────────────────────────── -->
            <div class="tab-pane fade" id="tab3" role="tabpanel">
                <h6 class="fw-bold text-primary mb-3"><i class="fas fa-file-lines me-1"></i> III. Nội dung mô tả và quy trình</h6>

                <!-- 7. Mô tả tài sản trí tuệ -->
                <div class="mb-4">
                    <label class="form-label fw-semibold">7. Mô tả tài sản trí tuệ</label>
                    <small class="text-muted d-block mb-2">(Tính mới, tính sáng tạo và khả năng áp dụng)</small>
                    <div class="border rounded p-3 bg-white ck-content">
                        @Html.Raw(Model.MoTa ?? "<em class='text-muted'>Chưa có nội dung</em>")
                    </div>
                </div>

                <!-- 8. Ảnh đại diện / Sơ đồ quy trình -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">8. Ảnh đại diện sản phẩm / Sơ đồ quy trình</label>
                    @if (!string.IsNullOrEmpty(Model.QuyTrinhHinhAnh))
                    {
                        <div class="text-center border rounded p-3 bg-light">
                            <img src="@Model.QuyTrinhHinhAnh" class="img-fluid rounded shadow-sm" style="max-height:400px;" />
                        </div>
                    }
                    else
                    {
                        <p class="text-muted fst-italic"><i class="fas fa-image me-1"></i> Chưa có ảnh đại diện.</p>
                    }
                </div>
            </div>

            <!-- ──────────────────────────────────────── -->
            <!-- TAB 4 — IV. MỤC TIÊU KÊU GỌI             -->
            <!-- ──────────────────────────────────────── -->
            <div class="tab-pane fade" id="tab4" role="tabpanel">
                <h6 class="fw-bold text-primary mb-3"><i class="fas fa-bullseye me-1"></i> IV. Mục tiêu kêu gọi đầu tư & Hợp tác</h6>

                <!-- 9. Phân loại mục tiêu kêu gọi -->
                <div class="mb-4">
                    <label class="form-label fw-semibold">9. Phân loại mục tiêu kêu gọi</label>
                    <div class="row g-2">
                        @foreach (var opt in goalOptions)
                        {
                            var isSelected = selectedGoals.Contains(opt);
                            <div class="col-md-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" disabled
                                           @(isSelected ? "checked" : "") />
                                    <label class="form-check-label @(isSelected ? "fw-bold text-success" : "text-muted")">
                                        @opt
                                    </label>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- 10. Hình thức hợp tác mong muốn -->
                <div class="mb-4">
                    <label class="form-label fw-semibold">10. Hình thức hợp tác mong muốn</label>
                    <div class="row g-2">
                        @foreach (var opt in transferOptions)
                        {
                            var isSelected = selectedTransfer.Contains(opt);
                            <div class="col-md-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" disabled
                                           @(isSelected ? "checked" : "") />
                                    <label class="form-check-label @(isSelected ? "fw-bold text-success" : "text-muted")">
                                        @opt
                                    </label>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- 11. Tình trạng phát triển -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">11. Tình trạng phát triển</label>
                    <div class="d-flex align-items-center gap-2 mt-1">
                        <i class="@ratingIcon fa-lg"></i>
                        <span class="badge bg-primary fs-6">@ratingLabel</span>
                    </div>
                </div>
            </div>

        </div><!-- /tab-content -->

    </div><!-- /card-body -->

    <div class="card-footer d-flex justify-content-between">
        <a href="javascript:history.back()" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Quay lại danh sách
        </a>
        <a asp-action="Edit" asp-route-id="@Model.ID" class="btn btn-warning">
            <i class="fas fa-edit me-1"></i> Sửa sản phẩm
        </a>
    </div>
</div>
