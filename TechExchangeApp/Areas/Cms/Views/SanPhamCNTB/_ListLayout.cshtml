@model List<TechExchangeApp.Areas.Cms.Controllers.SanPhamCNTBListItem>
@{
    var actionName = (string)ViewData["ActionName"]!;
    var productType = (int)ViewData["ProductType"]!;
    var pageTitle = (string)ViewData["PageTitle"]!;
    var addLabel = (string)ViewData["AddLabel"]!;
}

<!-- ─── Search Card ─── -->
<div class="card card-outline card-primary shadow-sm mb-3">
    <div class="card-header" id="searchCardHeader" style="cursor:pointer" title="Nhấn đúp để thu gọn/mở rộng">
        <h3 class="card-title"><i class="fas fa-search me-1"></i> Tìm kiếm @pageTitle</h3>
        <div class="card-tools">
            <button type="button" class="btn btn-tool" data-lte-toggle="card-collapse"><i class="fas fa-minus"></i></button>
        </div>
    </div>
    <div class="card-body">
        <form id="searchForm">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="mb-2">
                        <label class="form-label fw-semibold small mb-1">Từ khóa (tên / mã)</label>
                        <input type="text" name="keyword" value="@ViewBag.Keyword" class="form-control form-control-sm" placeholder="Nhập từ khóa..." />
                    </div>
                    <div class="mb-2">
                        <label class="form-label fw-semibold small mb-1">Trạng thái</label>
                        <select name="statusId" class="form-select form-select-sm">
                            <option value="">-- Tất cả --</option>
                            @{
                                var sts = ViewBag.StatusId?.ToString() ?? "";
                                var statuses = (IEnumerable<dynamic>?)ViewBag.Statuses;
                            }
                            @if (statuses != null)
                            {
                                foreach (var s in statuses)
                                {
                                    <option value="@s.StatusId" selected="@(sts == s.StatusId.ToString())">@s.Title</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label fw-semibold small mb-1">Người tạo</label>
                        <input type="text" name="creator" value="@ViewBag.Creator" class="form-control form-control-sm" placeholder="Tên người tạo..." />
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-2">
                        <label class="form-label fw-semibold small mb-1">Nhà cung ứng</label>
                        <select name="ncuId" id="filterNcu" class="form-select form-select-sm">
                            <option value="">-- Tất cả --</option>
                            @{
                                var selNcu = ViewBag.NcuId?.ToString() ?? "";
                                var ncus = (IEnumerable<dynamic>?)ViewBag.NhaCungUngs;
                            }
                            @if (ncus != null)
                            {
                                foreach (var n in ncus)
                                {
                                    <option value="@n.CungUngId" selected="@(selNcu == n.CungUngId.ToString())">@n.FullName</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label fw-semibold small mb-1">Xuất xứ</label>
                        <select name="xuatXuId" id="filterXuatXu" class="form-select form-select-sm">
                            <option value="">-- Tất cả --</option>
                            @{
                                var selXx = ViewBag.XuatXuId?.ToString() ?? "";
                                var xxList = (IEnumerable<dynamic>?)ViewBag.XuatXus;
                            }
                            @if (xxList != null)
                            {
                                foreach (var x in xxList)
                                {
                                    <option value="@x.Id" selected="@(selXx == x.Id.ToString())">@x.Title</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label fw-semibold small mb-1">Lĩnh vực</label>
                        <select name="linhVuc" id="filterLinhVuc" class="form-select form-select-sm">
                            <option value="">-- Tất cả --</option>
                            @{
                                var selLv = ViewBag.LinhVuc?.ToString() ?? "";
                                var lvList = (IEnumerable<dynamic>?)ViewBag.LinhVucs;
                            }
                            @if (lvList != null)
                            {
                                foreach (var lv in lvList)
                                {
                                    <option value="@lv.Id" selected="@(selLv == lv.Id.ToString())">@lv.Title</option>
                                }
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-2">
                        <label class="form-label fw-semibold small mb-1">Sàn</label>
                        @{
                            var configSiteId = (int)(ViewBag.CurrentSiteId ?? 0);
                        }
                        <select name="siteId" id="filterSiteId" class="form-select form-select-sm"
                                @(configSiteId > 1 ? "disabled" : "")>
                            <option value="">-- Tất cả --</option>
                            @{
                                var selSite = ViewBag.SiteId?.ToString() ?? ViewBag.CurrentSiteId?.ToString() ?? "";
                                var sites = (IEnumerable<TechExchangeApp.Entities.RootSite>?)ViewBag.Sites;
                            }
                            @if (sites != null)
                            {
                                foreach (var s in sites)
                                {
                                    <option value="@s.SiteId" selected="@(selSite == s.SiteId.ToString())">@s.SiteName</option>
                                }
                            }
                        </select>
                    </div>
                    @if (productType == 1)
                    {
                        <div class="mb-2">
                            <label class="form-label fw-semibold small mb-1">TRL (Mức độ sẵn sàng)</label>
                            <select name="trlLevel" class="form-select form-select-sm">
                                <option value="">-- Tất cả --</option>
                                @{
                                    var selTrl = ViewBag.TrlLevel?.ToString() ?? "";
                                    var mucDos = (IEnumerable<dynamic>?)ViewBag.MucDos;
                                }
                                @if (mucDos != null)
                                {
                                    foreach (var m in mucDos)
                                    {
                                        <option value="@m.Id" selected="@(selTrl == m.Id.ToString())">@m.Title</option>
                                    }
                                }
                            </select>
                        </div>
                    }
                    <div class="row g-2 mb-2">
                        <div class="col-6">
                            <label class="form-label fw-semibold small mb-1">Ngày tạo từ</label>
                            <input type="date" name="createdFrom" value="@ViewBag.CreatedFrom?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-semibold small mb-1">Ngày tạo đến</label>
                            <input type="date" name="createdTo" value="@ViewBag.CreatedTo?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
                        </div>
                    </div>
                </div>
            </div>
        </form>

    </div>
    <div class="card-footer bg-transparent">
        <button type="button" class="btn btn-primary btn-sm me-2" id="btnSearch">
            <i class="fas fa-search me-1"></i> Tìm kiếm
        </button>
        <button type="button" class="btn btn-outline-secondary btn-sm me-2" id="btnReset">
            <i class="fas fa-undo me-1"></i> Đặt lại
        </button>
        <button type="button" class="btn btn-outline-success btn-sm" id="btnExportExcel" title="Xuất danh sách hiện tại ra Excel">
            <i class="fas fa-file-excel me-1"></i> Export Excel
        </button>
    </div>
</div>

<!-- ─── Result Card ─── -->
<div class="card card-outline card-info shadow-sm">
    <div class="card-header d-flex align-items-center flex-wrap gap-2">
        <h3 class="card-title mb-0">
            <i class="fas fa-list me-1"></i> @pageTitle
            <span class="badge bg-info ms-1" id="badgeTotal">@ViewBag.TotalCount</span>
        </h3>
        <div class="ms-auto d-flex gap-2">
            <a asp-action="Create" asp-route-productType="@productType" class="btn btn-success btn-sm">
                <i class="fas fa-plus me-1"></i> @addLabel
            </a>
            <button type="button" class="btn btn-outline-danger btn-sm" id="btnBulkDelete" disabled>
                <i class="fas fa-trash-alt me-1"></i> Xóa chọn
            </button>
        </div>
    </div>

    <div id="listContainer">
        @await Html.PartialAsync("_ListPartial", Model)
    </div>
</div>

<!-- ─── Quick Config Modal ─── -->
<div class="modal fade" id="configModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title"><i class="fas fa-gear me-1"></i> Cấu hình nhanh</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="configModalBody">
                <div class="text-center py-4"><i class="fas fa-spinner fa-spin fa-2x"></i></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-primary btn-sm" id="btnSaveConfig">
                    <i class="fas fa-save me-1"></i> Lưu
                </button>
            </div>
        </div>
    </div>
</div>

@* Scripts are defined in parent views (CongNghe/ThietBi/SanPhamTriTue) via @section Scripts *@
