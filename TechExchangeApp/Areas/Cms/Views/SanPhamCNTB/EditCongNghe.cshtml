@model TechExchangeApp.Areas.Cms.Controllers.SanPhamCNTBFormVm
@{
    ViewData["Title"] = ViewData["Title"] ?? "Sửa công nghệ";
    var linhVucItems = (List<SelectListItem>)ViewBag.LinhVucList;
}

<style>
    .ck-editor__editable { min-height: 300px !important; }
</style>

<div class="card card-outline card-primary shadow-sm">
    <div class="card-header">
        <h3 class="card-title"><i class="fas fa-pen-to-square me-1"></i> @ViewData["Title"]</h3>
    </div>
    <form asp-action="Edit" method="post" id="frmCNTB">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ID" />
        <input type="hidden" asp-for="ProductType" id="hdnProductType" />
        <input type="hidden" asp-for="Code" />
        <input type="hidden" asp-for="StatusId" />
        <input type="hidden" asp-for="SiteId" />

        <div class="card-body">

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-triangle me-1"></i> Vui lòng kiểm tra lại thông tin bên dưới.
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <!-- ═══════════════════════════════════════ -->
            <!-- NAV TABS                                -->
            <!-- ═══════════════════════════════════════ -->
            <ul class="nav nav-tabs mb-0" id="cntbTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="tab1-tab" data-bs-toggle="tab"
                            data-bs-target="#tab1" type="button" role="tab">
                        <i class="fas fa-building me-1"></i> I. Chủ sở hữu
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="tab2-tab" data-bs-toggle="tab"
                            data-bs-target="#tab2" type="button" role="tab">
                        <i class="fas fa-id-card me-1"></i> II. Định danh
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="tab3-tab" data-bs-toggle="tab"
                            data-bs-target="#tab3" type="button" role="tab">
                        <i class="fas fa-file-lines me-1"></i> III. Mô tả
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="tab4-tab" data-bs-toggle="tab"
                            data-bs-target="#tab4" type="button" role="tab">
                        <i class="fas fa-star me-1"></i> IV. TRL
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="tab5-tab" data-bs-toggle="tab"
                            data-bs-target="#tab5" type="button" role="tab">
                        <i class="fas fa-chart-line me-1"></i> V. Ứng dụng
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="tab6-tab" data-bs-toggle="tab"
                            data-bs-target="#tab6" type="button" role="tab">
                        <i class="fas fa-money-bill-wave me-1"></i> VI. Chuyển giao
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="tab7-tab" data-bs-toggle="tab"
                            data-bs-target="#tab7" type="button" role="tab">
                        <i class="fas fa-certificate me-1"></i> VII. Chứng nhận
                    </button>
                </li>
            </ul>

            <!-- ═══════════════════════════════════════ -->
            <!-- TAB CONTENT                             -->
            <!-- ═══════════════════════════════════════ -->
            <div class="tab-content border border-top-0 rounded-bottom p-4" id="cntbTabContent">

                <!-- ──────────────────────────────────────── -->
                <!-- TAB 1 — I. THÔNG TIN CHỦ SỞ HỮU         -->
                <!-- ──────────────────────────────────────── -->
                <div class="tab-pane fade show active" id="tab1" role="tabpanel">
                    <h6 class="fw-bold text-primary mb-3"><i class="fas fa-building me-1"></i> I. Thông tin chủ sở hữu (Nhà cung ứng)</h6>

                    <div class="row g-3 mb-3">
                        <div class="col-md-12">
                            <label class="form-label fw-semibold">1. Tên đơn vị / Cá nhân chủ sở hữu</label>
                            <select asp-for="NCUId" class="form-select" asp-items="@((List<SelectListItem>)ViewBag.NhaCungUngList)">
                                <option value="">-- Chọn nhà cung ứng --</option>
                            </select>
                        </div>
                    </div>

                    <!-- 2. Loại hình -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">2. Loại hình</label>
                        <div class="row g-2">
                            <div class="col-auto">
                                <input type="radio" class="btn-check" name="LoaiDeTai" id="loai1" value="1"
                                       @(Model.LoaiDeTai == 1 ? "checked" : "") />
                                <label class="btn btn-outline-secondary btn-sm" for="loai1">Viện / Trường</label>
                            </div>
                            <div class="col-auto">
                                <input type="radio" class="btn-check" name="LoaiDeTai" id="loai2" value="2"
                                       @(Model.LoaiDeTai == 2 ? "checked" : "") />
                                <label class="btn btn-outline-secondary btn-sm" for="loai2">Doanh nghiệp KH&CN</label>
                            </div>
                            <div class="col-auto">
                                <input type="radio" class="btn-check" name="LoaiDeTai" id="loai3" value="3"
                                       @(Model.LoaiDeTai == 3 ? "checked" : "") />
                                <label class="btn btn-outline-secondary btn-sm" for="loai3">Cá nhân</label>
                            </div>
                            <div class="col-auto">
                                <input type="radio" class="btn-check" name="LoaiDeTai" id="loai4" value="4"
                                       @(Model.LoaiDeTai == 4 ? "checked" : "") />
                                <label class="btn btn-outline-secondary btn-sm" for="loai4">Khác</label>
                            </div>
                        </div>
                        <div class="mt-2" id="loaiDeTaiKhacBox" style="display:none;">
                            <input asp-for="LoaiDeTaiKhac" class="form-control form-control-sm" placeholder="Nhập loại hình khác..." />
                        </div>
                    </div>

                    <!-- 3. Thông tin liên hệ (auto-filled from NhaCungUng) -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">3. Thông tin liên hệ
                            <span class="badge bg-info text-dark ms-1"><i class="fas fa-info-circle"></i> Tự động điền từ NCC</span>
                        </label>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-12">
                            <label class="form-label">Địa chỉ</label>
                            <input id="ncuDiaChi" class="form-control bg-light" readonly />
                        </div>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label class="form-label">Người đại diện</label>
                            <input id="ncuNguoiDaiDien" class="form-control bg-light" readonly />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Chức vụ</label>
                            <input id="ncuChucVu" class="form-control bg-light" readonly />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Điện thoại</label>
                            <input id="ncuPhone" class="form-control bg-light" readonly />
                        </div>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Email</label>
                            <input id="ncuEmail" class="form-control bg-light" readonly />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Website</label>
                            <input id="ncuWebsite" class="form-control bg-light" readonly />
                        </div>
                    </div>

                    <div class="d-flex justify-content-end mt-4">
                        <button type="button" class="btn btn-primary btn-next-tab">
                            Tiếp theo <i class="fas fa-arrow-right ms-1"></i>
                        </button>
                    </div>
                </div>

                <!-- ──────────────────────────────────────── -->
                <!-- TAB 2 — II. THÔNG TIN ĐỊNH DANH          -->
                <!-- ──────────────────────────────────────── -->
                <div class="tab-pane fade" id="tab2" role="tabpanel">
                    <h6 class="fw-bold text-primary mb-3"><i class="fas fa-id-card me-1"></i> II. Thông tin định danh</h6>

                    <!-- Tên công nghệ / quy trình -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">4. Tên công nghệ / quy trình <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <!-- Row 2: Ảnh đại diện tiêu biểu -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">5. Ảnh đại diện tiêu biểu</label>
                        <div class="row g-3 align-items-end">
                            <div class="col-md-8">
                                <input asp-for="QuyTrinhHinhAnh" class="form-control" id="txtImageUrl" />
                            </div>
                            <div class="col-md-2">
                                <label class="btn btn-outline-primary w-100" id="btnUploadImage">
                                    <i class="fas fa-upload me-1"></i> Upload
                                    <input type="file" accept="image/*" id="fileUploadImage" class="d-none" />
                                </label>
                            </div>
                            <div class="col-md-2">
                                <div id="imgPreview" class="border rounded text-center p-1" style="min-height:80px; background:#f8f9fa;">
                                    @if (!string.IsNullOrEmpty(Model.QuyTrinhHinhAnh))
                                    {
                                        <img src="@Model.QuyTrinhHinhAnh" class="img-fluid rounded" style="max-height:80px;" />
                                    }
                                    else
                                    {
                                        <small class="text-muted"><i class="fas fa-image"></i> Preview</small>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Xuất xứ (Select2) -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">6. Xuất xứ</label>
                        <select asp-for="XuatXuId" class="form-select" id="selXuatXu" asp-items="@((List<SelectListItem>)ViewBag.XuatXuList)">
                            <option value="">-- Chọn --</option>
                        </select>
                    </div>

                    <!-- 7. Tình trạng pháp lý & SHTT -->
                    <div class="border rounded p-3 mb-3 bg-light">
                        <h6 class="fw-bold text-info mb-3"><i class="fas fa-gavel me-1"></i> 7. Tình trạng pháp lý & Sở hữu trí tuệ</h6>
                        <div class="row g-3 mb-2">
                            <div class="col-md-6">
                                <label class="form-label">Bằng sáng chế số</label>
                                <input asp-for="SoBang" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Ngày cấp bằng sáng chế</label>
                                <input asp-for="NgayCapBang" type="date" class="form-control" />
                            </div>
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Giấy CN Đăng ký Quyền tác giả (phần mềm) số</label>
                            <input asp-for="ApplicationNumber" class="form-control" placeholder="Số giấy chứng nhận..." />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Giấy chứng nhận đăng ký thiết kế bố trí mạch tích hợp bán dẫn số</label>
                            <input asp-for="CoQuanChuQuan" class="form-control" placeholder="Số giấy chứng nhận..." />
                        </div>
                        <div>
                            <label class="form-label">Bí mật công nghệ <small class="text-muted">(Sẵn sàng ký cam kết bảo mật NDA trong trường hợp chuyển giao độc quyền)</small></label>
                            <input asp-for="CoQuanChuTri" class="form-control" />
                        </div>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <button type="button" class="btn btn-outline-secondary btn-prev-tab">
                            <i class="fas fa-arrow-left me-1"></i> Quay lại
                        </button>
                        <button type="button" class="btn btn-primary btn-next-tab">
                            Tiếp theo <i class="fas fa-arrow-right ms-1"></i>
                        </button>
                    </div>
                </div>

                <!-- ──────────────────────────────────────── -->
                <!-- TAB 3 — III. MÔ TẢ CHI TIẾT              -->
                <!-- ──────────────────────────────────────── -->
                <div class="tab-pane fade" id="tab3" role="tabpanel">
                    <h6 class="fw-bold text-primary mb-3"><i class="fas fa-file-lines me-1"></i> III. Mô tả chi tiết giải pháp</h6>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">6. Bối cảnh & Vấn đề giải quyết</label>
                        <textarea asp-for="MoTaNgan" id="editorBoiCanh" class="form-control ck-editor-field" rows="20"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">7. Nguyên lý vận hành & Sơ đồ quy trình</label>
                        <textarea asp-for="MoTa" id="editorNguyenLy" class="form-control ck-editor-field" rows="20"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">8. Thông số kỹ thuật chủ yếu</label>
                        <textarea asp-for="ThongSo" id="editorThongSo" class="form-control ck-editor-field" rows="20"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">9. Ưu điểm nổi bật</label>
                        <textarea asp-for="UuDiem" id="editorUuDiem" class="form-control ck-editor-field" rows="20"></textarea>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <button type="button" class="btn btn-outline-secondary btn-prev-tab">
                            <i class="fas fa-arrow-left me-1"></i> Quay lại
                        </button>
                        <button type="button" class="btn btn-primary btn-next-tab">
                            Tiếp theo <i class="fas fa-arrow-right ms-1"></i>
                        </button>
                    </div>
                </div>

                <!-- ──────────────────────────────────────── -->
                <!-- TAB 4 — IV. ƯU ĐIỂM & TRL               -->
                <!-- ──────────────────────────────────────── -->
                <div class="tab-pane fade" id="tab4" role="tabpanel">
                    <h6 class="fw-bold text-primary mb-3"><i class="fas fa-star me-1"></i> IV. Ưu điểm & Đánh giá mức độ phát triển</h6>


                    <!-- TRL Table -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">10. Mức độ sẵn sàng công nghệ TRL <span class="text-danger">*</span></label>
                        <span asp-validation-for="Rating" class="text-danger small d-block mb-2"></span>
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover align-middle mb-0">
                                <thead class="table-primary">
                                    <tr>
                                        <th style="width:50px" class="text-center">Chọn</th>
                                        <th style="width:80px">Cấp độ</th>
                                        <th>Mô tả</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        var trlDescriptions = new Dictionary<int, string> {
                                            {1, "Nghiên cứu cơ bản và các nguyên tắc cơ bản của công nghệ được quan sát."},
                                            {2, "Khái niệm công nghệ và/hoặc ứng dụng được hình thành."},
                                            {3, "Thử nghiệm khái niệm và đánh giá phân tích ban đầu."},
                                            {4, "Công nghệ được chứng minh trong phòng thí nghiệm."},
                                            {5, "Công nghệ được chứng minh trong môi trường mô phỏng."},
                                            {6, "Công nghệ được chứng minh trong môi trường thực tế."},
                                            {7, "Nguyên mẫu hệ thống được trình diễn trong môi trường hoạt động."},
                                            {8, "Hệ thống hoàn chỉnh và được thử nghiệm."},
                                            {9, "Ứng dụng thực tế – thị trường."}
                                        };
                                    }
                                    @for (int i = 1; i <= 9; i++)
                                    {
                                        var isChecked = (Model.Rating ?? 9) == i;
                                        <tr class="@(isChecked ? "table-success" : "")" style="cursor:pointer"
                                            onclick="document.getElementById('trl@(i)').checked=true; $(this).closest('tbody').find('tr').removeClass('table-success'); $(this).addClass('table-success');">
                                            <td class="text-center">
                                                <input type="radio" class="form-check-input" name="Rating" id="trl@(i)"
                                                       value="@i" @(isChecked ? "checked" : "") />
                                            </td>
                                            <td class="fw-bold text-primary">TRL @i</td>
                                            <td>@trlDescriptions[i]</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <button type="button" class="btn btn-outline-secondary btn-prev-tab">
                            <i class="fas fa-arrow-left me-1"></i> Quay lại
                        </button>
                        <button type="button" class="btn btn-primary btn-next-tab">
                            Tiếp theo <i class="fas fa-arrow-right ms-1"></i>
                        </button>
                    </div>
                </div>

                <!-- ──────────────────────────────────────── -->
                <!-- TAB 5 — V. ỨNG DỤNG & HIỆU QUẢ          -->
                <!-- ──────────────────────────────────────── -->
                <div class="tab-pane fade" id="tab5" role="tabpanel">
                    <h6 class="fw-bold text-primary mb-3"><i class="fas fa-chart-line me-1"></i> V. Khả năng ứng dụng & Hiệu quả kinh tế</h6>

                    <!-- 11. Lĩnh vực ứng dụng — checkboxes -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">11. Lĩnh vực ứng dụng</label>
                        <input type="hidden" asp-for="CategoryId" id="hdnCategoryId" />
                        <div class="row g-2">
                            @foreach (var item in linhVucItems.Where(x => !string.IsNullOrEmpty(x.Value)))
                            {
                                var currentCats = Model.CategoryId?.Split(new[]{',',';'}, StringSplitOptions.RemoveEmptyEntries) ?? Array.Empty<string>();
                                var chk = currentCats.Contains(item.Value) ? "checked" : "";
                                <div class="col-md-4 col-lg-3">
                                    <div class="form-check">
                                        <input class="form-check-input chk-linhvuc" type="checkbox"
                                               value="@item.Value" id="cat_@item.Value" @chk />
                                        <label class="form-check-label" for="cat_@item.Value">@item.Text</label>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">12. Đối tượng khách hàng mục tiêu</label>
                        <textarea asp-for="TargetCustomer" id="editorKhachHang" class="form-control ck-editor-field-tab5" rows="20"></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">13. Hiệu quả kinh tế - xã hội</label>
                        <textarea asp-for="CooperationGoal" id="editorHieuQua" class="form-control ck-editor-field-tab5" rows="20"></textarea>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <button type="button" class="btn btn-outline-secondary btn-prev-tab">
                            <i class="fas fa-arrow-left me-1"></i> Quay lại
                        </button>
                        <button type="button" class="btn btn-primary btn-next-tab">
                            Tiếp theo <i class="fas fa-arrow-right ms-1"></i>
                        </button>
                    </div>
                </div>

                <!-- ──────────────────────────────────────── -->
                <!-- TAB 6 — VI. CHUYỂN GIAO & GIÁ            -->
                <!-- ──────────────────────────────────────── -->
                <div class="tab-pane fade" id="tab6" role="tabpanel">
                    <h6 class="fw-bold text-primary mb-3"><i class="fas fa-money-bill-wave me-1"></i> VI. Phương thức chuyển giao & Giá</h6>

                    <!-- 13. Hình thức chuyển giao — checkboxes -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">13. Hình thức chuyển giao</label>
                        <input type="hidden" asp-for="TransferMethod" id="hdnTransferMethod" />
                        @{
                            var transferOptions = new[] {
                                "Chuyển nhượng quyền sở hữu",
                                "Chuyển giao quyền sử dụng (Li-xăng)",
                                "Góp vốn bằng công nghệ",
                                "Chìa khóa trao tay",
                                "Hợp tác sản xuất & đại lý phân phối",
                                "Khác"
                            };
                            var selectedTransfer = Model.TransferMethod?.Split(',', StringSplitOptions.RemoveEmptyEntries) ?? Array.Empty<string>();
                        }
                        <div class="row g-2">
                            @for (int i = 0; i < transferOptions.Length; i++)
                            {
                                var opt = transferOptions[i];
                                var chk = selectedTransfer.Contains(opt) ? "checked" : "";
                                <div class="col-md-6">
                                    <div class="form-check">
                                        <input class="form-check-input chk-transfer" type="checkbox"
                                               value="@opt" id="transfer_@i" @chk />
                                        <label class="form-check-label" for="transfer_@i">@opt</label>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="mt-2" id="transferMethodKhacBox" style="display:none;">
                            <input asp-for="TransferMethodKhac" class="form-control form-control-sm" placeholder="Nhập hình thức chuyển giao khác..." />
                        </div>
                    </div>

                    <!-- 14. Giá bán dự kiến — CKEditor -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">14. Giá bán dự kiến</label>
                        <textarea asp-for="GiaBanDuKien" id="editorGiaBan" class="form-control ck-editor-field-tab6" rows="20"></textarea>
                    </div>

                    <!-- 15. Các chi phí phát sinh khác -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">15. Các chi phí phát sinh khác (Chi phí đào tạo, hướng dẫn kỹ thuật, bảo trì, bảo hành, vận chuyển, lắp đặt,…)</label>
                        <textarea asp-for="ChiPhiPhatSinh" id="editorChiPhi" class="form-control ck-editor-field-tab6" rows="20"></textarea>
                    </div>

                    <!-- 16. Chế độ bảo hành & Hỗ trợ kỹ thuật -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">16. Chế độ bảo hành & Hỗ trợ kỹ thuật</label>
                        <small class="text-muted d-block mb-2">(Đào tạo nhân sự, cung cấp linh kiện thay thế, bảo trì định kỳ...)</small>
                        <textarea asp-for="BaoHanhHoTro" id="editorBaoHanh" class="form-control ck-editor-field-tab6" rows="20"></textarea>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <button type="button" class="btn btn-outline-secondary btn-prev-tab">
                            <i class="fas fa-arrow-left me-1"></i> Quay lại
                        </button>
                        <button type="button" class="btn btn-primary btn-next-tab">
                            Tiếp theo <i class="fas fa-arrow-right ms-1"></i>
                        </button>
                    </div>
                </div>

                <!-- ──────────────────────────────────────── -->
                <!-- TAB 7 — VII. CHỨNG NHẬN & TÀI LIỆU SỐ      -->
                <!-- ──────────────────────────────────────── -->
                <div class="tab-pane fade" id="tab7" role="tabpanel">
                    <h6 class="fw-bold text-primary mb-3"><i class="fas fa-certificate me-1"></i> VII. Chứng nhận & Tài liệu số</h6>

                    <!-- 17. Chứng nhận chất lượng -->
                    <div class="mb-4">
                        <label class="form-label fw-semibold">17. Chứng nhận chất lượng</label>
                        <div class="row g-2">
                            <div class="col-md-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="chkISO" name="ChungNhanISO" value="true" @(Model.ChungNhanISO ? "checked" : "") />
                                    <label class="form-check-label" for="chkISO">ISO / CE / HACCP</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="chkQuatest" name="ChungNhanQuatest" value="true" @(Model.ChungNhanQuatest ? "checked" : "") />
                                    <label class="form-check-label" for="chkQuatest">Phiếu kết quả kiểm nghiệm (Quatest)</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="chkCNKhac" name="ChungNhanKhac" value="true" @(Model.ChungNhanKhac ? "checked" : "") />
                                    <label class="form-check-label" for="chkCNKhac">Khác</label>
                                </div>
                            </div>
                        </div>
                        <div id="cnKhacTextBox" class="mt-2" style="display:none;">
                            <input type="text" class="form-control" id="ChungNhanKhacText" name="ChungNhanKhacText" value="@Model.ChungNhanKhacText" placeholder="Nhập chứng nhận khác..." />
                        </div>
                    </div>

                    <!-- 18. Dữ liệu đa phương tiện -->
                    <div class="mb-4">
                        <label class="form-label fw-semibold">18. Dữ liệu đa phương tiện</label>

                        <!-- 18a. Video clip vận hành -->
                        <div class="border rounded p-3 bg-light mb-3">
                            <h6 class="fw-semibold mb-2"><i class="fas fa-video me-1 text-primary"></i> Video clip vận hành</h6>
                            <div class="mb-2">
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input media-toggle" type="radio" name="videoSource" id="videoUpload" value="upload" />
                                    <label class="form-check-label" for="videoUpload">Upload file</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input media-toggle" type="radio" name="videoSource" id="videoYoutube" value="youtube" checked />
                                    <label class="form-check-label" for="videoYoutube">YouTube URL</label>
                                </div>
                            </div>
                            <div id="videoUrlBox">
                                <input asp-for="URL" class="form-control" placeholder="https://www.youtube.com/watch?v=..." />
                            </div>
                            <div id="videoUploadBox" style="display:none">
                                <input type="file" class="form-control" id="fileVideo" accept="video/*" />
                                <small class="text-muted">Sau khi upload, URL sẽ được tự động lưu.</small>
                            </div>
                            <input type="hidden" asp-for="IsYoutube" />
                        </div>

                        <!-- 18b. Brochure / Catalogue sản phẩm -->
                        <div class="border rounded p-3 bg-light">
                            <h6 class="fw-semibold mb-2"><i class="fas fa-file-pdf me-1 text-danger"></i> Brochure / Catalogue sản phẩm</h6>
                            <div class="mb-2">
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input media-toggle" type="radio" name="brochureSource" id="brochureUpload" value="upload" checked />
                                    <label class="form-check-label" for="brochureUpload">Upload file</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input media-toggle" type="radio" name="brochureSource" id="brochureUrl" value="url" />
                                    <label class="form-check-label" for="brochureUrl">Nhập URL</label>
                                </div>
                            </div>
                            <div id="brochureUploadBox">
                                <input type="file" class="form-control" id="fileBrochure" accept=".pdf,.doc,.docx,.ppt,.pptx" />
                                <small class="text-muted">Sau khi upload, URL sẽ được tự động lưu.</small>
                            </div>
                            <div id="brochureUrlBox" style="display:none">
                                <input asp-for="BrochureUrl" class="form-control" placeholder="https://..." />
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <button type="button" class="btn btn-outline-secondary btn-prev-tab">
                            <i class="fas fa-arrow-left me-1"></i> Quay lại
                        </button>
                    </div>
                </div>

            </div><!-- /tab-content -->

        </div><!-- /card-body -->

        <div class="card-footer d-flex justify-content-between align-items-center">
            <a href="javascript:history.back()" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i> Quay lại danh sách
            </a>
            <button type="submit" class="btn btn-primary btn-lg">
                <i class="fas fa-save me-1"></i> Cập nhật sản phẩm
            </button>
        </div>
    </form>
</div>

@section Scripts {
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script src="https://cdn.ckeditor.com/ckeditor5/41.4.2/super-build/ckeditor.js"></script>
<script>
$(function(){

    // Toggle Khác text input for Chứng nhận chất lượng
    $('#chkCNKhac').on('change', function(){
        $('#cnKhacTextBox').toggle(this.checked);
        if (!this.checked) $('#ChungNhanKhacText').val('');
    });
    if ($('#chkCNKhac').is(':checked')) $('#cnKhacTextBox').show();

    // Select2 searchable dropdown for NhaCungUng
    $('#NCUId').select2({
        theme: 'bootstrap-5',
        placeholder: '-- Tìm và chọn nhà cung ứng --',
        allowClear: true,
        width: '100%'
    }).on('change', function(){ loadNhaCungUng($(this).val()); });

    // Select2 for Xuất xứ
    $('#selXuatXu').select2({ theme: 'bootstrap-5', placeholder: '-- Tìm xuất xứ --', allowClear: true, width: '100%' });

    // Image upload for Ảnh đại diện
    $('#fileUploadImage').on('change', function(){
        var file = this.files[0];
        if (!file) return;
        var fd = new FormData();
        fd.append('upload', file);
        $.ajax({
            url: '/cms/Upload/Upload',
            type: 'POST',
            data: fd,
            processData: false,
            contentType: false,
            success: function(res) {
                var url = res.url || res.Url;
                $('#txtImageUrl').val(url);
                $('#imgPreview').html('<img src="' + url + '" class="img-fluid rounded" style="max-height:80px;" />');
            },
            error: function(){ alert('Upload thất bại!'); }
        });
    });

    // ═══════════════════════════════════════
    // Tab navigation — Next / Previous
    // ═══════════════════════════════════════
    var $tabs = $('#cntbTabs button[data-bs-toggle="tab"]');

    function getActiveIndex() {
        return $tabs.index($tabs.filter('.active'));
    }

    $(document).on('click', '.btn-next-tab', function(){
        var idx = getActiveIndex();
        if (idx < $tabs.length - 1) {
            new bootstrap.Tab($tabs[idx + 1]).show();
        }
    });

    $(document).on('click', '.btn-prev-tab', function(){
        var idx = getActiveIndex();
        if (idx > 0) {
            new bootstrap.Tab($tabs[idx - 1]).show();
        }
    });

    // ═══════════════════════════════════════
    // CKEditor 5 — lazy init for all rich text fields in Tab 3
    // ═══════════════════════════════════════
    var ckInstances = {};
    var ckRemovePlugins = [
        'ExportPdf','ExportWord','AIAssistant','CKBox','CKFinder','EasyImage',
        'MultiLevelList','RealTimeCollaborativeComments','RealTimeCollaborativeTrackChanges',
        'RealTimeCollaborativeRevisionHistory','PresenceList','Comments','TrackChanges',
        'TrackChangesData','RevisionHistory','Pagination','WProofreader','MathType',
        'SlashCommand','Template','DocumentOutline','FormatPainter','TableOfContents',
        'PasteFromOfficeEnhanced','CaseChange'
    ];
    var ckToolbar = ['heading', '|', 'bold', 'italic', 'fontColor', 'fontBackgroundColor', '|',
                     'link', 'bulletedList', 'numberedList', '|',
                     'imageUpload', 'blockQuote', 'insertTable', 'undo', 'redo'];

    $('button[data-bs-target="#tab3"]').on('shown.bs.tab', function(){
        document.querySelectorAll('.ck-editor-field').forEach(function(el){
            if (ckInstances[el.id]) return;
            CKEDITOR.ClassicEditor.create(el, {
                simpleUpload: {
                    uploadUrl: '/cms/Upload/Upload',
                    withCredentials: true
                },
                toolbar: ckToolbar,
                removePlugins: ckRemovePlugins
            }).then(function(editor){
                ckInstances[el.id] = editor;
            }).catch(function(err){ console.error(err); });
        });
    });

    // CKEditor 5 — lazy init for Tab 5 fields
    $('button[data-bs-target="#tab5"]').on('shown.bs.tab', function(){
        document.querySelectorAll('.ck-editor-field-tab5').forEach(function(el){
            if (ckInstances[el.id]) return;
            CKEDITOR.ClassicEditor.create(el, {
                simpleUpload: { uploadUrl: '/cms/Upload/Upload', withCredentials: true },
                toolbar: ckToolbar,
                removePlugins: ckRemovePlugins
            }).then(function(editor){
                ckInstances[el.id] = editor;
            }).catch(function(err){ console.error(err); });
        });
    });

    // Sync CKEditor data back to textareas before submit
    $('#frmCNTB').on('submit', function(){
        Object.keys(ckInstances).forEach(function(id){
            document.getElementById(id).value = ckInstances[id].getData();
        });
    });

    // CKEditor 5 — lazy init for Tab 6 fields
    $('button[data-bs-target="#tab6"]').on('shown.bs.tab', function(){
        document.querySelectorAll('.ck-editor-field-tab6').forEach(function(el){
            if (ckInstances[el.id]) return;
            CKEDITOR.ClassicEditor.create(el, {
                simpleUpload: { uploadUrl: '/cms/Upload/Upload', withCredentials: true },
                toolbar: ckToolbar,
                removePlugins: ckRemovePlugins
            }).then(function(editor){
                ckInstances[el.id] = editor;
            }).catch(function(err){ console.error(err); });
        });
    });

    // ═══════════════════════════════════════
    // Category checkbox → hidden field sync
    // ═══════════════════════════════════════
    function syncCategoryCheckboxes() {
        var vals = [];
        $('.chk-linhvuc:checked').each(function(){ vals.push($(this).val()); });
        $('#hdnCategoryId').val(vals.join(';'));
    }
    $(document).on('change', '.chk-linhvuc', syncCategoryCheckboxes);
    syncCategoryCheckboxes();

    // ═══════════════════════════════════════
    // Transfer method checkbox → hidden field sync
    // ═══════════════════════════════════════
    function syncTransferCheckboxes() {
        var vals = [];
        $('.chk-transfer:checked').each(function(){ vals.push($(this).val()); });
        $('#hdnTransferMethod').val(vals.join(','));
    }
    $(document).on('change', '.chk-transfer', syncTransferCheckboxes);
    syncTransferCheckboxes();

    // ═══════════════════════════════════════
    // Media upload / URL toggle (Tab 7, field 18)
    // ═══════════════════════════════════════
    $('input[name="videoSource"]').on('change', function(){
        if ($(this).val() === 'upload') {
            $('#videoUploadBox').show();
            $('#videoUrlBox').hide();
            $('#IsYoutube').val('false');
        } else {
            $('#videoUploadBox').hide();
            $('#videoUrlBox').show();
            $('#IsYoutube').val('true');
        }
    });

    $('input[name="brochureSource"]').on('change', function(){
        if ($(this).val() === 'upload') {
            $('#brochureUploadBox').show();
            $('#brochureUrlBox').hide();
        } else {
            $('#brochureUploadBox').hide();
            $('#brochureUrlBox').show();
        }
    });

    function uploadMediaFile(fileInput, targetField) {
        var file = fileInput.files[0];
        if (!file) return;
        var fd = new FormData();
        fd.append('upload', file);
        $.ajax({
            url: '/cms/Upload/Upload',
            type: 'POST',
            data: fd,
            processData: false,
            contentType: false,
            success: function(res) {
                if (res && res.url) {
                    $(targetField).val(res.url);
                    alert('Upload thành công!');
                }
            },
            error: function() { alert('Upload thất bại. Vui lòng thử lại.'); }
        });
    }

    $('#fileVideo').on('change', function(){ uploadMediaFile(this, '#URL'); });
    $('#fileBrochure').on('change', function(){ uploadMediaFile(this, '#Keywords'); });

    // Image upload for QuyTrinhHinhAnh → resize 1200px, keep original name
    $('#fileUploadImage').on('change', function(){
        var file = this.files[0];
        if (!file) return;
        var fd = new FormData();
        fd.append('upload', file);
        $.ajax({
            url: '/cms/Upload/UploadImage',
            type: 'POST',
            data: fd,
            processData: false,
            contentType: false,
            success: function(res) {
                if (res && res.url) {
                    $('#txtImageUrl').val(res.url);
                    $('#imgPreview').html('<img src="' + res.url + '" class="img-fluid rounded" style="max-height:80px;" />');
                } else if (res && res.error) {
                    alert(res.error.message);
                }
            },
            error: function() { alert('Upload thất bại. Vui lòng thử lại.'); }
        });
    });

    // ═══════════════════════════════════════
    // Auto-fill NhaCungUng contact info
    // ═══════════════════════════════════════
    function loadNhaCungUng(id) {
        if (!id) {
            $('#ncuDiaChi, #ncuNguoiDaiDien, #ncuChucVu, #ncuPhone, #ncuEmail, #ncuWebsite').val('');
            return;
        }
        $.getJSON('/cms/SanPhamCNTB/GetNhaCungUng/' + id, function(d){
            $('#ncuDiaChi').val(d.diaChi || '');
            $('#ncuNguoiDaiDien').val(d.nguoiDaiDien || '');
            $('#ncuChucVu').val(d.chucVu || '');
            $('#ncuPhone').val(d.phone || '');
            $('#ncuEmail').val(d.email || '');
            $('#ncuWebsite').val(d.website || '');
        });
    }

    // Load on page init for Edit
    var initNcu = $('#NCUId').val();
    if (initNcu) loadNhaCungUng(initNcu);

    // ═══════════════════════════════════════
    // Toggle "Khác" text inputs
    // ═══════════════════════════════════════
    $('input[name="LoaiDeTai"]').on('change', function(){
        if ($(this).val() == '4') {
            $('#loaiDeTaiKhacBox').slideDown(200);
        } else {
            $('#loaiDeTaiKhacBox').slideUp(200);
            $('#LoaiDeTaiKhac').val('');
        }
    });
    if ($('input[name="LoaiDeTai"]:checked').val() == '4') {
        $('#loaiDeTaiKhacBox').show();
    }

    $(document).on('change', '.chk-transfer', function(){
        var khacChecked = false;
        $('.chk-transfer').each(function(){
            if ($(this).val().indexOf('Kh') === 0 && $(this).is(':checked')) khacChecked = true;
        });
        if (khacChecked) {
            $('#transferMethodKhacBox').slideDown(200);
        } else {
            $('#transferMethodKhacBox').slideUp(200);
            $('#TransferMethodKhac').val('');
        }
    });
    var initKhacTransfer = false;
    $('.chk-transfer').each(function(){
        if ($(this).val().indexOf('Kh') === 0 && $(this).is(':checked')) initKhacTransfer = true;
    });
    if (initKhacTransfer) $('#transferMethodKhacBox').show();

});
</script>
}
