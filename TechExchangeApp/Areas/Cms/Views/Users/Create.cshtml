@model TechExchangeApp.Areas.Cms.Controllers.CmsUserCreateVm
@{
    ViewData["Title"] = "Thêm mới người dùng";
    var roles = (List<TechExchangeApp.Entities.CmsRole>)ViewBag.Roles;
    var accountTypes = (List<TechExchangeApp.Entities.VAccountType>)ViewBag.AccountTypes;
    var sites = (List<TechExchangeApp.Entities.RootSite>)ViewBag.Sites;
    var stores = (IEnumerable<dynamic>)ViewBag.Stores;
}

<div class="card card-outline card-primary">
    <div class="card-header">
        <ul class="nav nav-tabs card-header-tabs">
            <li class="nav-item">
                <a class="nav-link" asp-action="Index"><i class="fas fa-list"></i> Quản lý</a>
            </li>
            <li class="nav-item">
                <a class="nav-link active" href="#"><i class="fas fa-plus"></i> Thêm mới</a>
            </li>
        </ul>
    </div>
    <div class="card-body">
        <h4 class="mb-3"><strong>THÊM MỚI NGƯỜI DÙNG</strong></h4>
        <p class="text-danger small">* Trường yêu cầu nhập dữ liệu</p>

        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

            <div class="row mb-3">
                <label class="col-md-3 col-form-label">Tên đăng nhập: <span class="text-danger">*</span></label>
                <div class="col-md-6">
                    <input asp-for="UserName" class="form-control" />
                    <span asp-validation-for="UserName" class="text-danger small"></span>
                </div>
            </div>

            <div class="row mb-3">
                <label class="col-md-3 col-form-label">Mật khẩu: <span class="text-danger">*</span></label>
                <div class="col-md-6">
                    <input asp-for="Password" type="password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
            </div>

            <div class="row mb-3">
                <label class="col-md-3 col-form-label">Xác nhận mật khẩu: <span class="text-danger">*</span></label>
                <div class="col-md-6">
                    <input asp-for="ConfirmPassword" type="password" class="form-control" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>
            </div>

            <div class="row mb-3">
                <label class="col-md-3 col-form-label">Họ và Tên: <span class="text-danger">*</span></label>
                <div class="col-md-6">
                    <input asp-for="FullName" class="form-control" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>
            </div>

            <div class="row mb-3">
                <label class="col-md-3 col-form-label">Email: <span class="text-danger">*</span></label>
                <div class="col-md-6">
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
            </div>

            <div class="row mb-3">
                <label class="col-md-3 col-form-label">Vai trò:</label>
                <div class="col-md-6">
                    @foreach (var role in roles)
                    {
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="SelectedRoleIds"
                                   value="@role.RoleId" id="role_@role.RoleId"
                                   @(Model.SelectedRoleIds?.Contains(role.RoleId) == true ? "checked" : "") />
                            <label class="form-check-label" for="role_@role.RoleId">@role.Title</label>
                        </div>
                    }
                </div>
            </div>

            <div class="row mb-3">
                <label class="col-md-3 col-form-label">Loại người dùng: <span class="text-danger">*</span></label>
                <div class="col-md-6">
                    <select asp-for="SelectedAccountTypeId" class="form-control">
                        <option value="">-- Chọn --</option>
                        @foreach (var at in accountTypes)
                        {
                            <option value="@at.Id">@at.Name</option>
                        }
                    </select>
                </div>
            </div>

            <div class="row mb-3">
                <label class="col-md-3 col-form-label">Sàn:</label>
                <div class="col-md-6">
                    <select asp-for="SelectedSiteId" class="form-control">
                        @foreach (var s in sites)
                        {
                            <option value="@s.SiteId">@s.SiteName</option>
                        }
                    </select>
                </div>
            </div>

            <div class="row mb-3">
                <label class="col-md-3 col-form-label">Kích hoạt:</label>
                <div class="col-md-6">
                    <div class="form-check mt-2">
                        <input asp-for="IsActivated" class="form-check-input" />
                        <label asp-for="IsActivated" class="form-check-label">Kích hoạt tài khoản</label>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 offset-md-3">
                    <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Lưu</button>
                    <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-times"></i> Hủy</a>
                </div>
            </div>
        </form>
    </div>
</div>
