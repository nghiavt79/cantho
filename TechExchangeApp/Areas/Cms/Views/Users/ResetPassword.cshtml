@model TechExchangeApp.Areas.Cms.Controllers.CmsResetPasswordVm
@{
    ViewData["Title"] = "Cập lại mật khẩu: " + Model.UserName;
}

<div class="card card-outline card-warning">
    <div class="card-header">
        <ul class="nav nav-tabs card-header-tabs">
            <li class="nav-item">
                <a class="nav-link" asp-action="Index"><i class="fas fa-list"></i> Quản lý</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-action="Edit" asp-route-id="@Model.UserId"><i class="fas fa-edit"></i> Sửa</a>
            </li>
            <li class="nav-item">
                <a class="nav-link active" href="#"><i class="fas fa-key"></i> Cập lại mật khẩu</a>
            </li>
        </ul>
    </div>
    <div class="card-body">
        <h4 class="mb-3"><strong>CẬP LẠI MẬT KHẨU: @Model.UserName</strong></h4>
        <p class="text-danger small">* Trường yêu cầu nhập dữ liệu</p>

        <form asp-action="ResetPassword" method="post">
            <input type="hidden" asp-for="UserId" />
            <input type="hidden" asp-for="UserName" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

            <div class="row mb-3">
                <label class="col-md-3 col-form-label">Người dùng:</label>
                <div class="col-md-6">
                    <input class="form-control" value="@Model.UserName" readonly disabled />
                </div>
            </div>

            <div class="row mb-3">
                <label class="col-md-3 col-form-label">Mật khẩu mới: <span class="text-danger">*</span></label>
                <div class="col-md-6">
                    <input asp-for="NewPassword" type="password" class="form-control" />
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>
            </div>

            <div class="row mb-3">
                <label class="col-md-3 col-form-label">Xác nhận mật khẩu: <span class="text-danger">*</span></label>
                <div class="col-md-6">
                    <input asp-for="ConfirmPassword" type="password" class="form-control" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 offset-md-3">
                    <button type="submit" class="btn btn-warning"><i class="fas fa-key"></i> Cập nhật mật khẩu</button>
                    <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-times"></i> Hủy</a>
                </div>
            </div>
        </form>
    </div>
</div>
