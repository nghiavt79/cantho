@model List<TechExchangeApp.Areas.Cms.Controllers.NhaTuVanListItem>
@{
    ViewData["Title"] = "Quản lý Nhà tư vấn";
}

<!-- ─── Search Card ─── -->
<div class="card card-outline card-primary shadow-sm mb-3">
    <div class="card-header" id="searchCardHeader" style="cursor:pointer" title="Nhấn đúp để thu gọn/mở rộng">
        <h3 class="card-title"><i class="fas fa-search me-1"></i> Tìm kiếm Nhà tư vấn</h3>
        <div class="card-tools">
            <button type="button" class="btn btn-tool" data-lte-toggle="card-collapse"><i class="fas fa-minus"></i></button>
        </div>
    </div>
    <div class="card-body">
        <form id="searchForm">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label fw-semibold small mb-1">Từ khóa</label>
                    <input type="text" name="keyword" value="@ViewBag.Keyword" class="form-control form-control-sm" placeholder="Tên nhà tư vấn..." />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold small mb-1">Trạng thái</label>
                    <select name="statusId" class="form-select form-select-sm">
                        <option value="">-- Tất cả --</option>
                        @{
                            var sts = ViewBag.StatusId?.ToString() ?? "";
                            var statuses = (IEnumerable<dynamic>?)ViewBag.Statuses;
                        }
                        @if (statuses != null)
                        {
                            foreach (var s in statuses)
                            {
                                <option value="@s.StatusId" selected="@(sts == s.StatusId.ToString())">@s.Title</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold small mb-1">Kích hoạt</label>
                    @{
                        var actVal = ViewBag.IsActivated;
                    }
                    <select name="isActivated" class="form-select form-select-sm">
                        <option value="">-- Tất cả --</option>
                        <option value="true" selected="@(actVal != null && (bool)actVal == true)">Đã kích hoạt</option>
                        <option value="false" selected="@(actVal != null && (bool)actVal == false)">Chưa kích hoạt</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold small mb-1">Lĩnh vực</label>
                    <select name="linhVuc" id="filterLinhVuc" class="form-select form-select-sm">
                        <option value="">-- Tất cả --</option>
                        @{
                            var selLv = ViewBag.LinhVuc?.ToString() ?? "";
                            var lvList = (IEnumerable<dynamic>?)ViewBag.LinhVucs;
                        }
                        @if (lvList != null)
                        {
                            foreach (var lv in lvList)
                            {
                                <option value="@lv.Id" selected="@(selLv == lv.Id.ToString())">@lv.Title</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold small mb-1">Người tạo</label>
                    <input type="text" name="createdBy" value="@ViewBag.CreatedBy" class="form-control form-control-sm" placeholder="Tên người tạo..." />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold small mb-1">Sàn GDCN</label>
                    @{
                        var configSiteId = (int)(ViewBag.CurrentSiteId ?? 0);
                    }
                    <select name="siteId" id="filterSiteId" class="form-select form-select-sm"
                            @(configSiteId > 1 ? "disabled" : "")>
                        <option value="">-- Tất cả --</option>
                        @{
                            var selSite = ViewBag.SiteId?.ToString() ?? "";
                            var sites = (IEnumerable<TechExchangeApp.Entities.RootSite>?)ViewBag.Sites;
                        }
                        @if (sites != null)
                        {
                            foreach (var s in sites)
                            {
                                <option value="@s.SiteId" selected="@(selSite == s.SiteId.ToString())">@s.SiteName</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold small mb-1">Dịch vụ tư vấn</label>
                    @{
                        var selDv = ViewBag.DichVu?.ToString() ?? "";
                        var dvList = (IEnumerable<TechExchangeApp.Areas.Cms.Models.LookupDto>?)ViewBag.DichVuList;
                    }
                    <select name="dichVu" id="filterDichVu" class="form-select form-select-sm">
                        <option value="">-- Tất cả --</option>
                        @if (dvList != null)
                        {
                            foreach (var dv in dvList)
                            {
                                <option value=";@dv.Id;" selected="@(selDv == ";" + dv.Id + ";")">@dv.Title</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold small mb-1">Ngày tạo từ</label>
                    <input type="date" name="createdFrom" value="@ViewBag.CreatedFrom" class="form-control form-control-sm" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold small mb-1">Ngày tạo đến</label>
                    <input type="date" name="createdTo" value="@ViewBag.CreatedTo" class="form-control form-control-sm" />
                </div>
            </div>
        </form>
    </div>
    <div class="card-footer bg-transparent">
        <button type="button" class="btn btn-primary btn-sm me-2" id="btnSearch">
            <i class="fas fa-search me-1"></i> Tìm kiếm
        </button>
        <button type="button" class="btn btn-outline-secondary btn-sm me-2" id="btnReset">
            <i class="fas fa-undo me-1"></i> Đặt lại
        </button>
        <button type="button" class="btn btn-outline-success btn-sm" id="btnExportExcel" title="Xuất danh sách ra Excel">
            <i class="fas fa-file-excel me-1"></i> Export Excel
        </button>
    </div>
</div>

<!-- ─── Result Card ─── -->
<div class="card card-outline card-info shadow-sm">
    <div class="card-header d-flex align-items-center flex-wrap gap-2">
        <h3 class="card-title mb-0">
            <i class="fas fa-user-tie me-1"></i> Danh sách Nhà tư vấn
            <span class="badge bg-info ms-1" id="badgeTotal">@ViewBag.TotalCount</span>
        </h3>
        <div class="ms-auto d-flex gap-2">
            <a asp-action="Create" class="btn btn-success btn-sm">
                <i class="fas fa-plus me-1"></i> Thêm nhà tư vấn
            </a>
            <button type="button" class="btn btn-outline-danger btn-sm" id="btnBulkDelete" disabled>
                <i class="fas fa-trash-alt me-1"></i> Xóa chọn
            </button>
        </div>
    </div>

    <div id="listContainer">
        @await Html.PartialAsync("_ListPartial", Model)
    </div>
</div>

<!-- ─── Change Owner Modal ─── -->
<div class="modal fade" id="configModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title"><i class="fas fa-gear me-1"></i> Quick config</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="configModalBody"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">
                    <i class="fas fa-times me-1"></i> Close
                </button>
                <button type="button" class="btn btn-warning btn-sm" id="btnSaveConfig">
                    <i class="fas fa-save me-1"></i> Save
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="changeOwnerModal" tabindex="-1" aria-labelledby="changeOwnerLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title" id="changeOwnerLabel">
                    <i class="fas fa-user-edit me-1"></i> Đổi chủ sở hữu
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-light small mb-3" id="ownerInfo"></div>

                <div class="input-group mb-3">
                    <span class="input-group-text"><i class="fas fa-search"></i></span>
                    <input type="text" id="ownerSearchKeyword" class="form-control form-control-sm"
                           placeholder="Tìm theo tên đăng nhập, họ tên, email..." />
                    <button type="button" class="btn btn-primary btn-sm" id="btnOwnerSearch">
                        <i class="fas fa-search me-1"></i> Tìm
                    </button>
                </div>

                <div id="ownerSearchResults">
                    <div class="text-center text-muted py-4">
                        <i class="fas fa-users fa-2x mb-2 d-block opacity-25"></i>
                        Nhập từ khóa và nhấn Tìm để hiển thị danh sách người dùng.
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-warning btn-sm" id="btnRemoveOwner">
                    <i class="fas fa-user-slash me-1"></i> Bỏ chủ sở hữu
                </button>
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">
                    <i class="fas fa-times me-1"></i> Đóng
                </button>
            </div>
        </div>
    </div>
</div>
<input type="hidden" id="changeOwnerId" value="" />

@section Scripts {
<script>
$(function(){
    toastr.options = { closeButton: true, progressBar: true, positionClass: 'toast-top-right', timeOut: 3000 };

    // Export Excel
    $('#btnExportExcel').on('click', function () {
        var params = $('#searchForm').serialize();
        window.location = '@Url.Action("ExportExcel", "NhaTuVanAdmin", new { area = "Cms" })?' + params;
    });

    // Select2
    $('#filterLinhVuc').select2({ theme: 'bootstrap-5', placeholder: '-- Chọn lĩnh vực --', allowClear: true, width: '100%' });
    $('#filterSiteId').select2({ theme: 'bootstrap-5', placeholder: '-- Chọn sàn --', allowClear: true, width: '100%' });
    $('#filterDichVu').select2({ theme: 'bootstrap-5', placeholder: '-- Chọn dịch vụ --', allowClear: true, width: '100%' });

    var token = $('input[name="__RequestVerificationToken"]').val() || '';
    var baseUrl = '@Url.Action("Index", "NhaTuVanAdmin", new { area = "Cms" })';
    var currentPage = 1, currentSortBy = '', currentSortDir = '';

    $('#searchCardHeader').on('dblclick', function() {
        $(this).find('[data-lte-toggle="card-collapse"]').trigger('click');
    });

    function loadList(page) {
        currentPage = page || 1;
        var params = $('#searchForm').serialize()
            + '&page=' + currentPage
            + '&sortBy=' + encodeURIComponent(currentSortBy)
            + '&sortDir=' + encodeURIComponent(currentSortDir);
        $('#listContainer').css('opacity', '0.5');
        $.ajax({
            url: baseUrl, data: params,
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
            success: function(html) {
                $('#listContainer').html(html).css('opacity', '1');
                $('#chkAll').prop('checked', false);
                $('#btnBulkDelete').prop('disabled', true);
                var cnt = $('#partialTotalCount').text();
                $('#badgeTotal').text(cnt);
            },
            error: function() {
                toastr.error('Lỗi tải dữ liệu.');
                $('#listContainer').css('opacity', '1');
            }
        });
    }

    $(document).on('click', '.sortable', function() {
        var col = $(this).data('sort');
        if (currentSortBy === col) currentSortDir = (currentSortDir === 'asc') ? 'desc' : 'asc';
        else { currentSortBy = col; currentSortDir = 'asc'; }
        loadList(1);
    });

    $('#searchForm').on('submit', function(e) { e.preventDefault(); loadList(1); });
    $('#btnSearch').on('click', function() { loadList(1); });
    $('#btnReset').on('click', function() {
        $('#searchForm')[0].reset();
        currentSortBy = ''; currentSortDir = '';
        loadList(1);
    });

    $(document).on('click', '.ajax-page', function(e) {
        e.preventDefault();
        if ($(this).closest('.page-item').hasClass('disabled') || $(this).closest('.page-item').hasClass('active')) return;
        loadList($(this).data('page'));
    });

    $(document).on('change', '#chkAll', function() { $('.chkRow:not(:disabled)').prop('checked', this.checked); toggleBulk(); });
    $(document).on('change', '.chkRow', toggleBulk);
    function toggleBulk() { $('#btnBulkDelete').prop('disabled', !$('.chkRow:checked').length); }

    $(document).on('click', '.btn-config', function(e) {
        e.preventDefault();
        var id = $(this).data('id');
        $('#configModalBody').html('<div class="text-center py-4"><i class="fas fa-spinner fa-spin fa-2x"></i></div>');
        new bootstrap.Modal(document.getElementById('configModal')).show();

        $.get('@Url.Action("QuickConfig", "NhaTuVanAdmin", new { area = "Cms" })', { id: id }, function(html) {
            $('#configModalBody').html(html);
        }).fail(function() {
            $('#configModalBody').html('<div class="alert alert-danger mb-0"><i class="fas fa-exclamation-triangle me-1"></i> Could not load quick config.</div>');
        });

        $('#btnSaveConfig').off('click').on('click', function() {
            var $btn = $(this);
            $btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-1"></i> Saving...');
            var formData = $('#quickConfigForm').serialize() + '&__RequestVerificationToken=' + encodeURIComponent(token);
            $.post('@Url.Action("QuickConfig", "NhaTuVanAdmin", new { area = "Cms" })', formData, function(r) {
                if (r.success) {
                    toastr.success(r.message);
                    bootstrap.Modal.getInstance(document.getElementById('configModal')).hide();
                    loadList(currentPage);
                } else {
                    toastr.error(r.message);
                }
            }).fail(function() {
                toastr.error('Save quick config failed.');
            }).always(function() {
                $btn.prop('disabled', false).html('<i class="fas fa-save me-1"></i> Save');
            });
        });
    });

    $(document).on('click', '.btn-del', function(e) {
        e.preventDefault();
        var id = $(this).data('id');
        Swal.fire({
            title: 'Xác nhận xóa?', text: 'Bạn chắc chắn muốn xóa nhà tư vấn #' + id + '?',
            icon: 'warning', showCancelButton: true,
            confirmButtonColor: '#d33', cancelButtonColor: '#6c757d',
            confirmButtonText: '<i class="fas fa-trash"></i> Xóa', cancelButtonText: 'Hủy'
        }).then(function(result) {
            if (result.isConfirmed) {
                $.post('@Url.Action("Delete", "NhaTuVanAdmin", new { area = "Cms" })',
                    { id: id, __RequestVerificationToken: token },
                    function(r) {
                        if (r.success) { toastr.success(r.message); loadList(currentPage); }
                        else { toastr.error(r.message); }
                    });
            }
        });
    });

    $('#btnBulkDelete').on('click', function() {
        var ids = $('.chkRow:checked').map(function() { return $(this).val(); }).get();
        if (!ids.length) return;
        Swal.fire({
            title: 'Xóa nhiều nhà tư vấn?', text: 'Bạn chắc chắn xóa ' + ids.length + ' nhà tư vấn đã chọn?',
            icon: 'warning', showCancelButton: true,
            confirmButtonColor: '#d33', cancelButtonColor: '#6c757d',
            confirmButtonText: '<i class="fas fa-trash"></i> Xóa tất cả', cancelButtonText: 'Hủy'
        }).then(function(result) {
            if (result.isConfirmed) {
                var promises = ids.map(function(id) {
                    return $.post('@Url.Action("Delete", "NhaTuVanAdmin", new { area = "Cms" })',
                        { id: id, __RequestVerificationToken: token });
                });
                $.when.apply($, promises).then(function() {
                    toastr.success('Đã xóa ' + ids.length + ' nhà tư vấn.');
                    loadList(currentPage);
                });
            }
        });
    });

    // ══════════ CHANGE OWNER ══════════
    var ownerSearchUrl = '@Url.Action("SearchUsers", "NhaTuVanAdmin", new { area = "Cms" })';
    var changeOwnerUrl = '@Url.Action("ChangeOwner", "NhaTuVanAdmin", new { area = "Cms" })';
    var ownerSearchPage = 1;

    $(document).on('click', '.btn-change-owner', function() {
        var id = $(this).data('id');
        var name = $(this).data('name');
        var owner = $(this).data('owner');
        $('#changeOwnerId').val(id);
        $('#ownerInfo').html('<i class="fas fa-user-tie me-1"></i> <strong>' + name + '</strong> (ID: ' + id + ')' +
            (owner ? ' — Chủ sở hữu hiện tại: <span class="badge bg-primary">' + owner + '</span>' : ' — <em>Chưa có chủ sở hữu</em>'));
        $('#ownerSearchKeyword').val('');
        $('#ownerSearchResults').html('<div class="text-center text-muted py-4"><i class="fas fa-users fa-2x mb-2 d-block opacity-25"></i>Nhập từ khóa và nhấn Tìm để hiển thị danh sách người dùng.</div>');
        ownerSearchPage = 1;
        var modal = new bootstrap.Modal(document.getElementById('changeOwnerModal'));
        modal.show();
    });

    $('#btnOwnerSearch').on('click', function() { ownerSearchPage = 1; searchOwnerUsers(); });
    $('#ownerSearchKeyword').on('keydown', function(e) {
        if (e.key === 'Enter') { e.preventDefault(); ownerSearchPage = 1; searchOwnerUsers(); }
    });

    function searchOwnerUsers() {
        var kw = $('#ownerSearchKeyword').val();
        $('#ownerSearchResults').html('<div class="text-center py-3"><i class="fas fa-spinner fa-spin"></i> Đang tìm...</div>');
        $.getJSON(ownerSearchUrl, { keyword: kw, page: ownerSearchPage, pageSize: 10 }, function(r) {
            if (!r.items || !r.items.length) {
                $('#ownerSearchResults').html('<div class="text-center text-muted py-3"><i class="fas fa-exclamation-circle me-1"></i>Không tìm thấy người dùng.</div>');
                return;
            }
            var totalPages = Math.ceil(r.totalCount / 10);
            var html = '<div class="table-responsive"><table class="table table-hover table-sm align-middle mb-0">';
            html += '<thead class="table-light"><tr><th style="width:60px">ID</th><th>Tên đăng nhập</th><th>Họ tên</th><th>Email</th><th style="width:80px">Chọn</th></tr></thead><tbody>';
            for (var i = 0; i < r.items.length; i++) {
                var u = r.items[i];
                html += '<tr>';
                html += '<td class="small text-muted">' + u.id + '</td>';
                html += '<td class="fw-semibold small">' + (u.userName || '—') + '</td>';
                html += '<td class="small">' + (u.fullName || '—') + '</td>';
                html += '<td class="small">' + (u.email || '—') + '</td>';
                html += '<td><button type="button" class="btn btn-success btn-sm btn-select-owner" data-uid="' + u.id + '" data-uname="' + (u.userName || '') + '"><i class="fas fa-hand-pointer"></i></button></td>';
                html += '</tr>';
            }
            html += '</tbody></table></div>';

            if (totalPages > 1) {
                html += '<div class="d-flex justify-content-between align-items-center mt-2 px-1">';
                html += '<small class="text-muted">Tổng: ' + r.totalCount + ' người dùng</small>';
                html += '<nav><ul class="pagination pagination-sm mb-0">';
                html += '<li class="page-item ' + (ownerSearchPage <= 1 ? 'disabled' : '') + '"><a class="page-link owner-page" href="#" data-p="' + (ownerSearchPage - 1) + '"><i class="fas fa-angle-left"></i></a></li>';
                var sp = Math.max(1, ownerSearchPage - 3), ep = Math.min(totalPages, ownerSearchPage + 3);
                for (var p = sp; p <= ep; p++) {
                    html += '<li class="page-item ' + (p === ownerSearchPage ? 'active' : '') + '"><a class="page-link owner-page" href="#" data-p="' + p + '">' + p + '</a></li>';
                }
                html += '<li class="page-item ' + (ownerSearchPage >= totalPages ? 'disabled' : '') + '"><a class="page-link owner-page" href="#" data-p="' + (ownerSearchPage + 1) + '"><i class="fas fa-angle-right"></i></a></li>';
                html += '</ul></nav></div>';
            }
            $('#ownerSearchResults').html(html);
        });
    }

    $(document).on('click', '.owner-page', function(e) {
        e.preventDefault();
        var p = $(this).data('p');
        if (p < 1 || $(this).closest('.page-item').hasClass('disabled') || $(this).closest('.page-item').hasClass('active')) return;
        ownerSearchPage = p;
        searchOwnerUsers();
    });

    $(document).on('click', '.btn-select-owner', function() {
        var uid = $(this).data('uid');
        var uname = $(this).data('uname');
        var ntvId = $('#changeOwnerId').val();
        Swal.fire({
            title: 'Xác nhận đổi chủ sở hữu?',
            html: 'Gán người dùng <strong>' + uname + '</strong> (ID: ' + uid + ') làm chủ sở hữu?',
            icon: 'question', showCancelButton: true,
            confirmButtonColor: '#17a2b8', cancelButtonColor: '#6c757d',
            confirmButtonText: '<i class="fas fa-check"></i> Xác nhận', cancelButtonText: 'Hủy'
        }).then(function(result) {
            if (result.isConfirmed) {
                $.post(changeOwnerUrl, { id: ntvId, userId: uid, __RequestVerificationToken: token }, function(r) {
                    if (r.success) {
                        toastr.success(r.message);
                        bootstrap.Modal.getInstance(document.getElementById('changeOwnerModal')).hide();
                        loadList(currentPage);
                    } else { toastr.error(r.message); }
                });
            }
        });
    });

    $('#btnRemoveOwner').on('click', function() {
        var ntvId = $('#changeOwnerId').val();
        Swal.fire({
            title: 'Bỏ chủ sở hữu?',
            text: 'Bạn chắc chắn muốn bỏ chủ sở hữu của nhà tư vấn này?',
            icon: 'warning', showCancelButton: true,
            confirmButtonColor: '#ffc107', cancelButtonColor: '#6c757d',
            confirmButtonText: '<i class="fas fa-user-slash"></i> Bỏ chủ', cancelButtonText: 'Hủy'
        }).then(function(result) {
            if (result.isConfirmed) {
                $.post(changeOwnerUrl, { id: ntvId, userId: '', __RequestVerificationToken: token }, function(r) {
                    if (r.success) {
                        toastr.success(r.message);
                        bootstrap.Modal.getInstance(document.getElementById('changeOwnerModal')).hide();
                        loadList(currentPage);
                    } else { toastr.error(r.message); }
                });
            }
        });
    });
});
</script>
}
