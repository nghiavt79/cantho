@model TechExchangeApp.Areas.Cms.Controllers.NhaTuVanFormVm
@{
    ViewData["Title"] = "Thêm Nhà tư vấn";
}

<form asp-action="Create" method="post" id="ntvForm">
    @Html.AntiForgeryToken()
    <div class="card card-outline card-success shadow-sm">
        <div class="card-header d-flex align-items-center flex-wrap gap-2">
            <h3 class="card-title mb-0">
                <i class="fas fa-plus me-1"></i> Thêm Nhà tư vấn mới
            </h3>
            <div class="ms-auto d-flex gap-2">
                <button type="submit" class="btn btn-success btn-sm">
                    <i class="fas fa-save me-1"></i> Lưu
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                    <i class="fas fa-arrow-left me-1"></i> Quay lại
                </a>
            </div>
        </div>
        <div class="card-body">
            @await Html.PartialAsync("_NhaTuVanForm", Model)
        </div>
    </div>
</form>

@section Styles {
<link rel="stylesheet" href="https://cdn.ckeditor.com/ckeditor5/43.0.0/ckeditor5.css" />
<style>.ck-editor__editable { min-height: 200px; }</style>
}

@section Scripts {
<script src="https://cdn.ckeditor.com/ckeditor5/43.0.0/ckeditor5.umd.js"></script>
<script>
$(function(){
    const { ClassicEditor, Essentials, Bold, Italic, Link, Paragraph,
            Heading, List, BlockQuote, Table, TableToolbar,
            SourceEditing, Alignment, Font, HtmlEmbed } = CKEDITOR;

    var myPlugins = [
        Essentials, Bold, Italic, Link, Paragraph, Heading,
        List, BlockQuote, Table, TableToolbar,
        SourceEditing, Alignment, Font, HtmlEmbed
    ];
    if (CKEDITOR.PasteFromOffice) myPlugins.push(CKEDITOR.PasteFromOffice);
    if (CKEDITOR.GeneralHtmlSupport) myPlugins.push(CKEDITOR.GeneralHtmlSupport);
    if (CKEDITOR.TableProperties) myPlugins.push(CKEDITOR.TableProperties);
    if (CKEDITOR.TableCellProperties) myPlugins.push(CKEDITOR.TableCellProperties);

    var editorConfig = {
        plugins: myPlugins,
        htmlSupport: {
            allow: [ { name: /.*/, attributes: true, classes: true, styles: true } ]
        },
        toolbar: {
            items: [
                'heading', '|',
                'bold', 'italic', 'link', '|',
                'alignment', '|',
                'fontSize', 'fontColor', '|',
                'bulletedList', 'numberedList', '|',
                'blockQuote', 'insertTable', 'htmlEmbed', '|',
                'sourceEditing', '|',
                'undo', 'redo'
            ]
        },
        table: {
            contentToolbar: ['tableColumn', 'tableRow', 'mergeTableCells']
        }
    };

    var editors = {};
    ['editorDaoTao', 'editorCongTac', 'editorSachXuatBan', 'editorCongBo', 'editorSangChe', 'editorDuAn', 'editorKinhNghiem', 'editorHoSo'].forEach(function(id) {
        var el = document.querySelector('#' + id);
        if (el) {
            ClassicEditor.create(el, editorConfig).then(function(editor) {
                editors[id] = editor;
            }).catch(function(err) { console.error('CKEditor init error:', err); });
        }
    });

    document.getElementById('ntvForm').addEventListener('submit', function() {
        try {
            for (var id in editors) {
                var el = document.getElementById(id);
                if (el) el.value = editors[id].getData();
            }
        } catch(e) { console.error('CKEditor sync error:', e); }
    });

    // Image upload buttons
    $('.btn-upload-field').on('click', function() {
        var targetId = $(this).data('target');
        var input = $('<input type="file" accept="image/*" style="display:none">');
        input.on('change', function() {
            var file = this.files[0];
            if (!file) return;
            var formData = new FormData();
            formData.append('upload', file);
            $.ajax({
                url: '@Url.Action("Upload", "Upload", new { area = "Cms" })',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function(r) {
                    if (r.url) {
                        $('#' + targetId).val(r.url);
                        var previewId = 'preview' + targetId.replace('input', '');
                        if ($('#' + previewId).length) {
                            $('#' + previewId).html('<img src="' + r.url + '" class="rounded" style="max-height:150px" />');
                        }
                        toastr.success('Upload thành công!');
                    } else if (r.error) {
                        toastr.error(r.error.message);
                    }
                },
                error: function() { toastr.error('Upload thất bại.'); }
            });
        });
        input.trigger('click');
    });
    // Lĩnh vực checkbox → hidden field sync
    function syncLinhVucCheckboxes() {
        var vals = [];
        $('.chk-linhvuc:checked').each(function(){ vals.push($(this).val()); });
        $('#hdnLinhVucId').val(vals.join(';'));
    }
    $(document).on('change', '.chk-linhvuc', syncLinhVucCheckboxes);
    syncLinhVucCheckboxes();

    // Dịch vụ checkbox → hidden field sync
    function syncDichVuCheckboxes() {
        var vals = [];
        $('.chk-dichvu:checked').each(function(){ vals.push($(this).val()); });
        $('#hdnDichVu').val(vals.join(';'));
    }
    $(document).on('change', '.chk-dichvu', syncDichVuCheckboxes);
    syncDichVuCheckboxes();
});
</script>
}
