@model TechExchangeApp.ViewModel.AdminDashboardVm
@{
    ViewData["Title"] = "Analytics Dashboard";
    Layout = "~/Areas/Cms/Views/Shared/_LayoutAdminLTE.cshtml";

    // Serialize monthly stats for Chart.js
    var labels    = Model.MonthlyStats.Select(m => m.Label).ToList();
    var newProds  = Model.MonthlyStats.Select(m => m.NewProducts).ToList();
    var newProjs  = Model.MonthlyStats.Select(m => m.NewProjects).ToList();
    var newSupps  = Model.MonthlyStats.Select(m => m.NewSuppliers).ToList();
    var newConss  = Model.MonthlyStats.Select(m => m.NewConsultants).ToList();

    string ToJson<T>(IEnumerable<T> list) => System.Text.Json.JsonSerializer.Serialize(list);
    string GrowthBadge(double pct) =>
        pct >= 0
            ? $"<span class=\"kpi-badge up\"><i class=\"fas fa-arrow-up\"></i> {pct:F1}%</span>"
            : $"<span class=\"kpi-badge down\"><i class=\"fas fa-arrow-down\"></i> {Math.Abs(pct):F1}%</span>";
}

@section Styles {
<style>
/* ═══════════════════════════════════════════════════════════════
   ADMIN ANALYTICS DASHBOARD — SaaS-Grade UI
   ═══════════════════════════════════════════════════════════════ */
:root {
    --clr-primary:   #4f46e5;
    --clr-secondary: #7c3aed;
    --clr-accent:    #06b6d4;
    --clr-success:   #10b981;
    --clr-warning:   #f59e0b;
    --clr-danger:    #ef4444;
    --clr-surface:   #ffffff;
    --clr-bg:        #f1f5f9;
    --clr-text:      #1e293b;
    --clr-muted:     #64748b;
    --shadow-card:   0 4px 24px rgba(79,70,229,.09);
    --radius:        16px;
    --radius-sm:     10px;
}

/* ─── Page ──────────────────────────────────────────────────── */
.adash-wrap { padding: 0 4px 40px; }

.adash-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 28px;
}
.adash-title { font-size: 1.5rem; font-weight: 700; color: var(--clr-text); margin: 0; }
.adash-meta  { font-size: .8rem; color: var(--clr-muted); margin-top: 2px; }

/* ─── Section headers ───────────────────────────────────────── */
.section-label {
    font-size: .7rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--clr-muted);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
}
.section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: #e2e8f0;
}

/* ─── KPI Cards ─────────────────────────────────────────────── */
.kpi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 18px;
    margin-bottom: 32px;
}
.kpi-card {
    background: var(--clr-surface);
    border-radius: var(--radius);
    padding: 22px 20px 18px;
    box-shadow: var(--shadow-card);
    position: relative;
    overflow: hidden;
    transition: transform .2s ease, box-shadow .2s ease;
    text-decoration: none;
    display: block;
    color: inherit;
    border: 1.5px solid transparent;
}
.kpi-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(79,70,229,.15);
    border-color: var(--clr-primary);
}
.kpi-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
    border-radius: var(--radius) var(--radius) 0 0;
}
.kpi-card.indigo::before  { background: linear-gradient(90deg,#4f46e5,#7c3aed); }
.kpi-card.cyan::before    { background: linear-gradient(90deg,#06b6d4,#0ea5e9); }
.kpi-card.emerald::before { background: linear-gradient(90deg,#10b981,#059669); }
.kpi-card.amber::before   { background: linear-gradient(90deg,#f59e0b,#d97706); }
.kpi-card.rose::before    { background: linear-gradient(90deg,#f43f5e,#e11d48); }
.kpi-card.violet::before  { background: linear-gradient(90deg,#8b5cf6,#7c3aed); }

.kpi-icon {
    width: 44px; height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    margin-bottom: 14px;
}
.kpi-icon.indigo  { background: #eef2ff; color: #4f46e5; }
.kpi-icon.cyan    { background: #ecfeff; color: #0891b2; }
.kpi-icon.emerald { background: #d1fae5; color: #059669; }
.kpi-icon.amber   { background: #fef3c7; color: #d97706; }
.kpi-icon.rose    { background: #ffe4e6; color: #e11d48; }
.kpi-icon.violet  { background: #ede9fe; color: #7c3aed; }

.kpi-number {
    font-size: 2.2rem;
    font-weight: 800;
    line-height: 1;
    color: var(--clr-text);
    letter-spacing: -.03em;
}
.kpi-label  { font-size: .78rem; color: var(--clr-muted); margin-top: 4px; font-weight: 500; }
.kpi-sub    { font-size: .75rem; color: var(--clr-muted); margin-top: 8px; }
.kpi-badge  {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    font-size: .7rem;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 20px;
}
.kpi-badge.up   { background: #d1fae5; color: #059669; }
.kpi-badge.down { background: #ffe4e6; color: #e11d48; }
.kpi-rate-bar {
    height: 4px;
    background: #e2e8f0;
    border-radius: 99px;
    margin-top: 10px;
    overflow: hidden;
}
.kpi-rate-fill {
    height: 100%;
    border-radius: 99px;
    background: linear-gradient(90deg,#4f46e5,#7c3aed);
    transition: width .6s cubic-bezier(.4,0,.2,1);
}

/* ─── Chart Cards ───────────────────────────────────────────── */
.chart-card {
    background: var(--clr-surface);
    border-radius: var(--radius);
    padding: 22px;
    box-shadow: var(--shadow-card);
    height: 100%;
}
.chart-card-title {
    font-size: .9rem;
    font-weight: 700;
    color: var(--clr-text);
    margin-bottom: 4px;
}
.chart-card-sub {
    font-size: .75rem;
    color: var(--clr-muted);
    margin-bottom: 18px;
}

/* ─── System Health ─────────────────────────────────────────── */
.health-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
    gap: 16px;
    margin-top: 8px;
}
.health-card {
    border-radius: var(--radius-sm);
    padding: 18px 16px;
    display: flex;
    align-items: center;
    gap: 14px;
}
.health-card.ok       { background: #f0fdf4; border: 1.5px solid #bbf7d0; }
.health-card.warn     { background: #fffbeb; border: 1.5px solid #fde68a; }
.health-card.critical { background: #fff1f2; border: 1.5px solid #fecdd3; }

.health-dot {
    width: 12px; height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
}
.health-dot.ok       { background: #22c55e; }
.health-dot.warn     { background: #f59e0b; }
.health-dot.critical { background: #ef4444; box-shadow: 0 0 0 4px #fecaca; animation: pulse 1.8s infinite; }
@@keyframes pulse {
    0%,100% { box-shadow: 0 0 0 0 rgba(239,68,68,.4); }
    50%      { box-shadow: 0 0 0 6px rgba(239,68,68,0); }
}

.health-count  { font-size: 1.5rem; font-weight: 800; line-height: 1; }
.health-count.ok       { color: #15803d; }
.health-count.warn     { color: #b45309; }
.health-count.critical { color: #be123c; }
.health-label  { font-size: .78rem; color: var(--clr-muted); }

/* ─── Ranking Tables ────────────────────────────────────────── */
.rank-table {
    width: 100%;
    border-collapse: collapse;
}
.rank-table th {
    font-size: .68rem;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--clr-muted);
    font-weight: 700;
    padding: 0 0 10px;
    border-bottom: 1px solid #f1f5f9;
}
.rank-table td {
    padding: 9px 0;
    border-bottom: 1px solid #f8fafc;
    font-size: .82rem;
    color: var(--clr-text);
}
.rank-table tr:last-child td { border-bottom: none; }
.rank-num {
    width: 22px; height: 22px;
    border-radius: 6px;
    background: #f1f5f9;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: .72rem;
    font-weight: 700;
    color: var(--clr-muted);
    margin-right: 8px;
    flex-shrink: 0;
}
.rank-num.gold   { background: #fef3c7; color: #b45309; }
.rank-num.silver { background: #f1f5f9; color: #475569; }
.rank-num.bronze { background: #fde8d8; color: #c2410c; }
.rank-bar-wrap { height: 4px; background: #f1f5f9; border-radius: 99px; overflow: hidden; flex: 1; }
.rank-bar-fill { height: 100%; border-radius: 99px; background: linear-gradient(90deg,#4f46e5,#7c3aed); }

/* ─── Filter bar ────────────────────────────────────────────── */
.filter-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
}
.filter-label { font-size: .78rem; font-weight: 600; color: var(--clr-muted); }
.filter-select {
    padding: 6px 14px;
    border: 1.5px solid #e2e8f0;
    border-radius: 8px;
    font-size: .82rem;
    background: #fff;
    color: var(--clr-text);
    cursor: pointer;
    transition: border-color .2s;
}
.filter-select:focus { outline: none; border-color: var(--clr-primary); }

/* ─── Action Buttons ────────────────────────────────────────── */
.btn-refresh {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 18px;
    background: linear-gradient(135deg,#4f46e5,#7c3aed);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: .82rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity .2s;
}
.btn-refresh:hover { opacity: .88; }

/* ─── Stale warning ────────────────────────────────────────── */
.stale-badge {
    background: #fef3c7;
    color: #92400e;
    border: 1px solid #fde68a;
    border-radius: 6px;
    padding: 3px 10px;
    font-size: .72rem;
    font-weight: 600;
}

/* ─── Responsive tweaks ─────────────────────────────────────── */
@@media (max-width: 768px) {
    .kpi-number { font-size: 1.7rem; }
    .kpi-grid   { grid-template-columns: 1fr 1fr; }
}
</style>
}

<div class="adash-wrap">

    @if (Model.Snapshot.TotalProducts == 0 && Model.Snapshot.TotalProjects == 0 && Model.Snapshot.TotalSuppliers == 0)
    {
        <div class="alert alert-warning d-flex align-items-center gap-3 mb-4" style="border-radius:12px;border:1.5px solid #fde68a;">
            <i class="fas fa-database fa-lg text-warning"></i>
            <div>
                <strong>Cần khởi tạo cơ sở dữ liệu Dashboard.</strong>
                Bảng <code>DashboardSnapshot</code> và <code>DashboardMonthlyStats</code> chưa được tạo hoặc chưa có dữ liệu.<br>
                <span class="text-muted small">Chạy script SQL: <code>Create_Admin_Dashboard_Tables.sql</code> rồi bấm <strong>Refresh Snapshot</strong> bên dưới.</span>
            </div>
        </div>
    }

    <!-- ═══ TOOLBAR ════════════════════════════════════════════ -->
    <div class="adash-toolbar">
        <div>
            <p class="adash-title"><i class="fas fa-chart-line text-primary me-2"></i>Analytics Dashboard</p>
            <p class="adash-meta">
                Cập nhật lúc: <strong>@Model.LastUpdated.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</strong>
                @if (Model.IsSnapshotStale)
                {
                    <span class="stale-badge ms-2"><i class="fas fa-exclamation-triangle"></i> Dữ liệu cũ hơn 15 phút</span>
                }
            </p>
        </div>
        <div class="d-flex align-items-center gap-3 flex-wrap">
            <!-- Year filter -->
            <form method="get" class="filter-bar">
                <label class="filter-label">Năm:</label>
                <select name="year" id="filterYear" class="filter-select">
                    @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 3; y--)
                    {
                        if (Model.FilterYear == y)
                        {
                            <option value="@y" selected="selected">@y</option>
                        }
                        else
                        {
                            <option value="@y">@y</option>
                        }
                    }
                </select>
                <label class="filter-label">Tháng:</label>
                <select name="month" id="filterMonth" class="filter-select">
                    <option value="">Tất cả</option>
                    @for (int m = 1; m <= 12; m++)
                    {
                        if (Model.FilterMonth == m)
                        {
                            <option value="@m" selected="selected">Tháng @m</option>
                        }
                        else
                        {
                            <option value="@m">Tháng @m</option>
                        }
                    }
                </select>
                <button type="submit" class="btn-refresh"><i class="fas fa-filter"></i> Lọc</button>
            </form>

            <!-- Manual refresh -->
            <form method="post" asp-action="RefreshSnapshot" asp-controller="AdminAnalytics" asp-area="Cms">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-refresh" id="btnRefreshSnapshot">
                    <i class="fas fa-sync-alt"></i> Refresh Snapshot
                </button>
            </form>
        </div>
    </div>

    <!-- ═══ ROW 1 — EXECUTIVE KPI CARDS ══════════════════════ -->
    <div class="section-label"><i class="fas fa-tachometer-alt"></i> KPI Tổng quan</div>
    <div class="kpi-grid">

        <!-- Total Products -->
        <a href="/cms/SanPhamCNTB/CongNghe" class="kpi-card indigo">
            <div class="kpi-icon indigo"><i class="fas fa-boxes"></i></div>
            <div class="kpi-number">@Model.Snapshot.TotalProducts.ToString("N0")</div>
            <div class="kpi-label">Tổng Sản phẩm</div>
            <div class="kpi-sub">
                @Html.Raw(GrowthBadge(Model.Snapshot.ProductMomGrowth))
                <span class="ms-1 text-muted" style="font-size:.72rem">tháng này</span>
            </div>
            <div class="kpi-rate-bar mt-2">
                <div class="kpi-rate-fill" style="width:@(Math.Min(100, (double)Model.Snapshot.TotalProducts / Math.Max(1, Model.Snapshot.TotalProducts) * 100))%"></div>
            </div>
        </a>

        <!-- Products by type -->
        <div class="kpi-card cyan">
            <div class="kpi-icon cyan"><i class="fas fa-microchip"></i></div>
            <div class="kpi-number">@Model.Snapshot.CongNgheCount.ToString("N0")</div>
            <div class="kpi-label">Công nghệ</div>
            <div class="kpi-sub text-muted" style="font-size:.72rem">
                ThB: @Model.Snapshot.ThietBiCount.ToString("N0") &nbsp;|&nbsp;
                TriT: @Model.Snapshot.TriTueCount.ToString("N0")
            </div>
        </div>

        <!-- Projects -->
        <a href="/cms/ProjectsAdmin" class="kpi-card emerald">
            <div class="kpi-icon emerald"><i class="fas fa-project-diagram"></i></div>
            <div class="kpi-number">@Model.Snapshot.TotalProjects.ToString("N0")</div>
            <div class="kpi-label">Tổng Dự án</div>
            <div class="kpi-sub">
                @Html.Raw(GrowthBadge(Model.Snapshot.ProjectMomGrowth))
                &nbsp;Active: <strong style="color:#059669">@Model.Snapshot.ActiveProjects</strong>
            </div>
            <div class="kpi-rate-bar mt-2">
                <div class="kpi-rate-fill" style="width:@Model.Snapshot.ActiveProjectRate%"></div>
            </div>
        </a>

        <!-- Active Project Rate -->
        <div class="kpi-card amber">
            <div class="kpi-icon amber"><i class="fas fa-check-circle"></i></div>
            <div class="kpi-number">@Model.Snapshot.ActiveProjectRate<small style="font-size:.9rem">%</small></div>
            <div class="kpi-label">Tỷ lệ Dự án Active</div>
            <div class="kpi-sub text-muted" style="font-size:.72rem">
                Completed: @Model.Snapshot.CompletedProjects
            </div>
            <div class="kpi-rate-bar mt-2">
                <div class="kpi-rate-fill" style="width:@Model.Snapshot.ActiveProjectRate%"></div>
            </div>
        </div>

        <!-- Suppliers -->
        <a href="/cms/NhaCungUngAdmin" class="kpi-card rose">
            <div class="kpi-icon rose"><i class="fas fa-building"></i></div>
            <div class="kpi-number">@Model.Snapshot.TotalSuppliers.ToString("N0")</div>
            <div class="kpi-label">Nhà cung ứng</div>
            <div class="kpi-sub">
                @Html.Raw(GrowthBadge(Model.Snapshot.SupplierMomGrowth))
                &nbsp;Active: <strong style="color:#e11d48">@Model.Snapshot.ActiveSuppliers</strong>
            </div>
            <div class="kpi-rate-bar mt-2">
                <div class="kpi-rate-fill" style="background:linear-gradient(90deg,#f43f5e,#e11d48);width:@Model.Snapshot.ActiveSupplierRate%"></div>
            </div>
        </a>

        <!-- Consultants -->
        <a href="/cms/NhaTuVanAdmin" class="kpi-card violet">
            <div class="kpi-icon violet"><i class="fas fa-user-tie"></i></div>
            <div class="kpi-number">@Model.Snapshot.TotalConsultants.ToString("N0")</div>
            <div class="kpi-label">Nhà tư vấn</div>
            <div class="kpi-sub">
                @Html.Raw(GrowthBadge(Model.Snapshot.ConsultantMomGrowth))
                &nbsp;Active: <strong style="color:#7c3aed">@Model.Snapshot.ActiveConsultants</strong>
            </div>
            <div class="kpi-rate-bar mt-2">
                <div class="kpi-rate-fill" style="background:linear-gradient(90deg,#8b5cf6,#7c3aed);width:@Model.Snapshot.ActiveConsultantRate%"></div>
            </div>
        </a>

    </div>

    <!-- ═══ ROW 2 — GROWTH TREND LINE CHART ══════════════════ -->
    <div class="section-label"><i class="fas fa-chart-area"></i> Tăng trưởng 12 Tháng</div>
    <div class="row g-4 mb-4">
        <div class="col-12">
            <div class="chart-card">
                <div class="chart-card-title">Xu hướng tăng trưởng</div>
                <div class="chart-card-sub">Số lượng mới theo tháng – Sản phẩm, Dự án, NCC, NTV</div>
                <canvas id="growthTrendChart" height="95"></canvas>
            </div>
        </div>
    </div>

    <!-- ═══ ROW 3 — OPERATIONAL STATUS CHARTS ════════════════ -->
    <div class="section-label"><i class="fas fa-chart-bar"></i> Phân phối Trạng thái</div>
    <div class="row g-4 mb-4">
        <div class="col-lg-6">
            <div class="chart-card">
                <div class="chart-card-title">Trạng thái Sản phẩm</div>
                <div class="chart-card-sub">Phân bố theo tình trạng phê duyệt</div>
                <canvas id="productStatusChart" height="80"></canvas>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="chart-card">
                <div class="chart-card-title">Phân loại Sản phẩm CNTB</div>
                <div class="chart-card-sub">Tỷ lệ: Công nghệ / Thiết bị / Trí tuệ</div>
                <canvas id="productTypeChart" height="80"></canvas>
            </div>
        </div>
    </div>

    <!-- ═══ ROW 4 — TOP RANKINGS ═════════════════════════════ -->
    <div class="section-label"><i class="fas fa-trophy"></i> Top Rankings</div>
    <div class="row g-4 mb-4">

        <!-- Top Categories -->
        <div class="col-lg-4">
            <div class="chart-card">
                <div class="chart-card-title"><i class="fas fa-tags text-primary me-1"></i> Top 5 Danh mục</div>
                <div class="chart-card-sub">Theo số lượng sản phẩm</div>
                @if (Model.TopCategories.Any())
                {
                    int maxCat = Model.TopCategories.Max(c => c.Count);
                    <table class="rank-table">
                        <thead><tr><th>#</th><th>Danh mục</th><th style="text-align:right">SL</th></tr></thead>
                        <tbody>
                            @foreach (var (cat, idx) in Model.TopCategories.Select((c, i) => (c, i)))
                            {
                                string rankCls = idx == 0 ? "gold" : idx == 1 ? "silver" : idx == 2 ? "bronze" : "";
                                <tr>
                                    <td><span class="rank-num @rankCls">@(idx+1)</span></td>
                                    <td>
                                        <div>@cat.CategoryName</div>
                                        <div class="rank-bar-wrap mt-1">
                                            <div class="rank-bar-fill" style="width:@(maxCat>0?(double)cat.Count/maxCat*100:0)%"></div>
                                        </div>
                                    </td>
                                    <td style="text-align:right;font-weight:700">@cat.Count</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted small">Chưa có dữ liệu</p>
                }
            </div>
        </div>

        <!-- Top Suppliers -->
        <div class="col-lg-4">
            <div class="chart-card">
                <div class="chart-card-title"><i class="fas fa-building text-danger me-1"></i> Top 5 Nhà cung ứng</div>
                <div class="chart-card-sub">Theo số lượng sản phẩm</div>
                @if (Model.TopSuppliers.Any())
                {
                    int maxSup = Model.TopSuppliers.Max(s => s.ProductCount);
                    <table class="rank-table">
                        <thead><tr><th>#</th><th>Nhà cung ứng</th><th style="text-align:right">SP</th></tr></thead>
                        <tbody>
                            @foreach (var (sup, idx) in Model.TopSuppliers.Select((s, i) => (s, i)))
                            {
                                string rankCls = idx == 0 ? "gold" : idx == 1 ? "silver" : idx == 2 ? "bronze" : "";
                                <tr>
                                    <td><span class="rank-num @rankCls">@(idx+1)</span></td>
                                    <td>
                                        <div>@sup.SupplierName</div>
                                        <div class="rank-bar-wrap mt-1">
                                            <div class="rank-bar-fill" style="background:linear-gradient(90deg,#f43f5e,#e11d48);width:@(maxSup>0?(double)sup.ProductCount/maxSup*100:0)%"></div>
                                        </div>
                                    </td>
                                    <td style="text-align:right;font-weight:700">@sup.ProductCount</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted small">Chưa có dữ liệu</p>
                }
            </div>
        </div>

        <!-- Top Consultants -->
        <div class="col-lg-4">
            <div class="chart-card">
                <div class="chart-card-title"><i class="fas fa-user-tie text-violet me-1" style="color:#7c3aed"></i> Top 5 Nhà tư vấn</div>
                <div class="chart-card-sub">Theo số dự án tham gia</div>
                @if (Model.TopConsultants.Any())
                {
                    int maxCon = Model.TopConsultants.Max(c => c.ProjectCount);
                    <table class="rank-table">
                        <thead><tr><th>#</th><th>Nhà tư vấn</th><th style="text-align:right">DA</th></tr></thead>
                        <tbody>
                            @foreach (var (con, idx) in Model.TopConsultants.Select((c, i) => (c, i)))
                            {
                                string rankCls = idx == 0 ? "gold" : idx == 1 ? "silver" : idx == 2 ? "bronze" : "";
                                <tr>
                                    <td><span class="rank-num @rankCls">@(idx+1)</span></td>
                                    <td>
                                        <div>@con.ConsultantName</div>
                                        <div class="rank-bar-wrap mt-1">
                                            <div class="rank-bar-fill" style="background:linear-gradient(90deg,#8b5cf6,#7c3aed);width:@(maxCon>0?(double)con.ProjectCount/maxCon*100:0)%"></div>
                                        </div>
                                    </td>
                                    <td style="text-align:right;font-weight:700">@con.ProjectCount</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted small">Chưa có dữ liệu</p>
                }
            </div>
        </div>

    </div>

    <!-- ═══ ROW 5 — SYSTEM HEALTH ════════════════════════════ -->
    <div class="section-label"><i class="fas fa-heartbeat"></i> System Health</div>
    <div class="health-grid">

        <div class="health-card @Model.SystemHealth.PendingProductsLevel">
            <div class="health-dot @Model.SystemHealth.PendingProductsLevel"></div>
            <div>
                <div class="health-count @Model.SystemHealth.PendingProductsLevel">@Model.SystemHealth.PendingProducts</div>
                <div class="health-label">Sản phẩm chờ duyệt</div>
            </div>
        </div>

        <div class="health-card @Model.SystemHealth.DelayedProjectsLevel">
            <div class="health-dot @Model.SystemHealth.DelayedProjectsLevel"></div>
            <div>
                <div class="health-count @Model.SystemHealth.DelayedProjectsLevel">@Model.SystemHealth.DelayedProjects</div>
                <div class="health-label">Dự án bị trễ (>90 ngày)</div>
            </div>
        </div>

        <div class="health-card @Model.SystemHealth.UnverifiedSuppliersLevel">
            <div class="health-dot @Model.SystemHealth.UnverifiedSuppliersLevel"></div>
            <div>
                <div class="health-count @Model.SystemHealth.UnverifiedSuppliersLevel">@Model.SystemHealth.UnverifiedSuppliers</div>
                <div class="health-label">NCC chưa xác thực</div>
            </div>
        </div>

        <div class="health-card @Model.SystemHealth.UnverifiedConsultantsLevel">
            <div class="health-dot @Model.SystemHealth.UnverifiedConsultantsLevel"></div>
            <div>
                <div class="health-count @Model.SystemHealth.UnverifiedConsultantsLevel">@Model.SystemHealth.UnverifiedConsultants</div>
                <div class="health-label">NTV chưa xác thực</div>
            </div>
        </div>

    </div>

</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
(function () {
    'use strict';

    // ── Shared Chart Defaults ──────────────────────────────────
    Chart.defaults.font.family = 'Inter, system-ui, sans-serif';
    Chart.defaults.font.size   = 12;
    Chart.defaults.color       = '#64748b';

    const labelsJson  = @Html.Raw(ToJson(labels));
    const newProdsJ   = @Html.Raw(ToJson(newProds));
    const newProjsJ   = @Html.Raw(ToJson(newProjs));
    const newSuppsJ   = @Html.Raw(ToJson(newSupps));
    const newConssJ   = @Html.Raw(ToJson(newConss));

    // ── 1. Growth Trend Line Chart ─────────────────────────────
    const growthCtx = document.getElementById('growthTrendChart');
    if (growthCtx && labelsJson.length > 0) {
        new Chart(growthCtx, {
            type: 'line',
            data: {
                labels: labelsJson,
                datasets: [
                    {
                        label: 'Sản phẩm mới',
                        data: newProdsJ,
                        borderColor: '#4f46e5',
                        backgroundColor: 'rgba(79,70,229,.08)',
                        borderWidth: 2.5,
                        pointRadius: 4,
                        pointHoverRadius: 6,
                        tension: 0.4,
                        fill: true
                    },
                    {
                        label: 'Dự án mới',
                        data: newProjsJ,
                        borderColor: '#10b981',
                        backgroundColor: 'rgba(16,185,129,.06)',
                        borderWidth: 2.5,
                        pointRadius: 4,
                        pointHoverRadius: 6,
                        tension: 0.4,
                        fill: true
                    },
                    {
                        label: 'NCC mới',
                        data: newSuppsJ,
                        borderColor: '#f43f5e',
                        backgroundColor: 'rgba(244,63,94,.05)',
                        borderWidth: 2,
                        pointRadius: 3,
                        pointHoverRadius: 5,
                        tension: 0.4,
                        fill: false
                    },
                    {
                        label: 'NTV mới',
                        data: newConssJ,
                        borderColor: '#8b5cf6',
                        backgroundColor: 'rgba(139,92,246,.05)',
                        borderWidth: 2,
                        pointRadius: 3,
                        pointHoverRadius: 5,
                        tension: 0.4,
                        fill: false
                    }
                ]
            },
            options: {
                responsive: true,
                interaction: { mode: 'index', intersect: false },
                plugins: {
                    legend: { position: 'top', labels: { usePointStyle: true, boxWidth: 8 } },
                    tooltip: { backgroundColor: '#1e293b', padding: 12, cornerRadius: 8 }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { color: '#f1f5f9' },
                        ticks: { stepSize: 1 }
                    },
                    x: { grid: { display: false } }
                }
            }
        });
    }

    // ── 2. Product Status Doughnut ─────────────────────────────
    const statusCtx = document.getElementById('productStatusChart');
    if (statusCtx) {
        new Chart(statusCtx, {
            type: 'doughnut',
            data: {
                labels: ['Chờ duyệt', 'Đang xử lý', 'Đã duyệt', 'Hoàn thành'],
                datasets: [{
                    data: [
                        @Model.ProductStatus.NewCount,
                        @Model.ProductStatus.ProcessingCount,
                        @Model.ProductStatus.ActiveCount,
                        @Model.ProductStatus.CompletedCount
                    ],
                    backgroundColor: ['#f59e0b','#06b6d4','#10b981','#4f46e5'],
                    borderWidth: 0,
                    hoverOffset: 6
                }]
            },
            options: {
                responsive: true,
                cutout: '65%',
                plugins: {
                    legend: { position: 'right', labels: { usePointStyle: true, boxWidth: 8 } },
                    tooltip: { backgroundColor: '#1e293b', padding: 12, cornerRadius: 8 }
                }
            }
        });
    }

    // ── 3. Product Type Horizontal Bar ────────────────────────
    const typeCtx = document.getElementById('productTypeChart');
    if (typeCtx) {
        new Chart(typeCtx, {
            type: 'bar',
            data: {
                labels: ['Công nghệ', 'Thiết bị', 'Trí tuệ'],
                datasets: [{
                    label: 'Số lượng',
                    data: [
                        @Model.Snapshot.CongNgheCount,
                        @Model.Snapshot.ThietBiCount,
                        @Model.Snapshot.TriTueCount
                    ],
                    backgroundColor: ['rgba(79,70,229,.8)','rgba(6,182,212,.8)','rgba(139,92,246,.8)'],
                    borderRadius: 8,
                    barThickness: 30
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                plugins: {
                    legend: { display: false },
                    tooltip: { backgroundColor: '#1e293b', padding: 12, cornerRadius: 8 }
                },
                scales: {
                    x: { beginAtZero: true, grid: { color: '#f1f5f9' } },
                    y: { grid: { display: false } }
                }
            }
        });
    }

    // ── Refresh button spinner ─────────────────────────────────
    document.getElementById('btnRefreshSnapshot')?.closest('form')
        ?.addEventListener('submit', e => {
            const btn = e.currentTarget.querySelector('button');
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang cập nhật...';
            btn.disabled = true;
        });

})();
</script>
}
